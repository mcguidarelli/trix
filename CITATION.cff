    given-names: "Mark"
    email: "guido@grumpy-cat.com"
version: "0.9.0"
date-released: "2026-06-06"
license: Apache-2.0
repository-code: "https://github.com/mcguidarelli/trix"
url: "https://github.com/mcguidarelli/trix"
keywords:
