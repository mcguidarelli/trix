% ====================================================================
% Time Quantum Tests (Phase 3 Scheduler)
% ====================================================================
% Tests coroutine auto-yield via instruction counter.

% rt-ok counts failures in a restore-immune slot -- string byte writes
% are unjournaled, so the count survives assertions made inside save
% scopes, and the 1-byte string lives in LOCAL VM, invisible to the
% global-heap/gc-counter probes some files assert on.  The file THROWS
% at EOF: test_all counts a file as failed only when its run throws,
% so print-only failures would slip the suite verdict.
/rt-fails 1 string def
rt-fails 0 16#0#b put
/rt-ok { exch { = } { (FAILED: ) print = rt-fails 0  rt-fails 0 get /integer-type cast 1 add dup 255 gt { pop 255 } if /byte-type cast  put } if-else } def

% ====================================================================
% SECTION 1: coroutine-quantum operator
% ====================================================================

/counter1 0 def
/done1 false def
[
    { 500 coroutine-quantum
      1000 { /counter1 counter1 1 add def } repeat
      /done1 true def
    }
    coroutine-launch
coroutine-join pop pop

done1                                     (quantum: coroutine completes with quantum set) rt-ok
counter1 1000 eq                          (quantum: all iterations executed) rt-ok

% ====================================================================
% SECTION 2: Auto-yield interleaving (quantum prevents starvation)
% ====================================================================

/progress-a 0 def
/progress-b 0 def
/snapshot-a 0 def
/snapshot-b 0 def
/snap-taken false def

[
    { 200 coroutine-quantum
      500 { /progress-a progress-a 1 add def } repeat
    }
    coroutine-launch
[
    { 200 coroutine-quantum
      500 { /progress-b progress-b 1 add def } repeat
    }
    coroutine-launch

% A third coroutine that snapshots both counters after a short time
[
    { 200 coroutine-quantum
      100 { } repeat
      /snapshot-a progress-a def
      /snapshot-b progress-b def
      /snap-taken true def
    }
    coroutine-launch

coroutine-join pop pop
coroutine-join pop pop
coroutine-join pop pop

progress-a 500 eq                         (interleave: coroutine A completed all iterations) rt-ok
progress-b 500 eq                         (interleave: coroutine B completed all iterations) rt-ok
snap-taken                                (interleave: snapshot coroutine ran) rt-ok
snapshot-a 0 gt                           (interleave: coroutine A had partial progress at snapshot) rt-ok
snapshot-b 0 gt                           (interleave: coroutine B had partial progress at snapshot) rt-ok
snapshot-a 500 lt                         (interleave: coroutine A was not yet done at snapshot) rt-ok
snapshot-b 500 lt                         (interleave: coroutine B was not yet done at snapshot) rt-ok

% ====================================================================
% SECTION 3: Quantum 0 = unlimited (no auto-yield)
% ====================================================================

% With quantum 0 (default), coroutines run to yield or completion.
% Verify the first coroutine runs its full loop before the second starts.
/first-done false def
/second-saw-first false def

[
    { 500 { } repeat
      /first-done true def
    }
    coroutine-launch
[
    { /second-saw-first first-done def
    }
    coroutine-launch

coroutine-join pop pop
coroutine-join pop pop

first-done                                (unlimited: first coroutine completed) rt-ok
second-saw-first                          (unlimited: second saw first was done) rt-ok

% ====================================================================
% SECTION 4: Quantum set to 0 mid-execution disables auto-yield
% ====================================================================

/switched false def

[
    { 100 coroutine-quantum
      50 { } repeat
      0 coroutine-quantum
      500 { } repeat
      /switched true def
    }
    coroutine-launch
coroutine-join pop pop

switched                                  (quantum-disable: coroutine completed after disabling quantum) rt-ok

% ====================================================================
% SECTION 5: Quantum survives suspend/resume
% ====================================================================

/q-counter 0 def
/q-done false def

[
    { 300 coroutine-quantum
      1000 { /q-counter q-counter 1 add def } repeat
      /q-done true def
    }
    coroutine-launch

0 coroutine-sleep
dup coroutine-suspend
0 coroutine-sleep
dup coroutine-resume

coroutine-join pop pop
q-done                                    (suspend-quantum: coroutine completed after suspend/resume) rt-ok
q-counter 1000 eq                         (suspend-quantum: all iterations completed) rt-ok

% ====================================================================
% SECTION 6: Large quantum (effectively unlimited for small workloads)
% ====================================================================

/large-first false def
/large-second-saw false def

[
    { 999999 coroutine-quantum
      100 { } repeat
      /large-first true def
    }
    coroutine-launch
[
    { 999999 coroutine-quantum
      /large-second-saw large-first def
    }
    coroutine-launch

coroutine-join pop pop
coroutine-join pop pop

large-first                               (large-quantum: first completed) rt-ok
large-second-saw                          (large-quantum: second saw first was done) rt-ok

% ====================================================================
% SECTION 7: Error cases
% ====================================================================

{ -1 coroutine-quantum } try /range-check eq   (error: negative quantum raises range-check) rt-ok
{ (hello) coroutine-quantum } try /type-check eq (error: string quantum raises type-check) rt-ok

clear
rt-fails 0 get /integer-type cast 0 gt { /rt-assertions-failed throw } if
(test_quantum: ALL TESTS PASSED) =
(__test_ok__) =
