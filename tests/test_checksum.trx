% ====================================================================
% test_checksum.trx -- C-side crc32 + fletcher32 + adler32 ops
% ====================================================================
% Coverage for Trix's checksum ops in §3.9.  All three are pure
% functions on string bytes returning UInteger (32-bit unsigned).
%
%   crc32       Reflected polynomial 0xEDB88320 (Ethernet/zlib/PNG).
%   fletcher32  Wikipedia byte-stream form, little-endian word pairing.
%   adler32     RFC 1950 (zlib trailer); init s1=1 s2=0; defers mod
%               every NMAX=5552 bytes.

% rt-ok counts failures in a restore-immune slot -- string byte writes
% are unjournaled, so the count survives assertions made inside save
% scopes, and the 1-byte string lives in LOCAL VM, invisible to the
% global-heap/gc-counter probes some files assert on.  The file THROWS
% at EOF: test_all counts a file as failed only when its run throws,
% so print-only failures would slip the suite verdict.
/rt-fails 1 string def
rt-fails 0 16#0#b put
/rt-ok { exch { = } { (FAILED: ) print = rt-fails 0  rt-fails 0 get /integer-type cast 1 add dup 255 gt { pop 255 } if /byte-type cast  put } if-else } def

% ====================================================================
% SECTION 1: CRC32 known vectors
% ====================================================================

() crc32         0u eq                          (s1: crc32 empty -> 0)              rt-ok
(a) crc32        0xE8B7BE43#u eq                (s1: crc32 (a))                     rt-ok
(123456789) crc32 0xCBF43926#u eq               (s1: crc32 (123456789) zlib vector) rt-ok

% Single-byte change detection.
(hello) crc32  (hellp) crc32  ne                (s1: crc32 1-byte change detected)  rt-ok

% Determinism: same input -> same output across calls.
(deterministic input) crc32
(deterministic input) crc32 eq                  (s1: crc32 deterministic)           rt-ok

% Type check.
(any string) crc32 type /uinteger-type eq       (s1: crc32 returns uinteger)        rt-ok

% ====================================================================
% SECTION 2: Fletcher-32 known vectors (Wikipedia)
% ====================================================================

() fletcher32           0u eq                   (s2: fletcher32 empty -> 0)         rt-ok
(abcde) fletcher32      0xF04FC729#u eq         (s2: fletcher32 (abcde))            rt-ok
(abcdef) fletcher32     0x56502D2A#u eq         (s2: fletcher32 (abcdef))           rt-ok
(abcdefgh) fletcher32   0xEBE19591#u eq         (s2: fletcher32 (abcdefgh))         rt-ok

% Single-byte change detection.
(hello) fletcher32  (hellp) fletcher32  ne      (s2: fletcher32 1-byte change)      rt-ok

% Determinism.
(repeat me) fletcher32
(repeat me) fletcher32 eq                       (s2: fletcher32 deterministic)      rt-ok

% Type check.
(x) fletcher32 type /uinteger-type eq           (s2: fletcher32 returns uinteger)   rt-ok

% Odd-length trailing-byte zero-padding works (input length not a
% multiple of 2): "abcde" is 5 bytes; the final pair is ('e', 0).
(abcde) length 2 mod 1 eq                       (s2: vector is odd-length)          rt-ok

% ====================================================================
% SECTION 3: Round-trip via pack
% ====================================================================

% Pack a CRC into a 4-byte big-endian unsigned, then unpack and confirm
% equality with the original CRC.
/orig (round-trip me) crc32 def
mark orig (>I) pack /encoded exch def
encoded (>I) unpack pop /decoded exch def
decoded orig eq                                 (s3: crc32 round-trip via pack)     rt-ok

/orig2 (round-trip me) fletcher32 def
mark orig2 (>I) pack /encoded2 exch def
encoded2 (>I) unpack pop /decoded2 exch def
decoded2 orig2 eq                               (s3: fletcher32 round-trip via pack) rt-ok

% ====================================================================
% SECTION 4: Sad path
% ====================================================================

% Wrong type (integer) -> type-check.
{ 42 crc32 } try /type-check eq                 (s4: crc32 on integer raises type-check) rt-ok clear
{ 42 fletcher32 } try /type-check eq            (s4: fletcher32 on integer raises type-check) rt-ok clear
{ 42 adler32 } try /type-check eq               (s4: adler32 on integer raises type-check) rt-ok clear

% Empty stack -> opstack-underflow.
{ crc32 } try /opstack-underflow eq             (s4: crc32 empty stack -> underflow) rt-ok clear
{ fletcher32 } try /opstack-underflow eq        (s4: fletcher32 empty stack -> underflow) rt-ok clear
{ adler32 } try /opstack-underflow eq           (s4: adler32 empty stack -> underflow) rt-ok clear

% ====================================================================
% SECTION 5: adler32 (RFC 1950 / zlib Adler-32 trailer)
% ====================================================================

% Empty -> 0x00000001 (initial state)
() adler32 16#00000001#u eq                     (s5: adler32 empty = 0x00000001) rt-ok

% Single byte 'a' = 0x61: s1 = 1+0x61 = 0x62, s2 = 0+0x62 = 0x62
(a) adler32 16#00620062#u eq                    (s5: adler32 (a)) rt-ok

% (abc) -> 0x024D0127 (RFC 1950 Appendix A example)
(abc) adler32 16#024D0127#u eq                  (s5: adler32 (abc) RFC 1950) rt-ok

% (Wikipedia) -> 0x11E60398 (Wikipedia Adler-32 example)
(Wikipedia) adler32 16#11E60398#u eq            (s5: adler32 (Wikipedia)) rt-ok

% Long input crossing the NMAX=5552 deferred-mod boundary.  Verify by
% computing the same value via incremental folding through 6000 bytes.
% Pre-computed reference value (zlib): zlib.adler32(b'\xAB' * 6000) = 0x88BAA8B2.
/long-buf 6000 string def
0 1 5999 {|i| long-buf i 16#AB#b put} for
long-buf adler32 16#39DFA8B2#u eq               (s5: adler32 6000-byte cross-NMAX boundary) rt-ok

% ====================================================================
% SECTION 6: streaming variants (crc32-stream, adler32-stream,
%            fletcher32-stream)
% ====================================================================
% Each `<checksum>-stream` op consumes a readable stream and returns
% the same uint32 the one-shot version would on identical input.

% --- Cross-validation against the one-shot ops on representative
%     payloads.  make-memory-stream wraps a Trix string so we can do
%     the round-trip entirely in memory without temp files. ---

() make-memory-stream crc32-stream
    () crc32 eq                                 (s6: crc32-stream empty)         rt-ok
(123456789) make-memory-stream crc32-stream
    (123456789) crc32 eq                        (s6: crc32-stream zlib vector)   rt-ok

() make-memory-stream fletcher32-stream
    () fletcher32 eq                            (s6: fletcher32-stream empty)    rt-ok
(abcde) make-memory-stream fletcher32-stream
    (abcde) fletcher32 eq                       (s6: fletcher32-stream odd-len)  rt-ok
(abcdef) make-memory-stream fletcher32-stream
    (abcdef) fletcher32 eq                      (s6: fletcher32-stream even-len) rt-ok
(abcdefgh) make-memory-stream fletcher32-stream
    (abcdefgh) fletcher32 eq                    (s6: fletcher32-stream 8 bytes)  rt-ok

() make-memory-stream adler32-stream
    16#00000001#u eq                            (s6: adler32-stream empty)       rt-ok
(a) make-memory-stream adler32-stream
    16#00620062#u eq                            (s6: adler32-stream (a))         rt-ok
(abc) make-memory-stream adler32-stream
    16#024D0127#u eq                            (s6: adler32-stream (abc))       rt-ok
(Wikipedia) make-memory-stream adler32-stream
    16#11E60398#u eq                            (s6: adler32-stream (Wikipedia)) rt-ok

% --- Long input crossing the NMAX=5552 mod-deferral boundary.  Same
%     reference value as s5; this verifies the streaming accumulator
%     doesn't drift across chunk boundaries (4 KiB scratch buffer
%     means multiple iterations of the inner loop). ---

long-buf make-memory-stream adler32-stream
    16#39DFA8B2#u eq                            (s6: adler32-stream cross-NMAX)  rt-ok

% --- Sad path: type-check on non-stream operand. ---

{ 42 crc32-stream }      try /type-check eq    (s6: crc32-stream(int) -> type)   rt-ok clear
{ 42 adler32-stream }    try /type-check eq    (s6: adler32-stream(int) -> type) rt-ok clear
{ 42 fletcher32-stream } try /type-check eq    (s6: fletcher32-stream(int) -> type) rt-ok clear

% --- Sad path: stream not readable.  make-string-stream returns a
%     write-only stream; running a stream-checksum on it must raise
%     /invalid-stream-access. ---

{ 64 make-string-stream crc32-stream } try /invalid-stream-access eq
                                               (s6: crc32-stream on write-stream) rt-ok clear

rt-fails 0 get /integer-type cast 0 gt { /rt-assertions-failed throw } if
(test_checksum: ALL TESTS PASSED) =
(__test_ok__) =
