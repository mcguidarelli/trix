% ====================================================================
% Mirror of test_lazy.trx long/ulong cases for Int128/UInt128.
%
% Every lazy-* combinator tested with `l` values in test_lazy.trx gets
% an `h` parallel here. Lazy-from was already proven to be a UB site
% with 128-bit increments (fixed in the 2026-04-17 UB sweep); this
% file keeps the rest of the combinator surface honest.
% ====================================================================

% rt-ok counts failures in a restore-immune slot -- string byte writes
% are unjournaled, so the count survives assertions made inside save
% scopes, and the 1-byte string lives in LOCAL VM, invisible to the
% global-heap/gc-counter probes some files assert on.  The file THROWS
% at EOF: test_all counts a file as failed only when its run throws,
% so print-only failures would slip the suite verdict.
/rt-fails 1 string def
rt-fails 0 16#0#b put
/rt-ok { exch { = } { (FAILED: ) print = rt-fails 0  rt-fails 0 get /integer-type cast 1 add dup 255 gt { pop 255 } if /byte-type cast  put } if-else } def

% ====================================================================
% SECTION 1: lazy-seq round-trip on a 128-bit array
% ====================================================================

[100q 200q 300q] lazy-seq lazy-to-array
    dup 0 get 100q deep-eq                    (int128 round-trip [0]) rt-ok
    dup 1 get 200q deep-eq                    (int128 round-trip [1]) rt-ok
    dup 2 get 300q deep-eq                    (int128 round-trip [2]) rt-ok
    pop clear

[100uq 200uq 300uq] lazy-seq lazy-to-array
    dup 0 get 100uq deep-eq                   (uint128 round-trip [0]) rt-ok
    dup 2 get 300uq deep-eq                   (uint128 round-trip [2]) rt-ok
    pop clear

% ====================================================================
% SECTION 2: lazy-map with 128-bit transformation
% ====================================================================

[1q 2q 3q 4q 5q] lazy-seq { 10q mul } lazy-map lazy-to-array
    dup 0 get 10q deep-eq                     (int128 map [0] = 10q) rt-ok
    dup 4 get 50q deep-eq                     (int128 map [4] = 50q) rt-ok
    pop clear

[1uq 2uq 3uq] lazy-seq { 10uq mul } lazy-map lazy-to-array
    dup 0 get 10uq deep-eq                    (uint128 map [0]) rt-ok
    dup 2 get 30uq deep-eq                    (uint128 map [2]) rt-ok
    pop clear

% ====================================================================
% SECTION 3: lazy-filter with 128-bit predicate
% ====================================================================

[10q 20q 30q 40q 50q] lazy-seq { 25q gt } lazy-filter lazy-to-array
    dup length 3 eq                           (int128 filter length) rt-ok
    dup 0 get 30q deep-eq                     (int128 filter [0]) rt-ok
    dup 2 get 50q deep-eq                     (int128 filter [2]) rt-ok
    pop clear

[10uq 20uq 30uq 40uq 50uq] lazy-seq { 25uq gt } lazy-filter lazy-to-array
    dup 0 get 30uq deep-eq                    (uint128 filter [0]) rt-ok
    pop clear

% ====================================================================
% SECTION 4: lazy-fold with 128-bit seed/accumulator
% ====================================================================

[1q 2q 3q 4q 5q] lazy-seq 0q { add } lazy-fold 15q deep-eq
    (int128 fold sum 1..5) rt-ok clear

[100q 200q 300q] lazy-seq 0q { add } lazy-fold 600q deep-eq
    (int128 fold larger values) rt-ok clear

[100uq 200uq 300uq] lazy-seq 0uq { add } lazy-fold 600uq deep-eq
    (uint128 fold sum) rt-ok clear

% ====================================================================
% SECTION 5: lazy-scan with 128-bit seed
% ====================================================================

[1q 2q 3q] lazy-seq 0q { add } lazy-scan lazy-to-array
    dup 0 get 0q deep-eq                      (int128 scan [0] = 0) rt-ok
    dup 1 get 1q deep-eq                      (int128 scan [1] = 1) rt-ok
    dup 3 get 6q deep-eq                      (int128 scan [3] = 6) rt-ok
    pop clear

[1uq 2uq 3uq] lazy-seq 0uq { add } lazy-scan lazy-to-array
    dup 3 get 6uq deep-eq                     (uint128 scan [3] = 6) rt-ok
    pop clear

% ====================================================================
% SECTION 6: lazy-find / lazy-any / lazy-all
% ====================================================================

[10q 20q 30q 40q] lazy-seq { 30q eq } lazy-find 30q deep-eq
    (int128 find) rt-ok clear

[10q 20q 30q] lazy-seq { 20q eq } lazy-any
    (int128 any true) rt-ok clear

[10q 20q 30q] lazy-seq { 5q gt } lazy-all
    (int128 all true) rt-ok clear

[10uq 20uq 30uq] lazy-seq { 5uq gt } lazy-all
    (uint128 all true) rt-ok clear

% ====================================================================
% SECTION 7: lazy-zip / lazy-chain / lazy-flat-map
% ====================================================================

[1q 2q 3q] lazy-seq [10q 20q 30q] lazy-seq lazy-zip lazy-to-array
    dup 0 get dup 0 get 1q deep-eq exch 1 get 10q deep-eq and
                                              (int128 zip pair 0) rt-ok
    dup 2 get dup 0 get 3q deep-eq exch 1 get 30q deep-eq and
                                              (int128 zip pair 2) rt-ok
    pop clear

[1q 2q] lazy-seq [3q 4q] lazy-seq lazy-chain lazy-to-array
    dup 0 get 1q deep-eq                      (int128 chain [0]) rt-ok
    dup 3 get 4q deep-eq                      (int128 chain [3]) rt-ok
    pop clear

[1uq 2uq] lazy-seq [3uq 4uq] lazy-seq lazy-chain lazy-to-array
    dup 3 get 4uq deep-eq                     (uint128 chain [3]) rt-ok
    pop clear

% ====================================================================
% SECTION 8: lazy-nth with 128-bit values
% ====================================================================

[10q 20q 30q] lazy-seq 2 lazy-nth 30q deep-eq (int128 nth) rt-ok clear
[10uq 20uq 30uq] lazy-seq 1 lazy-nth 20uq deep-eq (uint128 nth) rt-ok clear

% ====================================================================
% SECTION 9: lazy-dedupe with 128-bit runs
% ====================================================================

[1q 1q 2q 2q 3q] lazy-seq lazy-dedupe lazy-to-array
    dup length 3 eq                           (int128 dedupe length) rt-ok
    dup 0 get 1q deep-eq                      (int128 dedupe [0]) rt-ok
    dup 2 get 3q deep-eq                      (int128 dedupe [2]) rt-ok
    pop clear

[1uq 1uq 2uq 2uq] lazy-seq lazy-dedupe lazy-to-array
    dup length 2 eq                           (uint128 dedupe length) rt-ok
    pop clear

% ====================================================================
% SECTION 10: lazy-intersperse with 128-bit separator
% ====================================================================

[1q 2q 3q] lazy-seq 0q lazy-intersperse lazy-to-array
    dup 1 get 0q deep-eq                      (int128 intersperse [1] = 0) rt-ok
    dup 2 get 2q deep-eq                      (int128 intersperse [2] = 2) rt-ok
    pop clear

% ====================================================================
% SECTION 11: lazy-from (the original UB site) -- bounded take
% ====================================================================

5q lazy-from 3 lazy-take lazy-to-array [5q 6q 7q] deep-eq
    (lazy-from int128) rt-ok clear

5uq lazy-from 3 lazy-take lazy-to-array [5uq 6uq 7uq] deep-eq
    (lazy-from uint128) rt-ok clear

% ====================================================================
% SECTION 12: lazy pipeline combinator chain with 128-bit values
% ====================================================================

[1q 2q 3q 4q 5q 6q 7q 8q 9q 10q] lazy-seq
    { 100q mul } lazy-map
    { 500q gt } lazy-filter
    0q { add } lazy-fold
    4000q deep-eq                             (int128 lazy pipeline sum >500q) rt-ok clear

(test_int128_lazy_mirror.trx complete) =
rt-fails 0 get /integer-type cast 0 gt { /rt-assertions-failed throw } if
(__test_ok__) =
