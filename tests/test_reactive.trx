% SECTION 158: FUZZ -- cell-transduce xf-flatten
% =================================================================

[[1 2] [3 4] [5]] cell /src exch def
src xf-flatten cell-transduce /flat exch def
flat cell-get [1 2 3 4 5] deep-eq         (cell-transduce: xf-flatten) rt-ok  clear

% =================================================================
% SECTION 159: FUZZ -- cell-transduce xf-distinct
% =================================================================

[1 2 2 3 3 3 1] cell /src exch def
src xf-distinct cell-transduce /uniq exch def
uniq cell-get [1 2 3 1] deep-eq           (cell-transduce: xf-distinct) rt-ok  clear

% =================================================================
% SECTION 160: vm-validate
% =================================================================

/vm-validate query-status true eq         (vm-validate: heap integrity) rt-ok  clear

rt-fails 0 get /integer-type cast 0 gt { /rt-assertions-failed throw } if
(test_reactive: ALL TESTS PASSED) =
(__test_ok__) =
