% =================================================================
% SECTION 94: cell-dispose basic (base cell)
% =================================================================

10 cell /c exch def
c cell-dispose
{ c cell-get } try /invalid-access eq
    (dispose: cell-get errors on disposed) rt-ok
{ 20 c cell-set } try /invalid-access eq
    (dispose: cell-set errors on disposed) rt-ok
{ { 1 add } c cell-update } try /invalid-access eq
    (dispose: cell-update errors on disposed) rt-ok
{ c { pop pop } watch } try /invalid-access eq
    (dispose: watch errors on disposed) rt-ok  clear

% =================================================================
% SECTION 95: cell-dispose idempotent
% =================================================================

42 cell /c exch def
c cell-dispose
c cell-dispose  % second dispose is no-op
true (dispose: idempotent) rt-ok  clear

% =================================================================
% SECTION 96: cell-dispose disconnects cell-computed deps
% =================================================================

10 cell /base exch def
{ base cell-get 2 mul } cell-computed /comp exch def
comp cell-get 20 eq
    (dispose-dep: initial cell-computed = 20) rt-ok

% Dispose the base cell
base cell-dispose

% Computed cell keeps its cached value (not invalidated)
comp cell-get 20 eq
    (dispose-dep: cell-computed still has cached 20) rt-ok

% base should be disconnected from comp's deps
comp cell-deps length 0 eq
    (dispose-dep: cell-computed deps cleared) rt-ok  clear

% =================================================================
% SECTION 97: cell-dispose disconnects rdeps
% =================================================================

10 cell /base exch def
{ base cell-get 2 mul } cell-computed /comp exch def
comp cell-get pop  % force evaluation to register deps
base cell-rdeps length 1 eq
    (dispose-rdep: base has 1 rdep before dispose) rt-ok

% Dispose the cell-computed cell
comp cell-dispose

% base's rdeps should no longer include comp
base cell-rdeps length 0 eq
    (dispose-rdep: base has 0 rdeps after dispose) rt-ok  clear

% =================================================================
% SECTION 98: cell-dispose clears watchers
% =================================================================

10 cell /base exch def
base { pop pop } watch
base cell-watchers length 1 eq
    (dispose-watch: 1 watcher before) rt-ok
base cell-dispose
% Can't check watchers on disposed cell, but verifying it ran without error
true (dispose-watch: dispose cleared watchers) rt-ok  clear

% =================================================================
% SECTION 99: cell-dispose with ExtValue (Long)
% =================================================================

1000000000l cell /c exch def
c cell-dispose
true (dispose-ext: Long ExtValue freed) rt-ok  clear

% =================================================================
% SECTION 100: cell-dispose in chain (dispose leaf first)
% =================================================================

10 cell /a exch def
{ a cell-get 1 add } cell-computed /b exch def
{ b cell-get 2 mul } cell-computed /c exch def
c cell-get 22 eq (dispose-chain: initial c = 22) rt-ok

% Dispose leaf (c), then middle (b)
c cell-dispose
b cell-dispose

% a should have no rdeps now
a cell-rdeps length 0 eq
    (dispose-chain: a has no rdeps) rt-ok

% a is still live
20 a cell-set
a cell-get 20 eq
    (dispose-chain: a still works) rt-ok  clear

