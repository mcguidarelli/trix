% ====================================================================
% test_reactive.trx -- cell, cell-computed, cell-get, cell-set, cell-value,
%                      is-cell, cell-dirty?, watch, unwatch, batch
% ====================================================================

% rt-ok counts failures in a restore-immune slot -- string byte writes
% are unjournaled, so the count survives assertions made inside save
% scopes, and the 1-byte string lives in LOCAL VM, invisible to the
% global-heap/gc-counter probes some files assert on.  The file THROWS
% at EOF: test_all counts a file as failed only when its run throws,
% so print-only failures would slip the suite verdict.
/rt-fails 1 string def
rt-fails 0 16#0#b put
/rt-ok { exch { = } { (FAILED: ) print = rt-fails 0  rt-fails 0 get /integer-type cast 1 add dup 255 gt { pop 255 } if /byte-type cast  put } if-else } def
/==s { /==s-v exch def =string ({0:O}) [ ==s-v ] asprint-fmt pop } def

% =================================================================
% SECTION 1: HAPPY PATH -- cell creation and basic ops
% =================================================================

10 cell is-cell                             (happy: cell creates cell) rt-ok  clear
42 is-cell not                              (happy: integer is not cell) rt-ok  clear
(hello) is-cell not                         (happy: string is not cell) rt-ok  clear
null is-cell not                            (happy: null is not cell) rt-ok  clear
true is-cell not                            (happy: bool is not cell) rt-ok  clear

% =================================================================
% SECTION 2: HAPPY PATH -- cell-get returns base cell value
% =================================================================

10 cell /c exch def
c cell-get 10 eq                            (happy: cell-get returns initial value) rt-ok  clear

% =================================================================
% SECTION 3: HAPPY PATH -- cell-set updates base cell
% =================================================================

10 cell /c exch def
20 c cell-set
c cell-get 20 eq                            (happy: cell-set updates value) rt-ok  clear

% =================================================================
% SECTION 4: HAPPY PATH -- cell-get after cell-set
% =================================================================

10 cell /c exch def
c cell-get 10 eq                            (happy: initial cell-get) rt-ok
99 c cell-set
c cell-get 99 eq                            (happy: cell-get after cell-set) rt-ok  clear

% =================================================================
% SECTION 5: HAPPY PATH -- cell-computed cell evaluates proc
% =================================================================

10 cell /base exch def
{ base cell-get 2 mul } cell-computed /derived exch def
derived cell-get 20 eq                      (happy: cell-computed cell evaluates) rt-ok  clear

% =================================================================
% SECTION 6: HAPPY PATH -- cell-computed cell caches result
% =================================================================

/eval-count 0 def
10 cell /base exch def
{ /eval-count eval-count 1 add def  base cell-get 2 mul } cell-computed /derived exch def
derived cell-get 20 eq                      (happy: first eval correct) rt-ok
derived cell-get 20 eq                      (happy: cached eval correct) rt-ok
eval-count 1 eq                             (happy: proc ran only once) rt-ok  clear

% =================================================================
% SECTION 7: HAPPY PATH -- cell-set invalidates cell-computed cell
% =================================================================

10 cell /base exch def
{ base cell-get 2 mul } cell-computed /derived exch def
derived cell-get 20 eq                      (happy: initial derived) rt-ok
15 base cell-set
derived cell-get 30 eq                      (happy: derived recell-computed after cell-set) rt-ok  clear

% =================================================================
% SECTION 8: HAPPY PATH -- diamond dependency
% =================================================================

10 cell /a exch def
{ a cell-get 1 add } cell-computed /b exch def
{ a cell-get 2 mul } cell-computed /c exch def
{ b cell-get c cell-get add } cell-computed /d exch def
d cell-get 31 eq                            (happy: diamond initial: 11+20=31) rt-ok
5 a cell-set
d cell-get 16 eq                            (happy: diamond after update: 6+10=16) rt-ok  clear

% =================================================================
% SECTION 9: HAPPY PATH -- cell-value reads without dep
% =================================================================

10 cell /base exch def
/dep-observed false def
{ base cell-value 2 mul } cell-computed /c exch def
c cell-get 20 eq                            (happy: cell-value initial read) rt-ok
99 base cell-set
% c was NOT invalidated because cell-value didn't record dependency
c cell-dirty? not                           (happy: cell-value no dep recorded) rt-ok  clear

% =================================================================
% SECTION 10: HAPPY PATH -- cell-dirty?
% =================================================================

10 cell /base exch def
{ base cell-get 2 mul } cell-computed /derived exch def
derived cell-dirty?                         (happy: cell-computed starts dirty) rt-ok
derived cell-get pop
derived cell-dirty? not                     (happy: not dirty after eval) rt-ok
99 base cell-set
derived cell-dirty?                         (happy: dirty after cell-set) rt-ok  clear

% =================================================================
% SECTION 11: HAPPY PATH -- watch fires on change
% =================================================================

10 cell /c exch def
/watch-fired false def
c { pop pop /watch-fired true def } watch
20 c cell-set
watch-fired                                 (happy: watcher fired) rt-ok  clear

% =================================================================
% SECTION 12: HAPPY PATH -- watcher receives old and new values
% =================================================================

10 cell /c exch def
/old-val null def
/new-val null def
c { /new-val exch def /old-val exch def } watch
42 c cell-set
old-val 10 eq                               (happy: watcher old value) rt-ok
new-val 42 eq                               (happy: watcher new value) rt-ok  clear

% =================================================================
% SECTION 13: HAPPY PATH -- unwatch removes watcher
% =================================================================

10 cell /c exch def
/watch-fired false def
/my-watcher { pop pop /watch-fired true def } def
c //my-watcher watch
c //my-watcher unwatch
20 c cell-set
watch-fired not                             (happy: unwatch prevents firing) rt-ok  clear

% =================================================================
% SECTION 14: HAPPY PATH -- batch defers then fires watchers
% =================================================================

10 cell /c exch def
/fire-count 0 def
c { pop pop /fire-count fire-count 1 add def } watch
{
    20 c cell-set
    30 c cell-set
    40 c cell-set
} batch
fire-count 1 eq                             (happy: batch watcher fired once) rt-ok
c cell-get 40 eq                            (happy: batch final value) rt-ok  clear

% =================================================================
% SECTION 14a: HAPPY -- batch watcher receives correct old/new values
% =================================================================

10 cell /c exch def
/batch-old null def
/batch-new null def
c { /batch-new exch def /batch-old exch def } watch
{
    42 c cell-set
} batch
batch-old 10 eq                             (happy: batch old value correct) rt-ok
batch-new 42 eq                             (happy: batch new value correct) rt-ok  clear

% =================================================================
% SECTION 14b: HAPPY -- batch set-then-unset (net no change skips watcher)
% =================================================================

10 cell /c exch def
/fire-count 0 def
c { pop pop /fire-count fire-count 1 add def } watch
{
    20 c cell-set
    10 c cell-set
} batch
fire-count 0 eq                             (happy: batch no-change skips watcher) rt-ok
c cell-get 10 eq                            (happy: batch restored value) rt-ok  clear

% =================================================================
% SECTION 14c: HAPPY -- multiple cells updated in batch
% =================================================================

10 cell /a exch def
20 cell /b exch def
/a-fired false def
/b-fired false def
a { pop pop /a-fired true def } watch
b { pop pop /b-fired true def } watch
{
    11 a cell-set
    21 b cell-set
} batch
a-fired                                     (happy: batch cell-a watcher fired) rt-ok
b-fired                                     (happy: batch cell-b watcher fired) rt-ok  clear

% =================================================================
% SECTION 14d: HAPPY -- nested batch fires at outermost end
% =================================================================

10 cell /c exch def
/fire-count 0 def
c { pop pop /fire-count fire-count 1 add def } watch
{
    20 c cell-set
    {
        30 c cell-set
    } batch
    fire-count 0 eq                         (happy: nested batch still deferred) rt-ok
    40 c cell-set
} batch
fire-count 1 eq                             (happy: nested batch fired at outermost) rt-ok  clear

% =================================================================
% SECTION 14e: HAPPY -- batch error discards watchers
% =================================================================

10 cell /c exch def
/fire-count 0 def
c { pop pop /fire-count fire-count 1 add def } watch
{ { 20 c cell-set  1 0 div } batch } try pop
fire-count 0 eq                             (happy: batch error discards watchers) rt-ok  clear

% =================================================================
% SECTION 14f: HAPPY -- batch with downstream cell-computed cell watcher
% =================================================================

10 cell /base exch def
{ base cell-get 1 add } cell-computed /derived exch def
derived cell-get pop                        % force initial eval so cache is populated
/d-old null def
/d-new null def
derived { /d-new exch def /d-old exch def } watch
{
    20 base cell-set
    derived cell-get pop                    % recompute during batch
} batch
d-old 11 eq                                 (happy: batch downstream old value) rt-ok
d-new 21 eq                                 (happy: batch downstream new value) rt-ok  clear

% =================================================================
% SECTION 14g: STRESS -- multiple watchers on same cell in batch
% =================================================================

10 cell /c exch def
/w1 0 def  /w2 0 def  /w3 0 def
c { pop pop /w1 w1 1 add def } watch
c { pop pop /w2 w2 1 add def } watch
c { pop pop /w3 w3 1 add def } watch
{
    20 c cell-set
    30 c cell-set
} batch
w1 1 eq                                     (stress: batch multi-watcher w1) rt-ok
w2 1 eq                                     (stress: batch multi-watcher w2) rt-ok
w3 1 eq                                     (stress: batch multi-watcher w3) rt-ok  clear

% =================================================================
% SECTION 14q: BOUNDARY -- empty batch (no cell-sets)
% =================================================================

10 cell /c exch def
/fire-count 0 def
c { pop pop /fire-count fire-count 1 add def } watch
{ } batch
fire-count 0 eq                             (boundary: empty batch no watcher) rt-ok
c cell-get 10 eq                            (boundary: empty batch value unchanged) rt-ok  clear

% =================================================================
% SECTION 14i: BOUNDARY -- batch with only equality-skip sets
% =================================================================

42 cell /c exch def
/fire-count 0 def
c { pop pop /fire-count fire-count 1 add def } watch
{
    42 c cell-set
    42 c cell-set
} batch
fire-count 0 eq                             (boundary: eq-skip batch no watcher) rt-ok  clear

% =================================================================
% SECTION 14j: FUZZ -- batch with Long (ExtValue) values
% =================================================================

9999999999l cell /c exch def
/ev-old null def
/ev-new null def
c { /ev-new exch def /ev-old exch def } watch
{
    1111111111l c cell-set
    2222222222l c cell-set
} batch
ev-old 9999999999l eq                       (fuzz: batch extvalue old correct) rt-ok
ev-new 2222222222l eq                       (fuzz: batch extvalue new correct) rt-ok  clear

% =================================================================
% SECTION 15: HAPPY PATH -- chain of 3 cell-computed cells
% =================================================================

10 cell /base exch def
{ base cell-get 1 add } cell-computed /c1 exch def
{ c1 cell-get 2 mul } cell-computed /c2 exch def
{ c2 cell-get 3 add } cell-computed /c3 exch def
c3 cell-get 25 eq                           (happy: chain initial: ((10+1)*2)+3=25) rt-ok
5 base cell-set
c3 cell-get 15 eq                           (happy: chain after update: ((5+1)*2)+3=15) rt-ok  clear

% =================================================================
% SECTION 16: HAPPY PATH -- cell-computed with multiple deps
% =================================================================

10 cell /x exch def
20 cell /y exch def
{ x cell-get y cell-get add } cell-computed /sum-cell exch def
sum-cell cell-get 30 eq                          (happy: multi-dep initial) rt-ok
15 x cell-set
sum-cell cell-get 35 eq                          (happy: multi-dep after x change) rt-ok
25 y cell-set
sum-cell cell-get 40 eq                          (happy: multi-dep after y change) rt-ok  clear

% =================================================================
% SECTION 17: SAD PATH -- cell-set on cell-computed cell
% =================================================================

{ 42 } cell-computed /c exch def
{ 99 c cell-set } try /undefined-result eq     (sad: cell-set on cell-computed) rt-ok  clear

% =================================================================
% SECTION 18: SAD PATH -- cell-get on non-cell
% =================================================================

{ 42 cell-get } try /type-check eq          (sad: cell-get on int) rt-ok  clear
{ (hello) cell-get } try /type-check eq     (sad: cell-get on string) rt-ok  clear

% =================================================================
% SECTION 19: SAD PATH -- cell-set on non-cell
% =================================================================

{ 99 42 cell-set } try /type-check eq          (sad: cell-set on int) rt-ok  clear

% =================================================================
% SECTION 20: SAD PATH -- cell-computed with non-executable
% =================================================================

{ 42 cell-computed } try /type-check eq          (sad: cell-computed non-exec) rt-ok  clear

% =================================================================
% SECTION 21: SAD PATH -- error in cell-computed proc
% =================================================================

{ 1 0 div } cell-computed /bad exch def
{ bad cell-get } try /div-by-zero eq        (sad: error in cell-computed proc) rt-ok  clear

% =================================================================
% SECTION 22: SAD PATH -- error leaves cell dirty
% =================================================================

{ 1 0 div } cell-computed /bad exch def
{ bad cell-get } try pop
bad cell-dirty?                             (sad: cell stays dirty after error) rt-ok  clear

% =================================================================
% SECTION 23: SAD PATH -- watch on non-cell
% =================================================================

{ 42 { } watch } try /type-check eq        (sad: watch on non-cell) rt-ok  clear

% =================================================================
% SECTION 24: SAD PATH -- unwatch on non-cell
% =================================================================

{ 42 { } unwatch } try /type-check eq      (sad: unwatch on non-cell) rt-ok  clear

% =================================================================
% SECTION 25: SAD PATH -- batch with non-executable
% =================================================================

{ 42 batch } try /type-check eq             (sad: batch non-exec) rt-ok  clear

% =================================================================
% SECTION 26: SAD PATH -- cell-value on non-cell
% =================================================================

{ 42 cell-value } try /type-check eq        (sad: cell-value on non-cell) rt-ok  clear

% =================================================================
% SECTION 27: SAD PATH -- cell-dirty? on non-cell
% =================================================================

{ 42 cell-dirty? } try /type-check eq       (sad: cell-dirty? on non-cell) rt-ok  clear

% =================================================================
% SECTION 28: STRESS -- 20-cell dependency chain
% =================================================================

1 cell /chain-base exch def
/prev chain-base def
1 1 20 {
    pop
    prev { cell-get 1 add } curry cell-computed /prev exch def
} for
prev cell-get 21 eq                         (stress: 20-cell chain initial) rt-ok
10 chain-base cell-set
prev cell-get 30 eq                         (stress: 20-cell chain after update) rt-ok  clear

% =================================================================
% SECTION 29: STRESS -- wide fan-out (1 base, 10 cell-computed)
% =================================================================

10 cell /fan-base exch def
/fan-sum 0 def
1 1 10 {
    pop
    fan-base { cell-get } curry cell-computed /fc exch def
    /fan-sum fan-sum fc cell-get add def
} for
fan-sum 100 eq                              (stress: wide fan-out 10*10=100) rt-ok  clear

% =================================================================
% SECTION 30: STRESS -- repeated cell-set/cell-get cycles
% =================================================================

0 cell /counter exch def
{ counter cell-get 1 add } cell-computed /plus-one exch def
1 1 50 {
    counter cell-set
    plus-one cell-get pop
} for
counter cell-get 50 eq                      (stress: 50 cell-set/cell-get cycles) rt-ok
plus-one cell-get 51 eq                     (stress: plus-one after 50 cycles) rt-ok  clear

% =================================================================
% SECTION 31: STRESS -- multiple watchers on single cell
% =================================================================

10 cell /mw exch def
/mw-count 0 def
mw { pop pop /mw-count mw-count 1 add def } watch
mw { pop pop /mw-count mw-count 1 add def } watch
mw { pop pop /mw-count mw-count 1 add def } watch
20 mw cell-set
mw-count 3 eq                               (stress: 3 watchers all fired) rt-ok  clear

% =================================================================
% SECTION 32: STRESS -- nested batch
% =================================================================

10 cell /nb exch def
{
    20 nb cell-set
    {
        30 nb cell-set
    } batch
    40 nb cell-set
} batch
nb cell-get 40 eq                           (stress: nested batch final) rt-ok  clear

% =================================================================
% SECTION 33: FUZZ -- cell holding various types
% =================================================================

42 cell /fi exch def
fi cell-get 42 eq                           (fuzz: cell holds integer) rt-ok
(hello) fi cell-set
fi cell-get (hello) eq                      (fuzz: cell holds string) rt-ok
null fi cell-set
fi cell-get null eq                         (fuzz: cell holds null) rt-ok
true fi cell-set
fi cell-get                                 (fuzz: cell holds boolean) rt-ok  clear

% =================================================================
% SECTION 34: FUZZ -- cell holding array
% =================================================================

[ 1 2 3 ] cell /arr-c exch def
arr-c cell-get length 3 eq                  (fuzz: cell holds array) rt-ok  clear

% =================================================================
% SECTION 35: FUZZ -- cell holding tagged value
% =================================================================

42 /:some tag cell /tc exch def
tc cell-get tag-name /:some eq              (fuzz: cell holds tagged) rt-ok  clear

% =================================================================
% SECTION 36: FUZZ -- cell-computed returning different types
% =================================================================

0 cell /type-switch exch def
{
    type-switch cell-get
    0 eq { 42 }
    { type-switch cell-get 1 eq { (hello) } { true } if-else }
    if-else
} cell-computed /multi exch def
multi cell-get 42 eq                        (fuzz: cell-computed returns int) rt-ok
1 type-switch cell-set
multi cell-get (hello) eq                   (fuzz: cell-computed returns string) rt-ok
2 type-switch cell-set
multi cell-get                              (fuzz: cell-computed returns bool) rt-ok  clear

% =================================================================
% SECTION 37: BOUNDARY -- cell-computed with zero deps (constant)
% =================================================================

{ 42 } cell-computed /const-cell exch def
const-cell cell-get 42 eq                   (boundary: constant cell-computed) rt-ok
const-cell cell-dirty? not                  (boundary: constant not dirty) rt-ok  clear

% =================================================================
% SECTION 38: BOUNDARY -- unwatch on cell with no watchers
% =================================================================

10 cell /no-w exch def
no-w { } unwatch
true                                        (boundary: unwatch no-op) rt-ok  clear

% =================================================================
% SECTION 39: BOUNDARY -- cell-get on non-dirty cell-computed (cached)
% =================================================================

/bc-count 0 def
{ /bc-count bc-count 1 add def  99 } cell-computed /cached exch def
cached cell-get 99 eq                       (boundary: first get evaluates) rt-ok
cached cell-get 99 eq                       (boundary: second get uses cache) rt-ok
bc-count 1 eq                               (boundary: only evaluated once) rt-ok  clear

% =================================================================
% SECTION 40: BOUNDARY -- single-cell graph (no dependents)
% =================================================================

10 cell /solo exch def
solo cell-get 10 eq                         (boundary: solo cell read) rt-ok
20 solo cell-set
solo cell-get 20 eq                         (boundary: solo cell updated) rt-ok  clear

% =================================================================
% SECTION 41: BOUNDARY -- base cell is never dirty
% =================================================================

10 cell /bd exch def
bd cell-dirty? not                          (boundary: base cell not dirty) rt-ok
20 bd cell-set
bd cell-dirty? not                          (boundary: base cell still not dirty after set) rt-ok  clear

% =================================================================
% SECTION 42: SAVE/RESTORE -- cell-set inside save reverts
% =================================================================

10 cell /sv-c exch def
/sv-save save def
20 sv-c cell-set
sv-c cell-get 20 eq                         (save: cell-set value before restore) rt-ok
sv-save restore
sv-c cell-get 10 eq                         (save: cell-set reverted after restore) rt-ok  clear

% =================================================================
% SECTION 43: SAVE/RESTORE -- cell-computed re-evals after restore
% =================================================================

10 cell /sv-base exch def
{ sv-base cell-get 2 mul } cell-computed /sv-derived exch def
sv-derived cell-get 20 eq                   (save: derived initial) rt-ok
/sv-save save def
99 sv-base cell-set
sv-derived cell-get 198 eq                  (save: derived after cell-set) rt-ok
sv-save restore
sv-base cell-get 10 eq                      (save: base reverted) rt-ok  clear

% =================================================================
% SECTION 44: ERROR -- error in batch
% =================================================================

10 cell /eb exch def
{ { 1 0 div } batch } try /div-by-zero eq       (error: batch propagates error) rt-ok  clear

% =================================================================
% SECTION 45: HAPPY -- watcher that updates another cell
% =================================================================

10 cell /src exch def
0 cell /dst exch def
src { /new-val exch def  pop  new-val dst cell-set } watch
20 src cell-set
dst cell-get 20 eq                          (happy: watcher updates another cell) rt-ok  clear

% =================================================================
% SECTION 46: TYPE -- cell type name
% =================================================================

10 cell type /cell-type eq                  (type: cell type is cell-type) rt-ok  clear

% =================================================================
% SECTION 47: HAPPY -- equality skip: same value does not invalidate
% =================================================================

10 cell /c exch def
{ c cell-get 2 mul } cell-computed /d exch def
d cell-get 20 eq                           (eq-skip: initial cell-computed) rt-ok
10 c cell-set                                 % set to same value
d cell-get 20 eq                           (eq-skip: no recompute needed) rt-ok  clear

% =================================================================
% SECTION 48: HAPPY -- equality skip: watcher does NOT fire on same value
% =================================================================

/fired false def
42 cell /c exch def
c { pop pop /fired true def } watch
42 c cell-set                                 % same value
fired not                                  (eq-skip: watcher not fired) rt-ok  clear

% =================================================================
% SECTION 49: HAPPY -- equality skip: different value DOES invalidate
% =================================================================

10 cell /c exch def
{ c cell-get 2 mul } cell-computed /d exch def
d cell-get 20 eq                           (eq-skip: initial) rt-ok
20 c cell-set                                 % different value
d cell-get 40 eq                           (eq-skip: recell-computed after change) rt-ok  clear

% =================================================================
% SECTION 50: BOUNDARY -- equality skip with ExtValue (Long)
% =================================================================

9999999999l cell /c exch def
/fired false def
c { pop pop /fired true def } watch
9999999999l c cell-set                        % same Long value
fired not                                  (eq-skip: long same no fire) rt-ok
1l c cell-set                                 % different Long value
fired                                      (eq-skip: long diff fires) rt-ok  clear

% =================================================================
% SECTION 51: FUZZ -- equality skip with NaN (NaN != NaN per IEEE 754)
% =================================================================

nan cell /c exch def
/fired false def
c { pop pop /fired true def } watch
nan c cell-set                                % NaN != NaN, so this SHOULD fire
fired                                      (eq-skip: nan always invalidates) rt-ok  clear

% =================================================================
% SECTION 52: HAPPY -- cell-deps on cell-computed cell
% =================================================================

10 cell /a exch def
20 cell /b exch def
{ a cell-get b cell-get add } cell-computed /c exch def
c cell-get pop
c cell-deps length 2 eq                    (cell-deps: cell-computed has 2 deps) rt-ok
c cell-deps 0 get a eq                     (cell-deps: dep 0 is a) rt-ok
c cell-deps 1 get b eq                     (cell-deps: dep 1 is b) rt-ok  clear

% =================================================================
% SECTION 53: HAPPY -- cell-deps on base cell (empty)
% =================================================================

42 cell /x exch def
x cell-deps length 0 eq                    (cell-deps: base has 0 deps) rt-ok  clear

% =================================================================
% SECTION 54: HAPPY -- cell-rdeps
% =================================================================

10 cell /a exch def
{ a cell-get 2 mul } cell-computed /b exch def
{ a cell-get 3 mul } cell-computed /c exch def
b cell-get pop
c cell-get pop
a cell-rdeps length 2 eq                   (cell-rdeps: a has 2 dependents) rt-ok
b cell-rdeps length 0 eq                   (cell-rdeps: leaf has 0 rdeps) rt-ok  clear

% =================================================================
% SECTION 55: HAPPY -- cell-watchers
% =================================================================

10 cell /c exch def
c cell-watchers length 0 eq                (cell-watchers: none initially) rt-ok
c { pop pop } watch
c cell-watchers length 1 eq                (cell-watchers: 1 after watch) rt-ok
c { pop pop } watch
c cell-watchers length 2 eq                (cell-watchers: 2 after second) rt-ok  clear

% =================================================================
% SECTION 56: BOUNDARY -- cell-deps after re-evaluation
% =================================================================

10 cell /a exch def
20 cell /b exch def
/use-b true def
{ a cell-get  use-b { b cell-get add } if } cell-computed /c exch def
c cell-get pop
c cell-deps length 2 eq                    (cell-deps: initial 2 deps) rt-ok
/use-b false def
30 a cell-set                                 % triggers re-eval of c
c cell-get pop
c cell-deps length 1 eq                    (cell-deps: re-eval 1 dep) rt-ok  clear

% =================================================================
% SECTION 57: STRESS -- chain of 5 cell-computed cells
% =================================================================

1 cell /c0 exch def
{ c0 cell-get 1 add } cell-computed /c1 exch def
{ c1 cell-get 1 add } cell-computed /c2 exch def
{ c2 cell-get 1 add } cell-computed /c3 exch def
{ c3 cell-get 1 add } cell-computed /c4 exch def
c4 cell-get 5 eq                           (chain: c4 = 5) rt-ok
c0 cell-rdeps length 1 eq                  (chain: c0 has 1 rdep) rt-ok
c4 cell-deps length 1 eq                   (chain: c4 has 1 dep) rt-ok
c4 cell-deps 0 get c3 eq                   (chain: c4 dep is c3) rt-ok  clear

% =================================================================
% SECTION 58: SAD -- cell-deps on non-cell
% =================================================================

{ 42 cell-deps } try /type-check eq        (cell-deps: non-cell error) rt-ok  clear
{ 42 cell-rdeps } try /type-check eq       (cell-rdeps: non-cell error) rt-ok  clear
{ 42 cell-watchers } try /type-check eq    (cell-watchers: non-cell error) rt-ok  clear

% =================================================================
% SECTION 59: FUZZ -- deps survive cell-set update
% =================================================================

10 cell /a exch def
{ a cell-get 2 mul } cell-computed /c exch def
c cell-get pop
c cell-deps length 1 eq                    (fuzz: deps before update) rt-ok
20 a cell-set
c cell-get pop
c cell-deps length 1 eq                    (fuzz: deps after update) rt-ok
c cell-deps 0 get a eq                     (fuzz: dep still a) rt-ok  clear

% =================================================================
% =================================================================
% SECTION 60: HAPPY -- batch auto-recomputes dirty cell-computed cell for watcher
% =================================================================
% Core bug fix test: watcher on a cell-computed cell must fire even when
% the cell-computed cell is NOT manually recell-computed inside the batch.
% Previously, @batch-end read the stale cached value and the old==new
% equality check suppressed the watcher.

10 cell /base exch def
{ base cell-get 1 add } cell-computed /derived exch def
derived cell-get pop                        % initial eval — cache = 11
/d-old null def
/d-new null def
derived { /d-new exch def /d-old exch def } watch
{
    20 base cell-set                        % dirty 'derived', but do NOT recompute here
} batch
d-old 11 eq                                 (happy: batch lazy cell-computed old value) rt-ok
d-new 21 eq                                 (happy: batch lazy cell-computed new value) rt-ok  clear

% =================================================================
% SECTION 61: HAPPY -- batch auto-recomputes chain of dirty cell-computed cells
% =================================================================

1 cell /a exch def
{ a cell-get 10 mul } cell-computed /b exch def
{ b cell-get 1 add } cell-computed /c exch def
b cell-get pop  c cell-get pop              % initial eval: b=10, c=11
/c-old null def  /c-new null def
c { /c-new exch def /c-old exch def } watch
{
    5 a cell-set                            % dirty b and c, no manual recompute
} batch
c-old 11 eq                                 (happy: batch chain old value) rt-ok
c-new 51 eq                                 (happy: batch chain new value) rt-ok  clear

% =================================================================
% SECTION 62: HAPPY -- batch with mixed base + dirty cell-computed watchers
% =================================================================

10 cell /base exch def
{ base cell-get 2 mul } cell-computed /comp exch def
comp cell-get pop                           % initial eval: comp=20
/base-fired false def
/comp-fired false def
base { pop pop /base-fired true def } watch
comp { pop pop /comp-fired true def } watch
{
    99 base cell-set                        % no manual recompute of comp
} batch
base-fired                                  (happy: batch mixed base watcher fired) rt-ok
comp-fired                                  (happy: batch mixed cell-computed watcher fired) rt-ok  clear

% =================================================================
% SECTION 63: BOUNDARY -- batch cell-computed cell net-no-change skips watcher
% =================================================================
% If base is set then set back, cell-computed cell recomputes to same value — skip watcher.

10 cell /base exch def
{ base cell-get 2 mul } cell-computed /comp exch def
comp cell-get pop                           % initial eval: comp=20
/comp-fired false def
comp { pop pop /comp-fired true def } watch
{
    99 base cell-set
    10 base cell-set                        % restore original value
} batch
comp-fired not                              (boundary: batch cell-computed net-no-change skips) rt-ok  clear

% =================================================================
% SECTION 64: STRESS -- batch with multiple dirty cell-computed cells
% =================================================================

1 cell /x exch def
{ x cell-get 10 add } cell-computed /y exch def
{ x cell-get 100 add } cell-computed /z exch def
y cell-get pop  z cell-get pop              % initial: y=11, z=101
/y-old null def  /y-new null def
/z-old null def  /z-new null def
y { /y-new exch def /y-old exch def } watch
z { /z-new exch def /z-old exch def } watch
{
    5 x cell-set
} batch
y-old 11 eq                                 (stress: batch multi-cell-computed y-old) rt-ok
y-new 15 eq                                 (stress: batch multi-cell-computed y-new) rt-ok
z-old 101 eq                                (stress: batch multi-cell-computed z-old) rt-ok
z-new 105 eq                                (stress: batch multi-cell-computed z-new) rt-ok  clear

% =================================================================
% SECTION 65: ERROR -- error in batch-fire recomputation propagates
% =================================================================
% Computed cell succeeds initially but errors after base changes.
