% ====================================================================
% Suspend/Resume Tests
% ====================================================================

% rt-ok counts failures in a restore-immune slot -- string byte writes
% are unjournaled, so the count survives assertions made inside save
% scopes, and the 1-byte string lives in LOCAL VM, invisible to the
% global-heap/gc-counter probes some files assert on.  The file THROWS
% at EOF: test_all counts a file as failed only when its run throws,
% so print-only failures would slip the suite verdict.
/rt-fails 1 string def
rt-fails 0 16#0#b put
/rt-ok { exch { = } { (FAILED: ) print = rt-fails 0  rt-fails 0 get /integer-type cast 1 add dup 255 gt { pop 255 } if /byte-type cast  put } if-else } def

% ====================================================================
% SECTION 1: Basic suspend/resume round-trip
% ====================================================================

% Suspend a ready coroutine, verify status, resume, verify it runs
/R false def
[ { /R true def } coroutine-launch
dup coroutine-status /ready eq             (suspend: new coroutine starts ready) rt-ok
dup coroutine-suspend
dup coroutine-status /suspended eq         (suspend: status is /suspended) rt-ok
R not                                      (suspend: coroutine has not run yet) rt-ok
dup coroutine-resume
dup coroutine-status /suspended eq not     (resume: status is no longer /suspended) rt-ok
coroutine-join pop pop
R                                          (resume: coroutine ran after resume) rt-ok
clear

% Double suspend is no-op
/S false def
[ { /S true def } coroutine-launch
dup coroutine-suspend
dup coroutine-suspend  % second suspend is no-op
dup coroutine-status /suspended eq         (suspend: double suspend is no-op) rt-ok
dup coroutine-resume
coroutine-join pop pop
S                                          (suspend: coroutine ran after double-suspend+resume) rt-ok
clear

% Resume on non-suspended coroutine is no-op
/T false def
[ { /T true def } coroutine-launch
dup coroutine-resume  % not suspended -- no-op
coroutine-join pop pop
T                                          (resume: no-op on non-suspended coroutine) rt-ok
clear

% ====================================================================
% SECTION 2: Suspend while in timed sleep
% ====================================================================

% Suspend a coroutine that is in a timed sleep, resume, verify it completes
/V false def
[ { 5000 coroutine-sleep /V true def } coroutine-launch
0 coroutine-sleep  % yield to let it enter sleep
dup coroutine-status /sleeping eq          (timed-suspend: coroutine is sleeping) rt-ok
dup coroutine-suspend
dup coroutine-status /suspended eq         (timed-suspend: status is /suspended after suspend) rt-ok
dup coroutine-resume
% After resume, coroutine should be back in timed sleep (timer restarted with remaining delta)
dup coroutine-status /sleeping eq          (timed-suspend: back to sleeping after resume) rt-ok
% Kill it so we don't wait 5 seconds
coroutine-kill clear

% Suspend a coroutine in a short sleep, resume runs it
/W false def
[ { 1 coroutine-sleep /W true def } coroutine-launch
dup coroutine-suspend
dup coroutine-resume
coroutine-join pop pop
W                                          (timed-suspend: resume after short sleep runs coroutine) rt-ok
clear

% ====================================================================
% SECTION 3: Suspend blocked coroutine (pipe)
% ====================================================================

% Suspend a coroutine blocked on pipe-get, then write data, then resume
1 pipe-buffer
/buf exch def
/P false def
[ buf { buf pipe-get pop /P true def } coroutine-launch
0 coroutine-sleep  % yield to let consumer block on empty pipe
dup coroutine-status /sleeping eq          (blocked-suspend: coroutine is sleeping/blocked) rt-ok
dup coroutine-suspend
dup coroutine-status /suspended eq         (blocked-suspend: status is /suspended) rt-ok

% Write data while coroutine is suspended
42 buf pipe-put

% Resume -- producer already woke it, so it should become ready and run
dup coroutine-resume
coroutine-join pop pop
P                                          (blocked-suspend: coroutine ran after resume with data) rt-ok
clear

% ====================================================================
% SECTION 4: Error cases
% ====================================================================

% Suspend dead coroutine -- should raise /invalid-access
[ { } coroutine-launch
dup coroutine-join pop pop
{ coroutine-suspend } try
/invalid-access eq                         (error: suspend dead raises invalid-access) rt-ok
clear

% Suspend main coroutine -- should raise /invalid-exit
% From a coroutine: pass main's handle as a parameter, try to suspend it
/main-result null def
[ coroutine-self { { coroutine-suspend } try /main-result exch def } coroutine-launch
coroutine-join pop pop
main-result /invalid-exit eq               (error: suspend main raises invalid-exit) rt-ok
clear

% Suspend self -- should raise /invalid-exit
/self-result null def
[ { coroutine-self { coroutine-suspend } try /self-result exch def } coroutine-launch
coroutine-join pop pop
self-result /invalid-exit eq               (error: suspend self raises invalid-exit) rt-ok
clear

% Resume dead coroutine -- should raise /invalid-access
[ { } coroutine-launch
dup coroutine-join pop pop
{ coroutine-resume } try
/invalid-access eq                         (error: resume dead raises invalid-access) rt-ok
clear

% ====================================================================
% SECTION 5: Kill suspended coroutine
% ====================================================================

% Kill a suspended coroutine -- should work
[ { 99999 coroutine-sleep } coroutine-launch
0 coroutine-sleep  % yield to let it start sleeping
dup coroutine-suspend
dup coroutine-kill
dup coroutine-status /dead eq              (kill-suspended: status is /dead) rt-ok
pop clear

% ====================================================================
% SECTION 6: Suspend + coroutine-id round-trip
% ====================================================================

[ { 99999 coroutine-sleep } coroutine-launch
0 coroutine-sleep  % yield to let it start sleeping
dup coroutine-id
exch coroutine-suspend
% lookup by ID while suspended
dup coroutine-by-id
dup coroutine-status /suspended eq         (id-suspend: lookup by id while suspended) rt-ok
coroutine-kill
pop clear

rt-fails 0 get /integer-type cast 0 gt { /rt-assertions-failed throw } if
(test_suspend: ALL TESTS PASSED) =
(__test_ok__) =
