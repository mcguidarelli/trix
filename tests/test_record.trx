<< /x 3 /y 4 >> [ /x /y ] record-from-dict
dup /x get 3 eq               (from-dict: x) rt-ok
/y get 4 eq                   (from-dict: y) rt-ok clear

% extras ignored
<< /x 3 /y 4 /z 5 >> [ /x ] record-from-dict
dup /x get 3 eq               (from-dict: extras ignored) rt-ok
length 1 eq                   (from-dict: length 1) rt-ok clear

