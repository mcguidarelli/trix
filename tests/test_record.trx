6 7 8 [ /c /d /f ] record record-merge
dup length 6 eq               (merge: 5+3 overlap length) rt-ok
dup /c get 6 eq               (merge: 5+3 override c) rt-ok
/f get 8 eq                   (merge: 5+3 new f) rt-ok clear

