% SECTION 26: record-zip
% ====================================================================

% happy
[ [ (Alice) (Bob) ] [ 30 25 ] ] [ /name /age ] record-zip
dup length 2 eq               (zip: length) rt-ok
dup 0 get /name get (Alice) eq (zip: r0 name) rt-ok
dup 0 get /age get 30 eq      (zip: r0 age) rt-ok
dup 1 get /name get (Bob) eq  (zip: r1 name) rt-ok
1 get /age get 25 eq          (zip: r1 age) rt-ok clear

% single column
[ [ 10 20 30 ] ] [ /val ] record-zip
dup length 3 eq               (zip: single col length) rt-ok
2 get /val get 30 eq          (zip: single col r2) rt-ok clear

% single row
