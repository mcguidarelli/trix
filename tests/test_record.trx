1 2 3 [ /a /b /c ] record [ /a /c ] record-select
dup /a get 1 eq               (select: a) rt-ok
dup /c get 3 eq               (select: c) rt-ok
length 2 eq                   (select: length) rt-ok clear

% all fields (identity)
1 2 [ /x /y ] record [ /x /y ] record-select
1 2 [ /x /y ] record deep-eq
    (select: all fields deep-eq) rt-ok clear

