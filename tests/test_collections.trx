                                         (pk-zip: Long pair 2) rt-ok
pop clear

% chunk with packed ExtValue input
{ 10l 20l 30l 40l } 2 chunk
dup 0 get dup 0 get 10l eq exch 1 get 20l eq and
                                         (pk-chunk: Long group 0) rt-ok
