[2 4] deep-eq                            (pk-filter: evens) rt-ok clear

% take-while with packed input
{ 1 2 3 4 5 } { 4 lt } take-while
[1 2 3] deep-eq                          (pk-take-while: <4) rt-ok clear

% drop-while with packed input
{ 1 2 3 4 5 } { 3 lt } drop-while
[3 4 5] deep-eq                          (pk-drop-while: >=3) rt-ok clear

% map with packed input
{ 1 2 3 } { dup mul } map
[1 4 9] deep-eq                          (pk-map: squares) rt-ok clear

% sort-by with packed input
{ 3 1 4 1 5 } { } sort-by
[1 1 3 4 5] deep-eq                      (pk-sort-by: identity) rt-ok clear

% group-by with packed input
{ 1 2 3 4 5 6 } { 2 mod } group-by
dup length 2 eq                          (pk-group-by: 2 groups) rt-ok
pop clear

% reduce with packed input
{ 1 2 3 4 } 0 { add } reduce 10 eq      (pk-reduce: sum) rt-ok clear

% ====================================================================
% SECTION 62: Packed-input coverage for push_forall_frame helper
% ====================================================================

% sum with packed input
{ 1 2 3 4 5 } sum 15 eq                 (pk-sum: 1..5) rt-ok clear

% min-of with packed input
{ 3 1 4 1 5 } min-of 1 eq               (pk-min-of: min=1) rt-ok clear

% max-of with packed input
{ 3 1 4 1 5 } max-of 5 eq               (pk-max-of: max=5) rt-ok clear

% sum with packed ExtValue input
{ 10l 20l 30l } sum 60l eq              (pk-sum: Long) rt-ok clear

% min-of with packed ExtValue input
{ 30l 10l 20l } min-of 10l eq           (pk-min-of: Long) rt-ok clear

% max-of with packed ExtValue input
{ 10l 30l 20l } max-of 30l eq           (pk-max-of: Long) rt-ok clear

% ====================================================================
% SECTION 63: Null-element rejection in dict-keyed array ops
% Regression: fuzz/crashes/crash-424217e4 tripped Dict::get's null-key
% assert via `difference` over an array containing null.  All dict-keyed
% array ops must now reject null elements with a TypeCheck error rather
% than abort.
% ====================================================================

% intersect: null in arr1 / arr2
{ [1 null 2] [1 2] intersect } try /type-check eq
(intersect: null in arr1 rejected) rt-ok clear
{ [1 2] [1 null 2] intersect } try /type-check eq
(intersect: null in arr2 rejected) rt-ok clear

% difference: null in arr1 / arr2 (the original fuzz-found crash path)
{ [1 null 2] [3] difference } try /type-check eq
(difference: null in arr1 rejected) rt-ok clear
{ [1 2] [null 3] difference } try /type-check eq
(difference: null in arr2 rejected) rt-ok clear

% union: null in arr1 / arr2
{ [1 null] [2] union } try /type-check eq
(union: null in arr1 rejected) rt-ok clear
{ [1] [null 2] union } try /type-check eq
(union: null in arr2 rejected) rt-ok clear

% frequencies: null element
{ [1 2 null 1] frequencies } try /type-check eq
(frequencies: null rejected) rt-ok clear

% group-by: proc produces null key
{ [1 2 3] { pop null } group-by } try /type-check eq
(group-by: null key rejected) rt-ok clear

% happy paths still work after all the rejection tests
[1 2 3] [2 3 4] intersect [2 3] deep-eq
(intersect: happy path still works) rt-ok clear
[1 2 3] [4 5] union [1 2 3 4 5] deep-eq
(union: happy path still works) rt-ok clear
[1 2 3] [2] difference [1 3] deep-eq
(difference: happy path still works) rt-ok clear
[1 1 2 3 3 3] frequencies
<< 1 2 2 1 3 3 >> deep-eq
(frequencies: happy path still works) rt-ok clear

% ====================================================================
% Final ExtValue free-list integrity check
% ====================================================================

//:status:extvalue-validate
(extvalue free-list integrity after all collection tests) rt-ok clear

//:status:vm-validate
(vm heap integrity after all collection tests) rt-ok clear

(Collection operator tests complete.) =
rt-fails 0 get /integer-type cast 0 gt { /rt-assertions-failed throw } if
(__test_ok__) =
