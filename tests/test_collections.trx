[] deep-eq                                     (difference: empty arr1) rt-ok clear

% empty arr2 (nothing to remove)
[1 2 3] [] difference
[1 2 3] deep-eq                                (difference: empty arr2) rt-ok clear

% both empty
[] [] difference
[] deep-eq                                     (difference: both empty) rt-ok clear

% removes duplicates
[1 1 2 2 3] [2] difference
[1 3] deep-eq                                  (difference: dedup) rt-ok clear

% preserves arr1 order
[5 4 3 2 1] [2 4] difference
[5 3 1] deep-eq                                (difference: arr1 order) rt-ok clear

% string elements
[(a) (b) (c) (d)] [(b) (d)] difference
[(a) (c)] deep-eq                              (difference: strings) rt-ok clear

% arr2 has extras that don't matter
[1 2] [1 2 3 4 5] difference
[] deep-eq                                     (difference: arr2 superset) rt-ok clear

% packed input
{ 1 2 3 4 5 } { 2 4 } difference
[1 3 5] deep-eq                                (difference: packed input) rt-ok clear

% single element removed
[1 2 3] [2] difference
[1 3] deep-eq                                  (difference: single removed) rt-ok clear

% single element kept
[1 2 3] [99] difference
[1 2 3] deep-eq                                (difference: single kept) rt-ok clear

% large arrays: [1..200] - [50..150] = [1..49] ++ [151..200] = 99 elements
save
[1 1 200 { } for] [50 1 150 { } for] difference
dup length 99 eq                               (difference: large length) rt-ok
dup 0 get 1 eq                                 (difference: large first) rt-ok
dup 98 get 200 eq                              (difference: large last) rt-ok
pop
restore clear

% asymmetry: A-B != B-A
[1 2 3] [2 3 4] difference [1] deep-eq         (difference: A-B) rt-ok clear
[2 3 4] [1 2 3] difference [4] deep-eq         (difference: B-A) rt-ok clear

