% ====================================================================
% test_gc_visited_grow.trx -- visited-set grow-on-overflow regression
% ====================================================================
% Post Option 1 (PATCH 62+): the auxiliary visited-offset array
% (m_gc_local_visited, used for cycle-break of LOCAL-VM Tagged /
% Curry / Thunk / Array / Record / Packed containers visited from
% global walks) grows on overflow instead of erroring.  Initial
% capacity = 1024 entries (4 KiB scratch payload).
%
% This test triggers the grow path by creating > 1024 distinct
% local Tagged values referenced from a global Array, then running
% vm-global-gc.  The walker must see each local Tagged and call
% gc_mark_object on it, which adds it to the visited array; the
% array overflows and grow_gc_local_visited fires (doubling 1024
% -> 2048).  Scratch block size grows accordingly.
% ====================================================================

% rt-ok counts failures in a restore-immune slot -- string byte writes
% are unjournaled, so the count survives assertions made inside save
% scopes, and the 1-byte string lives in LOCAL VM, invisible to the
% global-heap/gc-counter probes some files assert on.  The file THROWS
% at EOF: test_all counts a file as failed only when its run throws,
% so print-only failures would slip the suite verdict.
/rt-fails 1 string def
rt-fails 0 16#0#b put
/rt-ok { exch { = } { (FAILED: ) print = rt-fails 0  rt-fails 0 get /integer-type cast 1 add dup 255 gt { pop 255 } if /byte-type cast  put } if-else } def

% --------------------------------------------------------------------
% SECTION 1: baseline scratch size after pre-warm
% --------------------------------------------------------------------
% Pre-warm with a small global dict triggers the lazy GC scratch.
% Initial scratch payload should be ~4 KiB (1024 vm_offset_t entries).

${ 8 dict } /pre-warm exch def

vm-global-info /by-kind get /gcscratch get /count get
1 eq                                          (1: gcscratch allocated) rt-ok

vm-global-info /by-kind get /gcscratch get /total-bytes get /pre-bytes exch def
pre-bytes 4096 ge                             (1: scratch >= 4 KiB initial payload) rt-ok
pre-bytes 4192 le                             (1: scratch <= 4 KiB + slack) rt-ok

% --------------------------------------------------------------------
% SECTION 2: build 2000 local Taggeds in a global Array
% --------------------------------------------------------------------
% Each Tagged wraps a global Long (just an anchor reference); the
% Tagged itself is in LOCAL VM (no #$ suffix and no enclosing ${...}).
% Storing into a global Array pulls the Taggeds into the global walk's
% reach; each one will be visited via gc_mark_object's local-VM branch.

% Single global Long anchor reused as the value of every Tagged.
% Each `tag` call still creates a DISTINCT local Tagged Object, so
% the visited set sees 2000 unique offsets.
${ 42l } /anchor exch def

${ 2000 array } /globarr exch def

/idx 0 def
2000 {
    globarr idx                                % stack: [globarr, idx]
    anchor /elem tag                           % stack: [globarr, idx, tagged]
    put                                        % globarr[idx] = tagged
    /idx idx 1 add def
} repeat

idx 2000 eq                                    (2: 2000 iterations completed) rt-ok

% --------------------------------------------------------------------
% SECTION 3: vm-global-gc triggers grow-on-overflow
% --------------------------------------------------------------------
% Walking globarr's contents calls gc_mark_object on each of the 2000
% local Taggeds.  Visited array starts at 1024 entries.  At the 1025th
% Tagged, grow_gc_local_visited fires (doubling to 2048).  Possibly
% fires AGAIN if visited count exceeds 2048 -- not in this test (only
% 2000 unique local Taggeds visited).

vm-global-gc /reclaimed exch def
reclaimed 0 ge                                 (3: gc completed without error) rt-ok

% Scratch payload after grow: 2048 entries * 4 bytes = 8 KiB.
% (The first overflow fires at the 1025th distinct local Tagged.)
vm-global-info /by-kind get /gcscratch get /total-bytes get /post-bytes exch def
post-bytes pre-bytes gt                        (3: scratch grew past initial size) rt-ok
post-bytes 8192 ge                             (3: scratch >= 8 KiB after one grow) rt-ok

% --------------------------------------------------------------------
% SECTION 4: globarr survived GC with all entries
% --------------------------------------------------------------------

globarr length 2000 eq                         (4: globarr has 2000 entries post-GC) rt-ok
globarr 0 get tag-name /elem eq                (4: entry[0] is Tagged with /elem name) rt-ok
globarr 1999 get tag-name /elem eq             (4: entry[1999] is Tagged with /elem name) rt-ok

rt-fails 0 get /integer-type cast 0 gt { /rt-assertions-failed throw } if
(test_gc_visited_grow: ALL TESTS PASSED) =
(__test_ok__) =
