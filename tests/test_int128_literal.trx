% ====================================================================
% Phase 2 literal round-trip test for Int128 / UInt128.
%
% Confirms that the scanner recognizes the h / uh suffixes in decimal,
% radix, and prefix forms, that the parsed values survive a print/parse
% round-trip and a binary-token round-trip, and that the WideValue
% heap accounting tracks live instances across save/restore.
% ====================================================================

% rt-ok counts failures in a restore-immune slot -- string byte writes
% are unjournaled, so the count survives assertions made inside save
% scopes, and the 1-byte string lives in LOCAL VM, invisible to the
% global-heap/gc-counter probes some files assert on.  The file THROWS
% at EOF: test_all counts a file as failed only when its run throws,
% so print-only failures would slip the suite verdict.
/rt-fails 1 string def
rt-fails 0 16#0#b put
/rt-ok { exch { = } { (FAILED: ) print = rt-fails 0  rt-fails 0 get /integer-type cast 1 add dup 255 gt { pop 255 } if /byte-type cast  put } if-else } def

% ---------- type detection ----------
/int128-type 42q type eq                  (42q is int128-type) rt-ok
/uint128-type 42uq type eq                (42uq is uint128-type) rt-ok
/int128-type 0q type eq                   (0q is int128-type) rt-ok
/uint128-type 0uq type eq                 (0uq is uint128-type) rt-ok
/int128-type -1q type eq                  (-1q is int128-type) rt-ok

% ---------- value correctness via deep-eq round-trip ----------
42q 42q deep-eq                           (42q equals 42q) rt-ok
-42q -42q deep-eq                         (-42q equals -42q) rt-ok
42uq 42uq deep-eq                         (42uq equals 42uq) rt-ok
0q 0q deep-eq                             (0q equals 0q) rt-ok
0uq 0uq deep-eq                           (0uq equals 0uq) rt-ok

% ---------- radix form equivalence ----------
16#FF#q 255q deep-eq                      (16#FF#q equals 255q) rt-ok
16#FF#uq 255uq deep-eq                    (16#FF#uq equals 255uq) rt-ok
2#1010#q 10q deep-eq                      (2#1010#q equals 10q) rt-ok
8#17#q 15q deep-eq                        (8#17#q equals 15q) rt-ok

% ---------- prefix form equivalence ----------
0xFF#q 255q deep-eq                       (0xFF#q equals 255q) rt-ok
0xFF#uq 255uq deep-eq                     (0xFF#uq equals 255uq) rt-ok
0b1010#q 10q deep-eq                      (0b1010#q equals 10q) rt-ok
0o17#q 15q deep-eq                        (0o17#q equals 15q) rt-ok

% ---------- boundary values ----------
% INT128_MAX  = 170141183460469231731687303715884105727
% INT128_MIN  = -170141183460469231731687303715884105728
% UINT128_MAX = 340282366920938463463374607431768211455
170141183460469231731687303715884105727q
 170141183460469231731687303715884105727q deep-eq        (INT128_MAX h round-trips) rt-ok
-170141183460469231731687303715884105728q
-170141183460469231731687303715884105728q deep-eq        (INT128_MIN h round-trips) rt-ok
340282366920938463463374607431768211455uq
340282366920938463463374607431768211455uq deep-eq        (UINT128_MAX uh round-trips) rt-ok

% ---------- binary-token round-trip ----------
/bt-rt { dup to-binary-token make-executable exec deep-eq } def
42q bt-rt                                 (bt: 42q) rt-ok clear
-42q bt-rt                                (bt: -42q) rt-ok clear
0q bt-rt                                  (bt: 0q) rt-ok clear
170141183460469231731687303715884105727q bt-rt            (bt: INT128_MAX h) rt-ok clear
-170141183460469231731687303715884105728q bt-rt           (bt: INT128_MIN h) rt-ok clear
42uq bt-rt                                (bt: 42uq) rt-ok clear
0uq bt-rt                                 (bt: 0uq) rt-ok clear
340282366920938463463374607431768211455uq bt-rt           (bt: UINT128_MAX uh) rt-ok clear

% ---------- WideValue heap accounting across save/restore ----------
% Note: restore relocates live above-barrier widevalues onto the below-barrier
% free list rather than popping them off the operand stack; popping is done
% separately in the test to confirm the active count returns to baseline.
/before //:status:widevalue-active def
/s save def
42q pop                                                   % alloc, then pop: stack empty
//:status:widevalue-active before eq                      (pop reclaims widevalue at base save level) rt-ok
42q                                                       % one live on op stack
//:status:widevalue-active before 1 add eq                (live widevalue bumps active count) rt-ok
s restore                                                 % relocates the live cell below save
pop                                                       % discard the relocated value
//:status:widevalue-active before eq                      (pop after restore returns active to baseline) rt-ok

% ---------- save/restore with multiple widevalues ----------
/s2 save def
1q 2q 3q 4q 5q pop pop pop pop pop                        % all popped
//:status:widevalue-active before eq                      (many alloc-then-pop leaves count at baseline) rt-ok
1q 2q 3q                                                  % three live
//:status:widevalue-active before 3 add eq                (three live widevalues counted) rt-ok
s2 restore
pop pop pop
//:status:widevalue-active before eq                      (pop after restore reclaims the three) rt-ok

% ---------- free-list integrity after churn ----------
//:status:widevalue-validate                              (widevalue free-list integrity OK after churn) rt-ok
//:status:vm-validate                                     (vm heap integrity OK after churn) rt-ok
//:status:extvalue-validate                               (extvalue free-list integrity OK after churn) rt-ok

(test_int128_literal.trx complete) =
rt-fails 0 get /integer-type cast 0 gt { /rt-assertions-failed throw } if
(__test_ok__) =
