% ====================================================================
% Phase 6 extras: rand-int128/uint128, bit?/bit-set/bit-clear/bit-toggle
% on 128-bit, gcd/lcm/nCr on 128-bit.
% ====================================================================

% rt-ok counts failures in a restore-immune slot -- string byte writes
% are unjournaled, so the count survives assertions made inside save
% scopes, and the 1-byte string lives in LOCAL VM, invisible to the
% global-heap/gc-counter probes some files assert on.  The file THROWS
% at EOF: test_all counts a file as failed only when its run throws,
% so print-only failures would slip the suite verdict.
/rt-fails 1 string def
rt-fails 0 16#0#b put
/rt-ok { exch { = } { (FAILED: ) print = rt-fails 0  rt-fails 0 get /integer-type cast 1 add dup 255 gt { pop 255 } if /byte-type cast  put } if-else } def

% ---------- rand-int128 / rand-uint128 ----------
% Seeded run: PCG stream is deterministic once seeded.  Different calls
% must produce different values (with overwhelming probability); each
% call must produce an object of the right type.
12345ul rand-seed
/a rand-uint128 def
/b rand-uint128 def
a is-uint128 (rand-uint128 produces uint128) rt-ok
b is-uint128 (rand-uint128 produces uint128) rt-ok
a b ne (rand-uint128 sequence advances)   rt-ok
/c rand-int128 def
/d rand-int128 def
c is-int128 (rand-int128 produces int128) rt-ok
d is-int128 (rand-int128 produces int128) rt-ok
c d ne (rand-int128 sequence advances)  rt-ok

% ---------- rand-bounded-uint128 ----------
/bound 100uq def
/r bound rand-bounded-uint128 def
r is-uint128    (bounded: type)            rt-ok
r 0uq ge      (bounded: >= 0)            rt-ok
r bound lt    (bounded: < bound)         rt-ok

% bound = 0 must raise range-check
/zero_u128 0uq def
{ zero_u128 rand-bounded-uint128 } try /range-check eq
(bounded: zero bound rejected) rt-ok clear

% ---------- bit? on 128-bit ----------
/u128_1 1uq def
/u128_top 16#80000000000000000000000000000000#uq def
/u128_all 16#FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF#uq def
/u128_zero 0uq def

u128_1 0 bit?        (bit?: bit 0 set)        rt-ok
u128_1 1 bit? not    (bit?: bit 1 clear)      rt-ok
u128_top 127 bit?    (bit?: MSB set)          rt-ok
u128_top 126 bit? not (bit?: bit 126 clear)   rt-ok
u128_all 63 bit?     (bit?: mid-bit set)      rt-ok
u128_zero 0 bit? not (bit?: zero has no bits) rt-ok

% int128 high bit is sign bit; test via a non-literal path
/i128_top 0q 127 bit-set def
i128_top 0q lt        (bit-set: bit 127 on int128 is sign bit) rt-ok

% ---------- bit-set ----------
0uq 0 bit-set 1uq deep-eq         (bit-set: bit 0)    rt-ok
0uq 127 bit-set u128_top deep-eq  (bit-set: bit 127)  rt-ok
0uq 63 bit-set 16#8000000000000000#uq deep-eq (bit-set: bit 63) rt-ok

% ---------- bit-clear ----------
u128_all 0 bit-clear
16#FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFE#uq deep-eq
(bit-clear: bit 0)  rt-ok
u128_all 127 bit-clear
16#7FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF#uq deep-eq
(bit-clear: bit 127) rt-ok

% ---------- bit-toggle involution ----------
u128_zero 50 bit-toggle 50 bit-toggle
u128_zero deep-eq
(bit-toggle: involution) rt-ok

% ---------- bit-set/clear/toggle preserves input type ----------
/q 0uq 100 bit-set def
q is-uint128 (bit-set preserves uint128 type) rt-ok

/qi 0q 100 bit-set def
qi is-int128 (bit-set preserves int128 type) rt-ok

% ---------- range-check on 128-bit ----------
{ u128_zero 128 bit? }  try /range-check eq (bit?: 128 rejected)  rt-ok clear
{ u128_zero -1  bit? }  try /range-check eq (bit?: -1  rejected)  rt-ok clear
{ u128_zero 200 bit-set } try /range-check eq (bit-set: 200 rejected) rt-ok clear

% ---------- gcd on 128-bit ----------
12q  18q  gcd 6q  deep-eq   (gcd int128 happy)  rt-ok
12uq 18uq gcd 6uq deep-eq   (gcd uint128 happy) rt-ok
0q   5q   gcd 5q  deep-eq   (gcd with 0 lhs)    rt-ok
5q   0q   gcd 5q  deep-eq   (gcd with 0 rhs)    rt-ok
-12q -18q gcd 6q  deep-eq   (gcd on negatives)  rt-ok

% coprime
17q 13q gcd 1q deep-eq (gcd coprime)  rt-ok

% large uint128 values
16#FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFE#uq 2uq gcd
2uq deep-eq (gcd large uint128) rt-ok

% INT128_MIN -> numerical-overflow
/int128_min -170141183460469231731687303715884105728q def
/five_h 5q def
{ int128_min five_h gcd } try
/numerical-overflow eq (gcd rejects INT128_MIN) rt-ok clear

% ---------- lcm on 128-bit ----------
4q 6q lcm 12q deep-eq (lcm int128 happy) rt-ok
4uq 6uq lcm 12uq deep-eq (lcm uint128 happy) rt-ok
0q  5q  lcm 0q  deep-eq (lcm with 0 is 0) rt-ok
5q  0q  lcm 0q  deep-eq (lcm with 0 is 0 (rhs)) rt-ok

% lcm overflow
/big_uh 16#FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFE#uq def
/three_uh 3uq def
{ big_uh three_uh lcm } try
/numerical-overflow eq (lcm overflow detected) rt-ok clear

% ---------- nCr on 128-bit ----------
100uq 3uq nCr 161700uq deep-eq (nCr 100 choose 3)     rt-ok
30q   10q  nCr 30045015q deep-eq (nCr 30 choose 10)    rt-ok
/n0 0uq def
/r0 0uq def
n0 r0 nCr 1uq deep-eq (nCr 0 choose 0 = 1) rt-ok
5q   0q   nCr 1q  deep-eq (nCr n choose 0 = 1) rt-ok
5q   5q   nCr 1q  deep-eq (nCr n choose n = 1) rt-ok

% r > n -> range check
/five_h2 5q def
/six_h 6q def
{ five_h2 six_h nCr } try /range-check eq (nCr r>n rejected) rt-ok clear

% negative -> range check
/neg_h -1q def
/three_h 3q def
{ neg_h three_h nCr } try /range-check eq (nCr negative rejected) rt-ok clear

% 128-bit overflow (large values that would overflow int128)
/big_n 200q def
/big_r 100q def
{ big_n big_r nCr } try /numerical-overflow eq
(nCr 200c100 overflows) rt-ok clear

% ---------- heap integrity ----------
//:status:widevalue-validate   (widevalue free-list OK)  rt-ok
//:status:vm-validate          (vm heap OK)              rt-ok
//:status:extvalue-validate    (extvalue free-list OK)   rt-ok

(test_int128_extras.trx complete) =
rt-fails 0 get /integer-type cast 0 gt { /rt-assertions-failed throw } if
(__test_ok__) =
