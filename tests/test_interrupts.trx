% ====================================================================
% Interrupt System Tests
% ====================================================================
% Requires: my-raise-interrupt user operator (defined in trix.cpp)
% which spawns a thread that calls raise_interrupt() after 1ms delay.

% rt-ok counts failures in a restore-immune slot -- string byte writes
% are unjournaled, so the count survives assertions made inside save
% scopes, and the 1-byte string lives in LOCAL VM, invisible to the
% global-heap/gc-counter probes some files assert on.  The file THROWS
% at EOF: test_all counts a file as failed only when its run throws,
% so print-only failures would slip the suite verdict.
/rt-fails 1 string def
rt-fails 0 16#0#b put
/rt-ok { exch { = } { (FAILED: ) print = rt-fails 0  rt-fails 0 get /integer-type cast 1 add dup 255 gt { pop 255 } if /byte-type cast  put } if-else } def

% helper: busy-wait until /flagname is true or 100ms timeout
/wait-for {
    clock
    {
        1 index load { pop pop exit } if
        clock 1 index sub 100000ul gt { pop pop exit } if
    } loop
} def

% helper: busy-wait for 10ms
/delay-10ms {
    clock { clock 1 index sub 10000ul gt { exit } if } loop  pop
} def

% ====================================================================
% SECTION 1: Level-0 interrupt fires
% ====================================================================

/flag false def
/l0-interrupt { /flag true def } def
0 my-raise-interrupt
/flag wait-for
flag  (l0: interrupt fired) rt-ok  clear

% ====================================================================
% SECTION 2: Level-1 interrupt fires
% ====================================================================

/flag false def
/l1-interrupt { /flag true def } def
1 my-raise-interrupt
/flag wait-for
flag  (l1: interrupt fired) rt-ok  clear

% ====================================================================
% SECTION 3: Level-2 interrupt fires
% ====================================================================

/flag false def
/l2-interrupt { /flag true def } def
2 my-raise-interrupt
/flag wait-for
flag  (l2: interrupt fired) rt-ok  clear

% ====================================================================
% SECTION 4: Interrupt handler receives correct level
% ====================================================================

/level -1 def

/flag false def
/l0-interrupt { /flag true def /level 0 def } def
0 my-raise-interrupt
/flag wait-for
level 0 eq  (level-id: l0 handler ran) rt-ok  clear

/flag false def
/l1-interrupt { /flag true def /level 1 def } def
1 my-raise-interrupt
/flag wait-for
level 1 eq  (level-id: l1 handler ran) rt-ok  clear

/flag false def
/l2-interrupt { /flag true def /level 2 def } def
2 my-raise-interrupt
/flag wait-for
level 2 eq  (level-id: l2 handler ran) rt-ok  clear

% ====================================================================
% SECTION 5: disable/enable queues and delivers
% ====================================================================
% Interrupts raised while disabled are now queued (not dropped).
% They are delivered after re-enabling.

/flag false def
/l0-interrupt { /flag true def } def
disable-interrupts
0 my-raise-interrupt
delay-10ms  % wait for background thread to set IRQ bit
flag not  (disable: not delivered while masked) rt-ok

enable-interrupts
/flag wait-for
flag  (enable: queued interrupt delivered after re-enable) rt-ok  clear

% ====================================================================
% SECTION 6: clear-interrupts discards queued user IRQs
% ====================================================================

/flag false def
/l0-interrupt { /flag true def } def
disable-interrupts
0 my-raise-interrupt
delay-10ms  % wait for background thread to queue the IRQ
clear-interrupts  % discard user-level IRQs while still disabled
enable-interrupts
delay-10ms  % verify nothing fires
flag not  (clear: queued interrupt discarded) rt-ok  clear

% ====================================================================
% SECTION 7: Interrupt handler modifies state
% ====================================================================

/flag false def
/handler-val 0 def
/l0-interrupt { /flag true def /handler-val 42 def } def
0 my-raise-interrupt
/flag wait-for
handler-val 42 eq  (handler-state: set value 42) rt-ok  clear

% ====================================================================
% SECTION 8: All three levels fire
% ====================================================================

/l0-ok false def  /l1-ok false def  /l2-ok false def
/l0-interrupt { /l0-ok true def } def
/l1-interrupt { /l1-ok true def } def
/l2-interrupt { /l2-ok true def } def

0 my-raise-interrupt  /l0-ok wait-for
1 my-raise-interrupt  /l1-ok wait-for
2 my-raise-interrupt  /l2-ok wait-for

l0-ok  (multi: l0 fired) rt-ok
l1-ok  (multi: l1 fired) rt-ok
l2-ok  (multi: l2 fired) rt-ok  clear

% ====================================================================
% SECTION 9: Interrupt inside try block
% ====================================================================

/flag false def
/l0-interrupt { /flag true def } def
{ 0 my-raise-interrupt  /flag wait-for } try
/no-error eq  (try-irq: no error) rt-ok
flag  (try-irq: fired inside try) rt-ok  clear

% ====================================================================
% SECTION 10: Error paths
% ====================================================================

{ 5 my-raise-interrupt } try
/range-check eq  (err: level 5 -> range-check) rt-ok  clear

{ -1 my-raise-interrupt } try
/range-check eq  (err: level -1 -> range-check) rt-ok  clear

% ====================================================================
% SECTION 11: Handler calls operators
% ====================================================================

/flag false def
/result 0 def
/l0-interrupt { /flag true def  3 4 add /result exch def } def
0 my-raise-interrupt
/flag wait-for
result 7 eq  (handler-ops: 3+4=7) rt-ok  clear

% ====================================================================
% SECTION 12: Repeated interrupts
% ====================================================================

/count 0 def
/flag false def
/l0-interrupt { /count count 1 add def  /flag true def } def

0 my-raise-interrupt  /flag wait-for  /flag false def
0 my-raise-interrupt  /flag wait-for  /flag false def
0 my-raise-interrupt  /flag wait-for  /flag false def
0 my-raise-interrupt  /flag wait-for  /flag false def
0 my-raise-interrupt  /flag wait-for

count 5 ge  (repeat: 5 interrupts delivered) rt-ok  clear

% ====================================================================
% SECTION 13: enable/disable round-trip
% ====================================================================

disable-interrupts
enable-interrupts
disable-interrupts
enable-interrupts
true  (enable-disable: round-trip ok) rt-ok  clear

% ====================================================================
% SECTION 14: clear-interrupts with nothing pending
% ====================================================================

clear-interrupts
true  (clear-empty: no crash) rt-ok  clear

% ====================================================================
% SECTION 15: interrupts-enabled? query
% ====================================================================

interrupts-enabled?  (query: initially enabled) rt-ok  clear
disable-interrupts
interrupts-enabled? not  (query: disabled after disable) rt-ok  clear
enable-interrupts
interrupts-enabled?  (query: enabled after enable) rt-ok  clear

% ====================================================================
% SECTION 16: interrupts-pending query
% ====================================================================

interrupts-pending 0 eq  (pending: none initially) rt-ok  clear

disable-interrupts
0 my-raise-interrupt
delay-10ms
interrupts-pending 0 gt  (pending: l0 queued while disabled) rt-ok
clear-interrupts
interrupts-pending 0 eq  (pending: none after clear) rt-ok  clear
enable-interrupts

% ====================================================================
% Final report
% ====================================================================
(Interrupt system tests complete.) =

rt-fails 0 get /integer-type cast 0 gt { /rt-assertions-failed throw } if
(__test_ok__) =
