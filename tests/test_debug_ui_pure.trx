% _dbg-stack-item-width(cols) = clamp((cols-9)/4, 10, 30).
60  _dbg-stack-item-width 12 eq            (width-adaptive: 60 cols -> 12)        expect
80  _dbg-stack-item-width 17 eq            (width-adaptive: 80 cols -> 17)        expect
100 _dbg-stack-item-width 22 eq            (width-adaptive: 100 cols -> 22)       expect
120 _dbg-stack-item-width 27 eq            (width-adaptive: 120 cols -> 27)       expect
40  _dbg-stack-item-width 10 eq            (width-adaptive: 40 cols clamps to 10) expect
200 _dbg-stack-item-width 30 eq            (width-adaptive: 200 cols clamps to 30) expect

% --- SECTION 47: bp hit count -------------------------------------------

% Clean slate.
debug-breakpoints { debug-unbreak } for-all

% Initial count for any name is 0.
/never-registered debug-bp-hits 0 eq        (hits: unregistered name = 0)         expect

% Register a bp on a proc that we'll call repeatedly.
/hits-target { 1 2 add pop } def
/hits-target debug-break

/hits-target debug-bp-hits 0 eq             (hits: fresh bp = 0)                  expect

% Call the proc -- each call hits the bp via name resolution.
hits-target
/hits-target debug-bp-hits 1 eq             (hits: after 1 call = 1)              expect

hits-target hits-target hits-target
/hits-target debug-bp-hits 4 eq             (hits: after 4 calls = 4)             expect

% Re-setting an existing bp PRESERVES the count.
/hits-target debug-break
/hits-target debug-bp-hits 4 eq             (hits: re-break preserves count)      expect

% Listing renders the hit count.
(bp) dbg-execute-command
dup (/hits-target) count-substring 0 gt    (hits: list shows name)               expect
    ([4 hits]) count-substring 0 gt        (hits: list shows count)              expect

% Unbreak drops the entry; count goes to 0 (entry no longer exists).
/hits-target debug-unbreak
/hits-target debug-bp-hits 0 eq             (hits: unbreak clears count)          expect

% Cleanup.
debug-continue

% --- SECTION 48: command history (up/down arrow nav) -----------------------

% Clean slate.
/_dbg-cmd-history [] store
/_dbg-cmd-history-idx -1 store
/_dbg-cmd-buf-saved   () store

% Initial state.
_dbg-cmd-history length 0 eq              (history: empty after reset)         expect
_dbg-cmd-history-idx -1 eq                (history: idx=-1 after reset)        expect

% Push first entry.
(b /foo) _dbg-history-push
_dbg-cmd-history length 1 eq              (history: push grows by 1)           expect
_dbg-cmd-history 0 get (b /foo) eq        (history: push stores buffer)        expect
_dbg-cmd-history-idx -1 eq                (history: push resets idx)           expect

% Adjacent-duplicate skip.
(b /foo) _dbg-history-push
_dbg-cmd-history length 1 eq              (history: dedup adjacent)            expect

% Different entry IS pushed.
(p 1 2 add) _dbg-history-push
_dbg-cmd-history length 2 eq              (history: distinct entries appended) expect

% Empty buffer is skipped.
() _dbg-history-push
_dbg-cmd-history length 2 eq              (history: empty buf skipped)         expect

% Up-arrow from idx=-1: stash live buf, move to newest entry.
(live-edit) _dbg-history-up
/up-status exch def
/up-buf exch def
up-status /editing eq                     (history: up returns /editing)       expect
up-buf (p 1 2 add) eq                     (history: up surfaces newest entry)  expect
_dbg-cmd-history-idx 1 eq                 (history: up bumps idx to length-1)  expect
_dbg-cmd-buf-saved (live-edit) eq         (history: live buf stashed on first up) expect

% Up again: walk to older entry.
up-buf _dbg-history-up
pop /up-buf2 exch def
up-buf2 (b /foo) eq                       (history: up walks to older entry)   expect
_dbg-cmd-history-idx 0 eq                 (history: idx decremented)           expect

% Up at oldest is idempotent.
up-buf2 _dbg-history-up
pop /up-buf3 exch def
up-buf3 (b /foo) eq                       (history: up at oldest stays)        expect
_dbg-cmd-history-idx 0 eq                 (history: idx pinned at 0)           expect

% Down: walk forward.
up-buf3 _dbg-history-down
pop /dn-buf exch def
dn-buf (p 1 2 add) eq                     (history: down walks newer)          expect
_dbg-cmd-history-idx 1 eq                 (history: idx incremented)           expect

% Down past newest: restore live buf, idx back to -1.
dn-buf _dbg-history-down
pop /dn-buf2 exch def
dn-buf2 (live-edit) eq                    (history: down past newest restores live) expect
_dbg-cmd-history-idx -1 eq                (history: idx back to -1)            expect

% Down with idx=-1 is a no-op.
(some-buf) _dbg-history-down
pop /dn-noop exch def
dn-noop (some-buf) eq                     (history: down at -1 is no-op)       expect
_dbg-cmd-history-idx -1 eq                (history: idx unchanged on no-op)    expect

% Up with empty history is a no-op.
/_dbg-cmd-history [] store
/_dbg-cmd-history-idx -1 store
(stay-put) _dbg-history-up
pop /up-empty exch def
up-empty (stay-put) eq                    (history: up on empty buffer no-op)  expect
_dbg-cmd-history-idx -1 eq                (history: idx unchanged with empty)  expect

% Non-nav key (printable) resets the history idx.
(seed) _dbg-history-push
(seed2) _dbg-history-push
(live) _dbg-history-up
pop pop
_dbg-cmd-history-idx 1 eq                 (history: idx >=0 after up)          expect
/x (junk) _dbg-cmd-line-edit
pop pop                                   % discard buf' status
_dbg-cmd-history-idx -1 eq                (history: printable resets idx)      expect

% Push trim: exceed cap, oldest entries drop.
/_dbg-cmd-history [] store
/_dbg-cmd-history-idx -1 store
% Push 35 distinct entries; cap is 32 so oldest 3 should drop.
/i 0 def
{
    i 35 ge { exit } if
    (e) i (                    ) to-string concat _dbg-history-push
    /i i 1 add def
} loop
_dbg-cmd-history length 32 eq             (history: trimmed to cap)            expect
_dbg-cmd-history 0 get (e3) eq            (history: oldest 3 dropped)          expect
_dbg-cmd-history 31 get (e34) eq          (history: newest preserved)          expect

% --- SECTION: dict-modal after render (use-after-free regression) ------
% dbg-render-stacks once bound its op/exec/dict/err snapshots with `def`,
% which the |locals| shadow rule routes to userdict -- so the snapshot
% arrays (holding references to the render proc's own transient frame)
% dangled in userdict after it returned.  Expanding the DICT pane then
% snapshots the dict stack and deep-formats each dict (incl. userdict),
% walking those stale references -> misaligned DictEntry read (UBSan).
% Fixed by binding the snapshots with local-def.  This drives the exact
% render-then-expand-dict sequence; a regression aborts on the UAF before
% the green sentinel below ever prints.
clear
1 2 3
80 24 make-screen
dbg-render-stacks
/_dbg-focus /dict store
dbg-modal-open
dbg-modal-active?                           (dict-modal: opens after render)     expect
_dbg-modal-pane /dict eq                    (dict-modal: pane = /dict)           expect
_dbg-modal-lines length 0 gt                (dict-modal: lines, no use-after-free) expect
dbg-modal-close
clear

% --- SECTION: teardown final-output re-emit ----------------------------
% uninstall re-emits the COMPLETE captured output (completed lines drained
% into the pane at halts + the in-progress partial + the un-drained tail)
% on a fresh column-0 line, so the shell scrollback shows the full program
% output below the command and no terminal clips its first line.
/_dbg-output-lines [ (line one) (line two) ] store
/_dbg-output-partial (partial ) store
/_dbg-output-truncated false store
8192 make-string-stream /cap-final exch def
cap-final set-stdout pop
(tail\n) _dbg-emit-final-output
stdout set-stdout pop
/out-final cap-final get-string-stream def
out-final 0 get (\n) 0 get eq               (final-emit: starts on a fresh line)  expect
out-final (line one) count-substring 0 gt   (final-emit: completed line 1)        expect
out-final (line two) count-substring 0 gt   (final-emit: completed line 2)        expect
out-final (partial tail) count-substring 0 gt (final-emit: partial+tail joined)   expect
% already ends in a newline (tail was "0\n") -> no DOUBLE trailing newline
out-final out-final length 2 sub get (\n) 0 get eq not (final-emit: no double trailing nl) expect

% q-style: paused mid-line (partial only, no completed lines, no tail) -> a
% trailing newline is appended so the shell prompt lands on a fresh line.
/_dbg-output-lines [] store
/_dbg-output-partial (mid-line so far) store
8192 make-string-stream /cap-q exch def
cap-q set-stdout pop
() _dbg-emit-final-output
stdout set-stdout pop
/out-q cap-q get-string-stream def
out-q (mid-line so far) count-substring 0 gt (final-emit: mid-line partial shown)  expect
out-q out-q length 1 sub get (\n) 0 get eq   (final-emit: trailing nl when mid-line) expect
clear

% Empty case: no captured output -> emit nothing (no stray blank line).
/_dbg-output-lines [] store
/_dbg-output-partial () store
8192 make-string-stream /cap-empty exch def
cap-empty set-stdout pop
() _dbg-emit-final-output
stdout set-stdout pop
cap-empty get-string-stream length 0 eq     (final-emit: no output = no emit)     expect
clear

% --- Wrap up ------------------------------------------------------------

(passed: ) print passed = clear
(failed: ) print failed = clear
(total:  ) print total  = clear

failed 0 eq                                 (test-debug-ui-pure: all green)    expect

(__test_ok__) =
