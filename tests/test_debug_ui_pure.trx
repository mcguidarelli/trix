/_dbg-focus /source store

% --- SECTION 40: one-shot breakpoints -----------------------------------

% Clean slate.
debug-breakpoints { debug-unbreak } for-all
_dbg-bp-conditions { pop _dbg-bp-conditions exch undef } for-all
_dbg-bp-oneshot    { pop _dbg-bp-oneshot    exch undef } for-all

% b1 /name registers AND tags one-shot.
(b1 oneshot-a) dbg-execute-command
(once: ) count-substring 0 gt              (oneshot: confirm prefix)              expect

debug-breakpoints length 1 eq              (oneshot: bp registered)               expect
_dbg-bp-oneshot /oneshot-a known?          (oneshot: tag set)                     expect
_dbg-bp-conditions /oneshot-a known? not   (oneshot: no condition attached)       expect

% bp listing includes (once) marker.
(bp) dbg-execute-command
dup (/oneshot-a) count-substring 0 gt      (oneshot: list shows name)             expect
    ((once)) count-substring 0 gt          (oneshot: list shows marker)           expect

% Simulate firing: set pc-name + call handle-oneshot.
/_dbg-last-pc-name /oneshot-a store
_dbg-handle-oneshot

debug-breakpoints length 0 eq              (oneshot: bp cleared after fire)       expect
_dbg-bp-oneshot /oneshot-a known? not      (oneshot: tag cleared after fire)      expect
/_dbg-last-pc-name null store

% --- SECTION 41: one-shot + conditional combo ---------------------------

(b1 oneshot-b when {1 2 lt}) dbg-execute-command pop
_dbg-bp-oneshot /oneshot-b known?          (oneshot+cond: tag set)                 expect
_dbg-bp-conditions /oneshot-b known?       (oneshot+cond: condition set)           expect

% Predicate-false case: silent-skip leaves bp + tag in place.
/_dbg-last-pc-name /oneshot-b store
_dbg-bp-conditions /oneshot-b (false) put          % force predicate to false
_dbg-should-silent-skip                            (oneshot+cond: false predicate skips) expect
% Note: handle-oneshot is NOT called when silent-skipping.  Verify state.
debug-breakpoints length 1 eq              (oneshot+cond: bp still set after silent-skip) expect
_dbg-bp-oneshot /oneshot-b known?          (oneshot+cond: tag still set after silent-skip) expect

% Now simulate predicate-true halt: handle-oneshot fires, clears everything.
_dbg-bp-conditions /oneshot-b (true) put
_dbg-should-silent-skip not                (oneshot+cond: true predicate halts)   expect
_dbg-handle-oneshot
debug-breakpoints length 0 eq              (oneshot+cond: bp cleared after halt)   expect
_dbg-bp-oneshot /oneshot-b known? not      (oneshot+cond: tag cleared after halt)  expect
_dbg-bp-conditions /oneshot-b known? not   (oneshot+cond: condition cleared after halt) expect
/_dbg-last-pc-name null store

% --- SECTION 42: clear-all wipes oneshot tags ---------------------------

(b1 oneshot-c) dbg-execute-command pop
(b  oneshot-d) dbg-execute-command pop
_dbg-bp-oneshot /oneshot-c known?          (oneshot: tag for c)                   expect
_dbg-bp-oneshot /oneshot-d known? not      (oneshot: no tag for permanent d)      expect

(clear-all) dbg-execute-command pop
debug-breakpoints length 0 eq              (oneshot: clear-all empties bp)        expect
_dbg-bp-oneshot /oneshot-c known? not      (oneshot: clear-all wipes oneshot tag) expect

% --- SECTION 43: clear /name drops oneshot tag --------------------------

(b1 oneshot-e) dbg-execute-command pop
_dbg-bp-oneshot /oneshot-e known?          (oneshot: tag pre-clear)               expect

(clear oneshot-e) dbg-execute-command pop
debug-breakpoints length 0 eq              (oneshot: clear /name removes bp)      expect
_dbg-bp-oneshot /oneshot-e known? not      (oneshot: clear /name removes tag)     expect

% --- SECTION 44: frame navigation commands ------------------------------

% Synthetic frame list to exercise the navigation logic.
/_dbg-frame-locs [
    [6 30 0 /inner-callee]
    [6 22 0 /middle]
    [6 15 0 /outer]
] store
/_dbg-frame-idx 0 store

% :frames lists all frames with current selection.
(frames) dbg-execute-command
dup (/inner-callee) count-substring 0 gt   (frames: list shows inner-callee)      expect
dup (/middle) count-substring 0 gt         (frames: list shows middle)            expect
    (/outer) count-substring 0 gt          (frames: list shows outer)             expect

% :up moves to older frame.  Test verifies _dbg-frame-idx incremented
% (string content is implementation detail; the side effect is the key).
(up) dbg-execute-command pop
_dbg-frame-idx 1 eq                        (frames: :up advanced to middle)       expect

(up) dbg-execute-command pop
_dbg-frame-idx 2 eq                        (frames: :up advanced to outer)        expect

% At oldest -- :up returns sentinel string but doesn't move.
(up) dbg-execute-command
(already at oldest frame) count-substring 0 gt
                                            (frames: :up caps at oldest)           expect
_dbg-frame-idx 2 eq                         (frames: idx unchanged at cap)         expect

% :down moves back toward newer frame.
(down) dbg-execute-command pop
_dbg-frame-idx 1 eq                        (frames: :down stepped back)           expect

(down) dbg-execute-command pop
_dbg-frame-idx 0 eq                        (frames: :down back at deepest)        expect

(down) dbg-execute-command
(already at newest frame) count-substring 0 gt
                                            (frames: :down caps at newest)         expect

% :frame N jumps directly.
(frame 2) dbg-execute-command pop
_dbg-frame-idx 2 eq                        (frames: :frame 2 jumped)              expect

(frame 0) dbg-execute-command pop
_dbg-frame-idx 0 eq                        (frames: :frame 0 jumped back)         expect

% Out-of-range index.
(frame 99) dbg-execute-command
(no frame at index) count-substring 0 gt   (frames: oob index rejected)           expect

% Empty index -- usage hint.
(frame) dbg-execute-command
(usage: frame N) count-substring 0 gt      (frames: missing index = usage)        expect

% Empty frame list.
/_dbg-frame-locs [] store
(frames) dbg-execute-command (no frames) eq    (frames: empty list)               expect
(up) dbg-execute-command (no frames available) eq  (frames: :up on empty)         expect

