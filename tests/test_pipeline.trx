length 0 eq                               (merge-empty: both empty) rt-ok  clear

% ====================================================================
% SECTION 112: pipe-merge — boundary: single-element sources
% ====================================================================

[[1] [10]] pipe-merge 8 pipe-collect
dup length 2 eq                           (merge-single: length = 2) rt-ok
dup 0 get 1 eq                            (merge-single: item 0 = 1) rt-ok
1 get 10 eq                               (merge-single: item 1 = 10) rt-ok  clear

% ====================================================================
% SECTION 113: pipe-merge — fuzz: merge + filter downstream
% ====================================================================

[[1 2 3 4] [10 20 30 40]] pipe-merge { 2 mod 0 eq } pipe-filter 8 pipe-collect
% Round-robin: 1 10 2 20 3 30 4 40 — evens: 10 2 20 30 4 40
dup length 6 eq                           (merge-filter: 6 evens) rt-ok
dup 0 get 10 eq                           (merge-filter: first even = 10) rt-ok
dup 1 get 2 eq                            (merge-filter: second even = 2) rt-ok
5 get 40 eq                               (merge-filter: last even = 40) rt-ok  clear

% ====================================================================
% SECTION 114: pipe-merge — stress: 5 sources
% ====================================================================

[[1 2] [10 20] [100 200] [1000 2000] [10000 20000]] pipe-merge 16 pipe-collect
dup length 10 eq                          (merge-5: length = 10) rt-ok
% Round-robin: 1 10 100 1000 10000 2 20 200 2000 20000
dup 0 get 1 eq                            (merge-5: item 0) rt-ok
dup 4 get 10000 eq                        (merge-5: item 4) rt-ok
9 get 20000 eq                            (merge-5: item 9) rt-ok  clear

% ====================================================================
% SECTION 115: pipe-merge — boundary: one empty, one non-empty
% ====================================================================

[[ ] [1 2 3]] pipe-merge 8 pipe-collect
dup length 3 eq                           (merge-one-empty: length = 3) rt-ok
0 get 1 eq                                (merge-one-empty: first = 1) rt-ok  clear

% ====================================================================
% SECTION 116: pipe-merge — stress: large sources (50 each)
% ====================================================================

% Build two 25-element arrays
[ 25 range  25 50 range-from ] pipe-merge 64 pipe-collect
length 50 eq                              (merge-large: 25+25 = 50) rt-ok  clear

% ====================================================================
% SECTION 117: pipe-zip — boundary: all sources empty
% ====================================================================

[[ ] [ ]] pipe-zip 8 pipe-collect
length 0 eq                               (zip-all-empty: empty result) rt-ok  clear

% ====================================================================
% SECTION 118: pipe-zip — boundary: single-element sources
% ====================================================================

[[1] [10]] pipe-zip 8 pipe-collect
dup length 1 eq                           (zip-single: one tuple) rt-ok
0 get dup 0 get 1 eq                      (zip-single: t0[0]=1) rt-ok
          1 get 10 eq                     (zip-single: t0[1]=10) rt-ok  clear

% ====================================================================
% SECTION 119: pipe-zip — fuzz: zip + distinct downstream
% ====================================================================

% Zip + filter: keep only tuples where sum > 15
[[1 2 3] [10 20 30]] pipe-zip { dup 0 get exch 1 get add 15 gt } pipe-filter 8 pipe-collect
dup length 2 eq                           (zip-filter: 2 tuples with sum>15) rt-ok
0 get 0 get 2 eq                          (zip-filter: first kept tuple[0]=2) rt-ok  clear

% ====================================================================
% SECTION 120: pipe-zip — fuzz: mixed types across sources
% ====================================================================

[[(a) (b) (c)] [1 2 3]] pipe-zip 8 pipe-collect
dup length 3 eq                           (zip-mixed: 3 tuples) rt-ok
0 get dup 0 get (a) eq                    (zip-mixed: t0[0]=a) rt-ok
          1 get 1 eq                      (zip-mixed: t0[1]=1) rt-ok  clear

% ====================================================================
% SECTION 121: pipe-zip — stress: 5 sources
% ====================================================================

[[1 2] [10 20] [100 200] [1000 2000] [10000 20000]] pipe-zip 8 pipe-collect
dup length 2 eq                           (zip-5: 2 tuples) rt-ok
0 get dup length 5 eq                     (zip-5: tuple width = 5) rt-ok
dup 0 get 1 eq                            (zip-5: t0[0]=1) rt-ok
dup 1 get 10 eq                           (zip-5: t0[1]=10) rt-ok
    4 get 10000 eq                        (zip-5: t0[4]=10000) rt-ok  clear

% ====================================================================
% SECTION 122: pipe-distinct — sad: non-hashable triggers error
% ====================================================================

% pipe-distinct uses set membership; all Trix types are hashable, so test
% integer/string/name mixing works without error.
[1 (hello) /name 1 (hello) /name] pipe-distinct 8 pipe-collect
length 3 eq                               (distinct-mixed: 3 distinct types) rt-ok  clear

% ====================================================================
% SECTION 123: pipe-distinct — stress: large dedup (50 items, half dupes)
% ====================================================================

% 25 range produces [0..24]; flatten [[0..24] [0..24]] to get 50 with 25 dupes
[ 25 range 25 range ] flatten pipe-distinct 64 pipe-collect
length 25 eq                              (distinct-stress: 50 in, 25 out) rt-ok  clear

% ====================================================================

rt-fails 0 get /integer-type cast 0 gt { /rt-assertions-failed throw } if
(test_pipeline: ALL TESTS PASSED) =
(__test_ok__) =
