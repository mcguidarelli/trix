[ 0 1 99 { } for ]
    5 pipe-batch
    2 pipe-collect
dup length 20 eq
    (batch-stress: 100 items / 5 = 20 batches) rt-ok
dup 0 get length 5 eq
    (batch-stress: first batch full) rt-ok
19 get length 5 eq
    (batch-stress: last batch full) rt-ok clear

