% ====================================================================
% SECTION 43: pipe-take — N = 1
% ====================================================================

[7 8 9] 1 pipe-take 2 pipe-collect
dup length 1 eq
    (take-one: length = 1) rt-ok
0 get 7 eq
    (take-one: value = 7) rt-ok

% ====================================================================
% SECTION 44: pipe-take — chained with pipe-map
% ====================================================================

[1 2 3 4 5] { 10 mul } pipe-map 3 pipe-take 2 pipe-collect
dup length 3 eq
    (take-map: length = 3) rt-ok
dup 0 get 10 eq
    (take-map: first = 10) rt-ok
dup 1 get 20 eq
    (take-map: second = 20) rt-ok
