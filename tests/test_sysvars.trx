% ============================================================
% 2b. Math constants (double-type)
% ============================================================

//:systemdict:numbers:double-type:e type /double-type eq (math-double-e-is-double) rt-ok clear
//:systemdict:numbers:double-type:pi type /double-type eq (math-double-pi-is-double) rt-ok clear
//:systemdict:numbers:double-type:log2e type /double-type eq (math-double-log2e-is-double) rt-ok clear
//:systemdict:numbers:double-type:log10e type /double-type eq (math-double-log10e-is-double) rt-ok clear
//:systemdict:numbers:double-type:ln2 type /double-type eq (math-double-ln2-is-double) rt-ok clear
//:systemdict:numbers:double-type:ln10 type /double-type eq (math-double-ln10-is-double) rt-ok clear
//:systemdict:numbers:double-type:sqrt2 type /double-type eq (math-double-sqrt2-is-double) rt-ok clear
//:systemdict:numbers:double-type:sqrt3 type /double-type eq (math-double-sqrt3-is-double) rt-ok clear
//:systemdict:numbers:double-type:phi type /double-type eq (math-double-phi-is-double) rt-ok clear
//:systemdict:numbers:double-type:egamma type /double-type eq (math-double-egamma-is-double) rt-ok clear

% double-type approximate value checks
//:systemdict:numbers:double-type:e 2.71828d 0.001d approx-eq (math-double-e-approx) rt-ok clear
//:systemdict:numbers:double-type:pi 3.14159d 0.001d approx-eq (math-double-pi-approx) rt-ok clear
//:systemdict:numbers:double-type:phi 1.618d 0.001d approx-eq (math-double-phi-approx) rt-ok clear
