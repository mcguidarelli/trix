% ====================================================================
% test_actor_snapshot.trx -- actor mailbox snap-shot / thaw round-trip
% ====================================================================
% Phase 1: spawn actor, fill mailbox, snap-shot, verify + process.
% Phase 2: thaw via tests/actor_snapshot_thaw.trx re-runs verification.
%
% Must NOT run inside save/restore (actors cannot span save scopes).

% rt-ok counts failures in a restore-immune slot -- string byte writes
% are unjournaled, so the count survives assertions made inside save
% scopes, and the 1-byte string lives in LOCAL VM, invisible to the
% global-heap/gc-counter probes some files assert on.  The file THROWS
% at EOF: test_all counts a file as failed only when its run throws,
% so print-only failures would slip the suite verdict.
/rt-fails 1 string def
rt-fails 0 16#0#b put
/rt-ok { exch { = } { (FAILED: ) print = rt-fails 0  rt-fails 0 get /integer-type cast 1 add dup 255 gt { pop 255 } if /byte-type cast  put } if-else } def

% --- setup: spawn actor, fill mailbox, do NOT yield ---
/snap-actor-sum 0 def
/snap-actor [ {
    actor-recv actor-recv add actor-recv add
    /snap-actor-sum exch def
} actor-spawn def

10 snap-actor actor-send
20 snap-actor actor-send
30 snap-actor actor-send

% --- second actor: mailbox holds 128-bit messages across snapshot ---
/snap-i128-sum 0q def
/snap-i128-actor [ {
    actor-recv actor-recv add actor-recv add
    /snap-i128-sum exch def
} actor-spawn def

/m1 10q def
/m2 20q def
/m3 30q def
m1 snap-i128-actor actor-send
m2 snap-i128-actor actor-send
m3 snap-i128-actor actor-send

(tests/actor_snapshot.img) snap-shot

% ==== post-snap-shot: runs in BOTH phases ====

% Mailbox state preserved for the integer actor
snap-actor is-actor (sa:is-actor) rt-ok
snap-actor is-coroutine (sa:is-coroutine) rt-ok
snap-actor actor-mailbox-count 3 eq (sa:mbx-count-3) rt-ok  clear

% Mailbox state preserved for the 128-bit actor
snap-i128-actor is-actor (sa:i128-is-actor) rt-ok
snap-i128-actor actor-mailbox-count 3 eq (sa:i128-mbx-count-3) rt-ok  clear

% Let both actors process their queued messages
0 coroutine-sleep 0 coroutine-sleep

% Integer actor received and summed all 3
snap-actor-sum 60 eq (sa:sum-60) rt-ok
snap-actor actor-mailbox-empty? (sa:mbx-drained) rt-ok
snap-actor coroutine-status /dead eq (sa:actor-dead) rt-ok  clear

% Int128 actor received and summed all 3: 10q + 20q + 30q = 60q
snap-i128-sum 60q deep-eq (sa:i128-sum-60) rt-ok
snap-i128-actor actor-mailbox-empty? (sa:i128-mbx-drained) rt-ok
snap-i128-actor coroutine-status /dead eq (sa:i128-actor-dead) rt-ok  clear

rt-fails 0 get /integer-type cast 0 gt { /rt-assertions-failed throw } if
(test_actor_snapshot: ALL TESTS PASSED) =
(__test_ok__) =
