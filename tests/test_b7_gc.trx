% ============================================================================
% test_b7_gc.trx -- B7 group 1b (GC-rooting + region-mismatch HIGH correctness)
% ============================================================================
% Grows per subsystem as G1b lands.  The precise mid-op-GC fault windows here
% need the global VM near-full so a gvm_alloc on its VMFull retry fires
% vm_global_gc mid-operation; those are code-inspection-covered (per the
% test_b6_gc.trx methodology) and exercised functionally below.  Where a fault
% is deterministically reproducible, the assertion is verified to fail pre-fix.
%
% coroutine:1-0  coroutine_launch_common allocated the CoroutineContext, then
%                allocated the stacks block (a SECOND global alloc that can fire
%                vm_global_gc) BEFORE linking the context into the scheduler
%                registry -- so a mid-launch sweep reclaimed the unrooted, half-
%                built context (UAF / corrupt registry).  Now the context is
%                spliced into the registry (with m_stacks_offset = nulloffset)
%                before coroutine_alloc_stacks.  (Functional + GC-survival.)
% actor:2-0      actor-recv-match-timeout popped both operands BEFORE building
%                the deadline Long; under ${...} make_long's gvm_alloc can fire
%                GC, and the predicate proc was then held only in a C local (not
%                a GC root) -> swept -> UAF when the predicate ran.  The pop is
%                now deferred until after make_long, keeping the predicate rooted
%                on the op stack.  (Functional; the sweep needs global pressure.)
% ============================================================================

% rt-ok counts failures in a restore-immune slot -- string byte writes
% are unjournaled, so the count survives assertions made inside save
% scopes, and the 1-byte string lives in LOCAL VM, invisible to the
% global-heap/gc-counter probes some files assert on.  The file THROWS
% at EOF: test_all counts a file as failed only when its run throws,
% so print-only failures would slip the suite verdict.
/rt-fails 1 string def
rt-fails 0 16#0#b put
/rt-ok { exch { = } { (FAILED: ) print = rt-fails 0  rt-fails 0 get /integer-type cast 1 add dup 255 gt { pop 255 } if /byte-type cast  put } if-else } def

% ---------------------------------------------------------------------------
% coroutine:1-0 -- launch interleaved with vm-global-gc, results intact
% ---------------------------------------------------------------------------
mark { 100 } coroutine-launch /c1 exch def
vm-global-gc pop
mark { 200 } coroutine-launch /c2 exch def
vm-global-gc pop
c1 coroutine-join /ok1 exch def /v1 exch def
c2 coroutine-join /ok2 exch def /v2 exch def
ok1 ok2 and (coroutine:1-0 both launches survive interleaved GC + join cleanly) rt-ok
v1 v2 add 300 eq (coroutine:1-0 launch+gc+join returns correct results) rt-ok

% Many launches with a GC between each -- registry stays consistent.
0 /tot exch store
0 1 9 {
  pop
  mark { 5 } coroutine-launch coroutine-join pop tot add /tot exch store
  vm-global-gc pop
} for
tot 50 eq (coroutine:1-0 10 launch/join cycles with GC: total 50) rt-ok

% ---------------------------------------------------------------------------
% actor:2-0 -- recv-match-timeout inside ${...} keeps the predicate rooted
% ---------------------------------------------------------------------------
mark {
  actor-self /me exch def
  [ /hi 7 ] me actor-send
  ${ { dup is-array { 0 get /hi eq } { pop false } if-else } 1000 actor-recv-match-timeout }
  /flag exch def
  /matched exch def
  flag (actor:2-0 recv-match-timeout in global mode matched) rt-ok
  matched 1 get 7 eq (actor:2-0 matched message payload intact) rt-ok
} actor-spawn coroutine-join pop clear

% ---------------------------------------------------------------------------
% genserver:1-4 -- gen-call cloned-message + predicate spines region-aware (${...})
% ---------------------------------------------------------------------------
% Functional + code-inspection: the call array + true/false/body proc spines are
% built via vm_alloc_dispatch_n and each in-flight composite is rooted on the op
% stack across make_curry_pair.  The mid-op-GC sweep and the cross-restore dangle
% (local spine under a global payload) need global VM pressure / a held enqueued
% message, so those exact windows are code-inspection-covered.
/b7-echo << /init { null } /handle-call { [/msg /from /state] let state msg /reply end } >> def
mark {
  b7-echo gen-server /srv exch def
  ${ srv 3.14 gen-call } 3.14 eq (genserver:1-4 gen-call Double in global mode -> intact reply) rt-ok
  srv (q) gen-call (q) eq (genserver:1-4 gen-call still works on the local path) rt-ok
  srv /done gen-stop
} actor-spawn coroutine-join pop clear

% ---------------------------------------------------------------------------
% system:1-0 -- backtrace built in ${...} survives restore (region-aware)
% ---------------------------------------------------------------------------
% backtrace's result array is region-aware (global under ${...}) but its frame
% dicts + /name,/file strings were allocated LOCAL -> dangled after a restore
% that reclaimed local VM.  Now the dicts use create_global_dict and the strings
% use make_string_dispatch in the global case (mirrors the ops_record region-aware
% pattern).  Functional + code-inspection coverage: the dangling read is a silent
% UAF (the VM bump/recycle allocator is not ASan-instrumented and the freed bytes
% are not reliably clobbered), so this exercises the post-fix path end-to-end
% rather than asserting a pre-fix crash.
/f { backtrace } def
/snap save def
${ f }                  % global backtrace array left on the op stack
snap restore            % reclaims local VM (pre-fix: frame dicts/strings dangle)
/bt exch def            % bind the survived global array (after restore)
% Churn LOCAL VM to reuse the region the restore reclaimed: pre-fix this clobbers
% bt's dangling local frame dicts/strings; post-fix they are global and untouched.
0 1 300 { pop [ 1 2 3 4 5 6 7 8 ] pop } for
bt length 1 eq (system:1-0 backtrace array survives restore) rt-ok
bt 0 get /name get (f) eq (system:1-0 frame /name string survives restore + churn) rt-ok

% ---------------------------------------------------------------------------
% pipeline:3-1 (subsumes 2-0) -- batch/window/zip/merge aux arrays global + GC-walkable
% ---------------------------------------------------------------------------
% The batch/window/zip/merge stages buffer pipe items (and zip tuple inputs) in
% auxiliary Object arrays that were LOCAL and stored as make_pipe_buffer
% companions gc_mark_object never descended into -> a global GC mid-accumulation
% swept the buffered global payloads (UAF on flush) and a restore dangled the
% array.  They are now global, null-init'd, literal-Array companions (read via
% arrays_offset) that the GC walks; the unlinked stage context + each in-flight
% aux array are rooted on the op stack across creation (gvm_alloc_n can fire GC).
% Functional + code-inspection: the mid-accumulation sweep needs a stage
% suspended on a full output buffer while a sibling forces GC, which isn't
% deterministically reproducible here; these confirm the stages produce correct
% results over global-subarray payloads and survive a post-collection GC.
[ [1 2] [3 4] [5 6] [7 8] ] 2 pipe-batch 16 pipe-collect /pb exch def
vm-global-gc pop
pb 0 get 0 get 0 get 1 eq (pipeline:3-1 batch over global items: pb[0][0][0]==1) rt-ok
[ [10 20] [30 40] [50 60] ] 2 pipe-window 16 pipe-collect /pw exch def
vm-global-gc pop
pw 0 get 0 get 0 get 10 eq (pipeline:3-1 window over global items: pw[0][0][0]==10) rt-ok
[ [ 1 2 3 ] [ 10 20 30 ] ] pipe-zip 16 pipe-collect /pz exch def
vm-global-gc pop
pz 0 get 1 get 10 eq (pipeline:3-1 zip tuple items survive GC: pz[0][1]==10) rt-ok
[ [ 1 2 ] [ 3 4 ] ] pipe-merge 16 pipe-collect /pmrg exch def
vm-global-gc pop
pmrg length 4 eq (pipeline:3-1 merge inputs survive GC: len 4) rt-ok

% ---------------------------------------------------------------------------
% reactive:1-0 -- cells are region-aware + GC-visible (values survive vm-global-gc)
% ---------------------------------------------------------------------------
% A CellHeader was always LOCAL and ChunkKind::Cell was a no-op GC leaf, so a
% global value/proc reachable only through a cell was swept by vm-global-gc.
% Now make_cell is region-aware, cell_gc_walk marks the header's references, the
% global walker dispatches Cell to it, and gc_mark_object descends into a LOCAL
% cell that holds global values.  These FAIL pre-fix (swept -> null/garbage).
${ [10 20 30] cell } /rc exch def
vm-global-gc pop
rc cell-get 0 get 10 eq (reactive:1-0 global cell value survives GC: [0]==10) rt-ok
rc cell-get 2 get 30 eq (reactive:1-0 global cell value survives GC: [2]==30) rt-ok
0 cell /rc2 exch def
${ [40 50 60] } rc2 cell-set
vm-global-gc pop
rc2 cell-get 0 get 40 eq (reactive:1-0 LOCAL cell w/ global value survives GC: [0]==40) rt-ok
${ { [70 80 90] } cell-computed } /rc3 exch def
rc3 cell-get pop
vm-global-gc pop
rc3 cell-get 1 get 80 eq (reactive:1-0 computed cell global result survives GC: [1]==80) rt-ok

% ---------------------------------------------------------------------------
% supervision:2-0 -- SupervisorState is GC-rooted (survives vm-global-gc)
% ---------------------------------------------------------------------------
% The SupervisorState block (global VM) was referenced only as an integer in the
% supervisor coroutine's m_return_value, so walk_all_roots never marked it and
% vm-global-gc swept it -> supervisor accessors read freed memory.  Now the
% supervisor context carries FlagSupervisor and gc_walk_coroutine_context marks
% the state; supervisor_op also reorders so the state is allocated + rooted only
% AFTER the coroutine is launched (no unrooted window during creation).
<< /strategy /one-for-one /intensity 5 /period 30000
   /children [ << /id /w1 /start { { actor-recv pop } loop } /restart /permanent >>
               << /id /w2 /start { { actor-recv pop } loop } /restart /permanent >> ] >> supervisor /SUP exch def
SUP supervisor-count-children 2 eq (supervision:2-0 supervisor created with 2 children) rt-ok
vm-global-gc pop
${ 0 1 300 { pop [ 1 2 3 4 5 6 7 8 ] pop } for }   % clobber any reclaimed region
SUP supervisor-count-children 2 eq (supervision:2-0 SupervisorState survives vm-global-gc + churn) rt-ok

(test_b7_gc.trx: all tests passed) =
rt-fails 0 get /integer-type cast 0 gt { /rt-assertions-failed throw } if
(__test_ok__) =
