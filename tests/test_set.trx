2 set /sf-big exch def
0l 1l 49l { sf-big exch set-add pop } for
sf-big { 25l ge } set-filter length 25 eq
(set-filter: large long set) rt-ok clear

% result members round-trip
{{ 1 2 3 4 5 }} { 3 gt } set-filter members length 2 eq
(set-filter: members round-trip length) rt-ok clear

% deep-eq on filtered result
{{ 1 2 3 }} { 1 gt } set-filter {{ 2 3 }} deep-eq
(set-filter: deep-eq on result) rt-ok clear

% --- set-filter: proc error mid-iteration ---
<< /type-check { clear true } >> { {{ 1 (hello) 3 }} { 2 gt } set-filter } try-catch
(set-filter: proc error caught) rt-ok clear

% --- set-filter result used in set algebra ---
{{ 1 2 3 4 5 }} { 3 gt } set-filter
{{ 4 5 6 }} set-intersection length 2 eq
(set-filter: result in intersection) rt-ok clear

