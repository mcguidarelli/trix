{{ /a /b /c }} { pop false } set-filter length 0 eq
(set-filter: keep none) rt-ok clear

% --- filter keep all ---
{{ /a /b /c }} { pop true } set-filter length 3 eq
(set-filter: keep all) rt-ok clear

% --- empty input ---
{{ }} { pop true } set-filter length 0 eq
(set-filter: empty set) rt-ok clear

% --- integer keys ---
{{ 1 2 3 4 5 }} { 3 gt } set-filter length 2 eq
(set-filter: integers > 3) rt-ok clear
{{ 1 2 3 4 5 }} { 3 gt } set-filter 4 set-member?
(set-filter: has 4) rt-ok clear
{{ 1 2 3 4 5 }} { 3 gt } set-filter 5 set-member?
(set-filter: has 5) rt-ok clear

% --- string keys ---
{{ (aa) (bb) (cc) }} { (bb) ne } set-filter length 2 eq
(set-filter: string keys) rt-ok clear

% --- ExtValue keys ---
{{ 1l 2l 3l 4l 5l }} { 3l gt } set-filter length 2 eq
(set-filter: long keys) rt-ok clear
{{ 1l 2l 3l 4l 5l }} { 3l gt } set-filter 4l set-member?
(set-filter: long has 4l) rt-ok clear

% --- result is dynamic ---
{{ 1 2 3 }} { 2 gt } set-filter 99 set-add length 2 eq
(set-filter: result is dynamic) rt-ok clear

% --- mixed types ---
{{ 1 /a (hello) true }} { type /integer-type eq } set-filter length 1 eq
(set-filter: keep only integers) rt-ok clear

% --- singleton ---
{{ /x }} { pop true } set-filter length 1 eq
(set-filter: singleton keep) rt-ok clear
{{ /x }} { pop false } set-filter length 0 eq
(set-filter: singleton drop) rt-ok clear

% --- sad: type mismatch ---
<< /type-check { clear true } >> { 42 { pop true } set-filter } try-catch
(set-filter: non-set error) rt-ok clear

% ExtValue: Double keys
{{ 1.0d 2.0d 3.0d 4.0d 5.0d }} { 3.0d gt } set-filter length 2 eq
(set-filter: double keys) rt-ok clear

% ExtValue: Address keys
{{ 10a 20a 30a 40a }} { 25a gt } set-filter length 2 eq
(set-filter: address keys) rt-ok clear

% ExtValue: ULong keys
{{ 1ul 2ul 3ul 4ul }} { 2ul gt } set-filter length 2 eq
(set-filter: ulong keys) rt-ok clear

% filter to exactly 1
{{ 1 2 3 4 5 }} { 3 eq } set-filter length 1 eq
(set-filter: filter to 1) rt-ok clear
{{ 1 2 3 4 5 }} { 3 eq } set-filter 3 set-member?
(set-filter: filter to 1 has 3) rt-ok clear

