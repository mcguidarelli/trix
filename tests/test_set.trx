{{ 1.0d 2.0d 3.0d }} length 3 eq (extval: double set length) rt-ok clear
{{ 1.0d 2.0d 3.0d }} 2.0d set-member? (extval: double member) rt-ok clear
{{ 1.0d 2.0d }} 3.0d set-add 3.0d set-member? (extval: double add) rt-ok clear

% --- Address keys ---
{{ 0a 1a 2a }} length 3 eq (extval: address set length) rt-ok clear
{{ 0a 1a 2a }} 1a set-member? (extval: address member) rt-ok clear

% --- ExtValue set algebra ---
{{ 1l 2l 3l }} {{ 2l 3l 4l }} set-union length 4 eq (extval: long union) rt-ok clear
{{ 1l 2l 3l }} {{ 2l 3l 4l }} set-intersection length 2 eq (extval: long intersection) rt-ok clear
{{ 1l 2l 3l }} {{ 2l 3l 4l }} set-difference length 1 eq (extval: long difference) rt-ok clear
{{ 1l 2l }} {{ 1l 2l 3l }} subset? (extval: long subset) rt-ok clear

% --- ExtValue members returns correct types ---
{{ 42l }} members 0 get type /long-type eq (extval: members returns long) rt-ok clear
{{ 3.14d }} members 0 get type /double-type eq (extval: members returns double) rt-ok clear

% --- ExtValue per-element type check (W07: use members + `all`,
% not for-all -- `all` requires an array, so materialize the set first.)
{{ 99l }} members { type /long-type eq } all (extval: for-all yields long) rt-ok clear
{{ 1.5d }} members { type /double-type eq } all (extval: for-all yields double) rt-ok clear

% --- ExtValue copy ---
{{ 1l 2l 3l }} 4 set copy length 3 eq (extval: copy length) rt-ok clear
{{ 1l 2l 3l }} 4 set copy 2l set-member? (extval: copy member) rt-ok clear

