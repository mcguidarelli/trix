% ====================================================================
% Test: Set type
% ====================================================================

% rt-ok counts failures in a restore-immune slot -- string byte writes
% are unjournaled, so the count survives assertions made inside save
% scopes, and the 1-byte string lives in LOCAL VM, invisible to the
% global-heap/gc-counter probes some files assert on.  The file THROWS
% at EOF: test_all counts a file as failed only when its run throws,
% so print-only failures would slip the suite verdict.
/rt-fails 1 string def
rt-fails 0 16#0#b put
/rt-ok { exch { = } { (FAILED: ) print = rt-fails 0  rt-fails 0 get /integer-type cast 1 add dup 255 gt { pop 255 } if /byte-type cast  put } if-else } def

% --- construction ---
{{ /a /b /c }} type /set-type eq (set: type) rt-ok clear
{{ /a /b /c }} length 3 eq (set: length 3) rt-ok clear
{{ }} length 0 eq (set: empty length 0) rt-ok clear
4 set type /set-type eq (set: operator creates set) rt-ok clear
4 set length 0 eq (set: operator creates empty) rt-ok clear

% --- is-set type predicate ---
{{ /a /b /c }} is-set                  (is-set: true for set) rt-ok clear
{{ }} is-set                           (is-set: true for empty set) rt-ok clear
4 set is-set                           (is-set: true for set-operator result) rt-ok clear
42 is-set not                          (is-set: false for integer) rt-ok clear
(hi) is-set not                        (is-set: false for string) rt-ok clear
[1 2 3] is-set not                     (is-set: false for array) rt-ok clear
<< /a 1 >> is-set not                  (is-set: false for dict) rt-ok clear
/n is-set not                          (is-set: false for name) rt-ok clear

% --- 0 set clamps to MinDynamicDictCapacity and stays growable ---
% Sets are dynamic; an empty one (0 set, or an internally-built empty result like
% set-filter on an empty set) is clamped capacity 0 -> 4 so set-add can grow it.
% (Pre-fix a 0-capacity set errored on the very first set-add.)
/s0cap 0 set def
0 1 5 { /i exch def s0cap i set-add pop } for
s0cap length 6 eq (set: 0-cap grows past clamp to hold 6) rt-ok clear
s0cap 3 set-member? (set: 0-cap grown member? 3) rt-ok clear
% the internal empty-result path: set-filter on an empty set returns a 0-cap dynamic
% set (ops_set.inl create_set(.., 0, ReadWriteDynamic)); it must accept later adds
0 set { pop true } set-filter /sf exch def
sf 99 set-add 99 set-member? (set: empty set-filter result is growable) rt-ok clear

% --- suffixes ---
{{ /x }}#r type /set-type eq (set: #r suffix) rt-ok clear
{{ /x }}#w type /set-type eq (set: #w suffix) rt-ok clear
{{ /x }}#= type /set-type eq (set: #= suffix) rt-ok clear

% --- dedup ---
{{ /a /a /b }} length 2 eq (set: dedup in literal) rt-ok clear

% --- set inside procedure ---
{ {{ /a /b }} } exec type /set-type eq (set: inside proc type) rt-ok clear
{ {{ /a /b }} } exec length 2 eq (set: inside proc length) rt-ok clear

% --- set-add ---
{{ /a /b }} /c set-add length 3 eq (set-add: length grows) rt-ok clear
{{ /a /b }} /c set-add /c set-member? (set-add: member after add) rt-ok clear
{{ /a /b }} /a set-add length 2 eq (set-add: no-op for existing) rt-ok clear

% --- set-remove ---
{{ /a /b /c }} /b set-remove length 2 eq (set-remove: length shrinks) rt-ok clear
{{ /a /b /c }} /b set-remove /b set-member? not (set-remove: gone after remove) rt-ok clear

% --- set-remove error ---
<< /undefined { clear true } >> { {{ /a }} /z set-remove } try-catch
(set-remove: error on missing) rt-ok clear

% --- set-member? ---
{{ /a /b /c }} /a set-member? (set-member?: present) rt-ok clear
{{ /a /b /c }} /z set-member? not (set-member?: absent) rt-ok clear
{{ }} /x set-member? not (set-member?: empty set) rt-ok clear

% --- set-union ---
{{ /a /b /c }} {{ /b /c /d }} set-union length 4 eq (set-union: length) rt-ok clear
{{ /a /b /c }} {{ /b /c /d }} set-union /a set-member? (set-union: has a) rt-ok clear
{{ /a /b /c }} {{ /b /c /d }} set-union /d set-member? (set-union: has d) rt-ok clear
{{ }} {{ /a }} set-union length 1 eq (set-union: empty + non-empty) rt-ok clear
{{ }} {{ }} set-union length 0 eq (set-union: empty + empty) rt-ok clear

% --- set-intersection ---
{{ /a /b /c }} {{ /b /c /d }} set-intersection length 2 eq (set-intersection: length) rt-ok clear
{{ /a /b /c }} {{ /b /c /d }} set-intersection /b set-member? (set-intersection: has b) rt-ok clear
{{ /a /b /c }} {{ /b /c /d }} set-intersection /a set-member? not (set-intersection: no a) rt-ok clear
{{ /a }} {{ /b }} set-intersection length 0 eq (set-intersection: disjoint) rt-ok clear

% --- set-difference ---
{{ /a /b /c }} {{ /b /c /d }} set-difference length 1 eq (set-difference: length) rt-ok clear
{{ /a /b /c }} {{ /b /c /d }} set-difference /a set-member? (set-difference: has a) rt-ok clear
{{ /a /b /c }} {{ /b /c /d }} set-difference /b set-member? not (set-difference: no b) rt-ok clear
{{ /a /b }} {{ /a /b }} set-difference length 0 eq (set-difference: identical) rt-ok clear

% --- subset? ---
{{ /a /b }} {{ /a /b /c }} subset? (subset?: true) rt-ok clear
{{ /a /b /d }} {{ /a /b /c }} subset? not (subset?: false) rt-ok clear
{{ }} {{ /a /b /c }} subset? (subset?: empty is subset) rt-ok clear
{{ /a }} {{ /a }} subset? (subset?: equal is subset) rt-ok clear

% --- members ---
{{ /x /y /z }} members type /array-type eq (members: returns array) rt-ok clear
{{ /x /y /z }} members length 3 eq (members: correct length) rt-ok clear
{{ }} members length 0 eq (members: empty set) rt-ok clear

% --- set-from-array ---
[/a /b /c] set-from-array type /set-type eq (set-from-array: type) rt-ok clear
[/a /b /c] set-from-array length 3 eq (set-from-array: length) rt-ok clear
[/a /b /c] set-from-array /b set-member? (set-from-array: member) rt-ok clear
[] set-from-array length 0 eq (set-from-array: empty) rt-ok clear
[/a /a /b] set-from-array length 2 eq (set-from-array: dedup) rt-ok clear

% --- set-from-array accepts any hashable ---
[1 2 3] set-from-array length 3 eq (set-from-array: integers) rt-ok clear
[(hello) (world)] set-from-array length 2 eq (set-from-array: strings) rt-ok clear
[true false] set-from-array length 2 eq (set-from-array: booleans) rt-ok clear

% --- for-all ---
/cnt 0 def
{{ /a /b /c }} { pop /cnt cnt 1 add def } for-all
cnt 3 eq (for-all: visits 3 elements) rt-ok clear

{{ }} { pop } for-all
true (for-all: empty set is no-op) rt-ok clear

% --- eq (identity) ---
{{ /a /b }} dup eq (eq: same object) rt-ok clear
{{ /a /b }} {{ /a /b }} eq not (eq: different objects) rt-ok clear

% --- deep-eq ---
{{ /a /b /c }} {{ /c /b /a }} deep-eq (deep-eq: same elements, different order) rt-ok clear
{{ /a /b /c }} {{ /a /b }} deep-eq not (deep-eq: different length) rt-ok clear
{{ /a /b }} {{ /a /c }} deep-eq not (deep-eq: different elements) rt-ok clear
{{ }} {{ }} deep-eq (deep-eq: empty sets) rt-ok clear
{{ /a }} {{ /a }} deep-eq (deep-eq: singleton) rt-ok clear

% --- copy ---
{{ /a /b /c }} 4 set copy length 3 eq (copy: length matches) rt-ok clear
{{ /a /b /c }} 4 set copy /a set-member? (copy: member a) rt-ok clear
{{ /a /b /c }} 4 set copy /b set-member? (copy: member b) rt-ok clear
{{ /a /b /c }} 4 set copy /c set-member? (copy: member c) rt-ok clear

% --- copy read-only error ---
<< /read-only { clear true } >> { {{ /a }} {{ }}#r copy } try-catch
(copy: read-only target error) rt-ok clear

% --- length polymorphism ---
{{ /a /b /c /d /e }} length 5 eq (length: 5 elements) rt-ok clear

% --- save/restore basic ---
/sr-set {{ /a /b }} def
save                           % stack: save_obj
sr-set /c set-add pop          % mutates set (adds c), pops set copy
sr-set /c set-member?          % stack: save_obj, true
exch restore                   % swap save_obj to top, restore
(save/restore: c present inside save) rt-ok
sr-set /c set-member? not (save/restore: c gone after restore) rt-ok clear

% --- sad: set-add on read-only ---
<< /read-only { clear true } >> { {{ /a }}#r /b set-add } try-catch
(set-add: read-only error) rt-ok clear

% --- sad: set-remove on read-only ---
<< /read-only { clear true } >> { {{ /a }}#r /a set-remove } try-catch
(set-remove: read-only error) rt-ok clear

% --- sad: set with negative capacity ---
<< /range-check { clear true } >> { -1 set } try-catch
(set: negative capacity error) rt-ok clear

% --- sad: set with zero capacity (should work) ---
0 set length 0 eq (set: zero capacity ok) rt-ok clear

% --- sad: type mismatch errors ---
<< /type-check { clear true } >> { 42 /a set-add } try-catch
(set-add: type mismatch non-set) rt-ok clear
<< /type-check { clear true } >> { 42 {{ /a }} set-union } try-catch
(set-union: type mismatch) rt-ok clear

% --- boundary: singleton operations ---
{{ /a }} {{ /a }} set-union length 1 eq (boundary: union singleton same) rt-ok clear
{{ /a }} {{ /b }} set-intersection length 0 eq (boundary: intersection disjoint singletons) rt-ok clear
{{ /a }} {{ /a }} set-difference length 0 eq (boundary: difference self) rt-ok clear

% --- boundary: self operations ---
{{ /a /b /c }} dup set-union length 3 eq (boundary: union with self) rt-ok clear
{{ /a /b /c }} dup set-intersection length 3 eq (boundary: intersection with self) rt-ok clear
{{ /a /b /c }} dup set-difference length 0 eq (boundary: difference with self) rt-ok clear
{{ /a /b /c }} dup subset? (boundary: self is subset) rt-ok clear

% --- deep-eq with composite elements (O(n^2) scan path) ---
{{ [1 2] [3 4] }} {{ [3 4] [1 2] }} deep-eq
  (deep-eq: sets of arrays, different order) rt-ok clear
{{ [1 2] [3 4] }} {{ [1 2] [3 5] }} deep-eq not
  (deep-eq: sets of arrays, different content) rt-ok clear
{{ [1 2] }} {{ [1 2] }} deep-eq
  (deep-eq: singleton array elements) rt-ok clear
{{ [[1] [2]] }} {{ [[1] [2]] }} deep-eq
  (deep-eq: nested arrays in set) rt-ok clear
{{ << /a 1 >> }} {{ << /a 1 >> }} deep-eq
  (deep-eq: dict elements in set) rt-ok clear

% --- boundary: deep-eq with non-set ---
{{ /a }} [/a] deep-eq not (deep-eq: set vs array) rt-ok clear
{{ /a }} /a deep-eq not (deep-eq: set vs name) rt-ok clear

% --- boundary: deep-ne ---
{{ /a /b }} {{ /a /b }} deep-ne not (deep-ne: equal sets) rt-ok clear
{{ /a /b }} {{ /a /c }} deep-ne (deep-ne: different sets) rt-ok clear

% --- boundary: copy into self ---
{{ /a /b }} dup copy length 2 eq (copy: self-copy no-op) rt-ok clear

% --- boundary: set-from-array with packed ---
{ /a /b /c } set-from-array length 3 eq (set-from-array: from packed) rt-ok clear

