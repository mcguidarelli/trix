{{ true false }} length 2 eq (any-key: boolean set) rt-ok clear
{{ 3.14 2.71 }} length 2 eq (any-key: real set) rt-ok clear
{{ 1 /a (hello) true }} length 4 eq (any-key: mixed types) rt-ok clear
{{ 1 2 3 }} {{ 2 3 4 }} set-intersection length 2 eq (any-key: integer intersection) rt-ok clear
{{ 1 2 3 }} {{ 2 3 4 }} set-union length 4 eq (any-key: integer union) rt-ok clear
{{ 1 2 3 }} {{ 2 3 4 }} set-difference length 1 eq (any-key: integer difference) rt-ok clear
{{ 1 2 3 }} {{ 2 3 4 }} set-difference 1 set-member? (any-key: difference has 1) rt-ok clear
{{ 1 2 }} {{ 1 2 3 }} subset? (any-key: integer subset) rt-ok clear
{{ 1 2 3 }} members length 3 eq (any-key: integer members) rt-ok clear
{{ 1 2 3 }} 4 set-add 4 set-member? (any-key: integer add) rt-ok clear
{{ 1 2 3 }} 2 set-remove 2 set-member? not (any-key: integer remove) rt-ok clear
{{ 1 2 3 }} {{ 3 2 1 }} deep-eq (any-key: integer deep-eq) rt-ok clear
/cnt 0 def
{{ 10 20 30 }} { pop /cnt cnt 1 add def } for-all
cnt 3 eq (any-key: integer for-all) rt-ok clear

% --- stress: dynamic expansion ---
2 set
/s exch def
s /a set-add pop  s /b set-add pop  s /c set-add pop  s /d set-add pop
s /e set-add pop  s /f set-add pop  s /g set-add pop  s /h set-add pop
s length 8 eq (stress: dynamic expansion to 8) rt-ok clear

% --- stress: add/remove cycles ---
{{ /a /b /c }}
/cycle-set exch def
cycle-set /d set-add pop
cycle-set /a set-remove
cycle-set /e set-add pop
cycle-set /b set-remove
cycle-set length 3 eq (stress: add/remove cycles length) rt-ok
cycle-set /d set-member? (stress: add/remove has d) rt-ok
cycle-set /a set-member? not (stress: add/remove no a) rt-ok clear

