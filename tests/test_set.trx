{{ (alpha) (beta) (gamma) }} length 3 eq (string: set length) rt-ok clear
{{ (alpha) (beta) (gamma) }} (beta) set-member? (string: member) rt-ok clear
{{ (alpha) (beta) (gamma) }} (delta) set-member? not (string: non-member) rt-ok clear
{{ (alpha) (beta) }} (gamma) set-add (gamma) set-member? (string: add) rt-ok clear
{{ (alpha) (beta) (gamma) }} (beta) set-remove (beta) set-member? not (string: remove) rt-ok clear
{{ (hello) (world) }} {{ (world) (foo) }} set-union length 3 eq (string: union) rt-ok clear
{{ (hello) (world) }} {{ (world) (foo) }} set-intersection length 1 eq (string: intersection) rt-ok clear
{{ (a) (b) (c) }} {{ (c) (b) (a) }} deep-eq (string: deep-eq) rt-ok clear
[(a) (b) (c)] set-from-array length 3 eq (string: set-from-array) rt-ok clear
{{ (x) (y) }} members length 2 eq (string: members length) rt-ok clear

% --- string for-all yields strings (W07: members + `all`) ---
{{ (hello) }} members { type /string-type eq } all (string: for-all yields string) rt-ok clear

