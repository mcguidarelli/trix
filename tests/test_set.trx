[1l 2l 3l 4l 5l 6l 7l 8l 9l 10l 11l 12l 13l 14l 15l 16l 17l 18l 19l 20l] set-from-array
{{ 5l 15l }} symmetric-difference length 18 eq
(sym-diff: asymmetric 20 vs 2) rt-ok clear

