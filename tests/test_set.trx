% ====================================================================
% SECTION: set-filter — set proc -- set'
% ====================================================================

% --- basic: filter names ---
{{ /a /b /c /d }} { dup /b ne exch /c ne and } set-filter length 2 eq
(set-filter: keep 2 of 4) rt-ok clear

