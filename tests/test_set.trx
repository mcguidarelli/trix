{{ /a /b /c /d /e /f /g /h /i /j }} {{ /k /l /m /n /o /p /q /r /s /t }} set-union
length 20 eq (stress: union of 10+10) rt-ok clear

% --- stress: for-all with exit ---
/exit-count 0 def
{{ /a /b /c /d /e }} { pop /exit-count exit-count 1 add def exit-count 3 eq { exit } if } for-all
exit-count 3 eq (stress: for-all with exit at 3) rt-ok clear

% --- stress: large intersection ---
{{ /a /b /c /d /e /f /g /h /i /j }} {{ /f /g /h /i /j /k /l /m /n /o }} set-intersection
length 5 eq (stress: large intersection) rt-ok clear

% --- stress: large difference ---
{{ /a /b /c /d /e /f /g /h /i /j }} {{ /f /g /h /i /j /k /l /m /n /o }} set-difference
length 5 eq (stress: large difference) rt-ok clear

