% ====================================================================
% test_logic_global_results.trx -- find-all/find-n/aggregate accept
% global-VM composite results
% ====================================================================
% Pre 2026-05-10: find-all / find-n / aggregate rejected non-persistable
% types (Array, String, Dict, Set, Tagged, Curry, Thunk, Record, Packed)
% with /type-check.  Documented as the "scalar restriction" -- callers
% had to deref to extract scalars.
%
% Post 2026-05-10: composites allocated in GLOBAL VM via ${...} survive
% the per-alternative save/restore cycle (global region is journal-
% skipped + R6 pointer-hygiene means transitively restore-safe).  The
% Object::is_persistable_now(trx) check honours this.
%
% This test verifies:
%   1. Local composites still raise /type-check (existing behaviour
%      preserved).
%   2. Global composites (allocated via ${...}) are accepted and
%      collected correctly into the result array.
%   3. Same applies to find-n and aggregate (init-acc check).
% ====================================================================

% rt-ok counts failures in a restore-immune slot -- string byte writes
% are unjournaled, so the count survives assertions made inside save
% scopes, and the 1-byte string lives in LOCAL VM, invisible to the
% global-heap/gc-counter probes some files assert on.  The file THROWS
% at EOF: test_all counts a file as failed only when its run throws,
% so print-only failures would slip the suite verdict.
/rt-fails 1 string def
rt-fails 0 16#0#b put
/rt-ok { exch { = } { (FAILED: ) print = rt-fails 0  rt-fails 0 get /integer-type cast 1 add dup 255 gt { pop 255 } if /byte-type cast  put } if-else } def

% --------------------------------------------------------------------
% SECTION 1: LOCAL composite still rejected (regression guard)
% --------------------------------------------------------------------
% Each alt pushes a LOCAL Array.  find-all calls is_persistable_now ->
% false (uses_vm + !global) -> /type-check.

[
    { [ 1 2 3 ] }       % local Array -- not persistable
] /alts-local exch def

{ alts-local find-all } try /type-check eq         (1: local array rejects with /type-check) rt-ok clear

% --------------------------------------------------------------------
% SECTION 2: GLOBAL Array result accepted
% --------------------------------------------------------------------
% Each alt allocates an Array via ${...} (-> global VM).  is_persistable_now
% returns true (uses_vm + global) -> result kept.  find-all collects all
% three into the result array.

[
    { ${ [ 1 2 3 ] } }       % global Array #1
    { ${ [ 4 5 6 ] } }       % global Array #2
    { ${ [ 7 8 9 ] } }       % global Array #3
] /alts-global-arrays exch def

alts-global-arrays find-all /results-arrays exch def

results-arrays length 3 eq                          (2: 3 results collected) rt-ok
results-arrays 0 get length 3 eq                    (2: result[0] is array of 3 elements) rt-ok
results-arrays 0 get 0 get 1 eq                     (2: result[0][0] = 1) rt-ok
results-arrays 1 get 1 get 5 eq                     (2: result[1][1] = 5) rt-ok
results-arrays 2 get 2 get 9 eq                     (2: result[2][2] = 9) rt-ok

% --------------------------------------------------------------------
% SECTION 3: GLOBAL String result accepted
% --------------------------------------------------------------------

[
    { (alpha)#$ }           % global String
    { (beta)#$ }
    { (gamma)#$ }
] /alts-global-strings exch def

alts-global-strings find-all /results-strings exch def

results-strings length 3 eq                         (3: 3 string results collected) rt-ok
results-strings 0 get (alpha) eq                    (3: result[0] = "alpha") rt-ok
results-strings 1 get (beta) eq                     (3: result[1] = "beta") rt-ok
results-strings 2 get (gamma) eq                    (3: result[2] = "gamma") rt-ok

% --------------------------------------------------------------------
% SECTION 4: GLOBAL Tagged result accepted
% --------------------------------------------------------------------
% Each alt builds a Tagged in global VM via ${...}.  Tag is a Name; the
% Tagged value is an inline scalar wrapped in a Tagged Object.

[
    { ${ 100 /score tag } }
    { ${ 200 /score tag } }
] /alts-global-tagged exch def

alts-global-tagged find-all /results-tagged exch def

results-tagged length 2 eq                          (4: 2 tagged results) rt-ok
results-tagged 0 get tag-name /score eq             (4: result[0] tag-name = /score) rt-ok
results-tagged 0 get tag-value 100 eq               (4: result[0] tag-value = 100) rt-ok
results-tagged 1 get tag-value 200 eq               (4: result[1] tag-value = 200) rt-ok

% --------------------------------------------------------------------
% SECTION 5: find-n with GLOBAL composite results
% --------------------------------------------------------------------

[
    { ${ [ 10 ] } }
    { ${ [ 20 ] } }
    { ${ [ 30 ] } }
    { ${ [ 40 ] } }
] /alts-fn exch def

2 alts-fn find-n /results-fn exch def
results-fn length 2 eq                              (5: find-n collected 2 results) rt-ok
results-fn 0 get 0 get 10 eq                        (5: find-n result[0] = [10]) rt-ok
results-fn 1 get 0 get 20 eq                        (5: find-n result[1] = [20]) rt-ok

% --------------------------------------------------------------------
% SECTION 6: aggregate accepts GLOBAL composite as init accumulator
% --------------------------------------------------------------------
% The init-acc check goes through is_persistable_now.  A global Array
% as initial accumulator must be accepted; a local Array must be
% rejected (preserved existing behaviour).
%
% Reducer here just discards the new alt-result and returns the
% (unchanged) accumulator -- proves the init check works without
% requiring the reducer to also produce global composites (that path
% needs append/etc. to honour m_curr_alloc_global, separate audit).

% Local init: rejected.  Reducer never runs (init check fires first).
{ [] { pop } [{ 1 }] aggregate }
    try /type-check eq                              (6: local init array rejected) rt-ok clear

% Global init: accepted.  Reducer pops alt result, keeps acc unchanged.
% Result = init array unchanged.
${ [ 99 ] } /init-global exch def
init-global { pop } [{ 1 } { 2 } { 3 }] aggregate /agg-result exch def

agg-result length 1 eq                              (6: agg result is the unchanged init [99]) rt-ok
agg-result 0 get 99 eq                              (6: agg result[0] = 99) rt-ok

% --------------------------------------------------------------------
% SECTION 7: vm-global-gc after find-all + composite results
% --------------------------------------------------------------------
% Regression guard for the save.inl::gc_walk_chain misaligned-cast bug
% fixed 2026-05-10.  Pre-fix: find-all leaves DictEntry-flavored save
% journal entries pointing at the per-alt scratch dicts; the subsequent
% vm-global-gc walks the journal via gc_walk_chain, which reinterpret_cast
% an Entry::m_data pointer (at byte offset 11 of a 4-aligned Entry) to
% Dict::DictEntry* / SetEntry* / Object* -- UB on alignof(8) Object,
% UBSan fired.  Fix: memcpy to a local at the access site.

vm-global-gc                                        (7: vm-global-gc completes after find-all+composites) = pop

rt-fails 0 get /integer-type cast 0 gt { /rt-assertions-failed throw } if
(test_logic_global_results: ALL TESTS PASSED) =
(__test_ok__) =
