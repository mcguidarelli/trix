% ====================================================================
% test_shim_matrix.trx -- operand-type x VM-region matrix for the
% shim-dispatched operators (Phase-3 P1).
%
% Every op is driven through each accepted operand-type arm (operands
% type-matched per the AllMustMatch contract), once in the local VM and
% once under `true set-global` so ExtValue (l/ul/d/a) and WideValue
% (q/uq) traffic lands in the global region.  Sad arms assert
% /type-check on a mismatched pair and an out-of-domain operand.
% ====================================================================

% rt-ok counts failures in a restore-immune slot -- string byte writes
% are unjournaled, so the count survives assertions made inside save
% scopes, and the 1-byte string lives in LOCAL VM, invisible to the
% global-heap/gc-counter probes some files assert on.  The file THROWS
% at EOF: test_all counts a file as failed only when its run throws,
% so print-only failures would slip the suite verdict.
/rt-fails 1 string def
rt-fails 0 16#0#b put
/rt-ok { exch { = } { (FAILED: ) print = rt-fails 0  rt-fails 0 get /integer-type cast 1 add dup 255 gt { pop 255 } if /byte-type cast  put } if-else } def

% a b feq: compare in the double domain with 1e-3 absolute tolerance
% (covers Real-arm precision over the value range used here, O(0.1..30)).
/feq {
    /double-type cast exch /double-type cast
    sub abs 1.0e-3d le
} def

% ---- sin ----
0.5 sin 0.47942553860420301d feq (sin: r arm) rt-ok clear
0.5d sin 0.47942553860420301d feq (sin: d arm) rt-ok clear
true set-global
0.5 sin 0.47942553860420301d feq (sin: r arm g) rt-ok clear
0.5d sin 0.47942553860420301d feq (sin: d arm g) rt-ok clear
false set-global

