% --- isqrt math property: N^2 -> N ---
/isqrt-ok true def
1 1 50 { dup dup mul isqrt eq isqrt-ok and /isqrt-ok exch def } for
isqrt-ok (isqrt: N^2 -> N for 1..50) rt-ok clear

% --- isqrt math property: N^2-1 -> N-1 ---
/isqrt-ok2 true def
2 1 50 { dup dup mul 1 sub isqrt exch 1 sub eq isqrt-ok2 and /isqrt-ok2 exch def } for
isqrt-ok2 (isqrt: N^2-1 -> N-1 for 2..50) rt-ok clear

% --- isqrt long near-boundary (values above 2^53 where double loses precision) ---
9007199254740992l isqrt 94906265l eq (isqrt: 2^53 long) rt-ok clear
9007199254740993l isqrt 94906265l eq (isqrt: 2^53+1 long) rt-ok clear

% --- capitalize output type ---
(hello) capitalize type /string-type eq (capitalize: output is string) rt-ok clear
() capitalize type /string-type eq (capitalize: empty output is string) rt-ok clear

% --- capitalize extended ASCII ---
(~test) capitalize (~test) eq (capitalize: tilde unchanged) rt-ok clear

% --- count-substring non-overlapping guarantee ---
(aaaaaa) (aaa) count-substring 2 eq (count-sub: 6 a's / 3-char = 2 non-overlap) rt-ok clear
(aaaaa) (aa) count-substring 2 eq (count-sub: 5 a's / 2-char = 2 non-overlap) rt-ok clear

% --- count-substring case sensitivity ---
(Hello hello HELLO) (hello) count-substring 1 eq (count-sub: case sensitive) rt-ok clear

% --- count-substring sub = entire haystack ---
(abc) (abc) count-substring 1 eq (count-sub: sub = haystack) rt-ok clear

% --- nCr sequential stress ---
/ncr-ok true def
0 1 10 { 10 exch nCr 0 ge ncr-ok and /ncr-ok exch def } for
ncr-ok (nCr: 10C0 through 10C10 all valid) rt-ok clear

% --- nCr large n small r ---
1000 2 nCr 499500 eq (nCr: 1000C2 = 499500) rt-ok clear
1000l 3l nCr 166167000l eq (nCr: 1000C3 long) rt-ok clear

(tests/test_tier1_gaps.trx: all tests passed) =
rt-fails 0 get /integer-type cast 0 gt { /rt-assertions-failed throw } if
(__test_ok__) =
