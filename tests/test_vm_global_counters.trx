% ====================================================================
% test_vm_global_counters.trx -- live counter status keys
% ====================================================================
% Verifies the //:status:vm-global-num-alloc and //:status:vm-global-num-free
% keys.  They are O(1) live counters maintained by:
%   - num-alloc: m_gvm_user_block_count, ++/-- in gvm_alloc / gvm_free.
%   - num-free:  m_gvm_free_block_count, ++/-- in the four lower-level
%                free-list mutators (gvm_free_list_insert/remove and
%                gvm_fastbin_insert/unlink).
%
% Cross-checks num-free against vm-global-info's /free-blocks (the O(N)
% heap walk) at every step.  Note: vm-global-info /live-blocks counts
% the gc-scratch too whereas m_gvm_user_block_count (num-alloc) does
% not -- only cross-check /free-blocks against num-free.
% ====================================================================

% rt-ok counts failures in a restore-immune slot -- string byte writes
% are unjournaled, so the count survives assertions made inside save
% scopes, and the 1-byte string lives in LOCAL VM, invisible to the
% global-heap/gc-counter probes some files assert on.  The file THROWS
% at EOF: test_all counts a file as failed only when its run throws,
% so print-only failures would slip the suite verdict.
/rt-fails 1 string def
rt-fails 0 16#0#b put
/rt-ok { exch { = } { (FAILED: ) print = rt-fails 0  rt-fails 0 get /integer-type cast 1 add dup 255 gt { pop 255 } if /byte-type cast  put } if-else } def

% Pre-intern slots locally so the literal names don't get interned
% globally under set-global true (interning bumps num-alloc).
/sink null def
/anchor null def
/b-slot null def
/c-slot null def

% ====================================================================
% SECTION 1: startup baseline
% ====================================================================
% Pre-warm the lazy GC scratch so the first user alloc has already
% fired.  After this, the scratch block is in place but is NOT counted
% by m_gvm_user_block_count (the live-user counter excludes gcscratch).
${ 8 dict } /pre-warm-dict exch def

% Free the pre-warm dict back, then test baseline.  Use vm-global-gc
% to reclaim it.
/pre-warm-dict null def
vm-global-gc pop

//:status:vm-global-num-alloc 0 eq
    (s1: num-alloc back to zero after pre-warm-dict reclaim) rt-ok
//:status:vm-global-num-free 0 eq
    (s1: num-free zero after reclaim)                        rt-ok

% Cross-check against vm-global-info.
vm-global-info /info1 exch def
info1 /free-blocks get //:status:vm-global-num-free eq
    (s1: vm-global-info /free-blocks == num-free)            rt-ok

% ====================================================================
% SECTION 2: alloc-only growth (no frees)
% ====================================================================
% Allocate three globals.  num-alloc should advance by 3; num-free
% stays at 0 (no frees yet -- each alloc bump-extends m_vm_global).

true set-global
12345l /sink exch def
99l /anchor exch def
1000l /b-slot exch def
false set-global

//:status:vm-global-num-alloc 3 eq
    (s2: num-alloc +3 after three Long allocs)               rt-ok
//:status:vm-global-num-free 0 eq
    (s2: num-free still zero (allocs bump m_vm_global))      rt-ok

vm-global-info /info2 exch def
info2 /free-blocks get //:status:vm-global-num-free eq
    (s2: vm-global-info /free-blocks agrees)                 rt-ok

% ====================================================================
% SECTION 3: free a mid block -- num-free goes up
% ====================================================================
% Layout (low->high): b-slot, anchor, sink.  m_vm_global = b-slot start.
% Free anchor (mid block): forward neighbour sink (live), backward
% neighbour b-slot (live) -- no coalesce.  anchor lands on the free
% list / fastbin.

/anchor 0 def

//:status:vm-global-num-alloc 2 eq
    (s3: num-alloc -1 after mid free)                        rt-ok
//:status:vm-global-num-free 1 eq
    (s3: num-free +1 (anchor on the free list))              rt-ok

vm-global-info /info3 exch def
info3 /free-blocks get //:status:vm-global-num-free eq
    (s3: free-blocks agrees after mid free)                  rt-ok

% ====================================================================
% SECTION 4: free top block -- top-edge advance, num-free returns to 0
% ====================================================================
% b-slot is at m_vm_global (lowest addr).  Free it.  Forward neighbour
% is anchor (FREE) -> forward coalesce.  Merged block is at m_vm_global
% -> top-edge advance: m_vm_global moves up by b-slot + anchor.  Free
% list ends empty.

/b-slot 0 def

//:status:vm-global-num-alloc 1 eq
    (s4: num-alloc -1 after top free + coalesce)             rt-ok
//:status:vm-global-num-free 0 eq
    (s4: num-free back to 0 (coalesce + top-edge advance))   rt-ok

vm-global-info /info4 exch def
info4 /free-blocks get //:status:vm-global-num-free eq
    (s4: free-blocks agrees)                                 rt-ok

% Free sink to return to baseline.
/sink 0 def

//:status:vm-global-num-alloc 0 eq
    (s4: num-alloc back to zero)                             rt-ok
//:status:vm-global-num-free 0 eq
    (s4: num-free still zero)                                rt-ok

% NOTE on snapshot round-trip:
% Snapshot+thaw within a single .trx process is impractical: thaw
% replaces the entire VM state.  The run_snapshot_tests.sh suite
% exercises the snapshot pathway end-to-end (write in process A, thaw
% in process B); the new gvm_free_block_count field travels the same
% path as the existing gvm_user_block_count.  Snapshot serialization
% is covered there.

% ====================================================================
% SECTION 5: heavy churn -- alloc/free in a loop
% ====================================================================
% Allocate 20 globals then free them all.  Counters must net to 0.
% This exercises the free-list mutator helpers many times.

/churn null def
0 1 19 {
    pop
    true set-global
    42l /churn exch def
    false set-global
    /churn 0 def
} for

vm-global-gc pop
//:status:vm-global-num-alloc 0 eq
    (s5: num-alloc back to zero after 20-iter churn)         rt-ok
//:status:vm-global-num-free 0 eq
    (s5: num-free back to zero after 20-iter churn)          rt-ok

rt-fails 0 get /integer-type cast 0 gt { /rt-assertions-failed throw } if
(__test_ok__) =
