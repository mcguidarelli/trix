% test_sched_interactions.trx -- the scheduler seam matrix.
%
% ENGINE BUGS #10-#13 all lived on seams BETWEEN subsystems that were
% individually green: scheduler x stdin, timer x reader-slot,
% restore x mailbox, death x registrations.  This file walks the park
% states x disruptive events grid: park a coroutine in every blocking
% state the script surface can reach, fire a disruptive event while it
% is parked (save/restore, vm-global-gc, sibling kill, kill-the-parked,
% suspend/resume), then prove the wakeup still happens -- and run the
% scheduler invariant validator (inside vm-validate) after every
% section, so a corrupted-but-not-yet-hung state fails here, not in a
% downstream wedge.  Stdin park states need a tty and live in
% tests/run_pty_tests.sh (S1/S2/S6-S8).
%
% Conventions: rt-ok counts failures and the file THROWS at EOF (a
% print-only rt-ok would slip past test_all's try wrapper).  Flags
% cross actor/restore boundaries as sl=0 one-slot arrays written with
% put-persist.  Every spawn is followed by a bootstrap yield so child
% frame dicts allocate below any save barrier taken later
% (Save::restore rejects above-barrier frame dicts).

/rt-fails 1 string def
rt-fails 0 16#0#b put
/rt-ok { exch { = } { (FAILED: ) print = rt-fails 0  rt-fails 0 get /integer-type cast 1 add dup 255 gt { pop 255 } if /byte-type cast  put } if-else } def

% Run the full integrity validator (heap + scheduler invariants).
/vm-ok { /vm-validate query-status } def

% Bounded wait: yield up to 300 x 10ms until slot 0 of arr equals val.
% Returns nothing; the caller re-checks and asserts.  Never hangs the
% suite on a regression -- the assert just fails after ~3s.
/wait-flag { |arr val|#2
    0 1 300 {
        pop
        arr 0 get val eq { exit } if
        10 coroutine-sleep
    } for
} def

% ====================================================================
% SECTION 1: recv-parked x nested save/restore, then send
% (test_actor S76 covers one level; this parks under TWO levels)
% ====================================================================

/got 1 array def
got 0 0 put
[ { actor-recv  got 0  3 -1 roll  put-persist } actor-spawn /a exch def
0 coroutine-sleep
save
save
restore
restore
7 a actor-send
got 7 wait-flag
got 0 get 7 eq      (recv-park: survives nested save/restore) rt-ok
vm-ok               (recv-park: validator after nested restore) rt-ok  clear

% ====================================================================
% SECTION 2: recv-parked x vm-global-gc, then send
% ====================================================================

/got 1 array def
got 0 0 put
[ { actor-recv  got 0  3 -1 roll  put-persist } actor-spawn /a exch def
0 coroutine-sleep
vm-global-gc pop
8 a actor-send
got 8 wait-flag
got 0 get 8 eq      (recv-park: survives vm-global-gc) rt-ok
vm-ok               (recv-park: validator after gc) rt-ok  clear

% ====================================================================
% SECTION 3: recv-parked x sibling kill (death scrub must not disturb
% an unrelated parked reader), then send
% ====================================================================

/got 1 array def
got 0 0 put
[ { actor-recv  got 0  3 -1 roll  put-persist } actor-spawn /a exch def
[ { actor-recv pop } actor-spawn /victim exch def
0 coroutine-sleep
victim coroutine-kill
9 a actor-send
got 9 wait-flag
got 0 get 9 eq      (recv-park: survives sibling kill) rt-ok
vm-ok               (recv-park: validator after sibling kill) rt-ok  clear

% ====================================================================
% SECTION 4: kill THE recv-parked actor -- registration must vanish;
% a later send is a silent drop; validator stays clean
% ====================================================================

[ { actor-recv pop } actor-spawn /a exch def
0 coroutine-sleep
a coroutine-kill
a coroutine-status /dead eq   (recv-park: killed parked reader is dead) rt-ok
10 a actor-send               % silent drop on dead target (documented)
vm-ok               (recv-park: validator after killing parked reader) rt-ok  clear

% ====================================================================
% SECTION 5: send-parked (capacity-4 mailbox) x save/restore, then
% drain -- the parked sender must finish its burst
% ====================================================================

/sdone 1 array def
sdone 0 0 put
/drained 1 array def
drained 0 0 put
/hold 1 array def
hold 0 0 put
[ {
    { hold 0 get 0 eq } { 10 coroutine-sleep } while
    0 1 7 { pop actor-recv pop drained 0 drained 0 get 1 add put-persist } for
} 4 actor-spawn-capacity /r exch def
[ r {
    /tgt exch def
    0 1 7 { tgt actor-send }  for
    sdone 0 1 put-persist
} actor-spawn pop
50 coroutine-sleep                     % sender fills 4 slots and parks
save restore
hold 0 1 put
sdone 1 wait-flag
drained 8 wait-flag                     % wait for the RECEIVER to drain, not just the sender (cf. SECTION 6)
sdone 0 get 1 eq    (send-park: parked sender finishes after restore) rt-ok
drained 0 get 8 eq  (send-park: all 8 messages drained) rt-ok
vm-ok               (send-park: validator) rt-ok  clear

% ====================================================================
% SECTION 6: kill the send-parked sender -- receiver still drains the
% queued messages; no phantom wake; validator clean (#13 sender shape)
% ====================================================================

/drained 1 array def
drained 0 0 put
/hold 1 array def
hold 0 0 put
[ {
    { hold 0 get 0 eq } { 10 coroutine-sleep } while
    0 1 3 { pop actor-recv pop drained 0 drained 0 get 1 add put-persist } for
} 4 actor-spawn-capacity /r exch def
[ r { /tgt exch def 0 1 7 { tgt actor-send } for } actor-spawn /s exch def
50 coroutine-sleep                     % sender parked with 4 queued
s coroutine-kill
s coroutine-status /dead eq   (send-park: killed parked sender is dead) rt-ok
vm-ok               (send-park: validator right after sender kill) rt-ok
hold 0 1 put
drained 4 wait-flag
drained 0 get 4 eq  (send-park: receiver drains the 4 queued messages) rt-ok
vm-ok               (send-park: validator after drain past dead sender) rt-ok  clear

% ====================================================================
% SECTION 7: timed sleeper x save/restore -- still wakes
% ====================================================================

/woke 1 array def
woke 0 0 put
[ { 60 coroutine-sleep woke 0 1 put-persist } actor-spawn pop
0 coroutine-sleep
save restore
woke 1 wait-flag
woke 0 get 1 eq     (timed: wakes through save/restore) rt-ok
vm-ok               (timed: validator) rt-ok  clear

% ====================================================================
% SECTION 8: timed sleeper x suspend/resume -- remaining delta honored
% ====================================================================

/woke 1 array def
woke 0 0 put
[ { 80 coroutine-sleep woke 0 1 put-persist } actor-spawn /t exch def
0 coroutine-sleep
t coroutine-suspend
t coroutine-status /suspended eq   (timed: suspended status) rt-ok
50 coroutine-sleep                 % let the original wake time pass partially
woke 0 get 0 eq     (timed: suspended sleeper does not wake) rt-ok
t coroutine-resume
woke 1 wait-flag
woke 0 get 1 eq     (timed: resumed sleeper wakes) rt-ok
vm-ok               (timed: validator after suspend/resume) rt-ok  clear

% ====================================================================
% SECTION 9: kill a timed sleeper -- timer list stays clean
% ====================================================================

[ { 5000 coroutine-sleep } actor-spawn /t exch def
0 coroutine-sleep
t coroutine-kill
t coroutine-status /dead eq   (timed: killed sleeper dead) rt-ok
vm-ok               (timed: validator after killing timer node) rt-ok  clear

% ====================================================================
% SECTION 10: pipe read-parked x save/restore, then put
% ====================================================================

/got 1 array def
got 0 0 put
4 pipe-buffer /buf exch def
[ buf { pipe-get { got 0 3 -1 roll put-persist } if } coroutine-launch pop
0 coroutine-sleep
save restore
42 buf pipe-put
got 42 wait-flag
got 0 get 42 eq     (pipe-read: survives save/restore) rt-ok
buf pipe-close
vm-ok               (pipe-read: validator) rt-ok  clear

% ====================================================================
% SECTION 11: kill the pipe read-parked consumer (#13 pipe shape) --
% the producer side must remain usable; validator clean
% ====================================================================

4 pipe-buffer /buf exch def
[ buf { pipe-get { pop } if } coroutine-launch /c exch def
0 coroutine-sleep
c coroutine-kill
c coroutine-status /dead eq   (pipe-read: killed parked consumer dead) rt-ok
vm-ok               (pipe-read: validator after consumer kill) rt-ok
43 buf pipe-put               % no parked reader anymore: plain enqueue
buf pipe-close
vm-ok               (pipe-read: validator after put+close) rt-ok  clear

% ====================================================================
% SECTION 12: pipe write-parked (capacity 1, second put blocks) x
% save/restore, then drain -- writer completes
% ====================================================================

/wdone 1 array def
wdone 0 0 put
1 pipe-buffer /buf exch def
[ buf { /b exch def 1 b pipe-put 2 b pipe-put wdone 0 1 put-persist } coroutine-launch pop
0 coroutine-sleep
50 coroutine-sleep                 % writer parks on the second put
save restore
buf pipe-get { pop } if            % frees a slot -> wakes parked writer
wdone 1 wait-flag
wdone 0 get 1 eq    (pipe-write: parked writer completes after restore) rt-ok
buf pipe-get { 2 eq (pipe-write: second item delivered) rt-ok } if
buf pipe-close
vm-ok               (pipe-write: validator) rt-ok  clear

% ====================================================================
% SECTION 13: kill the pipe write-parked producer -- reader drains
% what was queued; validator clean
% ====================================================================

1 pipe-buffer /buf exch def
[ buf { /b exch def 1 b pipe-put 2 b pipe-put } coroutine-launch /w exch def
0 coroutine-sleep
50 coroutine-sleep                 % writer parked on second put
w coroutine-kill
w coroutine-status /dead eq   (pipe-write: killed parked writer dead) rt-ok
vm-ok               (pipe-write: validator after writer kill) rt-ok
buf pipe-get { 1 eq (pipe-write: queued item survives writer death) rt-ok } if
buf pipe-close
vm-ok               (pipe-write: validator after drain) rt-ok  clear

% ====================================================================
% SECTION 14: await-parked x save/restore + vm-global-gc -- the
% awaiter gets the return value when the target finishes
% ====================================================================

/release 1 array def
release 0 0 put
/res 1 array def
res 0 0 put
[ { { release 0 get 0 eq } { 10 coroutine-sleep } while 77 } coroutine-launch /t exch def
[ t { coroutine-await res 0 3 -1 roll put-persist } coroutine-launch pop
0 coroutine-sleep
save restore
vm-global-gc pop
release 0 1 put
res 77 wait-flag
res 0 get 77 eq     (await: value delivered through restore+gc) rt-ok
vm-ok               (await: validator) rt-ok  clear

% ====================================================================
% SECTION 15: join-parked x target killed -- joiner observes the
% abnormal exit (null false), does not hang
% ====================================================================

/jdone 1 array def
jdone 0 0 put
[ { 5000 coroutine-sleep } coroutine-launch /t exch def
[ t { coroutine-join { pop } { pop } if-else jdone 0 1 put-persist } coroutine-launch pop
0 coroutine-sleep
t coroutine-kill
jdone 1 wait-flag
jdone 0 get 1 eq    (join: killed target releases the joiner) rt-ok
vm-ok               (join: validator) rt-ok  clear

% ====================================================================
% SECTION 16: the AWAITER is killed while parked, then the target
% finishes -- stale joiner link must have been scrubbed at death
% ====================================================================

/release 1 array def
release 0 0 put
[ { { release 0 get 0 eq } { 10 coroutine-sleep } while 5 } coroutine-launch /t exch def
[ t { coroutine-await pop } coroutine-launch /waiter exch def
0 coroutine-sleep
waiter coroutine-kill
vm-ok               (await: validator after awaiter kill -- joiner link scrubbed) rt-ok
release 0 1 put
t coroutine-join { pop } { pop } if-else   % reap the target ourselves
vm-ok               (await: validator after target completes sans awaiter) rt-ok  clear

% ====================================================================
% SECTION 17: recv-timeout window x save/restore inside the window --
% delivery within the window still lands; a quiet window times out
% and the actor re-arms cleanly (the tetrix 50ms input-loop shape)
% ====================================================================

/got 1 array def
got 0 0 put
/timeouts 1 array def
timeouts 0 0 put
[ {
    {
        400 actor-recv-timeout
        { got 0 3 -1 roll put-persist exit }
        { pop timeouts 0 timeouts 0 get 1 add put-persist } if-else
    } loop
} actor-spawn /a exch def
0 coroutine-sleep
save restore
30 coroutine-sleep
11 a actor-send
got 11 wait-flag
got 0 get 11 eq     (recv-timeout: delivery after restore inside window) rt-ok
vm-ok               (recv-timeout: validator) rt-ok  clear

/got 1 array def
got 0 0 put
/timeouts 1 array def
timeouts 0 0 put
[ {
    {
        40 actor-recv-timeout
        { got 0 3 -1 roll put-persist exit }
        { pop timeouts 0 timeouts 0 get 1 add put-persist } if-else
    } loop
} actor-spawn /a exch def
0 coroutine-sleep
save restore
120 coroutine-sleep                % let at least two quiet windows expire
save restore
12 a actor-send
got 12 wait-flag
got 0 get 12 eq     (recv-timeout: re-armed after quiet windows + restores) rt-ok
timeouts 0 get 1 ge (recv-timeout: at least one quiet window observed) rt-ok
vm-ok               (recv-timeout: validator after re-arm loop) rt-ok  clear

% ====================================================================
% SECTION 18: recv-match parked x save/restore -- non-matching message
% queues, matching message wakes
% ====================================================================

/got 1 array def
got 0 0 put
[ {
    { dup 100 ge } actor-recv-match  got 0  3 -1 roll  put-persist
    5000 coroutine-sleep               % stay alive so the mailbox can be probed
} actor-spawn /a exch def
0 coroutine-sleep
5 a actor-send                     % does not match; queues
save restore
150 a actor-send                   % matches
got 150 wait-flag
got 0 get 150 eq    (recv-match: matching send wakes through restore) rt-ok
a actor-mailbox-count 1 eq  (recv-match: non-matching message still queued) rt-ok
a coroutine-kill
vm-ok               (recv-match: validator) rt-ok  clear

% ====================================================================
% SECTION 19: suspended recv-parked actor x send -- no run while
% suspended; resume delivers
% ====================================================================

/got 1 array def
got 0 0 put
[ { actor-recv  got 0  3 -1 roll  put-persist } actor-spawn /a exch def
0 coroutine-sleep
a coroutine-suspend
13 a actor-send
50 coroutine-sleep
got 0 get 0 eq      (suspend: no processing while suspended) rt-ok
a coroutine-resume
got 13 wait-flag
got 0 get 13 eq     (suspend: resume delivers the queued message) rt-ok
vm-ok               (suspend: validator) rt-ok  clear

% ====================================================================
% SECTION 20: monitor x kill through a restore -- /down delivery wakes
% the parked monitoring actor
% ====================================================================

/mdone 1 array def
mdone 0 0 put
/victim-slot 1 array def
[ {
    [ { 5000 coroutine-sleep } actor-spawn /w exch def
    victim-slot 0 w put-persist
    w monitor pop
    actor-recv pop                 % parks until the /down message
    mdone 0 1 put-persist
} actor-spawn pop
50 coroutine-sleep                 % monitor registered, monitor parked
save restore
victim-slot 0 get coroutine-kill
mdone 1 wait-flag
mdone 0 get 1 eq    (monitor: /down wakes parked monitor through restore) rt-ok
vm-ok               (monitor: validator) rt-ok  clear

% ====================================================================
% SECTION 21: churn storm -- ping-pong actors under save/restore +
% gc + sibling kills; exact message accounting at the end
% ====================================================================

/pong-count 1 array def
pong-count 0 0 put
/ping-done 1 array def
ping-done 0 0 put
[ {
    { actor-recv /m exch def
      m /stop eq { exit } if
      pong-count 0 pong-count 0 get 1 add put-persist
    } loop
} actor-spawn /ponger exch def
[ ponger {
    /tgt exch def
    0 1 19 {
        pop 1 tgt actor-send
        5 coroutine-sleep
    } for
    /stop tgt actor-send
    ping-done 0 1 put-persist
} actor-spawn pop
0 coroutine-sleep
0 1 5 {
    pop
    save restore
    vm-global-gc pop
    [ { actor-recv pop } actor-spawn coroutine-kill
    10 coroutine-sleep
} for
ping-done 1 wait-flag
pong-count 20 wait-flag
ping-done 0 get 1 eq    (storm: pinger completed under churn) rt-ok
pong-count 0 get 20 eq  (storm: exactly 20 pongs delivered) rt-ok
vm-ok                   (storm: validator after churn) rt-ok  clear

% ====================================================================
% final integrity check
% ====================================================================

vm-ok
    (sched-interactions: final vm-validate) rt-ok

rt-fails 0 get /integer-type cast 0 gt { /sched-interactions-failed throw } if
(test_sched_interactions: ALL TESTS PASSED) =
(__test_ok__) =
