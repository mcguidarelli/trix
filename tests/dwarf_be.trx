% tests/dwarf_be.trx -- assert lib/dwarf.trx reads a BIG-ENDIAN ELF correctly.
% Fixture (a hand-built BE ELF64 + DWARF v4) is generated by
% tests/gen_dwarf_be_fixture.py; its path arrives as argv[0].  Every value
% checked here required a correct big-endian multi-byte read.
(lib/dwarf.trx) run

/rt-fails 1 string def
rt-fails 0 16#0#b put
/rt-ok { exch { = } { (FAILED: ) print = rt-fails 0  rt-fails 0 get /integer-type cast 1 add dup 255 gt { pop 255 } if /byte-type cast  put } if-else } def

/fixture command-line-args 0 get def
fixture dwarf-load /ctx exch def

ctx (g_be) dwarf-lookup /info exch def
info null eq not (be: g_be found) rt-ok clear
info /address get 4194624ul eq (be: address 0x400140 via big-endian u64) rt-ok clear

ctx info /type-offset get dwarf-layout /lay exch def
lay /kind get /struct eq (be: kind struct) rt-ok clear
lay /name get (BeProbe) eq (be: name BeProbe) rt-ok clear
lay /byte-size get 40 eq (be: byte-size 40 via data4 u32) rt-ok clear
/mem-list lay /members get def
mem-list length 5 eq (be: 5 members) rt-ok clear

/member-by {
    |nm|#+3
    /found null local-def
    0 1 mem-list length 1 sub { /i exch local-def /m mem-list i get local-def m /name get nm eq { /found m local-def } if } for
    found
} def

(uid) member-by /uid-m exch def
(amount) member-by /amount-m exch def
(count) member-by /count-m exch def
(ptr) member-by /ptr-m exch def
(mode) member-by /mode-m exch def

uid-m /offset get 0 eq (be: uid offset 0) rt-ok clear
uid-m /peek-type get /uinteger-type eq (be: uid typedef -> uinteger-type) rt-ok clear
amount-m /offset get 8 eq (be: amount offset 8) rt-ok clear
amount-m /peek-type get /double-type eq (be: amount -> double-type) rt-ok clear
count-m /offset get 16 eq (be: count offset 16) rt-ok clear
count-m /peek-type get /integer-type eq (be: count -> integer-type) rt-ok clear
ptr-m /offset get 24 eq (be: ptr offset 24) rt-ok clear
ptr-m /peek-type get /ulong-type eq (be: ptr pointer -> ulong-type) rt-ok clear
ptr-m /kind get /pointer eq (be: ptr kind pointer) rt-ok clear
mode-m /offset get 32 eq (be: mode offset 32) rt-ok clear
mode-m /peek-type get /uinteger-type eq (be: mode enum -> uinteger-type) rt-ok clear

% --- typed peek over a big-endian image: every field below required the
% --- decoder to prefix dw-endian (">") -- the one decode path the
% --- little-endian matrix cannot reach.  g_be = {0x11223344, 6.25, -123456,
% --- null, Mode 2} from the hand-built .data section.
ctx (g_be) dwarf-peek /bv exch def
bv is-record (be: peek g_be is a Record) rt-ok clear
bv null eq not {
    bv /uid get 287454020u eq (be: peek g_be.uid == 0x11223344u) rt-ok clear
    bv /amount get 6.25d eq (be: peek g_be.amount == 6.25d) rt-ok clear
    bv /count get -123456 eq (be: peek g_be.count == -123456 signed) rt-ok clear
    bv /ptr get 0ul eq (be: peek g_be.ptr == 0 (null)) rt-ok clear
    bv /mode get 2u eq (be: peek g_be.mode == Mode 2) rt-ok clear
} if

% --- L-23: big-endian bitfields -- the ONE BE decode path that was genuinely
% --- broken (extract-bits byte-assembly + bit-offset interpretation were
% --- LE-only).  BeBitsM (modern DW_AT_data_bit_offset) and BeBitsL (legacy
% --- MSB-based DW_AT_bit_offset) describe the SAME 0xDD 0xAA image; both must
% --- decode to hi=13, mid=-10 (signed), lo=42 big-endian. ---
ctx (g_be_bits_m) dwarf-peek /bm exch def
bm is-record (be: peek g_be_bits_m is a Record) rt-ok clear
bm null eq not {
    bm /hi get 13ul eq (be: g_be_bits_m.hi == 13u (modern, BE top 4 bits)) rt-ok clear
    bm /mid get -10l eq (be: g_be_bits_m.mid == -10 (modern, BE signed 6-bit)) rt-ok clear
    bm /lo get 42ul eq (be: g_be_bits_m.lo == 42u (modern, BE low 6 bits)) rt-ok clear
} if

ctx (g_be_bits_l) dwarf-peek /bl exch def
bl is-record (be: peek g_be_bits_l is a Record) rt-ok clear
bl null eq not {
    bl /hi get 13ul eq (be: g_be_bits_l.hi == 13u (legacy bit_offset)) rt-ok clear
    bl /mid get -10l eq (be: g_be_bits_l.mid == -10 (legacy bit_offset, signed)) rt-ok clear
    bl /lo get 42ul eq (be: g_be_bits_l.lo == 42u (legacy bit_offset)) rt-ok clear
} if

% --- L-23: big-endian array + recursive nested struct (BE-correct via dw-endian,
% --- now covered).  g_be_arr = {10,-20,30}; g_be_nest = {tag 7, inner{x -1, y 255}}. ---
ctx (g_be_arr) dwarf-peek /av exch def
av is-array (be: peek g_be_arr is an array) rt-ok clear
av null eq not {
    av length 3 eq (be: g_be_arr length 3) rt-ok clear
    av 0 get 10 eq (be: g_be_arr[0] == 10) rt-ok clear
    av 1 get -20 eq (be: g_be_arr[1] == -20 signed) rt-ok clear
    av 2 get 30 eq (be: g_be_arr[2] == 30) rt-ok clear
} if

ctx (g_be_nest) dwarf-peek /nv exch def
nv is-record (be: peek g_be_nest is a Record) rt-ok clear
nv null eq not {
    nv /tag get 7 eq (be: g_be_nest.tag == 7) rt-ok clear
    nv /inner get is-record (be: g_be_nest.inner is a nested Record) rt-ok clear
    nv /inner get /x get -1 eq (be: g_be_nest.inner.x == -1 signed) rt-ok clear
    nv /inner get /y get 255u eq (be: g_be_nest.inner.y == 255u) rt-ok clear
} if

% --- L-8: function lookup must read the subprogram's 8-byte big-endian low_pc. ---
ctx (be_fn) dwarf-lookup-fn /fn exch def
fn null eq not (be: dwarf-lookup-fn be_fn resolves) rt-ok clear
fn null eq not { fn /address get 4198400ul eq (be: be_fn low_pc == 0x401000 via BE addr) rt-ok clear } if

% --- L-5: out-of-line definition resolved through DW_AT_specification (a BE
% --- ref4) back to the declaration; g_be_spec's name+type come from the decl,
% --- its address + value from the def. ---
ctx (g_be_spec) dwarf-lookup /sp exch def
sp null eq not (be: dwarf-lookup g_be_spec (spec-resolved) resolves) rt-ok clear
sp null eq not { sp /address get 4194692ul eq (be: g_be_spec address 0x400184 from the def) rt-ok clear } if
ctx (g_be_spec) dwarf-peek /spv exch def
spv 305419896 eq (be: peek g_be_spec == 0x12345678 via spec-follow + BE int) rt-ok clear

(dwarf big-endian tests complete.) =
rt-fails 0 get /integer-type cast 0 gt { /rt-assertions-failed throw } if
(__test_ok__) =
