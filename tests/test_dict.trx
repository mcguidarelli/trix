% ====================================================================
% test_dict.trx -- Comprehensive Dict operation tests
% ====================================================================

% rt-ok counts failures in a restore-immune slot -- string byte writes
% are unjournaled, so the count survives assertions made inside save
% scopes, and the 1-byte string lives in LOCAL VM, invisible to the
% global-heap/gc-counter probes some files assert on.  The file THROWS
% at EOF: test_all counts a file as failed only when its run throws,
% so print-only failures would slip the suite verdict.
/rt-fails 1 string def
rt-fails 0 16#0#b put
/rt-ok { exch { = } { (FAILED: ) print = rt-fails 0  rt-fails 0 get /integer-type cast 1 add dup 255 gt { pop 255 } if /byte-type cast  put } if-else } def

% ====================================================================
% SECTION 1: Dict creation modes
% ====================================================================

% --- dict (ReadWriteFixed) ---
3 dict  type /dict-type eq  (dict-create: type is dict-type) rt-ok  clear
3 dict  dup max-length 3 eq  (dict-create: max-length is 3) rt-ok  clear
3 dict  dup length 0 eq  (dict-create: length starts at 0) rt-ok  clear

% --- dynamic-dict (ReadWriteDynamic) ---
3 dynamic-dict  type /dict-type eq  (dynamic-dict: type is dict-type) rt-ok  clear
3 dynamic-dict  dup max-length 3 eq  (dynamic-dict: max-length is 3) rt-ok  clear
3 dynamic-dict  dup length 0 eq  (dynamic-dict: length starts at 0) rt-ok  clear

% --- 0 dynamic-dict clamps to MinDynamicDictCapacity and stays growable ---
% A dynamic dict created empty would double a 0 base forever (i.e. never grow);
% create_dict clamps capacity 0 -> MinDynamicDictCapacity (4) so it is usable.
0 dynamic-dict  dup max-length 4 eq  (dynamic-dict: 0 capacity clamps to 4) rt-ok  clear
0 dynamic-dict  /d0cap exch def
0 1 5 { /i exch def d0cap i i 100 mul put } for
d0cap length 6 eq  (dynamic-dict: 0-cap grows past clamp to hold 6) rt-ok
d0cap 5 get 500 eq (dynamic-dict: 0-cap grown lookup d0cap[5]==500) rt-ok  clear
% control: a FIXED 0-capacity dict is left at 0 and rejects put (does not grow)
0 dict  dup max-length 0 eq  (dict: fixed 0-capacity stays 0) rt-ok  clear
{ 0 dict 1 2 put } try /dict-full eq  (dict: fixed 0-capacity rejects put) rt-ok  clear

% --- dict from mark << >> ---
<< /a 1 /b 2 >>  dup length 2 eq  (mark-dict: length is 2) rt-ok  clear
<< /a 1 /b 2 /c 3 >>  dup length 3 eq  (mark-dict: 3 entries) rt-ok  clear
<< >>  dup length 0 eq  (mark-dict: empty dict length 0) rt-ok  clear
<< /a 1 >>  type /dict-type eq  (mark-dict: type is dict-type) rt-ok  clear

% ====================================================================
% SECTION 2: Dict access operations
% ====================================================================

% --- def / load ---
3 dict begin
  /x 42 def
  /x load 42 eq  (def-load: basic def and load) rt-ok
end  clear

% --- store ---
3 dict begin
  /x 10 def
  /x 20 store
  /x load 20 eq  (store: updates existing value) rt-ok
end  clear

% --- store into current dict when key not found ---
3 dict begin
  /newkey 99 store
  /newkey load 99 eq  (store: new key goes to current dict) rt-ok
end  clear

% --- undef ---
3 dict begin
  /x 42 def
  current-dict /x known?  true eq  (undef: key exists before undef) rt-ok
  current-dict /x undef
  current-dict /x known?  false eq  (undef: key removed after undef) rt-ok
end  clear

% --- where ---
3 dict begin
  /x 42 def
  /x where  exch pop  true eq  (where: found returns true) rt-ok
end  clear
/nonexistent-key-12345 where  false eq  (where: missing returns false) rt-ok  clear

% --- known? ---
<< /a 1 /b 2 >>  dup /a known?  true eq  (known?: existing key) rt-ok  clear
<< /a 1 /b 2 >>  dup /c known?  false eq  (known?: missing key) rt-ok  clear

% --- get / put ---
<< /a 1 /b 2 >>  dup /a get 1 eq  (get: retrieve value) rt-ok  clear
<< /a 1 /b 2 >>  dup /b get 2 eq  (get: retrieve second value) rt-ok  clear

3 dict dup /x 42 put  dup /x get 42 eq  (put-get: roundtrip) rt-ok  clear
3 dict dup /x 10 put  dup /x 20 put  dup /x get 20 eq  (put: overwrite value) rt-ok  clear

% --- Error: get with missing key ---
{ << /a 1 >> /z get } try  /undefined eq  (get: missing key -> undefined) rt-ok  clear

% --- Error: put into ReadOnly dict ---
{ << /a 1 >>#r /b 2 put } try  /read-only eq  (put: readonly -> read-only) rt-ok  clear

% --- Error: undef from ReadOnly dict ---
{ << /a 1 >>#r /a undef } try  /read-only eq  (undef: readonly -> read-only) rt-ok  clear

% --- Error: def into ReadOnly dict on dictstack ---
{ << /a 1 >>#r begin /b 2 def } try  /read-only eq  (def: readonly dictstack -> read-only) rt-ok  clear-dictstack  clear

% ====================================================================
% SECTION 3: Dict modes
% ====================================================================

% --- ReadOnly: #r suffix ---
<< /a 1 >>#r  dup /a get 1 eq  (readonly: can read) rt-ok  clear
{ << /a 1 >>#r /b 2 put } try  /read-only eq  (readonly: put errors) rt-ok  clear
{ << /a 1 >>#r /a undef } try  /read-only eq  (readonly: undef errors) rt-ok  clear

% --- ReadWriteFixed: default << >> mode ---
% A fixed dict cannot grow beyond max-length.
% 1 dict creates a fixed dict with max-length = 1.
1 dict dup /a 1 put  dup max-length 1 eq  (fixed: max-length 1) rt-ok  clear

% Trying to add a second key to a max-length-1 fixed dict should error
1 dict dup /a 1 put  { /b 2 put } try  /dict-full eq  (fixed: put beyond capacity -> dict-full) rt-ok  clear

% --- ReadWriteDynamic: dynamic-dict or explicit ---
% A dynamic dict can grow beyond its initial max-length.
2 dynamic-dict
  dup /a 1 put
  dup /b 2 put
  dup /c 3 put
  dup length 3 eq  (dynamic: grows beyond initial max-length) rt-ok
clear

% --- make-readonly ---
3 dict dup /a 1 put  make-readonly
{ dup /b 2 put } try  /read-only eq  (make-readonly: dict becomes readonly) rt-ok  clear

% ====================================================================
% SECTION 4: Dict stack operations
% ====================================================================

% --- begin / end ---
count-dictstack  /base-depth exch def
3 dict begin
  count-dictstack  base-depth 1 add eq  (begin: dictstack grows by 1) rt-ok
end
count-dictstack  base-depth eq  (end: dictstack shrinks by 1) rt-ok  clear

% --- nested begin/end ---
count-dictstack  /base-depth2 exch def
3 dict begin
  3 dict begin
    count-dictstack  base-depth2 2 add eq  (nested-begin: dictstack grows by 2) rt-ok
  end
end
count-dictstack  base-depth2 eq  (nested-end: dictstack back to base) rt-ok  clear

% --- clear-dictstack ---
3 dict begin
3 dict begin
  clear-dictstack
  count-dictstack 3 eq  (clear-dictstack: resets to permanent dicts) rt-ok
clear

% --- Error: end with only systemdict+userdict ---
{ end } try  /dictstack-underflow eq  (end: underflow -> dictstack-underflow) rt-ok  clear

% --- current-dict ---
3 dict begin
  current-dict type /dict-type eq  (current-dict: returns dict) rt-ok
end  clear

% ====================================================================
% SECTION 5: Dict iteration
% ====================================================================

% --- for-all on dict ---
% Sum all values in a dict
/for-all-sum 0 def
<< /a 10 /b 20 /c 30 >>  { exch pop  for-all-sum add  /for-all-sum exch def } for-all
for-all-sum 60 eq  (for-all: sum of values) rt-ok  clear

% --- for-all: count entries ---
/cnt 0 def
<< /a 1 /b 2 /c 3 /d 4 >>  { pop pop  cnt 1 add  /cnt exch def } for-all
cnt 4 eq  (for-all: iterates all 4 entries) rt-ok  clear

% --- keys ---
<< /a 1 /b 2 /c 3 >>  keys
dup length 3 eq  (keys: returns 3 keys) rt-ok  clear

% --- values ---
<< /a 10 /b 20 /c 30 >>  values
dup length 3 eq  (values: returns 3 values) rt-ok
% Sum the values array
0 exch { add } for-all
60 eq  (values: sum is 60) rt-ok  clear

% --- for-all on empty dict ---
/empty-cnt 0 def
<< >>  { pop pop  empty-cnt 1 add  /empty-cnt exch def } for-all
empty-cnt 0 eq  (for-all: empty dict iterates 0 times) rt-ok  clear

% ====================================================================
% SECTION 6: Dict copy
% ====================================================================

% --- copy dict to another dict ---
<< /a 1 /b 2 >>  3 dict copy
  dup /a get 1 eq  (copy: entry a transferred) rt-ok
  dup /b get 2 eq  (copy: entry b transferred) rt-ok
  dup length 2 eq  (copy: length matches) rt-ok
clear

% --- copy into dynamic dict ---
<< /a 1 /b 2 /c 3 >>  1 dynamic-dict copy
  dup length 3 eq  (copy-dynamic: all entries copied) rt-ok
clear

% --- Error: copy into ReadOnly dict ---
{ << /a 1 >>  << /x 9 >>#r copy } try  /read-only eq  (copy: into readonly -> read-only) rt-ok  clear

% --- Error: copy into smaller fixed dict ---
{ << /a 1 /b 2 /c 3 >>  1 dict copy } try  /range-check eq  (copy: into smaller fixed -> range-check) rt-ok  clear

% ====================================================================
% SECTION 7: Per-save-level dict pool (CRITICAL)
% ====================================================================

% --- Basic pool usage via locals ---
% Locals create dicts via create_or_recycle and recycle on exit.
% After calling a proc with locals, the pool count should increase.
//:status:locals-pool-count  /pool-before exch def
10 20 { |a b| a b add } exec  pop
//:status:locals-pool-count  pool-before ge  (pool: locals recycled to pool) rt-ok  clear

% --- Multiple locals calls reuse pool ---
% Call a 2-arg locals proc several times; pool should stabilize.
{ |a b| a b add } /add2 exch def
1 2 add2 pop
3 4 add2 pop
5 6 add2 pop
//:status:locals-pool-count  /pool-after-reuse exch def
7 8 add2 pop
//:status:locals-pool-count  pool-after-reuse eq  (pool: reuse stabilizes count) rt-ok  clear

% --- Save/restore and dict pool ---
//:status:locals-pool-count  /pool-pre-save exch def
save
  10 20 { |a b| a b add } exec  pop
  //:status:locals-pool-count  pool-pre-save ge  (pool-save: pool grows inside save) rt-ok
restore
% After restore, save-level pools above are cleared
//:status:locals-pool-count  /pool-post-restore exch def
pool-post-restore pool-pre-save ge  (pool-save: pool count after restore >= pre-save) rt-ok  clear

% --- Nested save levels ---
save
  1 2 { |x y| x y add } exec  pop
  save
    3 4 { |p q| p q sub } exec  pop
  restore
  % inner save level pool cleared
  //:status:locals-pool-count  /pool-nested exch def
  pool-nested 0 ge  (pool-nested: pool count valid after inner restore) rt-ok
restore  clear

% --- Pool exhaustion: create more dicts than MaxDictPoolSize (16) ---
% Create 20 locals dicts of the same size, recycling each.
% This exercises the pool linked list (multiple entries per slot).
/pool-stress-ok true def
0 1 19 {
  pop
  1 2 { |a b| a b add } exec  pop
} for
pool-stress-ok  (pool-exhaust: 20 locals dicts no crash) rt-ok  clear

% --- Stress: many different sizes ---
1 { |a| a } exec  pop
1 2 { |a b| a b add } exec  pop
1 2 3 { |a b c| a b c add add } exec  pop
1 2 3 4 { |a b c d| a b c d add add add } exec  pop
1 2 3 4 5 { |a b c d e| a b c d e add add add add } exec  pop
true  (pool-sizes: multiple pool sizes no crash) rt-ok  clear

% ====================================================================
% SECTION 8: Local variables and dict pool interaction
% ====================================================================

% --- Basic locals ---
10 20 { |a b| a b add } exec  30 eq  (locals: basic add) rt-ok  clear

% --- Locals dict is recycled after proc exits ---
//:status:locals-pool-count  /pool-pre exch def
99 { |x| x } exec  pop
//:status:locals-pool-count  pool-pre ge  (locals-recycle: pool count >= before) rt-ok  clear

% --- Nested locals ---
10 { |outer| 20 { |inner| outer inner add } exec } exec
30 eq  (nested-locals: outer+inner) rt-ok  clear

% --- Locals variable not visible outside ---
{ 42 { |secret| secret } exec  pop  secret } try  /undefined eq  (locals: not visible outside) rt-ok  clear

% --- Locals with save/restore ---
save
  99 { |val| val 1 add } exec  100 eq  (locals-save: works inside save) rt-ok
restore  clear

% ====================================================================
% SECTION 9: Dict with ExtValue values (Long)
% ====================================================================

<< /a 42l /b 99l >>  dup /a get 42l eq  (extvalue-dict: get long a) rt-ok  clear
<< /a 42l /b 99l >>  dup /b get 99l eq  (extvalue-dict: get long b) rt-ok  clear

% --- Save, modify ExtValue entry, restore, verify revert ---
<< /a 42l >>  /mydict exch def
save  /sv1 exch def
  mydict /a 100l put
  mydict /a get 100l eq  (extvalue-save: modified to 100l) rt-ok
sv1 restore
mydict /a get 42l eq  (extvalue-save: reverted after restore) rt-ok  clear

% ====================================================================
% SECTION 10: Dict capacity and growth
% ====================================================================

% --- Dynamic dict grows beyond initial max-length ---
1 dynamic-dict
  dup /a 1 put
  dup /b 2 put
  dup /c 3 put
  dup /d 4 put
  dup /e 5 put
  dup length 5 eq  (dynamic-growth: 5 entries in max-length-1 dict) rt-ok
  dup max-length 1 ge  (dynamic-growth: max-length grew) rt-ok
clear

% --- Verify length tracks actual entries ---
3 dynamic-dict
  dup length 0 eq  (length-track: starts at 0) rt-ok
  dup /a 1 put
  dup length 1 eq  (length-track: 1 after first put) rt-ok
  dup /b 2 put
  dup length 2 eq  (length-track: 2 after second put) rt-ok
  dup /c 3 put
  dup length 3 eq  (length-track: 3 after third put) rt-ok
  dup /d 4 put
  dup length 4 eq  (length-track: 4 after dynamic growth) rt-ok
clear

% --- Stress: dynamic dict with many entries ---
% Use overwriting puts on same key set to stress growth
1 dynamic-dict
  dup /a 1 put  dup /b 2 put  dup /c 3 put  dup /d 4 put  dup /e 5 put
  dup /f 6 put  dup /g 7 put  dup /h 8 put  dup /i 9 put  dup /j 10 put
  dup /k 11 put  dup /l 12 put  dup /m 13 put  dup /n 14 put  dup /o 15 put
  dup /p 16 put  dup /q 17 put  dup /r 18 put  dup /s 19 put  dup /t 20 put
  dup length 20 eq  (large-dynamic: 20 entries) rt-ok
clear

% ====================================================================
% SECTION 11: Dict error paths
% ====================================================================

% --- get with missing key ---
{ << /a 1 >> /missing get } try  /undefined eq  (error: get missing -> undefined) rt-ok  clear

% --- Stack underflow on dict ops ---
{ def } try  /opstack-underflow eq  (error: def underflow) rt-ok  clear
{ load } try  /opstack-underflow eq  (error: load underflow) rt-ok  clear
{ undef } try  /opstack-underflow eq  (error: undef underflow) rt-ok  clear
{ known? } try  /opstack-underflow eq  (error: known? underflow) rt-ok  clear
{ begin } try  /opstack-underflow eq  (error: begin underflow) rt-ok  clear

% --- Type check errors ---
{ 42 length } try  /type-check eq  (error: length on int -> type-check) rt-ok  clear
{ 42 max-length } try  /type-check eq  (error: max-length on int -> type-check) rt-ok  clear
{ 42 keys } try  /type-check eq  (error: keys on int -> type-check) rt-ok  clear
{ 42 values } try  /type-check eq  (error: values on int -> type-check) rt-ok  clear

% --- put into full ReadWriteFixed dict ---
{
  1 dict dup /a 1 put  /b 2 put
} try  /dict-full eq  (error: put into full fixed -> dict-full) rt-ok  clear

% ====================================================================
% SECTION 12: Dict equality and comparison
% ====================================================================

% --- Same dict object: eq ---
3 dict  dup  eq  true eq  (eq: same dict is eq) rt-ok  clear

% --- Different dicts with same content: not eq (identity semantics) ---
<< /a 1 >>  << /a 1 >>  eq  false eq  (eq: different dicts not eq) rt-ok  clear

% --- Dict with self-reference ---
3 dynamic-dict dup /self 2 index put
dup /self get 1 index eq  true eq  (self-ref: dict stores itself) rt-ok  clear

% --- deep-eq: structural comparison ---
<< /a 1 /b 2 >> << /a 1 /b 2 >> deep-eq
  (deep-eq: same keys and values) rt-ok clear
<< /a 1 /b 2 >> << /a 1 /b 3 >> deep-eq not
  (deep-eq: same keys, different values) rt-ok clear
<< /a 1 /b 2 >> << /a 1 >> deep-eq not
  (deep-eq: different lengths) rt-ok clear
<< /a 1 >> << /b 1 >> deep-eq not
  (deep-eq: different keys) rt-ok clear
<< >> << >> deep-eq
  (deep-eq: empty dicts) rt-ok clear
<< /x 42 >> << /x 42 >> deep-eq
  (deep-eq: singleton) rt-ok clear

% --- deep-eq: nested values ---
<< /a [1 2 3] >> << /a [1 2 3] >> deep-eq
  (deep-eq: array values) rt-ok clear
<< /a [1 2 3] >> << /a [1 2 4] >> deep-eq not
  (deep-eq: different array values) rt-ok clear
<< /a << /b 1 >> >> << /a << /b 1 >> >> deep-eq
  (deep-eq: nested dicts) rt-ok clear
<< /a << /b 1 >> >> << /a << /b 2 >> >> deep-eq not
  (deep-eq: nested dicts different) rt-ok clear

% --- deep-ne ---
<< /a 1 >> << /a 1 >> deep-ne not
  (deep-ne: equal dicts) rt-ok clear
<< /a 1 >> << /a 2 >> deep-ne
  (deep-ne: different dicts) rt-ok clear

% --- deep-eq: dict vs non-dict ---
<< /a 1 >> [/a 1] deep-eq not
  (deep-eq: dict vs array) rt-ok clear

% ====================================================================
% SECTION 13: Stress tests
% ====================================================================

% --- Create and populate 50 dicts in a loop ---
0 1 49 {
  pop
  2 dynamic-dict
    dup /x 42 put
    dup /y 99 put
    dup length 2 eq  { } { /stress-50-failed print } if-else
  pop
} for
true  (stress: 50 dicts created and populated) rt-ok  clear

% --- Save, create 20 dicts, restore, create 20 more ---
save  /s1 exch def
0 1 19 {
  pop
  2 dict dup /a 1 put  pop
} for
s1 restore

0 1 19 {
  pop
  2 dict dup /b 2 put  pop
} for
true  (stress: save-restore-create cycle) rt-ok  clear

% --- Rapid begin/end cycles (100 iterations) ---
0 1 99 {
  pop
  3 dict begin
    /temp 42 def
  end
} for
true  (stress: 100 begin-end cycles) rt-ok  clear

% --- Rapid locals cycles (100 iterations) ---
0 1 99 {
  pop
  1 2 { |a b| a b add } exec  pop
} for
true  (stress: 100 locals cycles) rt-ok  clear

% --- Mixed dict operations stress ---
save  /s2 exch def
0 1 29 {
  /i exch def
  3 dynamic-dict begin
    /val i 10 mul def
    val i 10 mul eq  { } { (stress-mixed-failed) = } if-else
  end
} for
s2 restore
true  (stress: 30 begin-end inside save-restore) rt-ok  clear

% --- Pool reuse verification ---
% After heavy locals usage, the pool should have entries
//:status:locals-pool-count  0 ge  (pool-final: pool count non-negative) rt-ok  clear

% --- Dict operations inside for-all ---
<< /a 1 /b 2 /c 3 >>
/sum2 0 def
dup { exch pop  sum2 add  /sum2 exch def } for-all
sum2 6 eq  (for-all-sum: 1+2+3=6) rt-ok  clear

% --- known-get ---
<< /a 42 >>  dup /a known-get  true eq  (known-get: found returns true) rt-ok
42 eq  (known-get: found value correct) rt-ok  clear
<< /a 42 >>  dup /z known-get  false eq  (known-get: missing returns false) rt-ok  clear

% --- Multiple undef ---
3 dynamic-dict
  dup /a 1 put
  dup /b 2 put
  dup /c 3 put
  dup /a undef
  dup length 2 eq  (multi-undef: length after undef a) rt-ok
  dup /b undef
  dup length 1 eq  (multi-undef: length after undef b) rt-ok
  dup /c undef
  dup length 0 eq  (multi-undef: length after undef c) rt-ok
clear

% --- Dict max-length vs length ---
5 dict
  dup max-length 5 eq  (maxlen-vs-len: max-length is 5) rt-ok
  dup length 0 eq  (maxlen-vs-len: length starts 0) rt-ok
  dup /a 1 put
  dup /b 2 put
  dup length 2 eq  (maxlen-vs-len: length is 2 after 2 puts) rt-ok
  dup max-length 5 eq  (maxlen-vs-len: max-length unchanged) rt-ok
clear

% --- begin/end with def shadows userdict ---
/shadow-var 100 def
3 dict begin
  /shadow-var 200 def
  shadow-var 200 eq  (shadow: inner def shadows outer) rt-ok
end
shadow-var 100 eq  (shadow: outer value restored after end) rt-ok  clear

% --- where finds correct dict ---
3 dict begin
  /inner-key 42 def
  /inner-key where  exch pop  true eq  (where-inner: finds key in inner dict) rt-ok
end  clear

% --- Nested dict lookup ---
3 dict begin
  /outer-only 1 def
  3 dict begin
    outer-only 1 eq  (nested-lookup: inner sees outer def) rt-ok
  end
end  clear

% --- Dict from mark with various value types ---
<< /i 42 /s (hello) /b true /n null >>
  dup /i get 42 eq  (mark-types: integer) rt-ok
  dup /s get (hello) eq  (mark-types: string) rt-ok
  dup /b get true eq  (mark-types: boolean) rt-ok
  dup /n get null eq  (mark-types: null) rt-ok
clear

% --- Save/restore preserves dict contents ---
<< /a 1 /b 2 >>
save  /s3 exch def
  dup /a 99 put
  dup /a get 99 eq  (save-dict: modified inside save) rt-ok
s3 restore
% dict reverted
dup /a get 1 eq  (save-dict: restored after restore) rt-ok
clear

% --- Large fixed dict ---
16 dict
  dup /a 1 put  dup /b 2 put  dup /c 3 put  dup /d 4 put
  dup /e 5 put  dup /f 6 put  dup /g 7 put  dup /h 8 put
  dup /i 9 put  dup /j 10 put  dup /k 11 put  dup /l 12 put
  dup /m 13 put  dup /n 14 put  dup /o 15 put  dup /p 16 put
dup length 16 eq  (large-fixed: 16 entries fill exactly) rt-ok
clear

% --- Pool with different save levels ---
save  /s4 exch def
  1 2 { |a b| a b add } exec  pop
  save  /s5 exch def
    3 4 { |c d| c d mul } exec  pop
  s5 restore
s4 restore
true  (pool-multi-save: nested save-restore with locals) rt-ok  clear

% --- Overwrite same key many times ---
3 dynamic-dict
0 1 49 {
  /i exch def
  dup /key i put
} for
dup /key get 49 eq  (overwrite-key: last value wins) rt-ok
dup length 1 eq  (overwrite-key: length stays 1) rt-ok
clear

% --- for-all collects keys ---
<< /x 10 /y 20 >>
/key-count 0 def
dup { pop pop  key-count 1 add  /key-count exch def } for-all
key-count 2 eq  (for-all-keys: iterates 2 entries) rt-ok
clear

% ====================================================================
% Empty dict literal minimum capacity
% ====================================================================

% << >> has minimum capacity 4 — can accept put without error
<< >> dup /a 1 put dup /b 2 put dup /c 3 put dup /d 4 put
length 4 eq                              (empty-dict: accepts 4 puts) rt-ok clear

% 5th put exceeds capacity 4
<< >> dup /a 1 put dup /b 2 put dup /c 3 put dup /d 4 put
{ dup /e 5 put } try /dict-full eq       (empty-dict: 5th put raises dict-full) rt-ok clear

% empty dict starts with length 0
<< >> length 0 eq                        (empty-dict: length is 0) rt-ok clear

% small dicts (1-3 entries) also get minimum capacity 4
<< /a 1 >> dup /b 2 put dup /c 3 put dup /d 4 put
length 4 eq                              (small-dict: 1-entry grows to 4) rt-ok clear

<< /a 1 /b 2 /c 3 >> dup /d 4 put
length 4 eq                              (small-dict: 3-entry accepts 4th) rt-ok clear

% 5+ entry dicts get exact capacity (no minimum padding)
<< /a 1 /b 2 /c 3 /d 4 /e 5 >>
{ dup /f 6 put } try /dict-full eq       (exact-cap: 5-entry dict full at 5) rt-ok clear

% put and get round-trip on empty dict
<< >> dup /key (value) put
/key get (value) eq                      (empty-dict: put/get round-trip) rt-ok clear

% known? on empty dict
<< >> /a known? not                       (empty-dict: known? returns false) rt-ok clear

% save/restore with empty dict
/s1 save def
<< >> dup /a 42 put /a get 42 eq         (empty-dict: put inside save) rt-ok
s1 restore clear

% ====================================================================
% SECTION: filter-dict — dict proc -- dict'
% ====================================================================

% --- basic: filter by value (stack: key value, value on top) ---
<< /a 1 /b 2 /c 3 >> { nip 2 ge } filter-dict length 2 eq
(filter-dict: keep values >= 2) rt-ok clear

% --- check retained entries ---
<< /a 1 /b 2 /c 3 >> { nip 2 ge } filter-dict
dup /b known? (filter-dict: has b) rt-ok
dup /c known? (filter-dict: has c) rt-ok
/a known? not (filter-dict: no a) rt-ok clear

% --- filter to empty ---
<< /a 1 /b 2 >> { pop pop false } filter-dict length 0 eq
(filter-dict: keep none) rt-ok clear

% --- filter keep all ---
<< /a 1 /b 2 >> { pop pop true } filter-dict length 2 eq
(filter-dict: keep all) rt-ok clear

% --- empty input ---
<< >> { pop pop true } filter-dict length 0 eq
(filter-dict: empty dict) rt-ok clear

% --- result is dynamic ---
<< /a 1 /b 2 >> { nip 1 eq } filter-dict
dup /z 99 put /z known?
(filter-dict: result is dynamic) rt-ok clear

% --- proc receives key and value ---
<< /x 10 >> { nip 10 eq } filter-dict length 1 eq
(filter-dict: proc gets key value) rt-ok clear

% --- larger dict ---
<< /a 1 /b 2 /c 3 /d 4 /e 5 /f 6 /g 7 /h 8 >>
{ nip 4 gt } filter-dict length 4 eq
(filter-dict: keep values > 4 from 8 entries) rt-ok clear

% --- filter by key ---
<< /apple 1 /banana 2 /cherry 3 >> { pop type /name-type eq } filter-dict length 3 eq
(filter-dict: filter by key type) rt-ok clear

% --- sad: type mismatch ---
<< /type-check { clear true } >> { 42 { pop pop true } filter-dict } try-catch
(filter-dict: non-dict error) rt-ok clear

% --- ExtValue values (Long) ---
<< /a 100l /b 200l /c 300l >> { nip 200l gt } filter-dict length 1 eq
(filter-dict: long values) rt-ok clear
<< /a 100l /b 200l /c 300l >> { nip 200l gt } filter-dict /c known?
(filter-dict: long has c) rt-ok clear

% --- ExtValue values (Double) ---
<< /x 1.5d /y 2.5d /z 3.5d >> { nip 2.0d gt } filter-dict length 2 eq
(filter-dict: double values) rt-ok clear

% --- ExtValue values (Address) ---
<< /p 10a /q 20a /r 30a >> { nip 15a gt } filter-dict length 2 eq
(filter-dict: address values) rt-ok clear

% --- filter to single entry ---
<< /a 1 /b 2 /c 3 >> { nip 2 eq } filter-dict length 1 eq
(filter-dict: single result) rt-ok clear
<< /a 1 /b 2 /c 3 >> { nip 2 eq } filter-dict /b known?
(filter-dict: single has b) rt-ok clear

% --- filter by value type (mixed types) ---
<< /i 42 /s (hello) /b true >> { nip type /integer-type eq } filter-dict length 1 eq
(filter-dict: keep only integer values) rt-ok clear

% --- large dict ---
<< /a 1 /b 2 /c 3 /d 4 /e 5 /f 6 /g 7 /h 8 /i 9 /j 10 /k 11 /l 12 >>
{ nip 6 gt } filter-dict length 6 eq
(filter-dict: large dict 12 entries) rt-ok clear

% --- result deep-eq empty ---
<< /a 1 >> { pop pop false } filter-dict length 0 eq
(filter-dict: empty result) rt-ok clear

% --- filter-dict: proc error mid-iteration ---
<< /type-check { clear true } >> { << /a 1 /b (hello) /c 3 >> { nip 2 gt } filter-dict } try-catch
(filter-dict: proc error caught) rt-ok clear

% --- filter-dict: result used in further operations ---
<< /a 1 /b 2 /c 3 /d 4 >> { nip 2 gt } filter-dict
dup length 2 eq (filter-dict: chain length) rt-ok
keys length 2 eq (filter-dict: chain keys) rt-ok clear

(Dict tests complete.) =
rt-fails 0 get /integer-type cast 0 gt { /rt-assertions-failed throw } if
(__test_ok__) =
