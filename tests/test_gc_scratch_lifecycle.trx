% ====================================================================
% test_gc_scratch_lifecycle.trx -- lazy GC scratch block lifecycle
% ====================================================================
% The lazy GC scratch block (ChunkKind::GcScratch) is allocated on the
% first user gvm_alloc and freed when the last user block is released
% (m_gvm_user_block_count returns to 0).
%
% Post main-context-local (2026-05-09), main coroutine is in LOCAL VM,
% so a fresh program with no global allocs has m_gvm_user_block_count = 0
% and no scratch.  The first ${...} or #$ literal triggers ensure_gc_scratch.
% Freeing all globals via vm-global-gc returns the count to 0 and frees
% the scratch.  This test exercises the full round-trip.
% ====================================================================

% rt-ok counts failures in a restore-immune slot -- string byte writes
% are unjournaled, so the count survives assertions made inside save
% scopes, and the 1-byte string lives in LOCAL VM, invisible to the
% global-heap/gc-counter probes some files assert on.  The file THROWS
% at EOF: test_all counts a file as failed only when its run throws,
% so print-only failures would slip the suite verdict.
/rt-fails 1 string def
rt-fails 0 16#0#b put
/rt-ok { exch { = } { (FAILED: ) print = rt-fails 0  rt-fails 0 get /integer-type cast 1 add dup 255 gt { pop 255 } if /byte-type cast  put } if-else } def

% --------------------------------------------------------------------
% SECTION 1: scratch is absent at startup (main is local)
% --------------------------------------------------------------------

vm-global-info /by-kind get /gcscratch get /count get
0 eq                                          (1: gcscratch count = 0 at startup) rt-ok
vm-global-info /by-kind get /coroutinecontext get /count get
0 eq                                          (1: coroutinecontext count = 0 -- main is local) rt-ok
//:status:vm-global-used
0 eq                                          (1: vm-global-used = 0 at startup) rt-ok

% --------------------------------------------------------------------
% SECTION 2: first global alloc triggers scratch allocation
% --------------------------------------------------------------------

${ 8 dict } /g-dict exch def

vm-global-info /by-kind get /gcscratch get /count get
1 eq                                          (2: gcscratch count = 1 after first global alloc) rt-ok
vm-global-info /by-kind get /dict get /count get
1 eq                                          (2: dict count = 1 (the user dict)) rt-ok

% --------------------------------------------------------------------
% SECTION 3: scratch survives GC sweep
% --------------------------------------------------------------------
% While g-dict is rooted via userdict, GC keeps it alive AND keeps
% scratch alive (the kind-skip in gc_sweep_unmarked).

vm-global-gc pop
vm-global-info /by-kind get /gcscratch get /count get
1 eq                                          (3: gcscratch survives GC sweep) rt-ok
vm-global-info /by-kind get /dict get /count get
1 eq                                          (3: g-dict survives GC sweep (rooted)) rt-ok

% --------------------------------------------------------------------
% SECTION 4: lifecycle round-trip -- free all user globals, scratch frees too
% --------------------------------------------------------------------
% Drop the userdict reference to g-dict.  Without a root, the next GC
% pass sweeps it.  When it's freed, m_gvm_user_block_count drops to 0,
% which triggers the scratch to be freed too.

userdict /g-dict undef
vm-global-gc pop                               % sweep g-dict; scratch auto-freed on count==0
vm-global-info /by-kind get /gcscratch get /count get
0 eq                                          (4: gcscratch freed when last user block released) rt-ok
vm-global-info /by-kind get /dict get /count get
0 eq                                          (4: g-dict swept) rt-ok
//:status:vm-global-used
0 eq                                          (4: vm-global-used back to 0 -- idle state restored) rt-ok

% --------------------------------------------------------------------
% SECTION 5: re-allocate after the round-trip (lazy alloc fires again)
% --------------------------------------------------------------------

${ 4 dict } /g-dict-2 exch def

vm-global-info /by-kind get /gcscratch get /count get
1 eq                                          (5: gcscratch re-allocated on next first global) rt-ok
vm-global-info /by-kind get /dict get /count get
1 eq                                          (5: dict count = 1 again) rt-ok

% --------------------------------------------------------------------
% SECTION 6: scratch payload size matches GcScratchVisitedCapacity * 4
% --------------------------------------------------------------------
% Post Option 1 + 3 (PATCH 62+):
%   * Dict/Set use the in-Dict/Set link (m_next_in_visit), not visited set.
%   * GcScratchVisitedCapacity = 1024 (4 KiB initial visited set) for the
%     remaining 6 types (Tagged/Curry/Thunk/Array/Record/Packed).
%   * Mark-phase BFS queue + sweep-phase doomed list use GvmBlock::
%     m_next_in_work (no scratch needed).
% Total initial payload = 1024 * 4 = 4096 bytes.
% Plus block header (16) + tail tag (4) + alignment slack ~= 4116 -> 4120.
% On overflow, grow_gc_local_visited doubles the scratch -- this test
% measures the INITIAL size (no overflow triggered yet).

vm-global-info /by-kind get /gcscratch get /total-bytes get
4096 ge                                       (6: gcscratch total-bytes >= 4 KiB initial payload) rt-ok
vm-global-info /by-kind get /gcscratch get /total-bytes get
4192 le                                       (6: gcscratch total-bytes <= 4 KiB + alignment slack) rt-ok

rt-fails 0 get /integer-type cast 0 gt { /rt-assertions-failed throw } if
(test_gc_scratch_lifecycle: ALL TESTS PASSED) =
(__test_ok__) =
