% ====================================================================
% Mirror of test_reactive.trx, test_logic.trx, test_status.trx for
% Int128/UInt128. Covers:
%   * Reactive cells: cell-set/cell-get/cell-update/batch with int128
%   * Logic: cut with int128, copy-term, find-n results
%   * Status variables: widevalue-active tracking under churn
% ====================================================================

% rt-ok counts failures in a restore-immune slot -- string byte writes
% are unjournaled, so the count survives assertions made inside save
% scopes, and the 1-byte string lives in LOCAL VM, invisible to the
% global-heap/gc-counter probes some files assert on.  The file THROWS
% at EOF: test_all counts a file as failed only when its run throws,
% so print-only failures would slip the suite verdict.
/rt-fails 1 string def
rt-fails 0 16#0#b put
/rt-ok { exch { = } { (FAILED: ) print = rt-fails 0  rt-fails 0 get /integer-type cast 1 add dup 255 gt { pop 255 } if /byte-type cast  put } if-else } def

% ====================================================================
% SECTION 1: Reactive cells with Int128
% ====================================================================

9999999999q cell /c1 exch def
c1 cell-get 9999999999q deep-eq            (cell: int128 initial value) rt-ok clear
1111111111q c1 cell-set
c1 cell-get 1111111111q deep-eq            (cell: int128 after set) rt-ok clear
{ 999999999q add } c1 cell-update
c1 cell-get 2111111110q deep-eq            (cell: int128 after update) rt-ok clear

% Batch updates
9999999999q cell /c2 exch def
{
    1111111111q c2 cell-set
    2222222222q c2 cell-set
} batch
c2 cell-get 2222222222q deep-eq            (cell: int128 batch final value) rt-ok clear

% UInt128
42uq cell /c3 exch def
c3 cell-get 42uq deep-eq                   (cell: uint128 initial) rt-ok clear
100uq c3 cell-set
c3 cell-get 100uq deep-eq                  (cell: uint128 after set) rt-ok clear

% ====================================================================
% SECTION 2: Logic programming with Int128
% ====================================================================

% cut with int128 result (in a choice context)
[
    { 9999999999q cut }
    { 0q }
] choice
    9999999999q deep-eq                    (logic: cut with int128) rt-ok clear

% copy-term on a 128-bit value (passthrough)
9999999999q copy-term 9999999999q deep-eq  (logic: copy-term int128) rt-ok clear

% copy-term on an array containing int128
[ 9999999999q 3.14d ] copy-term /r exch def
r 0 get 9999999999q deep-eq                (logic: copy-term int128 in array) rt-ok
r 1 get 3.14d eq                           (logic: copy-term double in array) rt-ok clear

% find-n with int128 choices
2 [ { 1000000000q } { 2000000000q } { 3000000000q } ] find-n
    dup 0 get 1000000000q deep-eq          (logic: find-n int128 [0]) rt-ok
        1 get 2000000000q deep-eq          (logic: find-n int128 [1]) rt-ok clear

% ====================================================================
% SECTION 3: Status variables -- widevalue-active tracking
% ====================================================================

/base //:status:widevalue-active def

% Allocate and free 3 Int128 values -- active count should return to base
save
    42q pop 100q pop 999q pop
//:status:widevalue-active base eq          (status: int128 alloc+free returns to base) rt-ok clear

% Allocate via def (persistent) -- active count stays above base
save
    /keep-int128 42q def
    //:status:widevalue-active base gt      (status: def int128 keeps active above base) rt-ok
restore
//:status:widevalue-active base eq          (status: restore returns to base) rt-ok clear

% Map/filter with int128 -- verify free-list stability
save
    [1q 2q 3q 4q 5q] { 1q add } map pop
    [100q 200q 300q] { 150q gt } filter pop
restore
//:status:widevalue-active base eq
    (status: after map+filter+restore, back to base) rt-ok clear

% ====================================================================
% SECTION 4: Dict with mixed Int128 + Long + Double values
% ====================================================================

3 dict dup begin /a 42q def /b 99.9d def /c 42l def end
    dup /a get 42q deep-eq                  (dict mixed: int128 value) rt-ok
    dup /b get 99.9d eq                     (dict mixed: double value) rt-ok
    dup /c get 42l eq                       (dict mixed: long value) rt-ok
    pop clear

% Variable in dict with 128-bit, save/restore
/x 42q def
save
    /x 1q def
    x 1q deep-eq                            (dict binding: int128 inside save) rt-ok
restore
x 42q deep-eq                               (dict binding: int128 after restore) rt-ok clear

(test_int128_misc2_mirror.trx complete) =
rt-fails 0 get /integer-type cast 0 gt { /rt-assertions-failed throw } if
(__test_ok__) =
