% test_with_stream.trx -- tests for the with-stream operator

% rt-ok counts failures in a restore-immune slot -- string byte writes
% are unjournaled, so the count survives assertions made inside save
% scopes, and the 1-byte string lives in LOCAL VM, invisible to the
% global-heap/gc-counter probes some files assert on.  The file THROWS
% at EOF: test_all counts a file as failed only when its run throws,
% so print-only failures would slip the suite verdict.
/rt-fails 1 string def
rt-fails 0 16#0#b put
/rt-ok { exch { = } { (FAILED: ) print = rt-fails 0  rt-fails 0 get /integer-type cast 1 add dup 255 gt { pop 255 } if /byte-type cast  put } if-else } def

% ====================================================================
% SECTION 1: Normal read -- stream opened, proc runs, stream closed
% ====================================================================

% Create a temp file with known content
/tmp-file (/tmp/trix_ws_test1.txt) def
tmp-file (w)#b stream dup (hello world) write-string close-stream

% Read it back via with-stream
tmp-file (r)#b { read-all } with-stream
(hello world) eq            (read: content matches) rt-ok clear

% ====================================================================
% SECTION 2: Normal write -- stream opened for writing, proc writes
% ====================================================================

/tmp-file2 (/tmp/trix_ws_test2.txt) def
tmp-file2 (w)#b { (written by with-stream) write-string } with-stream

% Verify content was written (stream was flushed/closed)
tmp-file2 (r)#b { read-all } with-stream
(written by with-stream) eq  (write: content written and flushed) rt-ok clear

% ====================================================================
% SECTION 3: Error path -- stream closed on error, error propagated
% ====================================================================

/tmp-file3 (/tmp/trix_ws_test3.txt) def
tmp-file3 (w)#b stream dup (error test data) write-string close-stream

{
    tmp-file3 (r)#b { /type-check throw } with-stream
} try
/type-check eq               (error: error propagated) rt-ok clear

% Verify stream was closed: opening again succeeds (no leak)
tmp-file3 (r)#b stream close-stream

% ====================================================================
% SECTION 4: Error path with try-catch -- error caught after stream closed
% ====================================================================

/tmp-file4 (/tmp/trix_ws_test4.txt) def
tmp-file4 (w)#b stream dup (catch test) write-string close-stream

<< /range-check { pop (caught-it) } >>
{
    tmp-file4 (r)#b { /range-check throw } with-stream
} try-catch
(caught-it) eq               (try-catch: error caught after stream closed) rt-ok clear

% ====================================================================
% SECTION 5: Proc result on stack -- with-stream preserves stack values
% ====================================================================

tmp-file (r)#b { read-all length } with-stream
11 eq                        (result: string length on stack) rt-ok clear

% Multiple values left on stack (proc drops stream, pushes 3 values)
tmp-file (r)#b { pop 1 2 3 } with-stream
3 eq                         (result: third value) rt-ok
2 eq                         (result: second value) rt-ok
1 eq                         (result: first value) rt-ok clear

% ====================================================================
% SECTION 6: Append mode
% ====================================================================

/tmp-file6 (/tmp/trix_ws_test6.txt) def
tmp-file6 (w)#b stream dup (first) write-string close-stream

tmp-file6 (a)#b { (second) write-string } with-stream

tmp-file6 (r)#b { read-all } with-stream
(firstsecond) eq             (append: content appended) rt-ok clear

% ====================================================================
% SECTION 7: Uppercase mode -- read-write
% ====================================================================

/tmp-file7 (/tmp/trix_ws_test7.txt) def
tmp-file7 (w)#b stream dup (rw test) write-string close-stream

tmp-file7 (R)#b {
    dup read-all (rw test) eq (read-write: read content) rt-ok
    pop
} with-stream

% ====================================================================
% SECTION 8: Nested with-stream
% ====================================================================

/tmp-src (/tmp/trix_ws_src.txt) def
/tmp-dst (/tmp/trix_ws_dst.txt) def
tmp-src (w)#b stream dup (copy me) write-string close-stream

tmp-src (r)#b {
    read-all
    tmp-dst (w)#b {
        exch write-string
    } with-stream
} with-stream

tmp-dst (r)#b { read-all } with-stream
(copy me) eq                 (nested: content copied between streams) rt-ok clear

% ====================================================================
% SECTION 9: Error in nested with-stream -- both streams closed
% ====================================================================

{
    tmp-src (r)#b {
        pop
        tmp-dst (w)#b {
            /type-check throw
        } with-stream
    } with-stream
} try
/type-check eq               (nested-error: error propagated) rt-ok clear

% Both streams released: can open again
tmp-src (r)#b stream close-stream
tmp-dst (r)#b stream close-stream

% ====================================================================
% SECTION 10: with-stream + finally -- both cleanup mechanisms work
% ====================================================================

/ws-finally-ran false def
{
    { /ws-finally-ran true def }
    {
        tmp-file (r)#b { /range-check throw } with-stream
    } finally
} try
/range-check eq              (with-finally: error propagated) rt-ok clear
ws-finally-ran true eq       (with-finally: finally-block ran) rt-ok clear

% ====================================================================
% SECTION 11: with-stream inside finally block
% ====================================================================

/finally-read (none) def
{
    {
        tmp-file (r)#b { read-all } with-stream
        /finally-read exch def
    }
    { 42 }
    finally
} try
/no-error eq                 (finally-with-stream: no error) rt-ok clear
finally-read (hello world) eq (finally-with-stream: read inside finally) rt-ok clear
clear

% ====================================================================
% SECTION 12: stop through with-stream -- stream closed
% ====================================================================

{
    tmp-file (r)#b { pop stop } with-stream
} stopped
true eq                      (stop: stopped caught stop) rt-ok clear
% verify stream was closed and error stack not corrupted
{ 42 } try /no-error eq     (stop: try works after stop-through-with-stream) rt-ok clear

% ====================================================================
% SECTION 13: Proc throws real error -- stream still closed
% ====================================================================

{
    tmp-file (r)#b { 1 (bad) add } with-stream
} try
/type-check eq               (real-error: type-check from bad add) rt-ok clear

% ====================================================================
% SECTION 14: File not found
% ====================================================================

{ (/tmp/trix_nonexistent_file_xyz.txt) (r)#b { } with-stream } try
/filename-not-found eq       (file-not-found: error on missing file) rt-ok clear

% ====================================================================
% SECTION 15: Type errors
% ====================================================================

{ 1 (r)#b { } with-stream } try
/type-check eq               (error: non-string filename) rt-ok clear

{ tmp-file 1 { } with-stream } try
/type-check eq               (error: non-byte mode) rt-ok clear

{ tmp-file (r)#b 1 with-stream } try
/type-check eq               (error: non-proc body) rt-ok clear

% Invalid mode character
{ tmp-file (z)#b { } with-stream } try
/invalid-stream-access eq    (error: invalid mode) rt-ok clear

% Underflow
{ with-stream } try
/opstack-underflow eq        (error: underflow) rt-ok clear

% ====================================================================
% SECTION 16: Exclusive create mode
% ====================================================================

/tmp-excl (/tmp/trix_ws_excl.txt) def
% Remove if exists, ignore error
{ tmp-excl delete-file } try pop

tmp-excl (e)#b { (exclusive) write-string } with-stream

tmp-excl (r)#b { read-all } with-stream
(exclusive) eq               (exclusive: content written) rt-ok clear

% Second create with 'e should fail (file exists)
{ tmp-excl (e)#b { } with-stream } try
/filename-exists eq          (exclusive: second create fails) rt-ok clear

% ====================================================================
% SECTION 17: Stream available in proc via operand stack
% ====================================================================

% Verify the stream object is on the operand stack inside the proc
tmp-file (r)#b {
    type /stream-type eq (stream-on-stack: correct type) rt-ok clear
} with-stream

% Read individual byte via read operator
tmp-file (r)#b {
    read pop 104b eq          (read-byte: first byte is h) rt-ok
} with-stream

% ====================================================================
% SECTION 18: Write mode creates file
% ====================================================================

/tmp-new (/tmp/trix_ws_new.txt) def
{ tmp-new delete-file } try pop

tmp-new (w)#b { (brand new) write-string } with-stream
tmp-new (r)#b { read-all } with-stream
(brand new) eq               (write-create: file created) rt-ok clear

{ tmp-new delete-file } try pop

% ====================================================================
% SECTION 19: exit through with-stream inside a loop
% ====================================================================

% exit from within a with-stream block inside for-all
% stream must be closed and error stack must be clean
/tmp-exit (/tmp/trix_ws_exit.txt) def
{ tmp-exit delete-file } try pop
tmp-exit (w)#b { (test data) write-string } with-stream

/exit-count 0 def
[1 2 3] {
    pop
    tmp-exit (r)#b {
        /exit-count exit-count 1 add def
        pop exit
    } with-stream
} for-all
exit-count 1 eq               (exit-ws: loop exited at 1) rt-ok clear
% verify error stack not corrupted
{ 42 } try /no-error eq       (exit-ws: try works after) rt-ok clear
% verify stream was closed (re-open should succeed)
tmp-exit (r)#b { read-all (test data) eq } with-stream
                              (exit-ws: stream was closed) rt-ok clear

{ tmp-exit delete-file } try pop

% exit through with-stream + finally in a loop
/tmp-exit2 (/tmp/trix_ws_exit2.txt) def
{ tmp-exit2 delete-file } try pop
tmp-exit2 (w)#b { (data2) write-string } with-stream

/n 0 def
3 {
    { (fin) pop } {
        tmp-exit2 (r)#b {
            pop /n n 1 add def
            n 2 eq { exit } if
        } with-stream
    } finally
} repeat
n 2 eq                        (exit-ws: finally+ws in repeat) rt-ok clear
{ 1 } try /no-error eq        (exit-ws: try after finally+ws) rt-ok clear
tmp-exit2 (r)#b { read-all (data2) eq } with-stream
                              (exit-ws: stream closed after finally+ws) rt-ok clear

{ tmp-exit2 delete-file } try pop

% Cleanup temp files
{ (/tmp/trix_ws_test1.txt) delete-file } try pop
{ (/tmp/trix_ws_test2.txt) delete-file } try pop
{ (/tmp/trix_ws_test3.txt) delete-file } try pop
{ (/tmp/trix_ws_test4.txt) delete-file } try pop
{ (/tmp/trix_ws_test6.txt) delete-file } try pop
{ (/tmp/trix_ws_test7.txt) delete-file } try pop
{ (/tmp/trix_ws_src.txt) delete-file } try pop
{ (/tmp/trix_ws_dst.txt) delete-file } try pop
{ (/tmp/trix_ws_excl.txt) delete-file } try pop

(with-stream tests complete.) =
rt-fails 0 get /integer-type cast 0 gt { /rt-assertions-failed throw } if
(__test_ok__) =
