% ====================================================================
% test_gc_coroutine_churn.trx -- GC interactions with coroutine churn
% ====================================================================
% Verifies the Coroutine stacks-walk narrowing (commit 4879f50) and
% the `m_coroutine_stack_free` drain at GC entry behave correctly:
%
%   * Suspended-coroutine state survives GC: GC runs while a
%     coroutine is suspended (via coroutine-sleep) -- the suspended
%     coroutine's op stack must be preserved by the active-region
%     walk in gc_walk_coroutine_context.  When it resumes, the
%     stack frame must still hold its values.
%
%   * Free-listed stacks blocks are reclaimed: after coroutines die
%     and go on m_coroutine_stack_free, GC drains the head.  Blocks
%     get reclaimed; subsequent spawns alloc fresh from gvm_alloc.
%
%   * No false-positive UAF errors: with gc_mark_object's Free-block
%     check now error()ing, ANY accidental dangling reference to a
%     freed block crashes GC.  This test exercises the spawn/die/GC
%     paths heavily; a clean run validates that no slack-walking or
%     stale-Object hits remain.
%
% Notes:
%   coroutine-launch signature: `mark obj* proc -- coroutine`
%       Use `[` to push the mark, then the body proc.
%   coroutine-join signature: `coroutine -- value bool`
%       Returns BOTH the body's return value AND a status bool.
%       Drop the bool with `pop` if only the value matters.
% ====================================================================

% rt-ok counts failures in a restore-immune slot -- string byte writes
% are unjournaled, so the count survives assertions made inside save
% scopes, and the 1-byte string lives in LOCAL VM, invisible to the
% global-heap/gc-counter probes some files assert on.  The file THROWS
% at EOF: test_all counts a file as failed only when its run throws,
% so print-only failures would slip the suite verdict.
/rt-fails 1 string def
rt-fails 0 16#0#b put
/rt-ok { exch { = } { (FAILED: ) print = rt-fails 0  rt-fails 0 get /integer-type cast 1 add dup 255 gt { pop 255 } if /byte-type cast  put } if-else } def

% ====================================================================
% SECTION 1: spawn + join + GC reclaims dead stacks blocks
% ====================================================================

/runs0 //:status:gc-runs def

[ { 1 } coroutine-launch coroutine-join clear
[ { 2 } coroutine-launch coroutine-join clear
[ { 3 } coroutine-launch coroutine-join clear
[ { 4 } coroutine-launch coroutine-join clear
[ { 5 } coroutine-launch coroutine-join clear
[ { 6 } coroutine-launch coroutine-join clear
[ { 7 } coroutine-launch coroutine-join clear
[ { 8 } coroutine-launch coroutine-join clear
[ { 9 } coroutine-launch coroutine-join clear
[ { 10 } coroutine-launch coroutine-join clear

vm-global-gc /reclaimed exch def
//:status:gc-runs runs0 1l add eq   (1: gc-runs incremented) rt-ok
reclaimed 0 gt                      (1: GC reclaimed > 0 bytes after 10 spawns) rt-ok

% After GC, fresh spawns must work (drain emptied the runtime free
% list; coroutine_alloc_stacks goes through gvm_alloc).
[ { 100 } coroutine-launch coroutine-join clear
[ { 200 } coroutine-launch coroutine-join clear

% ====================================================================
% SECTION 2: GC while a coroutine is suspended preserves its state
% ====================================================================
% A coroutine sleeps for 0ns (yields back to scheduler).  While
% suspended, we run GC.  The active-region walk must mark the
% suspended coroutine's op stack -- otherwise the global composite
% values it pushed would be reclaimed.  When it resumes, the values
% must be intact and the body must complete cleanly.

[ {
    [ 1 2 3 ]#$          % global array on op stack
    (hello)#$            % global string on op stack
    42                   % integer
    0 coroutine-sleep    % suspend
    % After resume: 3 items still on stack from before sleep
    pop                  % drop integer
    pop                  % drop string
    pop                  % drop array
    /done
} coroutine-launch /co exch def

% Yield a few times to let `co` park, then run GC.
0 coroutine-sleep
0 coroutine-sleep
vm-global-gc pop

% Resume `co`: if GC corrupted its stack, the pops would crash or
% produce wrong types.  Successful join with /done return validates.
% join leaves: [value, true] on stack -- pop both, eq the value.
co coroutine-join pop /done eq   (2: suspended coroutine survived GC) rt-ok

% ====================================================================
% SECTION 3: heavy churn -- many spawn/die cycles with GC
% ====================================================================
% Stress the spawn/die/GC interleaving.  20 cycles x (spawn + join + GC).
% No false-positive UAF errors should fire.

1 1 20 {
    pop
    [ { 99 } coroutine-launch coroutine-join clear
    vm-global-gc pop
} for

//:status:gc-runs runs0 gt   (3: gc-runs accumulated across cycles) rt-ok
//:status:gc-in-progress not (3: gc-in-progress cleared after churn) rt-ok

rt-fails 0 get /integer-type cast 0 gt { /rt-assertions-failed throw } if
(test_gc_coroutine_churn: ALL TESTS PASSED) =
(__test_ok__) =
