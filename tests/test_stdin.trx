% test_stdin.trx — stdin I/O tests (must be run with piped input)
% Usage: printf 'line1\nline2\n42 hello\nABC' | ./trix test_stdin.trx
%
% Expected input (4 lines, last without trailing newline):
%   line1
%   line2
%   42 hello
%   ABC

% rt-ok counts failures in a restore-immune slot -- string byte writes
% are unjournaled, so the count survives assertions made inside save
% scopes, and the 1-byte string lives in LOCAL VM, invisible to the
% global-heap/gc-counter probes some files assert on.  The file THROWS
% at EOF: test_all counts a file as failed only when its run throws,
% so print-only failures would slip the suite verdict.
/rt-fails 1 string def
rt-fails 0 16#0#b put
/rt-ok { exch { = } { (FAILED: ) print = rt-fails 0  rt-fails 0 get /integer-type cast 1 add dup 255 gt { pop 255 } if /byte-type cast  put } if-else } def
/rt-count 0 def
/rt-inc { /rt-count rt-count 1 add def } def
/rt { rt-inc rt-ok } def

% --- read: single byte from stdin ---
stdin read pop  108b eq  (stdin-io: read byte = 'l') rt  clear

% --- read-line: reads up to newline ---
% consumed 'l' above, remainder of line1 is "ine1"
stdin 20 string read-line
true eq  (stdin-io: read-line returns true) rt
(ine1) eq  (stdin-io: read-line remainder = ine1) rt  clear

% --- read-line: second line ---
stdin 20 string read-line
true eq  (stdin-io: read-line line2 returns true) rt
(line2) eq  (stdin-io: read-line line2 content) rt  clear

% --- token: scan number from stdin ---
stdin token pop  42 eq  (stdin-io: token integer = 42) rt  clear

% --- token: scan name from stdin ---
stdin token pop  /hello eq  (stdin-io: token name = hello) rt  clear

% --- read: consume newline left by token scanner ---
stdin read pop  10b eq  (stdin-io: read trailing newline = LF) rt  clear

% --- read-string: read fixed bytes ---
stdin 3 string read-string
pop  (ABC) eq  (stdin-io: read-string = ABC) rt  clear

% --- read: EOF detection ---
stdin read  false eq  (stdin-io: read at EOF = false) rt  clear

% --- token: EOF detection ---
stdin token  false eq  (stdin-io: token at EOF = false) rt  clear

% --- summary ---
rt-count 11 eq  (stdin-io: all 11 tests passed) rt  clear

quit
rt-fails 0 get /integer-type cast 0 gt { /rt-assertions-failed throw } if
