% ====================================================================
% SUB-SECTION: PCG RNG operators
% ====================================================================

% Seed the RNG
42ul rand-seed

% rand-uinteger produces uinteger
rand-uinteger  type  /uinteger-type eq  (rand: uinteger type) rt-ok  clear

% rand-real produces real in [0, 1)
rand-real  dup  type  /real-type eq  (rand: real type) rt-ok
dup 0. ge  (rand: real >= 0) rt-ok
1. lt  (rand: real < 1) rt-ok  clear

% rand-double produces double
rand-double  type  /double-type eq  (rand: double type) rt-ok  clear

% rand-bounded-uinteger: result < bound
100u rand-bounded-uinteger  100u lt  (rand: bounded < 100) rt-ok  clear
1u rand-bounded-uinteger  0u eq  (rand: bounded with bound=1 always 0) rt-ok  clear

% rand-ulong produces ulong
rand-ulong  type  /ulong-type eq  (rand: ulong type) rt-ok  clear

% rand-bounded-ulong: result < bound
1000000000000ul rand-bounded-ulong  1000000000000ul lt  (rand: bounded-ulong < 1e12) rt-ok  clear
1ul rand-bounded-ulong  0ul eq  (rand: bounded-ulong with bound=1 always 0) rt-ok  clear

% Multiple calls produce different values (with high probability)
42ul rand-seed
rand-uinteger  rand-uinteger  ne  (rand: two calls differ) rt-ok  clear
rand-ulong  rand-ulong  ne  (rand: two ulong calls differ) rt-ok  clear

% RangeCheck for bound=0
<< /range-check { pop clear true } >> { 0u rand-bounded-uinteger } try-catch  (rand: bound=0 -> range-check) rt-ok  clear
<< /range-check { pop clear true } >> { 0ul rand-bounded-ulong } try-catch  (rand: ulong bound=0 -> range-check) rt-ok  clear
clear

clear

% ====================================================================
% SUB-SECTION: try-catch / throw / rethrow
% ====================================================================

% try on clean proc → no-error
{ 42 pop } try  /no-error eq  (try: clean proc returns no-error) rt-ok  clear

% try-catch with matching handler
<< /div-by-zero { pop clear true } >> { 1 0 div } try-catch  (try-catch: div-by-zero handler) rt-ok  clear
clear

% throw with valid error name
<< /range-check { pop true } >> { /range-check throw } try-catch
(throw: valid error name caught) rt-ok  clear

% throw with user-defined name → raised as that Name
<< /bogus-error-xyz { pop true } >> { /bogus-error-xyz throw } try-catch
(throw: user-defined name caught by matching handler) rt-ok  clear

% rethrow re-raises to outer handler
<< /range-check { pop clear true } >> {
  << /type-check { pop rethrow } >> { /range-check throw } try-catch
} try-catch  (rethrow: re-raises to outer handler) rt-ok  clear
clear

% Nested try-catch: inner handler catches, outer doesn't fire
/nested-result false def
<< /type-check { pop /nested-result true def clear } >> {
  << /div-by-zero { pop /nested-result true def clear } >> { 1 0 div } try-catch
} try-catch
nested-result  true eq  (try-catch: inner handler caught range-check) rt-ok  clear

clear

