16u countl-zero  27 eq  (countl-zero: 16u has 27 leading zeros) rt-ok  clear
16u countr-zero  4 eq  (countr-zero: 16 has 4 trailing zeros) rt-ok  clear

% --- ldexp / scalbn ---
1.0 10 ldexp  1024.0 eq  (ldexp: 1.0*2^10=1024) rt-ok  clear
