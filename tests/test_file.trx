% ====================================================================
% SECTION: Helpers
% ====================================================================

% rt-ok counts failures in a restore-immune slot -- string byte writes
% are unjournaled, so the count survives assertions made inside save
% scopes, and the 1-byte string lives in LOCAL VM, invisible to the
% global-heap/gc-counter probes some files assert on.  The file THROWS
% at EOF: test_all counts a file as failed only when its run throws,
% so print-only failures would slip the suite verdict.
/rt-fails 1 string def
rt-fails 0 16#0#b put
/rt-ok { exch { = } { (FAILED: ) print = rt-fails 0  rt-fails 0 get /integer-type cast 1 add dup 255 gt { pop 255 } if /byte-type cast  put } if-else } def
/pfmt { print-fmt pop pop } def
/ssfmt { sscan-fmt pop } def

% ====================================================================
% SECTION: Fixed Deficient Tests (formerly visual-only)
% ====================================================================

% --- over ---
1 2 over  1 eq  (over: copies second to top) rt-ok  clear
1 2 over  count 3 eq  (over: stack grows by 1) rt-ok  clear

% --- dip ---
% basic: hide top, execute proc, restore
1 2 3 { add } dip  3 eq  (dip: hidden value restored to top) rt-ok
3 eq  (dip: proc result below) rt-ok  clear

% dip with single item below proc arg
10 20 { 1 add } dip  20 eq  (dip: hidden restored) rt-ok
11 eq  (dip: proc ran on item below) rt-ok  clear

% dip preserves stack depth correctly
1 2 3 count  3 eq  (dip-pre: 3 items) rt-ok  clear
1 2 3 { pop } dip  count 2 eq  (dip: proc can reduce stack) rt-ok  clear

% dip with no-op proc
42 99 { } dip  99 eq  (dip: no-op proc restores hidden) rt-ok
42 eq  (dip: stack unchanged by no-op) rt-ok  clear

% dip with proc that pushes multiple values
1 2 { 10 20 30 } dip  2 eq  (dip: hidden on top after multi-push) rt-ok
30 eq  (dip: pushed values below hidden) rt-ok
20 eq  (dip: second pushed value) rt-ok
10 eq  (dip: third pushed value) rt-ok
1 eq  (dip: original bottom preserved) rt-ok  clear

% dip with composite types (array)
[1 2 3] [4 5 6] { length } dip
0 get  4 eq  (dip: array hidden and restored) rt-ok  clear

% dip with composite types (string)
(hello) (world) { length } dip
(world) eq  (dip: string hidden and restored) rt-ok
5 eq  (dip: proc computed length) rt-ok  clear

% dip with composite types (dict)
<< /a 1 >> (test) { length } dip
(test) eq  (dip: string hidden, dict length computed) rt-ok  clear

% nested dip: 1 2 3 4 → outer dip hides 4, inner dip hides 3, add 1+2=3, restore 3, restore 4
1 2 3 4 { { add } dip } dip
4 eq  (nested-dip: outermost hidden restored) rt-ok
3 eq  (nested-dip: inner hidden restored) rt-ok
3 eq  (nested-dip: 1+2 add result) rt-ok  clear

% dip inside a loop
/n 0 def  99  3 { { /n n 1 add def } dip } repeat
99 eq  (dip-loop: hidden preserved through repeat) rt-ok
n 3 eq  (dip-loop: proc ran 3 times) rt-ok  clear

% dip with error recovery via try
10 20 { { /undefined-name load } try pop } dip
20 eq  (dip-try: hidden restored after caught error) rt-ok
10 eq  (dip-try: original value preserved) rt-ok  clear

% --- keep ---
% basic: execute proc with value visible, then restore value
5 { dup mul } keep  5 eq  (keep: original restored to top) rt-ok
25 eq  (keep: proc result below) rt-ok  clear

% keep with add
3 7 { add } keep  7 eq  (keep: original restored) rt-ok
10 eq  (keep: add result) rt-ok  clear

% keep with no-op proc
42 { } keep  42 eq  (keep: restored after no-op) rt-ok
42 eq  (keep: value was visible to no-op) rt-ok  clear

% keep preserves composite types
[1 2 3] { length } keep
0 get  1 eq  (keep: array restored) rt-ok
3 eq  (keep: length computed) rt-ok  clear

% keep with string
(hello) { length } keep
(hello) eq  (keep: string restored) rt-ok
5 eq  (keep: length computed) rt-ok  clear

% keep proc sees the value
10 { 3 mul } keep  10 eq  (keep: original on top) rt-ok
30 eq  (keep: proc saw and used value) rt-ok  clear

% nested keep
5 { dup mul } keep { 1 add } keep
5 eq  (nested-keep: outermost original) rt-ok
6 eq  (nested-keep: 1 add result) rt-ok
25 eq  (nested-keep: dup mul result) rt-ok  clear

% keep with error recovery via try
10 { { /undefined-name load } try pop pop } keep
10 eq  (keep-try: original restored after caught error) rt-ok  clear

% dip and keep combined
1 2 3 { add } dip { dup mul } keep
3 eq  (dip+keep: keep restored 3) rt-ok
9 eq  (dip+keep: keep proc squared 3) rt-ok  clear

% practical example: add two items while preserving a third
% a b c { add } dip → (a+b) c
3 7 99 { add } dip
99 eq  (dip-practical: c preserved on top) rt-ok
10 eq  (dip-practical: a+b=10 below) rt-ok  clear

% --- pop-n ---
1 2 3 4  4 pop-n  count 0 eq  (pop-n: removes 4 items) rt-ok
1 2 3  2 pop-n  1 eq  (pop-n: 2 pops reveals bottom) rt-ok  clear
1 2  0 pop-n  count 2 eq  (pop-n: 0 is no-op) rt-ok  clear

% --- case operator ---
<< 1 {(One)} 2 {(Two)} /default {(Default)} >>#=r  1 case  (One) eq  (case dict: key 1) rt-ok  clear
<< 1 {(One)} /default {(Default)} >>#=r  99 case  (Default) eq  (case dict: default) rt-ok  clear

% --- byte subtraction ---
(B)#b (A)#b sub  1b eq  (byte sub: B-A=1) rt-ok  clear

% --- factorial ---
/fact { dup 1 gt { dup 1 sub fact mul } if } def
5 fact  120 eq  (fact: 5! = 120) rt-ok  clear
1 fact  1 eq  (fact: 1! = 1) rt-ok  clear
/lfact { dup 1l gt { dup 1l sub lfact mul } if } def
18l lfact  6402373705728000l eq  (lfact: 18! = 6402373705728000) rt-ok  clear

% --- save/restore with name redefinition ---
/trixie (best cat!)#r def
trixie (best cat!) eq  (save: trixie before save) rt-ok
save
  /trixie (gray cat) def
  trixie (gray cat) eq  (save: trixie modified inside save) rt-ok
restore
trixie (best cat!) eq  (restore: trixie reverted after restore) rt-ok  clear

% --- nested save/restore ---
/ns-val 1 def
save
  /ns-val 2 def
  save
    /ns-val 3 def
    ns-val 3 eq  (nested-save: innermost = 3) rt-ok
  restore
  ns-val 2 eq  (nested-save: middle restored = 2) rt-ok
restore
ns-val 1 eq  (nested-save: outer restored = 1) rt-ok  clear

% --- additional operator coverage ---
/nonexistent-name-xyz where  not  (where: name not found returns false) rt-ok  clear
{ 42 } exec  42 eq  (exec: proc execution) rt-ok  clear
42 exec  42 eq  (exec: integer pushes self) rt-ok  clear
42 no-op  42 eq  (no-op: value preserved) rt-ok  clear
4 dict  max-length  4 ge  (max-length: dict >= 4) rt-ok  clear
[1 2 3] 3 array copy  dup 0 get 1 eq exch dup 1 get 2 eq exch 2 get 3 eq and and  (copy: array content matches) rt-ok  clear
<< /a 1 /b 2 >> 4 dict copy  /a get 1 eq  (copy: dict preserves values) rt-ok  clear
<< /range-check { clear true } >> { -1. sqrt } try-catch  (sqrt: negative -> range-check) rt-ok  clear

% --- exit inside loops ---
0  1 1 10 { dup 5 gt { pop exit } if add } for  15 eq  (exit: breaks for at 5, sum=15) rt-ok  clear
0  10 { 1 add  dup 3 eq { exit } if } repeat  3 eq  (exit: breaks repeat at 3) rt-ok  clear

% --- rotate ---
1u 4 rotate-left  16u eq  (rotate: 1u rotl 4 = 16u) rt-ok  clear
16u 4 rotate-right  1u eq  (rotate: 16u rotr 4 = 1u) rt-ok  clear

% --- known-get ---
<< /a 42 >> /a known-get  pop 42 eq  (known-get: found value = 42) rt-ok  clear
<< /a 42 >> /b known-get  not  (known-get: missing key returns false) rt-ok  clear

% --- alloc / free tests ---
<< /range-check { clear true } >> { 0  alloc } try-catch  (alloc: zero size -> range-check) rt-ok  clear
<< /range-check { clear true } >> { -1 alloc } try-catch  (alloc: negative size -> range-check) rt-ok  clear

/abuf 64 alloc def                        % allocate 64 bytes

% --- peek / poke happy-path tests (require alloc) ---
42           abuf poke  abuf /integer-type  peek  42           eq  (peek/poke integer  round-trip) rt-ok
16#AB#b      abuf poke  abuf /byte-type     peek  16#AB#b      eq  (peek/poke byte     round-trip) rt-ok
3.14         abuf poke  abuf /real-type     peek  3.14         eq  (peek/poke real     round-trip) rt-ok
123456789012345l    abuf poke  abuf /long-type     peek  123456789012345l    eq  (peek/poke long     round-trip) rt-ok
2.718281828d abuf poke  abuf /double-type   peek  2.718281828d eq  (peek/poke double   round-trip) rt-ok
16#DEADBEEF#u       abuf poke  abuf /uinteger-type peek  16#DEADBEEF#u       eq  (peek/poke uinteger round-trip) rt-ok
16#CAFEBABE00000000#ul  abuf poke  abuf /ulong-type   peek  16#CAFEBABE00000000#ul  eq  (peek/poke ulong    round-trip) rt-ok

abuf free

% --- peek / poke error-path tests ---

% peek: null address → range-check
<< /range-check { clear true } >> { 0a /integer-type  peek } try-catch  (peek: null addr integer -> range-check) rt-ok  clear
<< /range-check { clear true } >> { 0a /byte-type     peek } try-catch  (peek: null addr byte -> range-check) rt-ok  clear
<< /range-check { clear true } >> { 0a /uinteger-type peek } try-catch  (peek: null addr uinteger -> range-check) rt-ok  clear
<< /range-check { clear true } >> { 0a /long-type     peek } try-catch  (peek: null addr long -> range-check) rt-ok  clear
<< /range-check { clear true } >> { 0a /ulong-type    peek } try-catch  (peek: null addr ulong -> range-check) rt-ok  clear
<< /range-check { clear true } >> { 0a /real-type     peek } try-catch  (peek: null addr real -> range-check) rt-ok  clear
<< /range-check { clear true } >> { 0a /double-type   peek } try-catch  (peek: null addr double -> range-check) rt-ok  clear

% peek: non-numeric type names → type-check
<< /type-check { clear true } >> { 0a /boolean-type   peek } try-catch  (peek: boolean-type -> type-check) rt-ok  clear
<< /type-check { clear true } >> { 0a /null-type      peek } try-catch  (peek: null-type -> type-check) rt-ok  clear
<< /type-check { clear true } >> { 0a /address-type   peek } try-catch  (peek: address-type -> type-check) rt-ok  clear
<< /type-check { clear true } >> { 0a /string-type    peek } try-catch  (peek: string-type -> type-check) rt-ok  clear

% peek: non-type-name → type-check
<< /type-check { clear true } >> { 0a /not-a-type     peek } try-catch  (peek: not-a-type -> type-check) rt-ok  clear

% poke: null address → range-check
<< /range-check { clear true } >> { 42   0a poke } try-catch  (poke: null addr integer -> range-check) rt-ok  clear
<< /range-check { clear true } >> { 3.14 0a poke } try-catch  (poke: null addr real -> range-check) rt-ok  clear
<< /range-check { clear true } >> { 99l  0a poke } try-catch  (poke: null addr long -> range-check) rt-ok  clear

% poke: address value rejected as non-numeric → type-check
<< /type-check { clear true } >> { 0a   0a poke } try-catch  (poke: address value -> type-check) rt-ok  clear

clear

% ===--- to-binary-token round-trip tests ---===

% --- Null ---
null to-binary-token make-executable exec  null eq  (btok null          round-trip ok) rt-ok

% --- Boolean ---
true  to-binary-token make-executable exec  true  eq  (btok true          round-trip ok) rt-ok
false to-binary-token make-executable exec  false eq  (btok false         round-trip ok) rt-ok

% --- Mark ---
% mark has no value; verify the decoded object is of mark-type
mark  to-binary-token make-executable exec  type /mark-type eq  (btok mark (type check)  round-trip ok) rt-ok

% --- Byte: five header-only constants ---
  0b  to-binary-token make-executable exec    0b  eq  (btok byte   0      round-trip ok) rt-ok
  1b  to-binary-token make-executable exec    1b  eq  (btok byte   1      round-trip ok) rt-ok
127b  to-binary-token make-executable exec  127b  eq  (btok byte 127      round-trip ok) rt-ok
128b  to-binary-token make-executable exec  128b  eq  (btok byte 128      round-trip ok) rt-ok
255b  to-binary-token make-executable exec  255b  eq  (btok byte 255      round-trip ok) rt-ok

% --- Byte: generic (Byte + 1 byte payload) ---
 42b  to-binary-token make-executable exec   42b  eq  (btok byte  42      round-trip ok) rt-ok
200b  to-binary-token make-executable exec  200b  eq  (btok byte 200      round-trip ok) rt-ok

% --- Integer: five header-only constants ---
//:systemdict:numbers:integer-type:min
      to-binary-token make-executable exec
//:systemdict:numbers:integer-type:min  eq  (btok integer min        round-trip ok) rt-ok

//:systemdict:numbers:integer-type:max
      to-binary-token make-executable exec
//:systemdict:numbers:integer-type:max  eq  (btok integer max        round-trip ok) rt-ok

-1  to-binary-token make-executable exec  -1  eq  (btok integer  -1      round-trip ok) rt-ok
 0  to-binary-token make-executable exec   0  eq  (btok integer   0      round-trip ok) rt-ok
 1  to-binary-token make-executable exec   1  eq  (btok integer   1      round-trip ok) rt-ok

% --- Integer: 8-bit payload (Integer_8) ---
 -128  to-binary-token make-executable exec  -128  eq  (btok integer -128  round-trip ok) rt-ok
  127  to-binary-token make-executable exec   127  eq  (btok integer  127  round-trip ok) rt-ok
   42  to-binary-token make-executable exec    42  eq  (btok integer   42  round-trip ok) rt-ok
  -99  to-binary-token make-executable exec   -99  eq  (btok integer  -99  round-trip ok) rt-ok

% --- Integer: 16-bit payload (Integer_16) ---
 -32768  to-binary-token make-executable exec  -32768  eq  (btok integer -32768 round-trip ok) rt-ok
  32767  to-binary-token make-executable exec   32767  eq  (btok integer  32767 round-trip ok) rt-ok
   1000  to-binary-token make-executable exec    1000  eq  (btok integer   1000 round-trip ok) rt-ok
  -1000  to-binary-token make-executable exec   -1000  eq  (btok integer  -1000 round-trip ok) rt-ok

% --- Integer: 32-bit payload (Integer_32) ---
  65536  to-binary-token make-executable exec   65536  eq  (btok integer  65536 round-trip ok) rt-ok
 -65537  to-binary-token make-executable exec  -65537  eq  (btok integer -65537 round-trip ok) rt-ok
1000000  to-binary-token make-executable exec 1000000  eq  (btok integer  1e6   round-trip ok) rt-ok

% --- UInteger: three header-only constants ---
0u  to-binary-token make-executable exec  0u  eq  (btok uinteger 0   (min)  round-trip ok) rt-ok
1u  to-binary-token make-executable exec  1u  eq  (btok uinteger 1          round-trip ok) rt-ok
//:systemdict:numbers:uinteger-type:max
    to-binary-token make-executable exec
//:systemdict:numbers:uinteger-type:max  eq  (btok uinteger max         round-trip ok) rt-ok

