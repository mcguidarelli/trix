//:systemdict:numbers:double-type:signaling-NaN to-binary-token make-executable exec
    type /double-type eq  (btok double signaling-NaN (type check)  round-trip ok) rt-ok
//:systemdict:numbers:double-type:quiet-NaN to-binary-token make-executable exec
    type /double-type eq  (btok double quiet-NaN     (type check)  round-trip ok) rt-ok

% --- Double: generic (Double + 8-byte payload) ---
3.141592653589793d  to-binary-token make-executable exec  3.141592653589793d  eq  (btok double pi-precise  round-trip ok) rt-ok
-2.718281828459045d to-binary-token make-executable exec  -2.718281828459045d eq  (btok double -e-precise   round-trip ok) rt-ok

% --- Name: system literal names ---
% system names are those in the SystemName enum (~155 operator/constant names)
% type names (/integer-type etc.) and error names are NOT system names and cannot be encoded
/null        to-binary-token make-executable exec  /null        eq  (btok sysname /null                    round-trip ok) rt-ok
/add         to-binary-token make-executable exec  /add         eq  (btok sysname /add                     round-trip ok) rt-ok
/pop         to-binary-token make-executable exec  /pop         eq  (btok sysname /pop                     round-trip ok) rt-ok
/to-binary-token  to-binary-token make-executable exec  /to-binary-token  eq  (btok sysname /to-binary-token  round-trip ok) rt-ok

% --- Name: system executable names (decoded result is executed, so test behavior) ---
% \add decoded and executed adds two numbers
2 3  \add to-binary-token make-executable exec  5 eq  (btok sysname \\add: 2+3=5  round-trip ok) rt-ok
% \pop decoded and executed pops the top
(sentinel) 42  \pop to-binary-token make-executable exec  (sentinel) eq  (btok sysname \\pop: pops top  round-trip ok) rt-ok

% --- String: empty ---
()  to-binary-token make-executable exec  ()  eq  (btok string empty        round-trip ok) rt-ok

% --- String: short (String_8, len <= 255) ---
(hello)  to-binary-token make-executable exec  (hello)  eq  (btok string hello        round-trip ok) rt-ok
(Trix binary token test string!)  to-binary-token make-executable exec  (Trix binary token test string!)  eq  (btok string medium       round-trip ok) rt-ok

% --- String: containing binary bytes (data preserved verbatim) ---
(\x00\x81\xFF\xAD)  to-binary-token make-executable exec  (\x00\x81\xFF\xAD)  eq  (btok string binary bytes  round-trip ok) rt-ok

% --- Error cases: unsupported types raise TypeCheck ---
<< /type-check { clear true } >>  { 0a to-binary-token }  try-catch  (btok err: address -> type-check) rt-ok  clear
% Operator must be placed on op-stack OUTSIDE the {} body
//add  << /type-check { clear true } >>  { to-binary-token }  try-catch  (btok err: operator -> type-check) rt-ok  clear
<< /type-check { clear true } >>  { [1 2 3] to-binary-token }  try-catch  (btok err: array -> type-check) rt-ok  clear
<< /type-check { clear true } >>  { << /a 1 >> to-binary-token }  try-catch  (btok err: dict -> type-check) rt-ok  clear
<< /type-check { clear true } >>  { {1 2 add} to-binary-token }  try-catch  (btok err: packed -> type-check) rt-ok  clear

% ===--- save/restore: dynamic dict expansion across save barrier ---===
% Regression for: maybe_expand() must be preceded by save() so restore()
% captures the pre-expansion m_pool/m_maxlength and does not leave a dangling pointer.
/test-dyn-dict-expand {
    2 dynamic-dict         % create a 2-entry dynamic dict
    dup /a 1 put           % fill to capacity
    dup /b 2 put
    save exch              % save point — stack: [save] [dict]
    dup /c 3 put           % triggers maybe_expand; save() must have run first
    dup /d 4 put
    dup length 4 eq        % 4 entries after expansion
    exch pop               % drop the dict (no longer needed before restore)
    exch restore           % restore to save point; dict should be valid with length=2
} def
test-dyn-dict-expand  (save/restore: dynamic dict expand + restore ok) rt-ok

% ===--- Name/Dict system: regression tests for Opus review bugs ---===

% Issue 1: store with key NOT on dict stack must store into current (top) dict, not crash
userdict begin
  /store-test-key 0 def
  /store-test-key 99 store        % key IS on dict stack — should update
  store-test-key 99 eq  (store: key found on dict stack) rt-ok
  /store-test-key2 77 store       % key NOT on dict stack — should def into current dict
  store-test-key2 77 eq  (store: key not found falls back to current dict) rt-ok
  current-dict /store-test-key undef
  current-dict /store-test-key2 undef
end

% Issue 2: Dict::reset (via clear-object) must invalidate name binding cache
<< /reset-name 1 >> begin
  reset-name 1 eq  (reset: name resolves before clear) rt-ok
  current-dict clear-object        % clears the dict; stale binding must NOT survive
  << /undefined { clear true } >> { reset-name } try-catch  (reset: name undefined after dict clear) rt-ok
end

% Issue 3: find_entry must match Name key against String-keyed entry (no duplicate)
% (This verifies that put with a Name key finds an existing String-keyed entry)
4 dict dup (str-key) 42 put        % insert with String key
dup /str-key 99 put               % update with Name key — must NOT create duplicate
dup /str-key get 99 eq exch       % value updated
length 1 eq and                   % only one entry (no duplicate)
(find_entry: Name key updates String-keyed entry) rt-ok

% Issue 4: undef with Name key must remove String-keyed entry
4 dict dup (undef-key) 55 put      % insert with String key
dup /undef-key undef              % remove with Name key — must find it
length 0 eq  (undef: Name key removes String-keyed entry) rt-ok

% ===--- proc body [array] / <<dict>> compile tests ---===
{ [1 2 3] } exec  dup type /array-type eq exch length 3 eq and  (proc body [array] compiles ok) rt-ok
{ << /k 7 >> } exec  /k get  7  eq  (proc body <<dict>> compiles ok) rt-ok
{ { [1 2] } exec } exec  dup type /array-type eq exch length 2 eq and  (nested proc body [array] ok) rt-ok
{ [1 2] [3 4] } exec  dup type /array-type eq exch length 2 eq and  (two arrays in proc body ok) rt-ok

clear

% ====================================================================
% COMPREHENSIVE REGRESSION TEST SUITE
% ====================================================================
% Pattern: <result> <expected> eq  (label) rt-ok
% rt-ok: { exch { = } { (FAILED: ) print = } if-else }  (defined above)

% ====================================================================
% SECTION: Stack Operators
% ====================================================================

% count: items on operand stack
1 2 3 count  3 eq  (stack count: 3 items) rt-ok  clear

% dup: top item is duplicated and equal
42 dup  eq  (stack dup: copies equal value) rt-ok  clear

% exch: swaps top two
1 2 exch  1 eq  (stack exch: former second now top) rt-ok  clear

% pop: removes top, revealing second
1 2 pop  1 eq  (stack pop: reveals second) rt-ok

% index: retrieve nth item (0=top)
10 20 30  0 index  30 eq  (stack index 0: top) rt-ok  clear
10 20 30  1 index  20 eq  (stack index 1: second) rt-ok  clear
10 20 30  2 index  10 eq  (stack index 2: third) rt-ok  clear

% roll: circular shift of top n items
% 3 1 roll: moves top to bottom of group
1 2 3  3 1 roll  pop pop  3 eq  (stack roll 3 1: top goes to bottom) rt-ok
% 3 -1 roll: moves bottom of group to top
1 2 3  3 -1 roll  1 eq  (stack roll 3 -1: bottom comes to top) rt-ok  clear

% dup-n: duplicate top n items
1 2 3  3 dup-n  count  6 eq  (stack dup-n: 3 items doubled) rt-ok  clear

