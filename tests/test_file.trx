% ====================================================================
% SUB-SECTION: scan_procedure fix — [array] and <<dict>> inside { }
% ====================================================================

% Array literal inside proc body
{ [1 2 3] } exec  length  3 eq  (proc-body: [1 2 3] length = 3) rt-ok  clear

% Array content inside proc body
{ [10 20 30] } exec  1 get  20 eq  (proc-body: [10 20 30] element 1 = 20) rt-ok  clear

% Dict literal inside proc body
{ << /k 7 >> } exec  /k get  7 eq  (proc-body: <<dict>> /k get = 7) rt-ok  clear

% Nested proc body with array
{ { [1 2] } exec } exec  length  2 eq  (proc-body: nested proc [1 2] length = 2) rt-ok  clear

% Two arrays in proc body — both are created
{ [1 2] [3 4] } exec
0 get 3 eq  (proc-body: second array [3 4] element 0 = 3) rt-ok
0 get 1 eq  (proc-body: first array [1 2] element 0 = 1) rt-ok  clear

% Array inside proc with other items
{ 42 [10 20] 99 } exec
99 eq  (proc-body: item after array = 99) rt-ok
length 2 eq  (proc-body: array length = 2) rt-ok
42 eq  (proc-body: item before array = 42) rt-ok  clear

% Dict inside proc with other items
{ 1 << /x 2 >> 3 } exec
3 eq  (proc-body: item after dict = 3) rt-ok
/x get 2 eq  (proc-body: dict /x = 2) rt-ok
1 eq  (proc-body: item before dict = 1) rt-ok  clear

% Empty array inside proc
{ [] } exec  length  0 eq  (proc-body: empty array length = 0) rt-ok  clear

% Empty dict inside proc
{ << >> } exec  length  0 eq  (proc-body: empty dict length = 0) rt-ok  clear

clear

