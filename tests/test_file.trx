% ====================================================================
% SECTION: Global handler / @handler-done
% ====================================================================
% Verify that make_control_operator(atHandlerDone) does not crash.
% global_handler() pushes @handler-done on the exec stack; if atHandlerDone
% is missing from make_control_operator's switch it hits assert(false)/UB.
% The custom handler pops the 6 handler args, prints a success line, then
% calls quit.  @handler-done fires after the handler proc returns (clearing
% m_in_global_handler), then the pending ExitIRQ from quit causes a clean exit.
% ====================================================================
% SECTION: Newly Registered Math/Numeric Operators
% ====================================================================

% --- inverse trig ---
0.0 asin  0.0 eq  (asin: asin(0)=0) rt-ok  clear
1.0 asin  1.5707963 sub abs 1e-6 lt  (asin: asin(1) approx pi/2) rt-ok  clear
1.0 acos  abs 1e-6 lt  (acos: acos(1) approx 0) rt-ok  clear
0.0 acos  1.5707963 sub abs 1e-6 lt  (acos: acos(0) approx pi/2) rt-ok  clear
1.0 0.0 atan2  1.5707963 sub abs 1e-6 lt  (atan2: atan2(1,0) approx pi/2) rt-ok  clear
0.0 1.0 atan2  abs 1e-6 lt  (atan2: atan2(0,1) approx 0) rt-ok  clear

% --- hyperbolic ---
0.0 sinh  0.0 eq  (sinh: sinh(0)=0) rt-ok  clear
0.0 cosh  1.0 eq  (cosh: cosh(0)=1) rt-ok  clear
0.0 tanh  0.0 eq  (tanh: tanh(0)=0) rt-ok  clear
0.0 asinh  0.0 eq  (asinh: asinh(0)=0) rt-ok  clear
1.0 acosh  abs 1e-6 lt  (acosh: acosh(1) approx 0) rt-ok  clear
0.0 atanh  0.0 eq  (atanh: atanh(0)=0) rt-ok  clear

% --- exponential/logarithmic ---
3.0 exp2  8.0 eq  (exp2: 2^3=8) rt-ok  clear
0.0 expm1  0.0 eq  (expm1: expm1(0)=0) rt-ok  clear
8.0 log2  3.0 eq  (log2: log2(8)=3) rt-ok  clear
100.0 log10  2.0 eq  (log10: log10(100)=2) rt-ok  clear
0.0 log1p  0.0 eq  (log1p: log1p(0)=0) rt-ok  clear
8.0 logb  3.0 eq  (logb: logb(8)=3) rt-ok  clear

% --- pow / hypot / cbrt ---
2.0 10.0 pow  1024.0 eq  (pow: 2^10=1024) rt-ok  clear
3.0 4.0 hypot  5.0 eq  (hypot: 3-4-5 triangle) rt-ok  clear
27.0 cbrt  3.0 eq  (cbrt: cbrt(27)=3) rt-ok  clear

% --- special functions ---
0.0 erf  0.0 eq  (erf: erf(0)=0) rt-ok  clear
0.0 erfc  1.0 eq  (erfc: erfc(0)=1) rt-ok  clear
5.0 tgamma  24.0 eq  (tgamma: gamma(5)=4!=24) rt-ok  clear
1.0 lgamma  0.0 eq  (lgamma: lgamma(1)=0) rt-ok  clear

% --- rounding variants ---
2.5 nearby-int  2.0 eq  (nearby-int: rounds 2.5 to even) rt-ok  clear
2.5 rint  2.0 eq  (rint: rounds 2.5 to even) rt-ok  clear

% --- float binary ops ---
5.0 3.0 fmod  2.0 eq  (fmod: 5 mod 3 = 2) rt-ok  clear
5.0 3.0 remainder  -1.0 eq  (remainder: IEEE rem 5,3 = -1) rt-ok  clear
3.0 4.0 fdim  0.0 eq  (fdim: max(3-4,0)=0) rt-ok  clear
4.0 3.0 fdim  1.0 eq  (fdim: max(4-3,0)=1) rt-ok  clear
2.0 3.0 fmin  2.0 eq  (fmin: min 2,3 = 2) rt-ok  clear
2.0 3.0 fmax  3.0 eq  (fmax: max 2,3 = 3) rt-ok  clear
1.0 -1.0 copy-sign  -1.0 eq  (copy-sign: copy-sign(1,-1)=-1) rt-ok  clear
2.0 3.0 5.0 fma  11.0 eq  (fma: 2*3+5=11) rt-ok  clear

% --- decomposition ---
3.75 modf  3.0 eq  (modf: integer part of 3.75 = 3) rt-ok
0.75 eq  (modf: fractional part of 3.75 = 0.75) rt-ok  clear

% --- float classification ---
1.0 sign-bit  false eq  (sign-bit: positive) rt-ok  clear
-1.0 sign-bit  true eq  (sign-bit: negative) rt-ok  clear
1.0 normal?  true eq  (normal?: 1.0 is normal) rt-ok  clear
1.0 nan?  false eq  (nan?: 1.0 is not NaN) rt-ok  clear
1.0 inf?  false eq  (inf?: 1.0 is not inf) rt-ok  clear
1.0 finite?  true eq  (finite?: 1.0 is finite) rt-ok  clear

% --- bit operations ---
255u pop-count  8 eq  (pop-count: 255 has 8 bits) rt-ok  clear
0u pop-count  0 eq  (pop-count: 0 has 0 bits) rt-ok  clear
