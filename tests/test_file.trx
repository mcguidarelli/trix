42 exec  42 eq  (exec: literal int passthrough) rt-ok  clear
{ } exec  count 0 eq  (exec: empty proc ok) rt-ok  clear
<< /opstack-underflow { clear true } >> { exec } try-catch  (exec: empty stack -> opstack-underflow) rt-ok  clear

% --- exec-n: comprehensive ---
10 { 2 mul } { 1 add } 2 exec-n  21 eq  (exec-n: 10 *2 +1 = 21) rt-ok  clear
42 0 exec-n  42 eq  (exec-n: n=0 is no-op) rt-ok  clear
5 { 1 add } 1 exec-n  6 eq  (exec-n: n=1 single proc) rt-ok  clear
<< /range-check { clear true } >> { -1 exec-n } try-catch  (exec-n: negative n -> range-check) rt-ok  clear
<< /type-check { clear true } >> { 3.14 exec-n } try-catch  (exec-n: non-integer n -> type-check) rt-ok  clear
<< /opstack-underflow { clear true } >> { 5 exec-n } try-catch  (exec-n: insufficient ops -> opstack-underflow) rt-ok  clear

% --- stop/stopped: edge cases ---
<< /invalid-stop { clear true } >> { stop } try-catch  (stop: outside stopped -> invalid-stop) rt-ok  clear
{ } stopped  false eq  (stopped: empty proc -> false) rt-ok  clear
{ 99 } stopped  false eq  (stopped: no-stop -> false) rt-ok
99 eq  (stopped: proc value preserved) rt-ok  clear
% triple nested stopped: inner stop, middle and outer see normal exit
{ { { stop } stopped } stopped } stopped
false eq  (stopped: outer sees normal) rt-ok
false eq  (stopped: middle sees normal) rt-ok
true eq  (stopped: innermost caught stop) rt-ok  clear

% --- try: edge cases ---
{ 1 0 div } try  /div-by-zero eq  (try: div-by-zero) rt-ok  clear
{ (a) (b) add } try  /type-check eq  (try: type error -> /type-check) rt-ok  clear
{ { 1 0 div } try } try
/no-error eq  (try: outer sees no-error) rt-ok
/div-by-zero eq  (try: inner caught div-by-zero) rt-ok  clear
<< /type-check { clear true } >> { 42 try } try-catch  (try: non-proc -> type-check) rt-ok  clear

% --- try-catch: edge cases ---
<< /range-check { pop clear false } >> { 42 } try-catch  42 eq  (try-catch: clean proc preserves stack) rt-ok  clear
<< /type-check { clear true } >> { [ /div-by-zero { pop clear true } ] { 1 0 div } try-catch } try-catch  (try-catch: array catch spec -> type-check) rt-ok  clear
<< /type-check { clear true } >> { /div-by-zero { pop clear true } 2 packed { 1 0 div } try-catch } try-catch  (try-catch: packed catch spec -> type-check) rt-ok  clear
<< /div-by-zero { pop clear (divzero) true } /type-check { pop clear (type) true } >>
{ 1 0 div } try-catch  (try-catch: multi-handler div-by-zero) rt-ok  clear
<< /range-check { pop clear (range) true } /type-check { pop clear (type) true } >>
{ (a) (b) add } try-catch  (try-catch: multi-handler type) rt-ok  clear
<< /type-check { pop clear true } >> {
  << /range-check { pop clear false } >> { (a) (b) add } try-catch
} try-catch  (try-catch: unmatched error re-raises) rt-ok  clear
<< /type-check { clear true } >> { << /range-check { } >> 42 try-catch } try-catch  (try-catch: non-proc body -> type-check) rt-ok  clear

% --- throw: edge cases ---
{ /type-check throw } try  /type-check eq  (throw: caught by try) rt-ok  clear
<< /type-check { clear true } >> { 42 throw } try-catch  (throw: non-name -> type-check) rt-ok  clear
<< /opstack-underflow { clear true } >> { throw } try-catch  (throw: empty stack -> opstack-underflow) rt-ok  clear

% --- rethrow: edge cases ---
{
  << /div-by-zero { pop rethrow } >> { 1 0 div } try-catch
} try  /div-by-zero eq  (rethrow: re-raised caught by try) rt-ok  clear

% --- last-error ---
{ 1 0 div } try pop
last-error  /div-by-zero eq  (last-error: after div-by-zero) rt-ok  clear
{ /type-check throw } try pop
last-error  /type-check eq  (last-error: after throw = /type-check) rt-ok  clear
% clean try does NOT reset last-error — it retains previous value
{ 42 pop } try pop
last-error  /type-check eq  (last-error: clean try retains previous = /type-check) rt-ok  clear

% --- case: edge cases ---
<< /undefined-case { clear true } >> { << 1 {(One)} >> 99 case } try-catch  (case: no match no default -> undefined-case) rt-ok  clear
<< 1 42 /default 0 >>  1 case  42 eq  (case: literal value pushed) rt-ok  clear
<< /type-check { clear true } >> { 42 1 case } try-catch  (case: non-container -> type-check) rt-ok  clear
<< /type-check { clear true } >> { [ 1 2 ] /x case } try-catch  (case: array container -> type-check) rt-ok  clear
<< /opstack-underflow { clear true } >> { 1 case } try-catch  (case: underflow -> opstack-underflow) rt-ok  clear

(Control operator comprehensive tests complete.) =
clear

% ====================================================================
% SECTION: exit / stop / stopped / run — exhaustive boundary tests
% ====================================================================

% --- exit from for-all on dict (single entry, deterministic) ---
0  << /x 42 >> { exch pop dup 42 eq { pop exit } if add } for-all
0 eq  (exit: for-all dict immediate exit sum=0) rt-ok  clear

% --- exit from for-all on packed array ---
0  { 1 2 3 4 5 } { dup 3 gt { pop exit } if add } for-all  6 eq  (exit: for-all packed breaks at >3 sum=6) rt-ok  clear

% --- exit across try-catch barrier inside loop ---
0  {
  1 add
  << /div-by-zero { pop pop pop } >> { 1 0 div } try-catch
  dup 3 eq { exit } if
} loop
3 eq  (exit: across try-catch barrier inside loop) rt-ok  clear

% --- exit across MULTIPLE try-catch barriers inside loop ---
0  {
  1 add
  << /div-by-zero { pop pop pop } >> { 1 0 div } try-catch
  << /div-by-zero { pop pop pop } >> { 1 0 div } try-catch
  dup 2 eq { exit } if
} loop
2 eq  (exit: across two try-catch barriers inside loop) rt-ok  clear

% --- exit across nested try-catch inside loop ---
0  {
  1 add
  << /div-by-zero { pop pop pop
    << /type-check { pop pop pop } >> { (a) (b) add } try-catch
  } >> { 1 0 div } try-catch
  dup 2 eq { exit } if
} loop
2 eq  (exit: across nested try-catch inside loop) rt-ok  clear

% --- exit hitting @stop boundary → InvalidExit ---
<< /invalid-exit { clear true } >> {
  { exit } stopped
} try-catch
(exit: hitting @stop boundary -> invalid-exit) rt-ok  clear

% --- exit hitting @stop inside stopped inside loop → InvalidExit ---
<< /invalid-exit { clear true } >> {
  { { exit } stopped } loop
} try-catch
(exit: inside stopped inside loop -> invalid-exit) rt-ok  clear

% --- exit preserves operand stack values below for ---
10 20 30
0  1 1 5 { dup 3 gt { pop exit } if add } for
6 eq  (exit: for result=6) rt-ok
30 eq  (exit: preserves 30 below for) rt-ok
20 eq  (exit: preserves 20 below for) rt-ok
10 eq  (exit: preserves 10 below for) rt-ok  clear

% --- exit preserves operand stack below loop ---
99 0  { 1 add  dup 5 eq { exit } if } loop
5 eq  (exit: loop result=5) rt-ok
99 eq  (exit: preserves 99 below loop) rt-ok  clear

% --- exit preserves operand stack below repeat ---
77 0  5 { 1 add  dup 2 eq { exit } if } repeat
2 eq  (exit: repeat result=2) rt-ok
77 eq  (exit: preserves 77 below repeat) rt-ok  clear

% --- exit from for with long counter ---
0l  1l 1l 10l { dup 5l gt { pop exit } if add } for
15l eq  (exit: long for breaks at >5 sum=15) rt-ok  clear

% --- exit from for with real counter ---
0.0  1.0 1.0 10.0 { dup 5.0 gt { pop exit } if add } for
15.0 eq  (exit: real for breaks at >5 sum=15) rt-ok  clear

% --- exit from for with double counter ---
0.0d  1.0d 1.0d 10.0d { dup 5.0d gt { pop exit } if add } for
15.0d eq  (exit: double for breaks at >5 sum=15) rt-ok  clear

% --- stop across try-catch barrier ---
{
  << /div-by-zero { pop pop pop } >> { 1 0 div } try-catch
  stop
} stopped
true eq  (stop: across try-catch barrier gives true) rt-ok  clear

% --- stop across MULTIPLE try-catch barriers ---
{
  << /div-by-zero { pop pop pop } >> { 1 0 div } try-catch
  << /type-check { pop pop pop } >> { (a) (b) add } try-catch
  stop
} stopped
true eq  (stop: across two try-catch barriers gives true) rt-ok  clear

% --- stop inside loop inside stopped ---
0  {
  { 1 add  dup 3 eq { stop } if } loop
} stopped
true eq  (stop: inside loop gives true) rt-ok
3 eq  (stop: inside loop counter=3) rt-ok  clear

% --- stop inside for inside stopped ---
0  {
  1 1 100 { add  dup 6 ge { stop } if } for
} stopped
true eq  (stop: inside for gives true) rt-ok
6 eq  (stop: inside for accumulator=6) rt-ok  clear

% --- stop inside repeat inside stopped ---
0  {
  100 { 1 add  dup 4 eq { stop } if } repeat
} stopped
true eq  (stop: inside repeat gives true) rt-ok
4 eq  (stop: inside repeat counter=4) rt-ok  clear

% --- stop inside for-all inside stopped ---
0  {
  [10 20 30 40 50] { dup 30 ge { pop stop } if add } for-all
} stopped
true eq  (stop: inside for-all gives true) rt-ok
30 eq  (stop: inside for-all accumulator=30) rt-ok  clear

% --- stopped inside repeat (doesn't interfere with loop) ---
/stopped-loop-count 0 def
3 {
  { 42 } stopped pop pop
  /stopped-loop-count stopped-loop-count 1 add def
} repeat
stopped-loop-count 3 eq  (stopped: inside repeat doesn't interfere) rt-ok  clear

% --- stopped catches stop inside repeat, loop continues ---
/stopped-in-loop 0 def
3 {
  { stop } stopped pop
  /stopped-in-loop stopped-in-loop 1 add def
} repeat
stopped-in-loop 3 eq  (stopped: catches stop inside repeat, loop continues) rt-ok  clear

% --- nested stopped: stop at different nesting levels ---
{
  { stop } stopped
  true eq  (stopped: nested inner caught stop) rt-ok
} stopped
false eq  (stopped: nested outer sees normal) rt-ok  clear

% --- outer stop after inner stopped completes ---
{
  { stop } stopped pop
  stop
} stopped
true eq  (stopped: outer stop after inner stopped gives true) rt-ok  clear

% --- stop preserves values pushed before stop ---
{
  10 20 30
  stop
} stopped
true eq  (stop: result is true) rt-ok
30 eq  (stop: preserves value 30) rt-ok
20 eq  (stop: preserves value 20) rt-ok
10 eq  (stop: preserves value 10) rt-ok  clear

% --- stopped with complex exec stack (proc calls before stop) ---
/stop-helper { 2 mul } def
{
  5 stop-helper
  stop
} stopped
true eq  (stopped: complex exec stop result true) rt-ok
10 eq  (stopped: complex exec value=10) rt-ok  clear

% --- stopped with complex exec stack (normal completion) ---
/nostop-helper { 3 add } def
{
  7 nostop-helper
} stopped
false eq  (stopped: complex exec normal result false) rt-ok
10 eq  (stopped: complex exec normal value=10) rt-ok  clear

% --- run on nonexistent file → error ---
<< /filename-not-found { clear true } >> { (nonexistent_file_xyz_123.trx) run } try-catch
(run: nonexistent file -> filename-not-found) rt-ok  clear

% --- run with non-string argument → TypeCheck ---
