65b eq  (sscan-fmt-7a: escape A value) rt-ok  clear

(\\n) ({:?}) mark 0b sscan-fmt
1 eq  (sscan-fmt-7b: escape \\n count) rt-ok
10b eq  (sscan-fmt-7b: escape \\n value) rt-ok  clear

% {:?} on string scans until raw whitespace; \\n is unescaped in output
(hello\\nworld ) ({:?}) mark 128 string sscan-fmt
1 eq  (sscan-fmt-7c: escape string count) rt-ok
dup length 11 eq  (sscan-fmt-7c: escape string length) rt-ok
% The scanned string should have a real newline at position 5
5 get 10b eq  (sscan-fmt-7c: escape string newline) rt-ok  clear

