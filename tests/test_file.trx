% ========================================================================
% SECTION: Regression Tests for 2026-03-19 Patches
% ========================================================================

% ====================================================================
% SUB-SECTION: token_op fix — failure path pushes only false
% ====================================================================

% Empty string → only false on stack (not "failed-string false")
() token  false eq  (token: empty string returns false only) rt-ok
() token  count  1 eq  (token: empty string count == 1 after token+check) rt-ok  clear

% Whitespace-only string → false
(   ) token  false eq  (token: whitespace-only string returns false) rt-ok  clear

% Successful token from string: pushes post-string, value, true
(42 rest) token  true eq  (token: success returns true) rt-ok
42 eq  (token: value is 42) rt-ok
( rest) eq  (token: post-string is remainder) rt-ok  clear

% Multiple tokens from a string
(10 20 30) token  pop  10 eq  (token: first token is 10) rt-ok
token  pop  20 eq  (token: second token is 20) rt-ok
token  pop  30 eq  (token: third token is 30) rt-ok
token  false eq  (token: exhausted string gives false) rt-ok  clear

% Token on name
(/foo bar) token  pop  /foo eq  (token: parses literal name from string) rt-ok  clear

clear

% ====================================================================
% SUB-SECTION: index_op off-by-one fix
% ====================================================================

% 0 index: copies top (needs 1 item below N plus N itself = 2 total)
99 0 index  99 eq  (index: 0 index copies top) rt-ok  clear

% 1 index: copies second item (needs 2 items below N plus N = 3 total)
10 20 1 index  10 eq  (index: 1 index copies second) rt-ok  clear

% 2 index: copies third item
10 20 30 2 index  10 eq  (index: 2 index copies third) rt-ok  clear

% n index where n is exactly op_count-1 (boundary)
1 2 3 4 5  4 index  1 eq  (index: boundary 4 index of 5 items copies bottom) rt-ok  clear

% index out of range — catch error
<< /index-check { pop clear true } >> { 10 20 2 index } try-catch  (index: out-of-range -> index-check) rt-ok  clear

clear

% ====================================================================
% SUB-SECTION: put_op error type fix (RangeCheck→LimitCheck for huge index)
% ====================================================================

% Normal out-of-range index -> IndexCheck
<< /index-check { pop clear true } >> { (abc) 5 65b put } try-catch  (put: string OOB -> index-check) rt-ok  clear

% String put in range works
3 string dup 0 65b put 0 get  65b eq  (put: string byte at index 0) rt-ok  clear

% Array put in range works
3 array dup 0 42 put 0 get  42 eq  (put: array value at index 0) rt-ok  clear

% Array put out of range → RangeCheck
<< /index-check { pop clear true } >> { 3 array 5 99 put } try-catch  (put: array OOB -> index-check) rt-ok  clear

clear

% ====================================================================
% SUB-SECTION: get_op — include key name in Undefined error
% ====================================================================

% Dict get with existing key
<< /a 10 /b 20 >> /a get  10 eq  (get: dict key /a = 10) rt-ok  clear

% Dict get with missing key → Undefined
<< /undefined { pop clear true } >> { << /a 1 >> /b get } try-catch  (get: dict missing -> undefined) rt-ok  clear

% Array get
[10 20 30] 1 get  20 eq  (get: array index 1 = 20) rt-ok  clear

% String get
(ABC) 0 get  65b eq  (get: string index 0 = A) rt-ok  clear

% Packed array get
{ 10 20 30 } 1 get  20 eq  (get: packed index 1 = 20) rt-ok  clear

clear

% ====================================================================
% SUB-SECTION: stopped_op / stop_op fixes
% ====================================================================

% stop inside stopped → true
{ stop } stopped  true eq  (stopped: stop gives true) rt-ok  clear

% Normal proc inside stopped → false
{ 42 pop } stopped  false eq  (stopped: normal exit gives false) rt-ok  clear

% Nested stopped: inner stop caught by inner stopped
{ { stop } stopped } stopped
exch true eq  (stopped: inner stop returns true to inner stopped) rt-ok
false eq  (stopped: outer stopped sees normal exit) rt-ok  clear

% stopped preserves values below
10 20 { stop } stopped
true eq  (stopped: stop result is true) rt-ok
20 eq  (stopped: value below preserved 20) rt-ok
10 eq  (stopped: value below preserved 10) rt-ok  clear

clear

% ====================================================================
% SUB-SECTION: forall_op — test on dict, array, string
% ====================================================================

% forall on array: sum elements
0 [1 2 3 4 5] { add } for-all  15 eq  (for-all: array sum 1..5 = 15) rt-ok

% forall on empty array
0 [] { add } for-all  0 eq  (for-all: empty array sum = 0) rt-ok

% forall on string: sum bytes
0b (ABC) { add } for-all  198b eq  (for-all: string byte sum A+B+C = 198b) rt-ok

% forall on dict: sum values
0 << /a 10 /b 20 /c 30 >> { exch pop add } for-all  60 eq  (for-all: dict sum values = 60) rt-ok

% forall on empty dict
0 << >> { exch pop add } for-all  0 eq  (for-all: empty dict sum = 0) rt-ok

clear

% ====================================================================
% SUB-SECTION: for_op — various step/limit combos
% ====================================================================

% Integer for: 1 to 5, step 1
0 1 1 5 { add } for  15 eq  (for: int 1..5 sum=15) rt-ok

% Integer for: step=2
0 1 2 9 { add } for  25 eq  (for: int step=2 sum=25) rt-ok

% Integer for: descending (step=-1)
0 5 -1 1 { add } for  15 eq  (for: int descending 5..1 sum=15) rt-ok

% Integer for: start > limit with positive step → no execution
0 5 1 1 { add } for  0 eq  (for: int start>limit no exec) rt-ok

% Real for
0. 1. 1. 3. { add } for  6. eq  (for: real 1..3 sum=6) rt-ok

% TypeCheck for incompatible types
<< /type-check { pop clear true } >> { 1 2. 5 { } for } try-catch  (for: type mismatch -> type-check) rt-ok  clear

clear

% ====================================================================
% SUB-SECTION: put-interval_op packed save tracking fix
% ====================================================================

% put-interval with packed source in save/restore context
5 array /pi-arr exch def
pi-arr 0 10 put
pi-arr 1 20 put
save
  pi-arr 0 { 99 88 } put-interval
  pi-arr 0 get 99 eq  (put-interval: packed src wrote 99) rt-ok
  pi-arr 1 get 88 eq  (put-interval: packed src wrote 88) rt-ok
restore
pi-arr 0 get 10 eq  (put-interval: restore reverted slot 0 to 10) rt-ok
pi-arr 1 get 20 eq  (put-interval: restore reverted slot 1 to 20) rt-ok

% put-interval with array source
5 string /pi-str exch def
pi-str 0 (hello) put-interval
pi-str (hello) eq  (put-interval: string wrote hello) rt-ok

% put-interval with offset
10 string /pi-str2 exch def
pi-str2 5 (world) put-interval
pi-str2 5 5 get-interval  (world) eq  (put-interval: string offset 5 wrote world) rt-ok

% put-interval type mismatch → TypeCheck
<< /type-check { pop clear true } >> { (abc) 0 [1 2 3] put-interval } try-catch  (put-interval: type mismatch -> type-check) rt-ok  clear

% put-interval range error → RangeCheck
<< /index-check { pop clear true } >> { (ab) 1 (xyz) put-interval } try-catch  (put-interval: overflow -> index-check) rt-ok  clear

clear

% ====================================================================
% SUB-SECTION: roll_op — negative roll and j=0
% ====================================================================

% Negative roll (downward rotation)
(a) (b) (c) 3 -1 roll
% Expected: (b) (c) (a) — top wraps to bottom
(a) eq  (roll: negative roll top element = a) rt-ok
(c) eq  (roll: negative roll second element = c) rt-ok
(b) eq  (roll: negative roll third element = b) rt-ok
clear

% Zero roll (no-op)
(a) (b) (c) 3 0 roll
(c) eq  (roll: 0 roll preserves top = c) rt-ok
(b) eq  (roll: 0 roll preserves second = b) rt-ok
(a) eq  (roll: 0 roll preserves third = a) rt-ok
clear

% Positive roll
(a) (b) (c) 3 1 roll
(b) eq  (roll: 3 1 roll top = b) rt-ok
(a) eq  (roll: 3 1 roll second = a) rt-ok
(c) eq  (roll: 3 1 roll third = c) rt-ok
clear

clear

