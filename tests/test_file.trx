128 string ({:g}) mark 3.14d sprint-fmt pop (3.14) eq (pfmt-2l: dbl {:g}) rt-ok
128 string ({:g}) mark 100000.d sprint-fmt pop (100000) eq (pfmt-2m: dbl {:g} 100000) rt-ok
128 string ({:g}) mark 1000000.d sprint-fmt pop (1e+06) eq (pfmt-2n: dbl {:g} 1e6) rt-ok
clear

