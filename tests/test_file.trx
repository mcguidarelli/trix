dup length 3 eq  (filter: all-pass length=3) rt-ok
dup 0 get  1 eq  (filter: all-pass[0]=1) rt-ok
dup 2 get  3 eq  (filter: all-pass[2]=3) rt-ok
pop  clear

% --- filter: none pass ---
[1 2 3] { false } filter
length 0 eq  (filter: none-pass length=0) rt-ok  clear

% --- filter: empty array ---
[] { true } filter  length 0 eq  (filter: empty array) rt-ok  clear

% --- filter: single element passes ---
[42] { 40 gt } filter
dup length 1 eq  (filter: single pass length=1) rt-ok
0 get  42 eq  (filter: single pass value=42) rt-ok  clear

% --- filter: single element fails ---
[42] { 50 gt } filter
length 0 eq  (filter: single fail length=0) rt-ok  clear

% --- filter: strings by length ---
[(hi) (hello) (yo) (world) (ok)] { length 3 gt } filter
dup length 2 eq  (filter: long strings length=2) rt-ok
dup 0 get  (hello) eq  (filter: long[0]=hello) rt-ok
dup 1 get  (world) eq  (filter: long[1]=world) rt-ok
pop  clear

% --- filter: original unchanged ---
[1 2 3 4 5] /orig exch def
orig { 3 gt } filter
dup length 2 eq  (filter: result length=2) rt-ok  pop
orig length 5 eq  (filter: orig length still 5) rt-ok
orig 0 get  1 eq  (filter: orig[0] still 1) rt-ok  clear

% --- filter: chained with map ---
[1 2 3 4 5 6] { 2 mod 0 eq } filter { dup mul } map
dup length 3 eq  (filter+map: length=3) rt-ok
dup 0 get  4 eq  (filter+map: 2^2=4) rt-ok
dup 1 get  16 eq  (filter+map: 4^2=16) rt-ok
dup 2 get  36 eq  (filter+map: 6^2=36) rt-ok
pop  clear

% --- filter: map then filter ---
[1 2 3 4 5] { dup mul } map { 10 gt } filter
dup length 2 eq  (map+filter: length=2) rt-ok
dup 0 get  16 eq  (map+filter: 4^2=16) rt-ok
dup 1 get  25 eq  (map+filter: 5^2=25) rt-ok
pop  clear

% --- filter: packed input ---
1 2 3 4 5  5 packed  { 3 gt } filter
dup length 2 eq  (filter: packed length=2) rt-ok
dup 0 get  4 eq  (filter: packed[0]=4) rt-ok
dup 1 get  5 eq  (filter: packed[1]=5) rt-ok
pop  clear

(Filter operator tests complete.) =

% ====================================================================
% SECTION: Uppercase / Lowercase Operators
% ====================================================================

% --- uppercase ---
(hello) uppercase  (HELLO) eq  (uppercase: hello->HELLO) rt-ok  clear
(Hello World) uppercase  (HELLO WORLD) eq  (uppercase: mixed case) rt-ok  clear
(ALREADY) uppercase  (ALREADY) eq  (uppercase: already upper) rt-ok  clear
(abc123def) uppercase  (ABC123DEF) eq  (uppercase: digits unchanged) rt-ok  clear
() uppercase  () eq  (uppercase: empty string) rt-ok  clear
(a) uppercase  (A) eq  (uppercase: single char) rt-ok  clear
(!@#$%^&*) uppercase  (!@#$%^&*) eq  (uppercase: symbols unchanged) rt-ok  clear

% --- lowercase ---
(HELLO) lowercase  (hello) eq  (lowercase: HELLO->hello) rt-ok  clear
(Hello World) lowercase  (hello world) eq  (lowercase: mixed case) rt-ok  clear
(already) lowercase  (already) eq  (lowercase: already lower) rt-ok  clear
(ABC123DEF) lowercase  (abc123def) eq  (lowercase: digits unchanged) rt-ok  clear
() lowercase  () eq  (lowercase: empty string) rt-ok  clear
(Z) lowercase  (z) eq  (lowercase: single char) rt-ok  clear

% --- roundtrip ---
(HeLLo WoRLd) lowercase uppercase  (HELLO WORLD) eq  (roundtrip: lower then upper) rt-ok  clear
(HeLLo WoRLd) uppercase lowercase  (hello world) eq  (roundtrip: upper then lower) rt-ok  clear

(Uppercase/lowercase tests complete.) =

% ====================================================================
% SECTION: Reverse Operator
% ====================================================================

% --- reverse: string ---
(hello) reverse  (olleh) eq  (reverse: hello->olleh) rt-ok  clear
(abcdef) reverse  (fedcba) eq  (reverse: abcdef) rt-ok  clear
(a) reverse  (a) eq  (reverse: single char) rt-ok  clear
() reverse  () eq  (reverse: empty string) rt-ok  clear
(abba) reverse  (abba) eq  (reverse: palindrome) rt-ok  clear

% --- reverse: array ---
[1 2 3 4 5] reverse
dup 0 get  5 eq  (reverse: arr[0]=5) rt-ok
dup 1 get  4 eq  (reverse: arr[1]=4) rt-ok
dup 2 get  3 eq  (reverse: arr[2]=3) rt-ok
dup 3 get  2 eq  (reverse: arr[3]=2) rt-ok
dup 4 get  1 eq  (reverse: arr[4]=1) rt-ok
length 5 eq  (reverse: arr length=5) rt-ok  clear

[42] reverse  0 get  42 eq  (reverse: single element array) rt-ok  clear
[] reverse  length 0 eq  (reverse: empty array) rt-ok  clear

% --- reverse: original unchanged ---
[1 2 3] /orig exch def
orig reverse
dup 0 get  3 eq  (reverse: result[0]=3) rt-ok  pop
orig 0 get  1 eq  (reverse: orig[0] still 1) rt-ok  clear

% --- reverse: packed ---
1 2 3  3 packed  reverse
dup 0 get  3 eq  (reverse: packed[0]=3) rt-ok
dup 2 get  1 eq  (reverse: packed[2]=1) rt-ok
pop  clear

% --- reverse: double reverse = identity ---
[10 20 30] reverse reverse
dup 0 get  10 eq  (reverse: double[0]=10) rt-ok
dup 2 get  30 eq  (reverse: double[2]=30) rt-ok
pop  clear

(hello) reverse reverse  (hello) eq  (reverse: string double=identity) rt-ok  clear

% --- reverse: composability ---
[5 3 1 4 2] sort reverse
dup 0 get  5 eq  (reverse: sort+reverse desc[0]=5) rt-ok
dup 4 get  1 eq  (reverse: sort+reverse desc[4]=1) rt-ok
pop  clear

(Reverse operator tests complete.) =

% ====================================================================
% SECTION: Local Variable Bindings { |name1 name2| body }
% ====================================================================

% --- basic binding ---
10 20 { |a b| a b add } exec
30 eq  (locals: a+b=30) rt-ok  clear

% --- binding order matches stack push order ---
1 2 3 { |x y z| x } exec  1 eq  (locals: x=1 deepest) rt-ok  clear
1 2 3 { |x y z| z } exec  3 eq  (locals: z=3 topmost) rt-ok  clear

% --- single local ---
42 { |x| x x mul } exec
1764 eq  (locals: x*x=1764) rt-ok  clear

% --- locals don't leak to outer scope ---
99 { |x| x } exec  99 eq  (locals: result correct) rt-ok
{ x } try  /undefined eq  (locals: x not visible outside) rt-ok  clear

% --- locals with arithmetic ---
3.0 4.0 { |x y| x x mul  y y mul  add  sqrt } exec
5.0 eq  (locals: hypotenuse 3-4-5) rt-ok  clear

% --- locals with string operations ---
(hello) (world) { |greeting name| greeting length  name length  add } exec
10 eq  (locals: string lengths 5+5=10) rt-ok  clear

% --- locals in named proc ---
/quadratic { |a b c| a c mul 4 mul  b b mul  exch sub } def
1 5 6 quadratic
1 eq  (locals: b^2-4ac = 25-24 = 1) rt-ok  clear

% --- nested procs with locals ---
10 { |outer| 20 { |inner| outer inner add } exec } exec
30 eq  (locals: nested outer+inner=30) rt-ok  clear

% --- locals with map ---
[1 2 3 4 5] 2 { |factor| { factor mul } map } exec
dup 0 get  2 eq  (locals+map: 1*2=2) rt-ok
dup 4 get  10 eq  (locals+map: 5*2=10) rt-ok
pop  clear

% --- locals with filter ---
[1 2 3 4 5 6] 3 { |threshold| { threshold gt } filter } exec
dup length 3 eq  (locals+filter: 3 elements > 3) rt-ok
dup 0 get  4 eq  (locals+filter: first is 4) rt-ok
pop  clear

% --- locals with dip ---
10 20 99 { |a b| a b add } dip
99 eq  (locals+dip: hidden preserved) rt-ok
30 eq  (locals+dip: a+b=30) rt-ok  clear

% --- empty body ---
42 { |x| } exec
count 0 eq  (locals: empty body leaves nothing) rt-ok  clear

% --- locals preserve dict stack depth ---
count-dictstack
10 20 { |a b| a b add } exec  pop
count-dictstack eq  (locals: dict stack balanced) rt-ok  clear

% --- locals: exit across locals boundary cleans dict stack ---
count-dictstack
0 { |acc| 1 1 10 { |n| n 5 gt { exit } if } for acc } exec pop
count-dictstack eq  (locals: exit cleans dict stack) rt-ok  clear

% --- locals: stop across locals boundary cleans dict stack ---
count-dictstack
{ 42 { |x| stop } exec } stopped pop
count-dictstack eq  (locals: stop cleans dict stack) rt-ok  clear

% --- locals: nested exit with multiple locals scopes ---
count-dictstack
1 1 3 { |i| 1 1 5 { |j| i j mul 10 gt { exit } if } for } for
count-dictstack eq  (locals: nested exit cleans all locals) rt-ok  clear

% --- locals: error across locals boundary cleans dict stack ---
clear count-dictstack
42 { |x| { /no-such-name load } try pop } exec
count-dictstack eq  (locals: error cleans dict stack) rt-ok  clear

(Local variable binding tests complete.) =

% ====================================================================
% SECTION: Keys / Values Operators
% ====================================================================

% --- keys: basic ---
<< /a 1 /b 2 /c 3 >> keys
dup length 3 eq  (keys: length=3) rt-ok
sort  % sort for deterministic order
dup 0 get  /a eq  (keys: sorted[0]=/a) rt-ok
dup 1 get  /b eq  (keys: sorted[1]=/b) rt-ok
dup 2 get  /c eq  (keys: sorted[2]=/c) rt-ok
pop  clear

% --- values: basic ---
<< /x 10 /y 20 /z 30 >> values
sort
dup 0 get  10 eq  (values: sorted[0]=10) rt-ok
dup 1 get  20 eq  (values: sorted[1]=20) rt-ok
dup 2 get  30 eq  (values: sorted[2]=30) rt-ok
pop  clear

% --- keys: empty dict ---
0 dict keys  length 0 eq  (keys: empty dict) rt-ok  clear

% --- values: empty dict ---
0 dict values  length 0 eq  (values: empty dict) rt-ok  clear

% --- keys: single entry ---
<< /only 42 >> keys
dup length 1 eq  (keys: single length=1) rt-ok
0 get  /only eq  (keys: single key=/only) rt-ok  clear

% --- values: single entry ---
<< /only 42 >> values
dup length 1 eq  (values: single length=1) rt-ok
0 get  42 eq  (values: single value=42) rt-ok  clear

% --- keys + values: same dict, matching lengths ---
<< /a 1 /b 2 /c 3 /d 4 >> dup
keys length exch values length eq  (keys/values: same length) rt-ok  clear

% --- values: mixed types ---
<< /i 42 /s (hello) /b true >> values
dup length 3 eq  (values: mixed length=3) rt-ok  pop  clear

% --- keys: composable with filter ---
<< /a 1 /b 2 /c 3 >> keys { /a ne } filter
length 2 eq  (keys+filter: filtered out /a) rt-ok  clear

(Keys/values tests complete.) =

% ====================================================================
% SECTION: Nip / Tuck Operators
% ====================================================================

% --- nip ---
1 2 nip  2 eq  (nip: keeps top) rt-ok  clear
1 2 nip  count 1 eq  (nip: depth=1) rt-ok  clear
10 20 30 nip  30 eq  (nip: top=30) rt-ok  20 ne  (nip: dropped 20) rt-ok  clear

% --- tuck ---
1 2 tuck  2 eq  (tuck: top=2) rt-ok
1 eq  (tuck: second=1) rt-ok
2 eq  (tuck: third=2) rt-ok  clear
1 2 tuck  count 3 eq  (tuck: depth=3) rt-ok  clear

% --- nip/tuck with composites ---
[1] [2] nip  0 get  2 eq  (nip: array) rt-ok  clear
[1] [2] tuck  0 get  2 eq  (tuck: top=[2]) rt-ok
0 get  1 eq  (tuck: second=[1]) rt-ok
0 get  2 eq  (tuck: third=[2]) rt-ok  clear

(Nip/tuck tests complete.) =

% ====================================================================
% SECTION: Split Operator
% ====================================================================

% --- split: basic comma delimiter ---
(a,b,c) (,) split
dup length 3 eq  (split: comma length=3) rt-ok
dup 0 get  (a) eq  (split: comma[0]=a) rt-ok
dup 1 get  (b) eq  (split: comma[1]=b) rt-ok
dup 2 get  (c) eq  (split: comma[2]=c) rt-ok
pop  clear

% --- split: multi-char delimiter ---
(one--two--three) (--) split
dup length 3 eq  (split: multi-delim length=3) rt-ok
dup 0 get  (one) eq  (split: multi[0]=one) rt-ok
dup 1 get  (two) eq  (split: multi[1]=two) rt-ok
dup 2 get  (three) eq  (split: multi[2]=three) rt-ok
pop  clear

% --- split: no delimiter found ---
(hello) (,) split
dup length 1 eq  (split: not-found length=1) rt-ok
0 get  (hello) eq  (split: not-found[0]=hello) rt-ok  clear

% --- split: delimiter at start ---
(,hello) (,) split
dup length 2 eq  (split: start-delim length=2) rt-ok
dup 0 get  () eq  (split: start-delim[0]=empty) rt-ok
dup 1 get  (hello) eq  (split: start-delim[1]=hello) rt-ok
pop  clear

% --- split: delimiter at end ---
(hello,) (,) split
dup length 2 eq  (split: end-delim length=2) rt-ok
dup 0 get  (hello) eq  (split: end-delim[0]=hello) rt-ok
dup 1 get  () eq  (split: end-delim[1]=empty) rt-ok
pop  clear

% --- split: adjacent delimiters ---
(a,,b) (,) split
dup length 3 eq  (split: adjacent length=3) rt-ok
dup 0 get  (a) eq  (split: adjacent[0]=a) rt-ok
dup 1 get  () eq  (split: adjacent[1]=empty) rt-ok
dup 2 get  (b) eq  (split: adjacent[2]=b) rt-ok
pop  clear

% --- split: empty string ---
() (,) split
dup length 1 eq  (split: empty-str length=1) rt-ok
0 get  () eq  (split: empty-str[0]=empty) rt-ok  clear

% --- split: empty delimiter (split into chars) ---
(abc) () split
dup length 3 eq  (split: chars length=3) rt-ok
dup 0 get  (a) eq  (split: chars[0]=a) rt-ok
dup 1 get  (b) eq  (split: chars[1]=b) rt-ok
dup 2 get  (c) eq  (split: chars[2]=c) rt-ok
pop  clear

% --- split: single char string ---
(x) (,) split
dup length 1 eq  (split: single-char length=1) rt-ok
0 get  (x) eq  (split: single-char[0]=x) rt-ok  clear

% --- split: space delimiter ---
(hello world foo) ( ) split
dup length 3 eq  (split: space length=3) rt-ok
dup 0 get  (hello) eq  (split: space[0]=hello) rt-ok
dup 1 get  (world) eq  (split: space[1]=world) rt-ok
dup 2 get  (foo) eq  (split: space[2]=foo) rt-ok
pop  clear

% --- split: composable with map ---
(1,2,3) (,) split { length } map
dup 0 get  1 eq  (split+map: len(1)=1) rt-ok
dup 1 get  1 eq  (split+map: len(2)=1) rt-ok
dup 2 get  1 eq  (split+map: len(3)=1) rt-ok
pop  clear

(Split operator tests complete.) =

% ====================================================================
% SECTION: Concat / Join Operators
% ====================================================================

% --- concat: basic ---
(hello) ( world) concat  (hello world) eq  (concat: hello+world) rt-ok  clear
(abc) (def) concat  (abcdef) eq  (concat: abc+def) rt-ok  clear

% --- concat: empty strings ---
() (hello) concat  (hello) eq  (concat: empty+hello) rt-ok  clear
(hello) () concat  (hello) eq  (concat: hello+empty) rt-ok  clear
() () concat  () eq  (concat: empty+empty) rt-ok  clear

% --- concat: single chars ---
(a) (b) concat  (ab) eq  (concat: a+b) rt-ok  clear

% --- join: basic ---
[(hello) (world) (foo)] (,) join
(hello,world,foo) eq  (join: comma) rt-ok  clear

% --- join: space separator ---
[(one) (two) (three)] ( ) join
(one two three) eq  (join: space) rt-ok  clear

% --- join: empty separator ---
[(a) (b) (c)] () join
(abc) eq  (join: empty sep) rt-ok  clear

% --- join: multi-char separator ---
[(x) (y) (z)] (--) join
(x--y--z) eq  (join: multi-char sep) rt-ok  clear

% --- join: single element ---
[(hello)] (,) join  (hello) eq  (join: single element) rt-ok  clear

% --- join: empty array ---
[] (,) join  () eq  (join: empty array) rt-ok  clear

% --- join: empty strings in array ---
[() (a) ()] (,) join
(,a,) eq  (join: empty strings) rt-ok  clear

% --- split + join roundtrip ---
(a,b,c) (,) split (,) join
(a,b,c) eq  (split+join: roundtrip) rt-ok  clear

% --- join + split roundtrip ---
[(hello) (world)] ( ) join ( ) split
dup 0 get  (hello) eq  (join+split: [0]=hello) rt-ok
dup 1 get  (world) eq  (join+split: [1]=world) rt-ok
pop  clear

(Concat/join tests complete.) =

% ====================================================================
% SECTION: Replace Operator
% ====================================================================

% --- replace: basic ---
(hello world) (world) (earth) replace
(hello earth) eq  (replace: world->earth) rt-ok  clear

% --- replace: multiple occurrences ---
(aXbXcXd) (X) (--) replace
(a--b--c--d) eq  (replace: all X replaced) rt-ok  clear

% --- replace: not found ---
(hello) (xyz) (abc) replace
(hello) eq  (replace: not found unchanged) rt-ok  clear

% --- replace: empty old (no-op) ---
(hello) () (abc) replace
(hello) eq  (replace: empty old unchanged) rt-ok  clear

% --- replace: empty new (deletion) ---
(hello world) ( world) () replace
(hello) eq  (replace: delete suffix) rt-ok  clear

% --- replace: replace with longer ---
(ab) (a) (xyz) replace
(xyzb) eq  (replace: longer replacement) rt-ok  clear

% --- replace: replace with shorter ---
(aXXb) (XX) (Y) replace
(aYb) eq  (replace: shorter replacement) rt-ok  clear

% --- replace: entire string is match ---
(abc) (abc) (xyz) replace
(xyz) eq  (replace: full match) rt-ok  clear

% --- replace: adjacent matches ---
(aaa) (a) (bb) replace
(bbbbbb) eq  (replace: adjacent a->bb) rt-ok  clear

% --- replace: multi-char search ---
(foo-bar-baz) (-bar) () replace
(foo-baz) eq  (replace: remove -bar) rt-ok  clear

% --- replace: composable with split+join ---
% split+join is equivalent to replace
(a.b.c) (.) (/) replace
(a.b.c) (.) split (/) join
eq  (replace: matches split+join) rt-ok  clear

(Replace operator tests complete.) =

% ====================================================================
% SECTION: While Operator
% ====================================================================

% --- while: basic countdown ---
5  { dup 0 gt } { 1 sub } while
0 eq  (while: countdown to 0) rt-ok  clear

% --- while: accumulate sum 1..5 ---
0 1  { dup 5 le } { dup 3 1 roll add exch 1 add } while  pop
15 eq  (while: sum 1..5 = 15) rt-ok  clear

% --- while: false on first check ---
0  { false } { 1 add } while
0 eq  (while: false immediately) rt-ok  clear

% --- while: single iteration ---
0  { dup 0 eq } { 1 add } while
1 eq  (while: single iteration) rt-ok  clear

% --- while: with locals ---
0 10 { |limit| { dup limit lt } { 1 add } while } exec
10 eq  (while+locals: count to limit) rt-ok  clear

% --- while: exit breaks out ---
0  { true } { dup 5 ge { exit } if  1 add } while
5 eq  (while: exit at 5) rt-ok  clear

% --- while: nested while ---
0  { dup 3 lt } {
    0  { dup 2 lt } { 1 add } while  pop
    1 add
} while
3 eq  (while: nested) rt-ok  clear

% --- while: stack depth unchanged on false ---
42  { false } { } while
42 eq  (while: stack balanced on false) rt-ok  clear

(While operator tests complete.) =

% ====================================================================
% SECTION: Index-of / Find Operators
% ====================================================================

% --- index-of: found ---
[10 20 30 40 50] 30 index-of  2 eq  (index-of: 30 at index 2) rt-ok  clear
[10 20 30 40 50] 10 index-of  0 eq  (index-of: 10 at index 0) rt-ok  clear
[10 20 30 40 50] 50 index-of  4 eq  (index-of: 50 at index 4) rt-ok  clear

% --- index-of: not found ---
[10 20 30] 99 index-of  -1 eq  (index-of: not found = -1) rt-ok  clear

% --- index-of: empty array ---
[] 42 index-of  -1 eq  (index-of: empty = -1) rt-ok  clear

% --- index-of: first occurrence ---
[1 2 3 2 1] 2 index-of  1 eq  (index-of: first occurrence) rt-ok  clear

% --- index-of: strings ---
[(apple) (banana) (cherry)] (banana) index-of  1 eq  (index-of: string match) rt-ok  clear
[(apple) (banana)] (grape) index-of  -1 eq  (index-of: string not found) rt-ok  clear

% --- index-of: packed ---
1 2 3 4 5  5 packed  3 index-of  2 eq  (index-of: packed) rt-ok  clear

% --- find: found ---
[1 2 3 4 5] { 3 gt } find
true eq  (find: found=true) rt-ok
4 eq  (find: first > 3 is 4) rt-ok  clear

% --- find: not found ---
[1 2 3] { 10 gt } find
false eq  (find: not found=false) rt-ok  clear

% --- find: empty array ---
[] { true } find
false eq  (find: empty=false) rt-ok  clear

% --- find: first element matches ---
[99 1 2 3] { 50 gt } find
true eq  (find: first-match true) rt-ok
99 eq  (find: first-match value=99) rt-ok  clear

% --- find: last element matches ---
[1 2 3 99] { 50 gt } find
true eq  (find: last-match true) rt-ok
99 eq  (find: last-match value=99) rt-ok  clear

% --- find: string predicate ---
[(hi) (hello) (hey)] { length 4 gt } find
true eq  (find: long string found) rt-ok
(hello) eq  (find: long string=hello) rt-ok  clear

% --- find: all match (returns first) ---
[10 20 30] { 0 gt } find
true eq  (find: all-match true) rt-ok
10 eq  (find: all-match first=10) rt-ok  clear

% --- find: packed input ---
1 2 3 4 5  5 packed  { 3 eq } find
true eq  (find: packed found) rt-ok
3 eq  (find: packed value=3) rt-ok  clear

(Index-of/find tests complete.) =

% ====================================================================
% SECTION: Clock Operator
% ====================================================================

% --- clock: returns a ulong ---
clock type  /ulong-type eq  (clock: type is ulong) rt-ok  clear

% --- clock: monotonically increasing ---
clock clock exch sub  0ul ge  (clock: monotonic) rt-ok  clear

% --- clock: measurable elapsed time ---
clock  0 1 100000 { pop } for  clock
exch sub  0ul gt  (clock: elapsed > 0) rt-ok  clear

(Clock operator tests complete.) =

% ====================================================================
% SECTION: Reduce Operator
% ====================================================================

% --- reduce: sum ---
[1 2 3 4 5] 0 { add } reduce
15 eq  (reduce: sum 1..5 = 15) rt-ok  clear

% --- reduce: product ---
[1 2 3 4 5] 1 { mul } reduce
120 eq  (reduce: product 1..5 = 120) rt-ok  clear

% --- reduce: empty array returns init ---
[] 42 { add } reduce
42 eq  (reduce: empty returns init) rt-ok  clear

% --- reduce: single element ---
[10] 5 { add } reduce
15 eq  (reduce: single 5+10=15) rt-ok  clear

% --- reduce: string concat via reduce ---
[(hello) ( ) (world)] () { concat } reduce
(hello world) eq  (reduce: string concat) rt-ok  clear

% --- reduce: max via reduce ---
[3 7 2 9 1 8] 0 { max } reduce
9 eq  (reduce: max=9) rt-ok  clear

% --- reduce: count elements (ignore values) ---
[10 20 30 40] 0 { pop 1 add } reduce
4 eq  (reduce: count=4) rt-ok  clear

% --- reduce: with locals ---
[1 2 3 4] 0 { |acc x| acc x x mul add } reduce
30 eq  (reduce+locals: sum of squares 1+4+9+16=30) rt-ok  clear

