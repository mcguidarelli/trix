(9223372036854775808) ({:d}) mark 0ul sscan-fmt
1 eq  (sscan-fmt-33e: ulong 2^63 count) rt-ok
9223372036854775808ul eq  (sscan-fmt-33e: ulong 2^63 value) rt-ok  clear

% byte at boundaries
(128) ({:d}) mark 0b sscan-fmt
1 eq  (sscan-fmt-33f: byte 128 count) rt-ok
128b eq  (sscan-fmt-33f: byte 128 value) rt-ok  clear

(0) ({:d}) mark 0b sscan-fmt
1 eq  (sscan-fmt-33g: byte 0 count) rt-ok
0b eq  (sscan-fmt-33g: byte 0 value) rt-ok  clear

% hint does not override explicit suffix
(42) ({:d}) mark 0 sscan-fmt
1 eq  (sscan-fmt-33q: int hint no suffix count) rt-ok
42 eq  (sscan-fmt-33q: int hint no suffix value) rt-ok  clear

% multiple typed targets in one format
(4294967295 128) ({:d} {:d}) mark 0u 0b sscan-fmt
2 eq  (sscan-fmt-33i: multi-type count) rt-ok
128b eq  (sscan-fmt-33i: multi-type byte) rt-ok
4294967295u eq  (sscan-fmt-33i: multi-type uint) rt-ok  clear

% --- 34. Literal delimiter stress (issue 2 fix) ---

% various punctuation delimiters
(1;2;3) ({:d};{:d};{:d}) mark 0 0 0 sscan-fmt
3 eq  (sscan-fmt-34a: semicolon delim count) rt-ok
3 eq  (sscan-fmt-34a: semicolon delim val3) rt-ok
2 eq  (sscan-fmt-34a: semicolon delim val2) rt-ok
1 eq  (sscan-fmt-34a: semicolon delim val1) rt-ok  clear

(x=10&y=20) (x={:d}&y={:d}) mark 0 0 sscan-fmt
2 eq  (sscan-fmt-34b: ampersand kv count) rt-ok
20 eq  (sscan-fmt-34b: ampersand kv y) rt-ok
10 eq  (sscan-fmt-34b: ampersand kv x) rt-ok  clear

([42]) ([{:d}]) mark 0 sscan-fmt
1 eq  (sscan-fmt-34c: bracket delim count) rt-ok
42 eq  (sscan-fmt-34c: bracket delim value) rt-ok  clear

% number immediately followed by string via literal
save
(42=hello ) ({:d}={:s}) mark 0 128 string sscan-fmt
2 eq  (sscan-fmt-34d: num=str count) rt-ok
(hello) eq  (sscan-fmt-34d: num=str string) rt-ok
42 eq  (sscan-fmt-34d: num=str int) rt-ok
restore

% float with literal delimiters
(3.14/2.71) ({:f}/{:f}) mark 0. 0. sscan-fmt
2 eq  (sscan-fmt-34e: float slash count) rt-ok
2.71 eq  (sscan-fmt-34e: float slash val2) rt-ok
3.14 eq  (sscan-fmt-34e: float slash val1) rt-ok  clear

% tab and special whitespace between fields
(100	200) ({:d} {:d}) mark 0 0 sscan-fmt
2 eq  (sscan-fmt-34f: tab sep count) rt-ok
200 eq  (sscan-fmt-34f: tab sep val2) rt-ok
100 eq  (sscan-fmt-34f: tab sep val1) rt-ok  clear

% adjacent numbers with no separator (precision-limited)
(1234) ({:.2d}{:.2d}) mark 0 0 sscan-fmt
2 eq  (sscan-fmt-34g: adjacent precision count) rt-ok
34 eq  (sscan-fmt-34g: adjacent precision val2) rt-ok
12 eq  (sscan-fmt-34g: adjacent precision val1) rt-ok  clear

% no separator: first field consumes all digits
<< /scan-type-fail { clear true } >> { (4277) ({:d}{:d}) mark 0 0 sscan-fmt } try-catch  (sscan-fmt-34q: no sep exhausts input) rt-ok  clear

% --- 35. Trailing fill stress (issue 3 fix) ---

% dash fill: all alignments
(---42) ({:->d}) mark 0 sscan-fmt
1 eq  (sscan-fmt-35a: dash right count) rt-ok
42 eq  (sscan-fmt-35a: dash right value) rt-ok  clear

(42---) ({:-<.5d}) mark 0 sscan-fmt
1 eq  (sscan-fmt-35b: dash left count) rt-ok
42 eq  (sscan-fmt-35b: dash left value) rt-ok  clear

(--42---) ({:-^.7d}) mark 0 sscan-fmt
1 eq  (sscan-fmt-35c: dash center count) rt-ok
42 eq  (sscan-fmt-35c: dash center value) rt-ok  clear

% plus fill with negative value
(+++-99+++) ({:+^.9d}) mark 0 sscan-fmt
1 eq  (sscan-fmt-35d: plus center neg count) rt-ok
-99 eq  (sscan-fmt-35d: plus center neg value) rt-ok  clear

% dot fill with float values
(.1.5.) ({:.^.5f}) mark 0. sscan-fmt
1 eq  (sscan-fmt-35e: dot center 1.5 count) rt-ok
1.5 eq  (sscan-fmt-35e: dot center 1.5 value) rt-ok  clear

(..0.25..) ({:.^.7f}) mark 0. sscan-fmt
1 eq  (sscan-fmt-35f: dot center 0.25 count) rt-ok
0.25 eq  (sscan-fmt-35f: dot center 0.25 value) rt-ok  clear

(...100...) ({:.^.9f}) mark 0. sscan-fmt
1 eq  (sscan-fmt-35g: dot center int-like float count) rt-ok
100. eq  (sscan-fmt-35g: dot center int-like float value) rt-ok  clear

% zero fill left-aligned (0 is ambiguous as fill vs digit, so value includes trailing zeros)
(42000) ({:0<.5d}) mark 0 sscan-fmt
1 eq  (sscan-fmt-35q: zero left count) rt-ok
42000 eq  (sscan-fmt-35q: zero left value) rt-ok  clear

(7000000) ({:0<.7d}) mark 0 sscan-fmt
1 eq  (sscan-fmt-35i: zero left single digit count) rt-ok
7000000 eq  (sscan-fmt-35i: zero left single digit value) rt-ok  clear

% non-numeric fill (should work without retry)
(***42***) ({:*^.8d}) mark 0 sscan-fmt
1 eq  (sscan-fmt-35j: star center count) rt-ok
42 eq  (sscan-fmt-35j: star center value) rt-ok  clear

(42____) ({:_<.6d}) mark 0 sscan-fmt
1 eq  (sscan-fmt-35k: underscore left count) rt-ok
42 eq  (sscan-fmt-35k: underscore left value) rt-ok  clear

% combined: fill + delimiter in same format
(--42--,--7--) ({:-^.6d},{:-^.5d}) mark 0 0 sscan-fmt
2 eq  (sscan-fmt-35l: fill+delim count) rt-ok
7 eq  (sscan-fmt-35l: fill+delim val2) rt-ok
42 eq  (sscan-fmt-35l: fill+delim val1) rt-ok  clear

% fill with typed target hint
(---4294967295---) ({:-^.16d}) mark 0u sscan-fmt
1 eq  (sscan-fmt-35m: fill+hint uint count) rt-ok
4294967295u eq  (sscan-fmt-35m: fill+hint uint value) rt-ok  clear

% width enforcement with fill
(--42--) ({:-^6.6d}) mark 0 sscan-fmt
1 eq  (sscan-fmt-35n: fill width=precision count) rt-ok
42 eq  (sscan-fmt-35n: fill width=precision value) rt-ok  clear

% --- 36. Phase 1 correctness fixes ---

% B1: lone trailing '{' at end of format-string
<< /invalid-format-string { clear true } >> { (x{) (x{) mark sscan-fmt } try-catch  (sscan-fmt-36a: lone trailing { -> invalid-format-string) rt-ok  clear

% B1: lone trailing '}' at end of format-string
<< /invalid-format-string { clear true } >> { (x}) (x}) mark sscan-fmt } try-catch  (sscan-fmt-36b: lone trailing } -> invalid-format-string) rt-ok  clear

% B5: readonly target reached after successful scan -> invalid-access (not scan-input-fail)
<< /invalid-access { clear true } >> { (hello ) ({:s}) mark (readonly)#r sscan-fmt } try-catch  (sscan-fmt-36c: readonly target -> invalid-access) rt-ok  clear

% B6: {:0...} (PrintFmt zero-pad flag) -> invalid-format-string (not range-check)
<< /invalid-format-string { clear true } >> { (42) ({:0d}) mark 0 sscan-fmt } try-catch  (sscan-fmt-36d: zero-pad flag -> invalid-format-string) rt-ok  clear

% B7: :c with no width/precision -> invalid-format-string (not scan-input-fail)
<< /invalid-format-string { clear true } >> { (hello) ({:c}) mark 128 string sscan-fmt } try-catch  (sscan-fmt-36e: :c missing width -> invalid-format-string) rt-ok  clear

% --- 37. Phase 2 strict type safety (B2) ---
% Target type acts as an implicit suffix for unsuffixed input, but NO implicit
% lossy conversion is performed.  The coercion-capable Number::scan(buffer, type)
% API remains available for callers that explicitly want coercion.

% Fractional literal scanned into integer target is rejected (was silently truncated)
<< /scan-type-fail { clear true } >> { (42.5) ({:d}) mark 0 sscan-fmt } try-catch  (sscan-fmt-37a: 42.5 to int -> scan-type-fail) rt-ok  clear
<< /scan-type-fail { clear true } >> { (99.9) ({:d}) mark 0 sscan-fmt } try-catch  (sscan-fmt-37b: 99.9 to int -> scan-type-fail) rt-ok  clear
<< /scan-type-fail { clear true } >> { (-3.7) ({:d}) mark 0 sscan-fmt } try-catch  (sscan-fmt-37c: -3.7 to int -> scan-type-fail) rt-ok  clear

% Unsigned-suffixed input into signed target is rejected
<< /scan-type-fail { clear true } >> { (42u) ({:d}) mark 0i sscan-fmt } try-catch  (sscan-fmt-37d: 42u to int -> scan-type-fail) rt-ok  clear

% Scientific notation literal into integer target is rejected
<< /scan-type-fail { clear true } >> { (1e3) ({:d}) mark 0 sscan-fmt } try-catch  (sscan-fmt-37e: 1e3 to int -> scan-type-fail) rt-ok  clear
<< /scan-type-fail { clear true } >> { (1.5e3) ({:d}) mark 0 sscan-fmt } try-catch  (sscan-fmt-37f: 1.5e3 to int -> scan-type-fail) rt-ok  clear

% Explicit double suffix into real target is rejected (explicit suffix wins over hint)
<< /scan-type-fail { clear true } >> { (3.14d) ({:f}) mark 0. sscan-fmt } try-catch  (sscan-fmt-37g: 3.14d to real -> scan-type-fail) rt-ok  clear

% Byte scan :d rejects non-byte literals
<< /scan-type-fail { clear true } >> { (42.5) ({:d}) mark 0b sscan-fmt } try-catch  (sscan-fmt-37q: 42.5 to byte -> scan-type-fail) rt-ok  clear

% --- 37 positive: hint-as-suffix still works ---

% Double hint on un-suffixed float: promoted via hint
(3.14) ({:f}) mark 0.d sscan-fmt
1 eq  (sscan-fmt-37i: double hint count) rt-ok
dup type /double-type eq  (sscan-fmt-37i: double hint type) rt-ok
3.14d eq  (sscan-fmt-37i: double hint value) rt-ok  clear

(1.5e3) ({:f}) mark 0.d sscan-fmt
1 eq  (sscan-fmt-37j: double sci hint count) rt-ok
1500.d eq  (sscan-fmt-37j: double sci hint value) rt-ok  clear

% Real hint on un-suffixed float: stays Real
(3.14) ({:f}) mark 0. sscan-fmt
1 eq  (sscan-fmt-37k: real hint count) rt-ok
dup type /real-type eq  (sscan-fmt-37k: real hint type) rt-ok
3.14 eq  (sscan-fmt-37k: real hint value) rt-ok  clear

% Byte target, bare integer literal: hint-as-suffix gives Byte
(65) ({:d}) mark 0b sscan-fmt
1 eq  (sscan-fmt-37l: byte hint count) rt-ok
65b eq  (sscan-fmt-37l: byte hint value) rt-ok  clear

% UInteger target, value that fits: hint-as-suffix
(3000000000) ({:d}) mark 0u sscan-fmt
1 eq  (sscan-fmt-37m: uint hint count) rt-ok
3000000000u eq  (sscan-fmt-37m: uint hint value) rt-ok  clear

% Null target: auto-detect natural type
(42) ({:d}) mark null sscan-fmt
1 eq  (sscan-fmt-37n: null->int count) rt-ok
dup type /integer-type eq  (sscan-fmt-37n: null->int type) rt-ok
42 eq  (sscan-fmt-37n: null->int value) rt-ok  clear

(3.14) ({:f}) mark null sscan-fmt
1 eq  (sscan-fmt-37o: null->real count) rt-ok
dup type /real-type eq  (sscan-fmt-37o: null->real type) rt-ok
3.14 eq  (sscan-fmt-37o: null->real value) rt-ok  clear

% --- 38. Phase 3 hex type specifier :x ---
% Optional 0x/0X prefix.  Target type acts as implicit suffix.  Strict: no
% coercion between parsed type and target type (same contract as :d).

% Basic hex into UInteger
(FF) ({:x}) mark 0u sscan-fmt
1 eq  (sscan-fmt-38a: hex FF uint count) rt-ok
255u eq  (sscan-fmt-38a: hex FF uint value) rt-ok  clear

% Lowercase hex digits
(ff) ({:x}) mark 0u sscan-fmt
1 eq  (sscan-fmt-38b: hex ff uint count) rt-ok
255u eq  (sscan-fmt-38b: hex ff uint value) rt-ok  clear

% 0x prefix accepted
(0xFF) ({:x}) mark 0u sscan-fmt
1 eq  (sscan-fmt-38c: 0xFF uint count) rt-ok
255u eq  (sscan-fmt-38c: 0xFF uint value) rt-ok  clear

% 0X (uppercase) prefix accepted
(0XFF) ({:x}) mark 0u sscan-fmt
1 eq  (sscan-fmt-38d: 0XFF uint count) rt-ok
255u eq  (sscan-fmt-38d: 0XFF uint value) rt-ok  clear

% Hex into Integer
(ff) ({:x}) mark 0 sscan-fmt
1 eq  (sscan-fmt-38e: hex ff int count) rt-ok
255 eq  (sscan-fmt-38e: hex ff int value) rt-ok  clear

% Hex into Byte
(ff) ({:x}) mark 0b sscan-fmt
1 eq  (sscan-fmt-38f: hex ff byte count) rt-ok
255b eq  (sscan-fmt-38f: hex ff byte value) rt-ok  clear

% Large hex into Long via hint (no inline #l suffix needed)
(DEADBEEF) ({:x}) mark 0l sscan-fmt
1 eq  (sscan-fmt-38g: hex DEADBEEF long count) rt-ok
3735928559l eq  (sscan-fmt-38g: hex DEADBEEF long value) rt-ok  clear

% Null target auto-detects as Integer
(ff) ({:x}) mark null sscan-fmt
1 eq  (sscan-fmt-38q: hex null->int count) rt-ok
dup type /integer-type eq  (sscan-fmt-38q: hex null->int type) rt-ok
255 eq  (sscan-fmt-38q: hex null->int value) rt-ok  clear

% Invalid hex rejected
<< /scan-type-fail { clear true } >> { (zz) ({:x}) mark 0 sscan-fmt } try-catch  (sscan-fmt-38i: zz not hex -> scan-type-fail) rt-ok  clear

% :x on Real target rejected (type-check at scan-input)
<< /type-check { clear true } >> { (3.14) ({:x}) mark 0. sscan-fmt } try-catch  (sscan-fmt-38j: :x on real -> type-check) rt-ok  clear

% :x overflow
<< /numerical-overflow { clear true } >> { (FFF) ({:x}) mark 0b sscan-fmt } try-catch  (sscan-fmt-38k: FFF too big for byte -> numerical-overflow) rt-ok  clear

% Empty hex payload rejected
<< /scan-type-fail { clear true } >> { (0x) ({:x}) mark 0 sscan-fmt } try-catch  (sscan-fmt-38l: 0x with no digits -> scan-type-fail) rt-ok  clear

% :x with fill/align still works
(00ff) ({:0>x}) mark 0u sscan-fmt
1 eq  (sscan-fmt-38m: zero-right-fill hex count) rt-ok
255u eq  (sscan-fmt-38m: zero-right-fill hex value) rt-ok  clear

(--ff--) ({:-^.6x}) mark 0u sscan-fmt
1 eq  (sscan-fmt-38n: dash-center-fill hex count) rt-ok
255u eq  (sscan-fmt-38n: dash-center-fill hex value) rt-ok  clear

% --- 38 drop: :! is no longer a valid type specifier ---
<< /invalid-format-string { clear true } >> { (true) ({:!}) mark false sscan-fmt } try-catch  (sscan-fmt-38o: :! dropped -> invalid-format-string) rt-ok  clear

% --- 39. fscan-fmt (Phase 5): scan from a readable stream ---
% Stack effect: stream fmt-str mark arg1 ... argN -- arg1 ... argN count
% Inherits the full ScanFmt feature set (type safety, fill/align, :x, etc).
%
% Note: Stream::fill_file auto-closes a read-only stream when EOF is reached,
% so trailing whitespace/newline in test data avoids EOF during scan, keeping
% the stream open for the subsequent close-stream.

% Write a file (with trailing newline), then scan its contents back.
(/tmp/trix_fscan_test.txt) (w)#b stream
dup (42 hello 3.14\n) write-string
close-stream

(/tmp/trix_fscan_test.txt) (r)#b stream
dup ({:d} {:s} {:f}) mark 0 32 string 0. fscan-fmt
3 eq  (fscan-fmt-39a: three fields count) rt-ok
3.14 eq  (fscan-fmt-39a: float) rt-ok
(hello) eq  (fscan-fmt-39a: string) rt-ok
42 eq  (fscan-fmt-39a: int) rt-ok
close-stream  clear

% Null target auto-detect through stream
(/tmp/trix_fscan_test.txt) (r)#b stream
dup ({:d}) mark null fscan-fmt
1 eq  (fscan-fmt-39b: null auto count) rt-ok
42 eq  (fscan-fmt-39b: null auto value) rt-ok
close-stream  clear

% :x hex scan from stream
(/tmp/trix_fscan_hex.txt) (w)#b stream
dup (DEADBEEF\n) write-string
close-stream

(/tmp/trix_fscan_hex.txt) (r)#b stream
dup ({:x}) mark 0l fscan-fmt
1 eq  (fscan-fmt-39c: hex from stream count) rt-ok
3735928559l eq  (fscan-fmt-39c: hex from stream value) rt-ok
close-stream  clear

% Strict type-safety still applies (fractional -> int rejected)
(/tmp/trix_fscan_bad.txt) (w)#b stream
dup (42.5\n) write-string
close-stream

<< /scan-type-fail { clear true } >> { (/tmp/trix_fscan_bad.txt) (r)#b stream dup ({:d}) mark 0 fscan-fmt } try-catch  (fscan-fmt-39d: strict 42.5 to int -> scan-type-fail) rt-ok  clear

% Write-only stream rejected with invalid-stream-access
<< /invalid-stream-access { clear true } >> { (/tmp/trix_fscan_writeonly.txt) (w)#b stream dup ({:d}) mark 0 fscan-fmt } try-catch  (fscan-fmt-39e: non-readable stream -> invalid-stream-access) rt-ok  clear

% Literal mismatch against stream content
(/tmp/trix_fscan_lit.txt) (w)#b stream
dup (xyz\n) write-string
close-stream

<< /scan-match-fail { clear true } >> { (/tmp/trix_fscan_lit.txt) (r)#b stream dup (abc) mark fscan-fmt } try-catch  (fscan-fmt-39f: literal mismatch -> scan-match-fail) rt-ok  clear

% Zero-field format returns 0 count
(/tmp/trix_fscan_any.txt) (w)#b stream
dup (anything\n) write-string
close-stream

(/tmp/trix_fscan_any.txt) (r)#b stream
dup () mark fscan-fmt
0 eq  (fscan-fmt-39g: empty format -> 0 count) rt-ok
close-stream  clear

(ScanFmt complete coverage tests complete.) =

% ====================================================================
% SECTION: Control Operator Comprehensive Coverage
% ====================================================================

% --- if: edge cases ---
5  true  { } if  5 eq  (if: true empty proc is no-op) rt-ok  clear
5  true  { 10 add } if  15 eq  (if: true modifies stack) rt-ok  clear
<< /type-check { clear true } >> { 1 { } if } try-catch  (if: non-boolean -> type-check) rt-ok  clear
<< /type-check { clear true } >> { true 1 if } try-catch  (if: non-proc -> type-check) rt-ok  clear
<< /opstack-underflow { clear true } >> { { } if } try-catch  (if: underflow -> opstack-underflow) rt-ok  clear

% --- if-else: edge cases ---
true  { } { 99 } if-else  count 0 eq  (if-else: true empty branch) rt-ok  clear
false { 99 } { } if-else  count 0 eq  (if-else: false empty branch) rt-ok  clear
<< /type-check { clear true } >> { 1 { } { } if-else } try-catch  (if-else: non-boolean -> type-check) rt-ok  clear
<< /type-check { clear true } >> { true 1 { } if-else } try-catch  (if-else: non-proc first -> type-check) rt-ok  clear
<< /type-check { clear true } >> { true { } 1 if-else } try-catch  (if-else: non-proc second -> type-check) rt-ok  clear
<< /opstack-underflow { clear true } >> { { } { } if-else } try-catch  (if-else: underflow -> opstack-underflow) rt-ok  clear

% --- for: additional types ---
0b  0b 1b 3b { add } for  6b eq  (for byte: 0b..3b sum=6) rt-ok  clear
0u  1u 1u 5u { add } for  15u eq  (for uint: 1u..5u sum=15) rt-ok  clear
0l  1l 1l 5l { add } for  15l eq  (for long: 1l..5l sum=15) rt-ok  clear
0ul  1ul 1ul 5ul { add } for  15ul eq  (for ulong: 1ul..5ul sum=15) rt-ok  clear
0.d  1.d 1.d 3.d { add } for  6.d eq  (for double: 1d..3d sum=6) rt-ok  clear

% --- for: edge cases ---
0  5 1 5 { add } for  5 eq  (for: single iteration start=limit) rt-ok  clear
0  1 -1 5 { add } for  0 eq  (for: start<limit neg step no exec) rt-ok  clear
0  10 -2 2 { add } for  30 eq  (for: descend step=-2 sum=30) rt-ok  clear
0  1 1 100 { dup 3 gt { pop exit } if add } for  6 eq  (for: exit at >3 sum=6) rt-ok  clear
1 1 5 { pop } for  count 0 eq  (for: pop-only proc no residue) rt-ok  clear
1 1 3 { } for  3 eq exch 2 eq and exch 1 eq and  (for: pushes counter values) rt-ok  clear
<< /opstack-underflow { clear true } >> { { } for } try-catch  (for: underflow -> opstack-underflow) rt-ok  clear
<< /type-check { clear true } >> { 1 1 5 42 for } try-catch  (for: non-proc body -> type-check) rt-ok  clear

% --- repeat: edge cases ---
0  1 { 1 add } repeat  1 eq  (repeat: single iteration) rt-ok  clear
5 { } repeat  count 0 eq  (repeat: empty proc body ok) rt-ok  clear
0  100 { 1 add  dup 3 eq { exit } if } repeat  3 eq  (repeat: exit at count=3) rt-ok  clear
<< /type-check { clear true } >> { 3.14 { } repeat } try-catch  (repeat: real count -> type-check) rt-ok  clear
<< /range-check { clear true } >> { -1 { } repeat } try-catch  (repeat: negative count -> range-check) rt-ok  clear
<< /type-check { clear true } >> { 5 42 repeat } try-catch  (repeat: non-proc body -> type-check) rt-ok  clear
0l  5l { 1l add } repeat  5l eq  (repeat: long count=5l) rt-ok  clear

% --- loop: edge cases ---
<< /type-check { clear true } >> { 42 loop } try-catch  (loop: non-proc -> type-check) rt-ok  clear
{ exit } loop  count 0 eq  (loop: immediate exit) rt-ok  clear
0  { 1 add  dup 3 eq { exit } if } loop  3 eq  (loop: exit at 3) rt-ok  clear
/ctrl-outer-count 0 def
3 {
  0 { 1 add  dup 2 eq { exit } if } loop
  pop
  /ctrl-outer-count ctrl-outer-count 1 add def
} repeat
ctrl-outer-count 3 eq  (loop: nested in repeat inner exits correctly) rt-ok  clear

% --- exit: edge cases ---
<< /invalid-exit { clear true } >> { exit } try-catch  (exit: outside loop -> invalid-exit) rt-ok  clear
0  [1 2 3 4 5] { dup 3 gt { pop exit } if add } for-all  6 eq  (exit: breaks for-all at >3 sum=6) rt-ok  clear
0b  (ABCDE) { dup 67b gt { pop exit } if add } for-all  198b eq  (exit: breaks string for-all at >C sum=198) rt-ok  clear
% nested for with inner exit: inner sums 1+2=3, outer runs 3 times
/ctrl-nested-sum 0 def
3 {
  0  1 1 10 { dup 2 gt { pop exit } if add } for
  ctrl-nested-sum add /ctrl-nested-sum exch def
} repeat
ctrl-nested-sum 9 eq  (exit: nested for inner exit sum=3*3=9) rt-ok  clear

