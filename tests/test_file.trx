% --- Real: NaN (any NaN maps to Real_qNAN; verify result is of real-type and is NaN) ---
//:systemdict:numbers:real-type:signaling-NaN to-binary-token make-executable exec
    type /real-type eq  (btok real signaling-NaN (type check)  round-trip ok) rt-ok
//:systemdict:numbers:real-type:quiet-NaN to-binary-token make-executable exec
    type /real-type eq  (btok real quiet-NaN     (type check)  round-trip ok) rt-ok

