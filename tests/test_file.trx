% --- ilogb ---
8.0 ilogb  3 eq  (ilogb: ilogb(8)=3) rt-ok  clear

% --- byte-swap ---
16#01020304#u byte-swap  16#04030201#u eq  (byte-swap: reverses bytes) rt-ok  clear

% --- quot-rem ---
17 5 quot-rem  2 eq  (quot-rem: 17 mod 5 = 2) rt-ok
3 eq  (quot-rem: 17 div 5 = 3) rt-ok  clear

% --- fe-get-round / fe-set-round ---
fe-get-round  /fe-to-nearest eq  (fe-get-round: default is fe-to-nearest) rt-ok  clear

(Newly registered math operators complete.) =

% ====================================================================
% SECTION: Sort Operator
% ====================================================================

% --- sort: integers ---
[3 1 4 1 5 9 2 6] sort
dup 0 get  1 eq  (sort: int[0]=1) rt-ok
dup 1 get  1 eq  (sort: int[1]=1) rt-ok
dup 2 get  2 eq  (sort: int[2]=2) rt-ok
dup 3 get  3 eq  (sort: int[3]=3) rt-ok
dup 4 get  4 eq  (sort: int[4]=4) rt-ok
dup 5 get  5 eq  (sort: int[5]=5) rt-ok
dup 6 get  6 eq  (sort: int[6]=6) rt-ok
dup 7 get  9 eq  (sort: int[7]=9) rt-ok
length 8 eq  (sort: int length=8) rt-ok  clear

% --- sort: empty array ---
[] sort  length 0 eq  (sort: empty array) rt-ok  clear

% --- sort: single element ---
[42] sort  0 get  42 eq  (sort: single element) rt-ok  clear

% --- sort: already sorted ---
[1 2 3 4 5] sort
dup 0 get  1 eq  (sort: presorted[0]=1) rt-ok
dup 4 get  5 eq  (sort: presorted[4]=5) rt-ok
length 5 eq  (sort: presorted length=5) rt-ok  clear

% --- sort: reverse sorted ---
[5 4 3 2 1] sort
dup 0 get  1 eq  (sort: reverse[0]=1) rt-ok
dup 4 get  5 eq  (sort: reverse[4]=5) rt-ok
pop  clear

% --- sort: reals ---
[3.14 1.41 2.72 0.57] sort
dup 0 get  0.57 eq  (sort: real[0]=0.57) rt-ok
dup 3 get  3.14 eq  (sort: real[3]=3.14) rt-ok
pop  clear

% --- sort: strings ---
[(cherry) (apple) (banana) (date)] sort
dup 0 get  (apple) eq  (sort: str[0]=apple) rt-ok
dup 1 get  (banana) eq  (sort: str[1]=banana) rt-ok
dup 2 get  (cherry) eq  (sort: str[2]=cherry) rt-ok
dup 3 get  (date) eq  (sort: str[3]=date) rt-ok
pop  clear

% --- sort: booleans ---
[true false true false] sort
dup 0 get  false eq  (sort: bool[0]=false) rt-ok
dup 1 get  false eq  (sort: bool[1]=false) rt-ok
dup 2 get  true eq  (sort: bool[2]=true) rt-ok
dup 3 get  true eq  (sort: bool[3]=true) rt-ok
pop  clear

% --- sort: negative integers ---
[5 -3 0 -1 4 -2] sort
dup 0 get  -3 eq  (sort: neg[0]=-3) rt-ok
dup 1 get  -2 eq  (sort: neg[1]=-2) rt-ok
dup 2 get  -1 eq  (sort: neg[2]=-1) rt-ok
dup 3 get  0 eq  (sort: neg[3]=0) rt-ok
dup 5 get  5 eq  (sort: neg[5]=5) rt-ok
pop  clear

% --- sort: duplicates ---
[3 3 1 1 2 2] sort
dup 0 get  1 eq  (sort: dup[0]=1) rt-ok
dup 2 get  2 eq  (sort: dup[2]=2) rt-ok
dup 4 get  3 eq  (sort: dup[4]=3) rt-ok
pop  clear

% --- sort: original array unchanged (returns new array) ---
[3 1 2] /original exch def
original sort
dup 0 get  1 eq  (sort: sorted[0]=1) rt-ok  pop
original 0 get  3 eq  (sort: original[0] still 3) rt-ok  clear

% --- sort: packed array ---
3 1 4 1 5  5 packed  sort
dup 0 get  1 eq  (sort: packed[0]=1) rt-ok
dup 4 get  5 eq  (sort: packed[4]=5) rt-ok
pop  clear

(Sort operator tests complete.) =

% ====================================================================
% SECTION: Map Operator
% ====================================================================

% --- map: basic integer transformation ---
[1 2 3 4 5] { 2 mul } map
dup 0 get  2 eq  (map: 2*1=2) rt-ok
dup 1 get  4 eq  (map: 2*2=4) rt-ok
dup 2 get  6 eq  (map: 2*3=6) rt-ok
dup 3 get  8 eq  (map: 2*4=8) rt-ok
dup 4 get  10 eq  (map: 2*5=10) rt-ok
length 5 eq  (map: length=5) rt-ok  clear

% --- map: square ---
[1 2 3 4] { dup mul } map
dup 0 get  1 eq  (map: 1^2=1) rt-ok
dup 1 get  4 eq  (map: 2^2=4) rt-ok
dup 2 get  9 eq  (map: 3^2=9) rt-ok
dup 3 get  16 eq  (map: 4^2=16) rt-ok
pop  clear

% --- map: empty array ---
[] { 2 mul } map  length 0 eq  (map: empty array) rt-ok  clear

% --- map: single element ---
[42] { 1 add } map  0 get  43 eq  (map: single element) rt-ok  clear

% --- map: identity ---
[10 20 30] { } map
dup 0 get  10 eq  (map: identity[0]=10) rt-ok
dup 2 get  30 eq  (map: identity[2]=30) rt-ok
pop  clear

% --- map: type conversion via cast ---
[1 2 3] { /real-type cast } map
dup 0 get  type /real-type eq  (map: int->real type) rt-ok
dup 0 get  1.0 eq  (map: int->real value) rt-ok
pop  clear

% --- map: string operations ---
[(hello) (world)] { length } map
dup 0 get  5 eq  (map: strlen hello=5) rt-ok
dup 1 get  5 eq  (map: strlen world=5) rt-ok
pop  clear

% --- map: original unchanged ---
[1 2 3] /orig exch def
orig { 10 mul } map
dup 0 get  10 eq  (map: result[0]=10) rt-ok  pop
orig 0 get  1 eq  (map: orig[0] still 1) rt-ok  clear

% --- map: nested map ---
[1 2 3] { dup mul } map { 1 add } map
dup 0 get  2 eq  (map: nested 1^2+1=2) rt-ok
dup 1 get  5 eq  (map: nested 2^2+1=5) rt-ok
dup 2 get  10 eq  (map: nested 3^2+1=10) rt-ok
pop  clear

% --- map: with dip ---
99  [1 2 3] { 10 add } map
dup length 3 eq  (map+dip: result length=3) rt-ok  pop
99 eq  (map+dip: value below preserved) rt-ok  clear

% --- map: packed input ---
1 2 3  3 packed  { 5 mul } map
dup 0 get  5 eq  (map: packed[0]=5) rt-ok
dup 1 get  10 eq  (map: packed[1]=10) rt-ok
dup 2 get  15 eq  (map: packed[2]=15) rt-ok
pop  clear

% --- map: result usable after creation ---
[1 2 3] { 10 mul } map
dup 0 get  10 eq  (map: result[0]=10) rt-ok
dup 1 get  20 eq  (map: result[1]=20) rt-ok
dup 2 get  30 eq  (map: result[2]=30) rt-ok
pop  clear

(Map operator tests complete.) =

