% --- 19. Error conditions ---
<< /scan-match-fail { clear true } >> { (abc) (xyz{:d}) mark 0 sscan-fmt } try-catch  (sscan-fmt-19a: literal mismatch) rt-ok  clear
<< /scan-input-fail { clear true } >> { (hello) ({:s}) mark (readonly)#r sscan-fmt } try-catch  (sscan-fmt-19b: readonly string) rt-ok  clear
<< /scan-type-fail { clear true } >> { (hello) ({:d}) mark 0 sscan-fmt } try-catch  (sscan-fmt-19c: non-numeric for d) rt-ok  clear
<< /invalid-format-string { clear true } >> { (42 7) ({0:d} {:d}) mark 0 0 sscan-fmt } try-catch  (sscan-fmt-19d: mixed indexing) rt-ok  clear
<< /scan-duplicate-arg-id { clear true } >> { (42 7) ({0:d} {0:d}) mark 0 sscan-fmt } try-catch  (sscan-fmt-19e: dup arg-id) rt-ok  clear
<< /range-check { clear true } >> { (42) ({5:d}) mark 0 sscan-fmt } try-catch  (sscan-fmt-19f: arg-id range) rt-ok  clear
<< /invalid-format-string { clear true } >> { (42) ({:z}) mark 0 sscan-fmt } try-catch  (sscan-fmt-19g: invalid type spec) rt-ok  clear
<< /invalid-format-string { clear true } >> { (x) (}x) mark 0 sscan-fmt } try-catch  (sscan-fmt-19q: unbalanced }) rt-ok  clear
<< /scan-type-fail { clear true } >> { (42) ({}) mark null sscan-fmt } try-catch  (sscan-fmt-19i: null default type) rt-ok  clear
({) ({{) mark sscan-fmt  0 eq  (sscan-fmt-19j: {{ match count) rt-ok  clear
(}) (}}) mark sscan-fmt  0 eq  (sscan-fmt-19k: }} match count) rt-ok  clear
<< /scan-match-fail { clear true } >> { (x) ({{) mark sscan-fmt } try-catch  (sscan-fmt-19l: {{ mismatch) rt-ok  clear
<< /type-check { clear true } >> { (42) ({:f}) mark 0 sscan-fmt } try-catch  (sscan-fmt-19m: type/target mismatch) rt-ok  clear

