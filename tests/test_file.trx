% --- stdin: type is stream-type ---
stdin type /stream-type eq  (stdin: type = stream-type) rt-ok  clear

% --- stdin: is readable ---
stdin readable?  true eq  (stdin: readable? = true) rt-ok  clear

% --- stdin: is not writable ---
stdin writable?  false eq  (stdin: writable? = false) rt-ok  clear

% --- stdin: write errors (read-only) ---
{ stdin 65b write } try
/invalid-stream-access eq  (stdin: write errors) rt-ok  clear

% --- stdin: write-string errors (read-only) ---
