% --- 1. Basic format specifiers (type d) ---

128 string ({:d}) mark 42 sprint-fmt pop (42) eq (pfmt-1a: int 42) rt-ok
128 string ({:d}) mark -42 sprint-fmt pop (-42) eq (pfmt-1b: int -42) rt-ok
128 string ({:d}) mark 0 sprint-fmt pop (0) eq (pfmt-1c: int 0) rt-ok
128 string ({:d}) mark 42u sprint-fmt pop (42) eq (pfmt-1d: uint 42u) rt-ok
128 string ({:d}) mark 0u sprint-fmt pop (0) eq (pfmt-1e: uint 0u) rt-ok
128 string ({:d}) mark 42l sprint-fmt pop (42) eq (pfmt-1f: long 42l) rt-ok
128 string ({:d}) mark -42l sprint-fmt pop (-42) eq (pfmt-1g: long -42l) rt-ok
128 string ({:d}) mark 42ul sprint-fmt pop (42) eq (pfmt-1q: ulong 42ul) rt-ok
128 string ({:d}) mark 65b sprint-fmt pop (65) eq (pfmt-1i: byte 65b) rt-ok
128 string ({:d}) mark true sprint-fmt pop (1) eq (pfmt-1j: bool true) rt-ok
128 string ({:d}) mark false sprint-fmt pop (0) eq (pfmt-1k: bool false) rt-ok
128 string ({:d}) mark 16#FF#a sprint-fmt pop (16#ff) eq (pfmt-1l: addr 0xFF) rt-ok
clear

