/sub to-binary-token make-executable exec  /sub eq  (btok: system name /sub round-trip) rt-ok
/mul to-binary-token make-executable exec  /mul eq  (btok: system name /mul round-trip) rt-ok
/div to-binary-token make-executable exec  /div eq  (btok: system name /div round-trip) rt-ok
/dup to-binary-token make-executable exec  /dup eq  (btok: system name /dup round-trip) rt-ok
