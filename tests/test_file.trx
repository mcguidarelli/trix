% ====================================================================
% SUB-SECTION: Misc operator coverage
% ====================================================================

% make-literal and make-executable
{ 42 } make-literal  executable? not  (make-literal: proc becomes literal) rt-ok  clear
/foo make-executable  executable?  (make-executable: name becomes executable) rt-ok  clear

% where finds the correct dict
/where-test-123 42 def
/where-test-123 where  pop  type  /dict-type eq  (where: returns dict containing name) rt-ok  clear

% known? on current-dict
4 dict begin
  /known?-test 1 def
  current-dict /known?-test known?  (known?: existing key true) rt-ok
  current-dict /missing-key known?  not  (known?: missing key false) rt-ok  clear
end

% store updates existing binding
/store-test-var 10 def
/store-test-var 20 store
store-test-var  20 eq  (store: value updated to 20) rt-ok  clear

clear

(All 2026-03-19 regression tests complete.) =

% ====================================================================
% SECTION: 2026-03-20 design-review regression tests (findings 1-22)
% ====================================================================

% --- Finding 1: Name::status() total overflow (fix verified by build) ---
% --- Finding 2: Name::status() vm_used alignment (fix verified by build) ---

% --- Finding 3/4: Number::cast_to_type (not fixed, documented) ---

% --- Finding 5: Address truncation on 32-bit (not fixed, documented) ---

% --- Finding 6: Dict::copy capacity pre-check ---
/f6-src 3 dict dup begin /a 1 def /b 2 def /c 3 def end def
/f6-dst 1 dict def
<< /range-check { clear true } >> { f6-src f6-dst copy } try-catch  (find-06: dict copy capacity -> range-check) rt-ok  clear

% --- Finding 7: open_file errno not clobbered (tested by build/ASan) ---

% --- Finding 8: fill_stdedit newline (interactive-only, not scriptable) ---

% --- Finding 9: shim_OFloats_Integer__RFloats dispatch on x_object type ---
% scalbn/ldexp are not in systemdict, but the shim is tested by any
% operator that uses it. Verify build succeeds (the old code crashed).

% --- Finding 10: roll_op pops operands when n=0 ---
(a) (b) (c) 0 0 roll
count 3 eq  (find-10: roll n=0 pops j and n) rt-ok  clear

% --- Finding 11: dup-n_op frees ExtValue when n=0 ---
0l dup  0 dup-n
count 2 eq  (find-11: dup-n 0 pops N without leak) rt-ok  clear

% --- Finding 12: put-interval overlapping string memmove ---
% dst index src put-interval: copy src into dst at index
% overlap: src at [2..4], dst write at [0..2]
(abcdefgh)#= dup  0  2 index 2 3 get-interval  put-interval
(cdedefgh) eq  (find-12: put-interval overlap src>dst) rt-ok  clear
% overlap: src at [0..2], dst write at [2..4]
(abcdefgh)#= dup  2  2 index 0 3 get-interval  put-interval
(ababcfgh) eq  (find-12: put-interval overlap dst>src) rt-ok  clear

% --- Finding 13: shift_left/right_op INT_MIN negate UB ---
% INT_MIN = -2147483648; just verify no crash/UB (result is implementation-defined)
//:systemdict:numbers:integer-type:min
1u exch shift-left  type /uinteger-type eq  (find-13: shift-left INT_MIN no UB) rt-ok  clear
//:systemdict:numbers:integer-type:min
1u exch shift-right  type /uinteger-type eq  (find-13: shift-right INT_MIN no UB) rt-ok  clear

% --- Finding 14: search empty needle in empty haystack ---
% search returns: post match pre true (TOS=true)
() () search
(find-14: search empty/empty found) rt-ok
() eq  (find-14: search empty/empty pre) rt-ok
() eq  (find-14: search empty/empty match) rt-ok
() eq  (find-14: search empty/empty post) rt-ok  clear

% empty needle in non-empty haystack (should always match at position 0)
% search returns: post match pre true (TOS=true)
(hello) () search
(find-14: search hello/empty found) rt-ok
() eq  (find-14: search hello/empty pre) rt-ok
() eq  (find-14: search hello/empty match) rt-ok
(hello) eq  (find-14: search hello/empty post) rt-ok  clear

% --- Finding 15: op_stack_op ExtValue leak (tested by ASan, no script test) ---

% --- Finding 16: PrintFmt lone { at end of format string ---
% use hex strings for lone { and } to avoid PostScript escape issues
<< /invalid-format-string { clear true } >> { <7B> mark print-fmt } try-catch  (find-16: print-fmt lone { -> invalid-format-string) rt-ok  clear
<< /invalid-format-string { clear true } >> { <7D> mark print-fmt } try-catch  (find-16: print-fmt lone } -> invalid-format-string) rt-ok  clear

% --- Finding 17: PrintFmt/ScanFmt get_integer overflow ---
<< /range-check { clear true } >> { ({:9999999999d}) mark 1 print-fmt } try-catch  (find-17: print-fmt huge width -> range-check) rt-ok  clear

% --- Finding 18: ScanFmt trailing non-whitespace after whitespace ---
% format " {:s} X" should consume whitespace then scan string then match literal X
(hi X) ( {:s} X) mark null sscan-fmt
pop  (hi) eq  (find-18: sscan-fmt trailing literal after ws) rt-ok  clear

% --- Finding 19: ScanFmt scan_string vm_end_alloc before error ---
% readonly string target should error cleanly
<< /scan-input-fail { clear true } >> { (hello) ({:s}) mark (readonly)#r sscan-fmt } try-catch  (find-19: sscan-fmt readonly -> scan-input-fail) rt-ok  clear

% --- Finding 20: restore_from_header resets m_in_global_handler ---
% (tested by thaw smoke test, not scriptable without snap-shot)

% --- Finding 21: restore_from_header resets debug state ---
% (tested by thaw smoke test, not scriptable without snap-shot)

% --- Finding 22: make_binary_token_string preserves negative zero ---
% -0.0 round-tripped through binary token must remain -0.0
% verify by converting to string: -0.0 should produce "-0" not "0"
-0.0  to-binary-token make-executable exec
=string to-string (-0) eq  (find-22: btok real  -0.0 round-trip) rt-ok  clear
-0.0d to-binary-token make-executable exec
=string to-string (-0) eq  (find-22: btok double -0.0 round-trip) rt-ok  clear

(All 2026-03-20 design-review tests complete.) =
clear


