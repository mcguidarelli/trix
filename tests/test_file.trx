128 string ({0:o}) mark 8 sprint-fmt pop (10) eq (pfmt-28d: :o int) rt-ok  clear
% alt flag adds prefix
128 string ({0:#x}) mark 255 sprint-fmt pop (0xff) eq (pfmt-28e: :#x adds 0x) rt-ok  clear
128 string ({0:#X}) mark 255 sprint-fmt pop (0XFF) eq (pfmt-28f: :#X adds 0X) rt-ok  clear
128 string ({0:#b}) mark 10 sprint-fmt pop (0b1010) eq (pfmt-28g: :#b adds 0b) rt-ok  clear
128 string ({0:#o}) mark 8 sprint-fmt pop (0o10) eq (pfmt-28q: :#o adds 0o) rt-ok  clear
% negative scanner round-trip
128 string ({0:x}) mark -5 sprint-fmt pop (-5) eq (pfmt-28i: :x negative) rt-ok  clear
128 string ({0:#x}) mark -5 sprint-fmt pop (0x-5) eq (pfmt-28j: :#x negative prefix-sign order) rt-ok  clear
% width + align + zero-pad
128 string ({0:10x}) mark 255 sprint-fmt pop (        ff) eq (pfmt-28k: :x right-aligned) rt-ok  clear
128 string ({0:<10x}) mark 255 sprint-fmt pop (ff        ) eq (pfmt-28l: :x left-aligned) rt-ok  clear
128 string ({0:010x}) mark 255 sprint-fmt pop (00000000ff) eq (pfmt-28m: :x zero-pad) rt-ok  clear
128 string ({0:#010x}) mark 255 sprint-fmt pop (0x000000ff) eq (pfmt-28n: :#x zero-pad with prefix) rt-ok  clear
% other integer types
128 string ({0:X}) mark 255ui sprint-fmt pop (FF) eq (pfmt-28o: :X uinteger) rt-ok  clear
128 string ({0:x}) mark 255l sprint-fmt pop (ff) eq (pfmt-28p: :x long) rt-ok  clear
128 string ({0:#X}) mark 255ul sprint-fmt pop (0XFF) eq (pfmt-28q: :#X ulong) rt-ok  clear
128 string ({0:b}) mark 5b sprint-fmt pop (101) eq (pfmt-28r: :b byte) rt-ok  clear
% :c on Integer
128 string ({0:c}{1:c}{2:c}) mark 72 105 33 sprint-fmt pop (Hi!) eq (pfmt-28s: :c integer codepoints) rt-ok  clear
% :c range check
<< /range-check { clear true } >> { 128 string ({0:c}) mark 300 sprint-fmt } try-catch  (pfmt-28t: :c out of range) rt-ok  clear
<< /range-check { clear true } >> { 128 string ({0:c}) mark -1 sprint-fmt } try-catch  (pfmt-28u: :c negative) rt-ok  clear

(PrintFmt complete coverage tests complete.) =
% ====================================================================
% SECTION: ScanFmt (sscan-fmt) Complete Coverage
% ====================================================================

% --- 1. Basic integer scanning {:d} ---

(42) ({:d}) mark 0 sscan-fmt
1 eq  (sscan-fmt-1a: int 42 count) rt-ok
42 eq  (sscan-fmt-1a: int 42 value) rt-ok  clear

(-7) ({:d}) mark 0 sscan-fmt
1 eq  (sscan-fmt-1b: int -7 count) rt-ok
-7 eq  (sscan-fmt-1b: int -7 value) rt-ok  clear

(0) ({:d}) mark 0 sscan-fmt
1 eq  (sscan-fmt-1c: int 0 count) rt-ok
0 eq  (sscan-fmt-1c: int 0 value) rt-ok  clear

(42) ({:d}) mark 0u sscan-fmt
1 eq  (sscan-fmt-1d: uint 42 count) rt-ok
42u eq  (sscan-fmt-1d: uint 42 value) rt-ok  clear

(42) ({:d}) mark 0l sscan-fmt
1 eq  (sscan-fmt-1e: long 42 count) rt-ok
42l eq  (sscan-fmt-1e: long 42 value) rt-ok  clear

(42) ({:d}) mark 0ul sscan-fmt
1 eq  (sscan-fmt-1f: ulong 42 count) rt-ok
42ul eq  (sscan-fmt-1f: ulong 42 value) rt-ok  clear

(65) ({:d}) mark 0b sscan-fmt
1 eq  (sscan-fmt-1g: byte 65 count) rt-ok
65b eq  (sscan-fmt-1g: byte 65 value) rt-ok  clear

% --- 2. Float scanning {:f} ---

(3.14) ({:f}) mark 0. sscan-fmt
1 eq  (sscan-fmt-2a: real 3.14 count) rt-ok
3.14 eq  (sscan-fmt-2a: real 3.14 value) rt-ok  clear

(-2.5) ({:f}) mark 0. sscan-fmt
1 eq  (sscan-fmt-2b: real -2.5 count) rt-ok
-2.5 eq  (sscan-fmt-2b: real -2.5 value) rt-ok  clear

(3.14) ({:f}) mark 0.d sscan-fmt
1 eq  (sscan-fmt-2c: double 3.14 count) rt-ok
dup type /double-type eq  (sscan-fmt-2c: double 3.14 type) rt-ok
pop clear

% --- 3. String scanning {:s} ---
% {:s} scans until whitespace; input must have trailing ws or delimiter

(hello ) ({:s}) mark 128 string sscan-fmt
1 eq  (sscan-fmt-3a: string hello count) rt-ok
(hello) eq  (sscan-fmt-3a: string hello value) rt-ok  clear

(hello world) ({:s}) mark 128 string sscan-fmt
1 eq  (sscan-fmt-3b: string stops at ws count) rt-ok
(hello) eq  (sscan-fmt-3b: string stops at ws value) rt-ok  clear

(hello ) ({:s}) mark null sscan-fmt
1 eq  (sscan-fmt-3c: null target string count) rt-ok
(hello) eq  (sscan-fmt-3c: null target string value) rt-ok  clear

% --- 4. Character scanning {:c} ---

(A) ({:c}) mark 0b sscan-fmt
1 eq  (sscan-fmt-4a: char A count) rt-ok
65b eq  (sscan-fmt-4a: char A value) rt-ok  clear

( ) ({:c}) mark 0b sscan-fmt
1 eq  (sscan-fmt-4b: char space count) rt-ok
32b eq  (sscan-fmt-4b: char space value) rt-ok  clear

% --- 5. Boolean scanning {:c} on boolean ---

(t) ({:c}) mark false sscan-fmt
1 eq  (sscan-fmt-5a: bool t count) rt-ok
true eq  (sscan-fmt-5a: bool t value) rt-ok  clear

(f) ({:c}) mark true sscan-fmt
1 eq  (sscan-fmt-5b: bool f count) rt-ok
false eq  (sscan-fmt-5b: bool f value) rt-ok  clear

(1) ({:c}) mark false sscan-fmt
1 eq  (sscan-fmt-5c: bool 1 count) rt-ok
true eq  (sscan-fmt-5c: bool 1 value) rt-ok  clear

(0) ({:c}) mark true sscan-fmt
1 eq  (sscan-fmt-5d: bool 0 count) rt-ok
false eq  (sscan-fmt-5d: bool 0 value) rt-ok  clear

% --- 6. Boolean string scanning {:s} on boolean ---

(true) ({:s}) mark false sscan-fmt
1 eq  (sscan-fmt-6a: bool true count) rt-ok
true eq  (sscan-fmt-6a: bool true value) rt-ok  clear

(false) ({:s}) mark true sscan-fmt
1 eq  (sscan-fmt-6b: bool false count) rt-ok
false eq  (sscan-fmt-6b: bool false value) rt-ok  clear

(TRUE) ({:s}) mark false sscan-fmt
