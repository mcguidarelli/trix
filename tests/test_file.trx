(hello) eq  (sscan-fmt-10a: multi d+s string) rt-ok
42 eq  (sscan-fmt-10a: multi d+s int) rt-ok  clear

(10 20 30) ({:d} {:d} {:d}) mark 0 0 0 sscan-fmt
