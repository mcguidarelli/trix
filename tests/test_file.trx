3000000000l   to-binary-token make-executable exec  3000000000l   eq  (btok long  3e9     round-trip ok) rt-ok
-3000000000l  to-binary-token make-executable exec  -3000000000l  eq  (btok long -3e9     round-trip ok) rt-ok

