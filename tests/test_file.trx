% ====================================================================
% SECTION: Write / WriteString Operators
% ====================================================================

% --- write: single byte to file ---
(/tmp/trix_write_test.txt) (w)#b stream
dup 72b write    % H
dup 105b write   % i
dup 10b write    % newline
close-stream

(/tmp/trix_write_test.txt) (r)#b stream
dup read pop  72b eq  (write: byte H) rt-ok
dup read pop  105b eq  (write: byte i) rt-ok
dup read pop  10b eq  (write: byte newline) rt-ok
close-stream  clear

% --- write-string: string to file ---
(/tmp/trix_writestr_test.txt) (w)#b stream
dup (hello world) write-string
close-stream

(/tmp/trix_writestr_test.txt) (r)#b stream
dup  11 string read-string pop
(hello world) eq  (write-string: hello world) rt-ok
close-stream  clear

% --- write-string: multiple writes ---
(/tmp/trix_multi_test.txt) (w)#b stream
dup (abc) write-string
dup (def) write-string
close-stream

(/tmp/trix_multi_test.txt) (r)#b stream
dup  6 string read-string pop
(abcdef) eq  (write-string: multiple writes concat) rt-ok
close-stream  clear

% --- write-string: empty string ---
(/tmp/trix_empty_test.txt) (w)#b stream
dup () write-string
dup (ok) write-string
close-stream

(/tmp/trix_empty_test.txt) (r)#b stream
dup  2 string read-string pop
(ok) eq  (write-string: empty + ok) rt-ok
close-stream  clear

% --- write: error on read-only stream ---
(/tmp/trix_write_test.txt) (r)#b stream /s exch def
{ s 65b write } try
/invalid-stream-access eq  (write: read-only stream error) rt-ok
s close-stream  clear

(Write/write-string tests complete.) =

% ====================================================================
% SECTION: Delete-stream Operator
% ====================================================================

% --- delete-file: create, delete, verify gone ---
(/tmp/trix_delete_test.txt) (w)#b stream
dup (test) write-string
close-stream

(/tmp/trix_delete_test.txt) delete-file

% verify file is gone by trying to open it
{ (/tmp/trix_delete_test.txt) (r)#b stream close-stream } try
/filename-not-found eq  (delete-file: file removed) rt-ok  clear

% --- delete-file: nonexistent file errors ---
{ (/tmp/trix_no_such_file_ever.txt) delete-file } try
/filename-not-found eq  (delete-file: nonexistent errors) rt-ok  clear

(Delete-stream tests complete.) =

% ====================================================================
% SECTION: Stream-position / Set-stream-position Operators
% ====================================================================

% --- stream-position: initial position is 0 ---
(/tmp/trix_pos_test.txt) (w)#b stream
dup (hello world) write-string
close-stream

(/tmp/trix_pos_test.txt) (r)#b stream
dup stream-position  0l eq  (stream-position: initial=0) rt-ok

% --- stream-position: advances after read ---
dup read pop pop  % read one byte
dup stream-position  1l eq  (stream-position: after read=1) rt-ok

% --- set-stream-position: seek to position ---
dup 6 set-stream-position
dup stream-position  6l eq  (set-stream-position: seeked to 6) rt-ok

% --- read after seek ---
dup 5 string read-string pop
(world) eq  (set-stream-position: read after seek) rt-ok

% --- set-stream-position: seek back to start ---
dup 0 set-stream-position
dup 5 string read-string pop
(hello) eq  (set-stream-position: rewind to start) rt-ok

close-stream
(/tmp/trix_pos_test.txt) delete-file  clear

(Stream-position tests complete.) =

% ====================================================================
% SECTION: Stream Read/Write Mode Transition
% ====================================================================

% A read+write file stream requires set-stream-position between
% direction changes: write->read and read->write.

% --- write -> set-position -> read (success) ---
(/tmp/trix_rw_test.txt) (W)#b stream
dup (ABCDE) write-string
dup 0 set-stream-position
dup 5 string read-string pop
(ABCDE) eq  (rw-mode: write -> set-pos -> read ok) rt-ok
close-stream  clear

% --- read -> set-position -> write (success) ---
(/tmp/trix_rw_test.txt) (R)#b stream
dup 3 string read-string pop pop  % read 3 bytes, discard string
dup 3 set-stream-position         % set-position before switching to write
dup (XY) write-string
dup 0 set-stream-position
dup 5 string read-string pop
(ABCXY) eq  (rw-mode: read -> set-pos -> write ok) rt-ok
close-stream  clear

% --- write -> read without set-position (error) ---
(/tmp/trix_rw_test.txt) (W)#b stream /s exch def
s (hello) write-string
{ s read pop pop } try
/set-file-position-required eq  (rw-mode: write -> read error) rt-ok
s close-stream  clear

% --- read -> write without set-position (error) ---
(/tmp/trix_rw_test.txt) (R)#b stream /s exch def
s read pop pop  % read one byte
{ s 65b write } try
/set-file-position-required eq  (rw-mode: read -> write error) rt-ok
s close-stream  clear

% --- write -> set-position -> write (no error, same direction) ---
(/tmp/trix_rw_test.txt) (W)#b stream /s exch def
s (AB) write-string
s 0 set-stream-position
s (CD) write-string
s 0 set-stream-position
s 2 string read-string pop
(CD) eq  (rw-mode: write -> set-pos -> write ok) rt-ok
s close-stream  clear

% --- read -> set-position -> read (no error, same direction) ---
(/tmp/trix_rw_test.txt) (R)#b stream /s exch def
s read pop pop  % read one byte
s 0 set-stream-position
s 2 string read-string pop
(CD) eq  (rw-mode: read -> set-pos -> read ok) rt-ok
s close-stream  clear

% --- write-string -> read-string without set-position (error) ---
(/tmp/trix_rw_test.txt) (W)#b stream /s exch def
s (test) write-string
{ s 4 string read-string pop pop } try
/set-file-position-required eq  (rw-mode: write-string -> read-string error) rt-ok
s close-stream  clear

% --- read-string -> write-string without set-position (error) ---
(/tmp/trix_rw_test.txt) (R)#b stream /s exch def
s 2 string read-string pop pop  % read 2 bytes
{ s (ZZ) write-string } try
/set-file-position-required eq  (rw-mode: read-string -> write-string error) rt-ok
s close-stream  clear

% --- read-only stream rejects write (invalid-stream-access) ---
(/tmp/trix_rw_test.txt) (r)#b stream /s exch def
{ s 65b write } try
/invalid-stream-access eq  (rw-mode: read-only rejects write) rt-ok
s close-stream  clear

% --- write-only stream rejects read (invalid-stream-access) ---
(/tmp/trix_rw_test.txt) (w)#b stream /s exch def
{ s read pop pop } try
/invalid-stream-access eq  (rw-mode: write-only rejects read) rt-ok
s close-stream  clear

(/tmp/trix_rw_test.txt) delete-file  clear

(Stream read/write mode transition tests complete.) =

% ====================================================================
% SECTION: Rename-stream Operator
% ====================================================================

% --- rename-file: rename a file and verify ---
(/tmp/trix_rename_src.txt) (w)#b stream
dup (test data) write-string
close-stream

(/tmp/trix_rename_src.txt) (/tmp/trix_rename_dst.txt) rename-file

% verify old name is gone
{ (/tmp/trix_rename_src.txt) (r)#b stream close-stream } try
/filename-not-found eq  (rename-file: old name gone) rt-ok  clear

% verify new name has content
(/tmp/trix_rename_dst.txt) (r)#b stream
dup  9 string read-string pop
(test data) eq  (rename-file: content preserved) rt-ok
close-stream
(/tmp/trix_rename_dst.txt) delete-file  clear

% --- rename-file: nonexistent source errors ---
{ (/tmp/trix_no_such_file.txt) (/tmp/trix_dst.txt) rename-file } try
/filename-not-found eq  (rename-file: nonexistent errors) rt-ok  clear

(Rename-stream tests complete.) =

% ====================================================================
% SECTION: Filename-for-all Operator
% ====================================================================

% --- create test files ---
(/tmp/trix_glob_a.txt) (w)#b stream dup (a) write-string close-stream
(/tmp/trix_glob_b.txt) (w)#b stream dup (b) write-string close-stream
(/tmp/trix_glob_c.log) (w)#b stream dup (c) write-string close-stream

% --- filename-for-all: glob *.txt ---
/n 0 def
(/tmp/trix_glob_*.txt) { pop /n n 1 add def } filename-for-all
n 2 eq  (filename-for-all: found 2 .txt files) rt-ok  clear

% --- filename-for-all: collect into array ---
% W07: body must consume the iter value; collect via an explicit
% accumulator rather than relying on for-all's body to leak filenames
% into a surrounding [ ... ] literal.
/glob-accum [] def
(/tmp/trix_glob_*.txt) { glob-accum exch append /glob-accum exch store } filename-for-all
glob-accum sort /glob-accum exch def
glob-accum length 2 eq  (filename-for-all: array length=2) rt-ok
glob-accum 0 get  (/tmp/trix_glob_a.txt) eq  (filename-for-all: [0]=a.txt) rt-ok
glob-accum 1 get  (/tmp/trix_glob_b.txt) eq  (filename-for-all: [1]=b.txt) rt-ok
clear

% --- filename-for-all: glob *.log ---
/glob-accum [] def
(/tmp/trix_glob_*.log) { glob-accum exch append /glob-accum exch store } filename-for-all
glob-accum length 1 eq  (filename-for-all: 1 .log file) rt-ok
glob-accum 0 get  (/tmp/trix_glob_c.log) eq  (filename-for-all: [0]=c.log) rt-ok  clear

% --- filename-for-all: no matches ---
/n 0 def
(/tmp/trix_glob_*.xyz) { pop /n n 1 add def } filename-for-all
n 0 eq  (filename-for-all: no matches) rt-ok  clear

% --- cleanup ---
(/tmp/trix_glob_a.txt) delete-file
(/tmp/trix_glob_b.txt) delete-file
(/tmp/trix_glob_c.log) delete-file

(Filename-for-all tests complete.) =

% ====================================================================
% SECTION: Getenv Operator
% ====================================================================

% --- getenv: HOME exists ---
(HOME) getenv
true eq  (getenv: HOME found) rt-ok
length 0 gt  (getenv: HOME non-empty) rt-ok  clear

% --- getenv: PATH exists ---
(PATH) getenv
true eq  (getenv: PATH found) rt-ok
length 0 gt  (getenv: PATH non-empty) rt-ok  clear

% --- getenv: nonexistent variable ---
(TRIX_NO_SUCH_VAR_EVER_12345) getenv
false eq  (getenv: nonexistent returns false) rt-ok  clear

% --- getenv: result is usable string ---
(HOME) getenv pop
0 get type  /byte-type eq  (getenv: result is indexable string) rt-ok  clear

(Getenv tests complete.) =

% ====================================================================
% SECTION: Time / Epoch-time Operators
% ====================================================================

% --- time: returns ulong ---
{ 1 1 100 { pop } for } time
type /ulong-type eq  (time: returns ulong) rt-ok  clear

% --- time: measures elapsed > 0 ---
{ 1 1 10000 { pop } for } time
0ul gt  (time: elapsed > 0) rt-ok  clear

% --- time: proc results preserved ---
{ 42 } time
exch 42 eq  (time: proc result preserved) rt-ok
0ul ge  (time: elapsed returned) rt-ok  clear

% --- time: empty proc fast ---
{ } time
type /ulong-type eq  (time: empty proc returns ulong) rt-ok  clear

% --- epoch-time: returns ulong ---
epoch-time type  /ulong-type eq  (epoch-time: returns ulong) rt-ok  clear

% --- epoch-time: reasonable value (after 2020-01-01 = 1577836800000ms) ---
epoch-time  1577836800000ul gt  (epoch-time: after 2020) rt-ok  clear

% --- epoch-time: monotonic within call ---
epoch-time epoch-time exch sub  0ul ge  (epoch-time: monotonic) rt-ok  clear

% --- now: returns ulong (monotonic milliseconds) ---
now type  /ulong-type eq  (now: returns ulong) rt-ok  clear

% --- now: monotonic within call ---
now /a-now exch def now a-now ge  (now: monotonic across calls) rt-ok  clear

% --- now: ms units approximately match clock/1000 ---
% clock returns micros; now returns ms.  Within a single test the two
% should agree to within a small tolerance.  Sample now first, then
% clock; clock_us / 1000 should be >= now_ms (clock was read later)
% and within a few ms of it.
now /a-now exch def
clock /a-clock exch def
a-clock 1000ul div  /a-clock-ms exch def
a-clock-ms a-now ge
  (now: clock-ms is at least now-ms when sampled later) rt-ok  clear
a-clock-ms a-now sub  10ul lt
  (now: ms agrees with clock/1000 within 10ms tolerance) rt-ok  clear

% --- now: positive ---
now 0ul gt  (now: positive) rt-ok  clear

(Time/epoch-time/now tests complete.) =

% ====================================================================
% SECTION: String Predicates, Trim, Any/All, Append
% ====================================================================

% --- starts-with? ---
(hello world) (hello) starts-with?  true eq  (starts-with?: match) rt-ok  clear
(hello world) (world) starts-with?  false eq  (starts-with?: no match) rt-ok  clear
(hello) (hello world) starts-with?  false eq  (starts-with?: needle longer) rt-ok  clear
(hello) () starts-with?  true eq  (starts-with?: empty needle) rt-ok  clear
() (hello) starts-with?  false eq  (starts-with?: empty haystack) rt-ok  clear
() () starts-with?  true eq  (starts-with?: both empty) rt-ok  clear

% --- ends-with? ---
(hello world) (world) ends-with?  true eq  (ends-with?: match) rt-ok  clear
(hello world) (hello) ends-with?  false eq  (ends-with?: no match) rt-ok  clear
(test.trx) (.trx) ends-with?  true eq  (ends-with?: extension) rt-ok  clear
(hello) () ends-with?  true eq  (ends-with?: empty needle) rt-ok  clear

% --- contains? ---
(hello world) (lo wo) contains?  true eq  (contains?: middle match) rt-ok  clear
(hello world) (xyz) contains?  false eq  (contains?: no match) rt-ok  clear
(hello) (hello) contains?  true eq  (contains?: exact match) rt-ok  clear
(hello) () contains?  true eq  (contains?: empty needle) rt-ok  clear
() (hello) contains?  false eq  (contains?: empty haystack) rt-ok  clear

% --- trim ---
(  hello  ) trim  (hello) eq  (trim: both sides) rt-ok  clear
(hello) trim  (hello) eq  (trim: no whitespace) rt-ok  clear
(   ) trim  () eq  (trim: all whitespace) rt-ok  clear
() trim  () eq  (trim: empty) rt-ok  clear

% --- trim-left ---
(  hello  ) trim-left  (hello  ) eq  (trim-left: strips left) rt-ok  clear
(hello) trim-left  (hello) eq  (trim-left: no change) rt-ok  clear

% --- trim-right ---
(  hello  ) trim-right  (  hello) eq  (trim-right: strips right) rt-ok  clear
(hello) trim-right  (hello) eq  (trim-right: no change) rt-ok  clear

% --- any ---
[1 2 3 4 5] { 3 gt } any  true eq  (any: some > 3) rt-ok  clear
[1 2 3] { 10 gt } any  false eq  (any: none > 10) rt-ok  clear
[] { true } any  false eq  (any: empty = false) rt-ok  clear
[false false true] { } any  true eq  (any: identity pred) rt-ok  clear
[1] { 0 gt } any  true eq  (any: single match) rt-ok  clear

% --- all ---
[1 2 3 4 5] { 0 gt } all  true eq  (all: all positive) rt-ok  clear
[1 2 -1 4] { 0 gt } all  false eq  (all: not all positive) rt-ok  clear
[] { false } all  true eq  (all: empty = true) rt-ok  clear
[true true true] { } all  true eq  (all: identity pred) rt-ok  clear
[1] { 0 gt } all  true eq  (all: single match) rt-ok  clear
[1 2 3] { 5 lt } all  true eq  (all: all < 5) rt-ok  clear

% --- append ---
[1 2 3] 4 append
dup length 4 eq  (append: length=4) rt-ok
dup 3 get  4 eq  (append: [3]=4) rt-ok
dup 0 get  1 eq  (append: [0]=1) rt-ok
pop  clear

[] 42 append
dup length 1 eq  (append: empty+42 length=1) rt-ok
0 get  42 eq  (append: empty+42 [0]=42) rt-ok  clear

% --- append: original unchanged ---
[1 2] /orig exch def
orig 3 append  length 3 eq  (append: result length=3) rt-ok  clear
orig length 2 eq  (append: orig unchanged) rt-ok  clear

% --- append: packed input ---
1 2 3  3 packed  4 append
dup length 4 eq  (append: packed length=4) rt-ok
dup 3 get  4 eq  (append: packed [3]=4) rt-ok
pop  clear

% --- append: composable with map ---
[] [1 2 3] { dup mul } map { |arr| arr exch append } reduce
dup 0 get  1 eq  (append+reduce: [0]=1) rt-ok
dup 1 get  4 eq  (append+reduce: [1]=4) rt-ok
dup 2 get  9 eq  (append+reduce: [2]=9) rt-ok
pop  clear

(String predicates/trim/any/all/append tests complete.) =

% ====================================================================
% SECTION: Range Operator
% ====================================================================

% --- range: 1-arg form ---
5 range
dup length 5 eq  (range: 5 length=5) rt-ok
dup 0 get  0 eq  (range: 5 [0]=0) rt-ok
dup 4 get  4 eq  (range: 5 [4]=4) rt-ok
pop  clear

0 range  length 0 eq  (range: 0 = empty) rt-ok  clear
1 range  dup length 1 eq  (range: 1 length=1) rt-ok
0 get  0 eq  (range: 1 [0]=0) rt-ok  clear

% --- range: 2-arg form ---
3 7 range-from
dup length 4 eq  (range: 3..7 length=4) rt-ok
dup 0 get  3 eq  (range: 3..7 [0]=3) rt-ok
dup 3 get  6 eq  (range: 3..7 [3]=6) rt-ok
pop  clear

0 5 range-from
dup length 5 eq  (range: 0..5 length=5) rt-ok
dup 0 get  0 eq  (range: 0..5 [0]=0) rt-ok
pop  clear

5 5 range-from  length 0 eq  (range: 5..5 = empty) rt-ok  clear
7 3 range-from  length 0 eq  (range: 7..3 = empty) rt-ok  clear

% --- range: negative start ---
-2 3 range-from
dup length 5 eq  (range: -2..3 length=5) rt-ok
dup 0 get  -2 eq  (range: -2..3 [0]=-2) rt-ok
dup 4 get  2 eq  (range: -2..3 [4]=2) rt-ok
pop  clear

% --- range: composable with map ---
5 range { dup mul } map
dup 0 get  0 eq  (range+map: 0^2=0) rt-ok
dup 4 get  16 eq  (range+map: 4^2=16) rt-ok
pop  clear

% --- range: composable with filter ---
10 range { 2 mod 0 eq } filter
dup length 5 eq  (range+filter: 5 evens) rt-ok
dup 0 get  0 eq  (range+filter: [0]=0) rt-ok
dup 4 get  8 eq  (range+filter: [4]=8) rt-ok
pop  clear

% --- range: composable with reduce ---
1 11 range-from  0 { add } reduce
55 eq  (range+reduce: sum 1..10 = 55) rt-ok  clear

(Range operator tests complete.) =

