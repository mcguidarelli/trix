42 eq  (sscan-fmt-8a: literal prefix value) rt-ok  clear

(x=7) (x={:d}) mark 0 sscan-fmt
1 eq  (sscan-fmt-8b: literal x= count) rt-ok
7 eq  (sscan-fmt-8b: literal x= value) rt-ok  clear

