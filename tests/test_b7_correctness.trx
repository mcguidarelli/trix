% ============================================================================
% test_b7_correctness.trx -- B7 group 2 (MED/LOW correctness, functional)
% ============================================================================
% coroutine:2-0  coroutine-wait-all from a NON-MAIN coroutine counted itself in
%                m_live_coroutine_count, so the count could never drop to 0 and
%                the caller busy-looped forever.  It now waits until everyone
%                *else* is gone (count > self_slot, self_slot=1 for non-main).
%                Pre-fix this test HANGS (the child never returns); post-fix it
%                returns immediately.
%
% The other G2 findings are code-inspection-covered -- they need instrumentation
% or conditions a deterministic .trx cannot exercise:
%   genserver:1-1/1-2/1-3  gen-call-timeout/gen-cast/gen-stop freed the wrong (or
%                          no) operand slot -> ExtValue (Double/Long/...) leak;
%                          needs an ExtValue active-count probe.
%   system:2-0             shell leaked the popen FILE*/fds on a VMFull throw;
%                          needs a near-full heap + leak sanitizer.
%   actor:2-1              recv-match-timeout checked the deadline before scanning
%                          the mailbox on wakeup; needs send/timeout race timing.
%   coroutine:1-1          coroutine death cleared the SHARED userdict's binding
%                          cache (off-by-one after protocoldict); output stays
%                          correct, only the binding cache is tombstoned.
%   supervision:1-1        one-for-all/rest-for-one resurrected already-stopped
%                          /temporary children; needs scheduler choreography
%                          (start children, exit one, crash a sibling, drain).
%   supervision:1-2        ~49.7-day uint32_t-ms wrap in the intensity window.
%   debugger:1-2           covered functionally in test_b7_debugger_safety.trx.
% ============================================================================

% rt-ok counts failures in a restore-immune slot -- string byte writes
% are unjournaled, so the count survives assertions made inside save
% scopes, and the 1-byte string lives in LOCAL VM, invisible to the
% global-heap/gc-counter probes some files assert on.  The file THROWS
% at EOF: test_all counts a file as failed only when its run throws,
% so print-only failures would slip the suite verdict.
/rt-fails 1 string def
rt-fails 0 16#0#b put
/rt-ok { exch { = } { (FAILED: ) print = rt-fails 0  rt-fails 0 get /integer-type cast 1 add dup 255 gt { pop 255 } if /byte-type cast  put } if-else } def

% ---------------------------------------------------------------------------
% coroutine:2-0 -- non-main coroutine-wait-all returns instead of hanging
% ---------------------------------------------------------------------------
/c20-done false def
mark { coroutine-wait-all /c20-done true store } coroutine-launch pop
coroutine-wait-all
c20-done (coroutine:2-0 non-main wait-all returns, does not busy-loop) rt-ok

(test_b7_correctness.trx: all tests passed) =
rt-fails 0 get /integer-type cast 0 gt { /rt-assertions-failed throw } if
(__test_ok__) =
