% test_eqref_behavior.trx
%
% Semantic tests for the eqref family: these prove the mechanism behaves as
% documented when refs are stashed through containers, when independent
% kinds are created in sequence, and when the clone escape-hatch is used to
% make a ref durable.
%
%   Through-container:    a ref stored via `def` (i.e. in a dict) stays
%                         stale after a same-kind `#=` creation -- the
%                         staleness check is not stack-local.
%   Cross-kind:           creating one kind (say `)#=`) does NOT invalidate
%                         a live ref of a different kind (say `]#=`).  Each
%                         kind owns an independent generation counter.
%   Clone escape-hatch:   a `dup length <kind> copy` pattern materialises a
%                         durable VM-heap clone; subsequent same-kind
%                         creations don't touch the clone.

(=== eqref behavior tests ===) =

% rt-ok counts failures in a restore-immune slot -- string byte writes
% are unjournaled, so the count survives assertions made inside save
% scopes, and the 1-byte string lives in LOCAL VM, invisible to the
% global-heap/gc-counter probes some files assert on.  The file THROWS
% at EOF: test_all counts a file as failed only when its run throws,
% so print-only failures would slip the suite verdict.
/rt-fails 1 string def
rt-fails 0 16#0#b put
/rt-ok { exch { = } { (FAILED: ) print = rt-fails 0  rt-fails 0 get /integer-type cast 1 add dup 255 gt { pop 255 } if /byte-type cast  put } if-else } def

% ===========================================================================
% Through-container staleness: ref stashed in userdict, second creation
% same kind, retrieve via dict lookup -- must error as stale.
% ===========================================================================

/ref (first)#= def
(garbage)#= pop
{ ref 0 get pop } try /unsupported eq
  (through-container: eqstring ref in dict stays stale) rt-ok clear

/ref [1 2 3]#= def
[9 9 9]#= pop
{ ref 0 get pop } try /unsupported eq
  (through-container: eqarray ref in dict stays stale) rt-ok clear

/ref << /a 1 >>#= def
<< /x 9 >>#= pop
{ ref /a get pop } try /unsupported eq
  (through-container: eqdict ref in dict stays stale) rt-ok clear

/ref {{ /a /b }}#= def
{{ /x /y }}#= pop
{ ref length pop } try /unsupported eq
  (through-container: eqset ref in dict stays stale) rt-ok clear

/ref { 1 2 add }#= def
{ 9 9 add }#= pop
{ ref exec pop } try /unsupported eq
  (through-container: eqproc ref in dict stays stale) rt-ok clear

% ===========================================================================
% Cross-kind independence: creating one kind must not invalidate a live ref
% of a different kind.  Each chain creates the four other kinds and then
% accesses the held kind -- must succeed.
% ===========================================================================

/ref (hello)#= def
[1 2 3]#= pop
<< /a 1 >>#= pop
{{ /a }}#= pop
{ 1 2 add }#= pop
ref 0 get 104b eq
  (cross-kind: eqstring survives other-kind creations) rt-ok clear

/ref [10 20 30]#= def
(other)#= pop
<< /a 1 >>#= pop
{{ /a }}#= pop
{ 1 2 add }#= pop
ref 0 get 10 eq
  (cross-kind: eqarray survives other-kind creations) rt-ok clear

/ref << /key 42 >>#= def
(other)#= pop
[1 2 3]#= pop
{{ /a }}#= pop
{ 1 2 add }#= pop
ref /key get 42 eq
  (cross-kind: eqdict survives other-kind creations) rt-ok clear

/ref {{ /a /b /c }}#= def
(other)#= pop
[1 2 3]#= pop
<< /k 1 >>#= pop
{ 1 2 add }#= pop
ref length 3 eq
  (cross-kind: eqset survives other-kind creations) rt-ok clear

/ref { 11 22 add }#= def
(other)#= pop
[1 2 3]#= pop
<< /k 1 >>#= pop
{{ /a }}#= pop
ref exec 33 eq
  (cross-kind: eqproc survives other-kind creations) rt-ok clear

% ===========================================================================
% Clone escape-hatch: `src dup length <kind> copy` produces a durable VM-heap
% clone; subsequent same-kind `#=` creations don't touch it.
% ===========================================================================

/clone (first)#= dup length string copy def
(garbage)#= pop
clone (first) eq
  (clone-escape: eqstring clone survives same-kind creation) rt-ok clear

/clone [10 20 30]#= dup length array copy def
[99 99 99]#= pop
clone 0 get 10 eq
  (clone-escape: eqarray clone survives same-kind creation) rt-ok clear

/clone << /a 1 /b 2 >>#= dup length dict copy def
<< /x 99 >>#= pop
clone /a get 1 eq
  (clone-escape: eqdict clone survives same-kind creation) rt-ok clear

/clone {{ /a /b }}#= dup length set copy def
{{ /x /y /z }}#= pop
clone length 2 eq
  (clone-escape: eqset clone survives same-kind creation) rt-ok clear

% eqproc: `src dup length array copy make-executable` clones the body Objects
% (or packed bytes via extract_packed) into a fresh VM-heap array, then marks
% it executable -- the result is a plain executable array, not an eqref.
/clone { 11 22 add }#= dup length array copy make-executable def
{ 99 99 add }#= pop
clone exec 33 eq
  (clone-escape: eqproc clone survives same-kind creation) rt-ok clear

(eqref behavior tests complete.) =
rt-fails 0 get /integer-type cast 0 gt { /rt-assertions-failed throw } if
(__test_ok__) =
