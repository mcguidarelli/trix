% ====================================================================
% Mirror of test_set.trx long/ulong cases for Int128/UInt128.
%
% test_int128_containers.trx covers the basic Int128/UInt128 set
% surface (length, member?, add, remove, union/intersection/difference,
% distinct-member-type). This file fills the gaps that test_set.trx
% exercises with `l`/`ul`:
%   * set deep-eq across reordered literal forms
%   * subset? with 128-bit keys
%   * members return type preservation
%   * for-all on sets with 128-bit elements
%   * set copy (capacity-specifying form) with 128-bit
%   * save/restore of mutations
%   * stress add/remove churn
%   * cross-type distinction between 1q and 1l (or 1 and 1q)
%   * dedup of repeated 128-bit literals
% ====================================================================

% rt-ok counts failures in a restore-immune slot -- string byte writes
% are unjournaled, so the count survives assertions made inside save
% scopes, and the 1-byte string lives in LOCAL VM, invisible to the
% global-heap/gc-counter probes some files assert on.  The file THROWS
% at EOF: test_all counts a file as failed only when its run throws,
% so print-only failures would slip the suite verdict.
/rt-fails 1 string def
rt-fails 0 16#0#b put
/rt-ok { exch { = } { (FAILED: ) print = rt-fails 0  rt-fails 0 get /integer-type cast 1 add dup 255 gt { pop 255 } if /byte-type cast  put } if-else } def

% ====================================================================
% deep-eq across reordered literal forms (hash/equal on 128-bit)
% ====================================================================

{{ 1q 2q 3q }} {{ 3q 2q 1q }} deep-eq    (int128 deep-eq reordered) rt-ok clear
{{ 1uq 2uq 3uq }} {{ 3uq 2uq 1uq }} deep-eq (uint128 deep-eq reordered) rt-ok clear

% ====================================================================
% subset? with 128-bit elements
% ====================================================================

{{ 1q 2q }} {{ 1q 2q 3q }} subset?      (int128 subset?) rt-ok clear
{{ 1q 2q 4q }} {{ 1q 2q 3q }} subset? not (int128 non-subset) rt-ok clear
{{ 1uq 2uq }} {{ 1uq 2uq 3uq }} subset?  (uint128 subset?) rt-ok clear

% ====================================================================
% members returns values with correct type
% ====================================================================

{{ 42q }} members 0 get type /int128-type eq (members: int128 element type) rt-ok clear
{{ 42uq }} members 0 get type /uint128-type eq (members: uint128 element type) rt-ok clear

% ====================================================================
% for-all yields correctly-typed element
% ====================================================================

% W07: body is a per-element predicate; use `members` + `all` rather
% than for-all (which expects body to consume all iter values; `all`
% accepts only arrays so the set is materialized first).
{{ 99q }} members { type /int128-type eq } all  (for-all: yields int128) rt-ok clear
{{ 99uq }} members { type /uint128-type eq } all (for-all: yields uint128) rt-ok clear

% ====================================================================
% set copy (capacity-specifying form)
% ====================================================================

{{ 1q 2q 3q }} 4 set copy length 3 eq     (copy: length preserved int128) rt-ok clear
{{ 1q 2q 3q }} 4 set copy 2q set-member?  (copy: membership preserved int128) rt-ok clear
{{ 1uq 2uq 3uq }} 4 set copy 2uq set-member? (copy: membership preserved uint128) rt-ok clear

% ====================================================================
% cross-type distinction: Integer 1 vs Int128 1q are different members
% ====================================================================

{{ 1 1q }} length 2 eq                     (cross-type: int vs int128) rt-ok clear
{{ 1l 1q }} length 2 eq                    (cross-type: long vs int128) rt-ok clear
{{ 1uq 1q }} length 2 eq                   (cross-type: int128 vs uint128) rt-ok clear

% ====================================================================
% dedup of repeated 128-bit literals
% ====================================================================

{{ 42q 42q }} length 1 eq                  (dedup: repeated int128) rt-ok clear
{{ 42uq 42uq 42uq }} length 1 eq           (dedup: repeated uint128) rt-ok clear

% ====================================================================
% save/restore of 128-bit set mutation
% ====================================================================

/sr-set {{ 1q 2q }} def
/s save def
sr-set 3q set-add pop
sr-set 3q set-member?                      (save/restore: int128 add visible) rt-ok clear
s restore
sr-set 3q set-member? not                  (save/restore: int128 add rolled back) rt-ok clear

% ====================================================================
% stress: add loop of many 128-bit elements
% ====================================================================

/stress-set 64 set def
0 1 49 { /i exch def stress-set i /int128-type cast set-add pop } for
stress-set length 50 eq                    (stress: 50 int128 members) rt-ok clear
stress-set 25q set-member?                 (stress: member 25q) rt-ok clear
stress-set 49q set-member?                 (stress: member 49q) rt-ok clear

% ====================================================================
% union / intersection over larger 128-bit sets
% ====================================================================

{{ 1q 2q 3q 4q 5q }} {{ 6q 7q 8q 9q 10q }} set-union
    length 10 eq                           (union: disjoint int128 10 elements) rt-ok clear

{{ 1q 2q 3q 4q 5q 6q 7q 8q 9q 10q }} {{ 5q 6q 7q 8q 9q 10q 11q 12q }} set-intersection
    length 6 eq                            (intersection: int128 overlap) rt-ok clear

% ====================================================================
% for-all with accumulator on 128-bit set
% ====================================================================

/fa-sum 0q def
{{ 10q 20q 30q }} { fa-sum add /fa-sum exch def } for-all
fa-sum 60q deep-eq                         (for-all: int128 accumulator) rt-ok clear

(test_int128_set_mirror.trx complete) =
rt-fails 0 get /integer-type cast 0 gt { /rt-assertions-failed throw } if
(__test_ok__) =
