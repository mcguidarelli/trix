    (tag-bind: selective match value) rt-ok clear

% Integration: tag-bind inside map
[ 1 /ok tag 2 /ok tag 3 /ok tag ]
{ /ok { 10 mul /ok tag } tag-bind } map
dup 0 get tag-value 10 eq
exch dup 1 get tag-value 20 eq
exch 2 get tag-value 30 eq and and
    (tag-bind: map over tagged array) rt-ok clear

% Integration: mixed ok/err through map with bind
[ { 10 } try-result { 1 0 div } try-result { 20 } try-result ]
{ /ok { { 2 mul } try-result } tag-bind } map
dup 0 get tag-value 20 eq
exch dup 1 get tag-name /err eq
exch 2 get tag-value 40 eq and and
    (tag-bind: map mixed ok/err) rt-ok clear

% Integration: tag-bind + tag-value-or (full railway with default)
{ 42 } try-result
/ok { { 2 mul } try-result } tag-bind
/ok 0 tag-value-or
84 eq
    (tag-bind: railway + tag-value-or success) rt-ok clear

{ 1 0 div } try-result
/ok { { 2 mul } try-result } tag-bind
/ok 0 tag-value-or
0 eq
    (tag-bind: railway + tag-value-or error) rt-ok clear

% Integration: tag-bind + tag-match (dispatch after chain)
{ 42 } try-result
/ok { { 1 add } try-result } tag-bind
<< /ok { (success) } /err { pop (error) } >> tag-match
(success) eq
    (tag-bind: railway + tag-match success) rt-ok clear

{ 1 0 div } try-result
/ok { { 1 add } try-result } tag-bind
<< /ok { (success) } /err { pop (error) } >> tag-match
(error) eq
