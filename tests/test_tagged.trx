1000 { /err { pop 0 /err tag } tag-bind } repeat
dup tag-name /ok eq
    (tag-bind: stress 1000 no-match tag) rt-ok
tag-value 42 eq
    (tag-bind: stress 1000 no-match value) rt-ok clear

