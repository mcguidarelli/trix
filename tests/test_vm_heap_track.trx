% ====================================================================
% vm-heap-tracking Phase 2: vm-heap-snapshot / vm-heap-diff + status keys
% ====================================================================

% rt-ok counts failures in a restore-immune slot -- string byte writes
% are unjournaled, so the count survives assertions made inside save
% scopes, and the 1-byte string lives in LOCAL VM, invisible to the
% global-heap/gc-counter probes some files assert on.  The file THROWS
% at EOF: test_all counts a file as failed only when its run throws,
% so print-only failures would slip the suite verdict.
/rt-fails 1 string def
rt-fails 0 16#0#b put
/rt-ok { exch { = } { (FAILED: ) print = rt-fails 0  rt-fails 0 get /integer-type cast 1 add dup 255 gt { pop 255 } if /byte-type cast  put } if-else } def

% --- 1. status keys exist and have plausible types
//:status:heap-track-count type /integer-type eq      (heap-track-count is an integer)        rt-ok
//:status:heap-track-capacity type /integer-type eq   (heap-track-capacity is an integer)     rt-ok
//:status:heap-track-saturated type /boolean-type eq  (heap-track-saturated is a boolean)     rt-ok
//:status:heap-track-generation type /integer-type eq (heap-track-generation is an integer)   rt-ok

% --- 2. snapshot returns a ulong; back-to-back snapshots with nothing
%        in between yield an empty diff (no allocations to attribute to).
%        Bind via def AFTER the diff so /def itself doesn't allocate
%        between the two snapshots.
clear-alloc-stats
vm-heap-snapshot type /ulong-type eq                  (vm-heap-snapshot returns a ulong)      rt-ok
vm-heap-snapshot vm-heap-snapshot vm-heap-diff length 0 eq (back-to-back -> empty diff)        rt-ok

% --- 3. snapshot pair around real allocations records growth
clear-alloc-stats
/before vm-heap-snapshot def
[1 2 3] pop
[4 5 6] pop
/after vm-heap-snapshot def
/diff before after vm-heap-diff def
diff length 0 gt                                      (real allocs -> non-empty diff)         rt-ok
% sum bytes across all entries
/sum-bytes { 0 exch { /bytes get add } for-all } def
diff sum-bytes 0 gt                                   (diff: total bytes > 0)                 rt-ok

% --- 4. diff entries have all four expected fields with the right types
diff 0 get /file get type /string-type eq             (diff entry: /file is string)           rt-ok
diff 0 get /line get type /integer-type eq            (diff entry: /line is integer)          rt-ok
diff 0 get /count get type /integer-type eq           (diff entry: /count is integer)         rt-ok
diff 0 get /bytes get type /integer-type eq           (diff entry: /bytes is integer)         rt-ok

% --- 5. swapped argument order yields the same diff (op normalizes)
/d-swapped after before vm-heap-diff def
d-swapped sum-bytes diff sum-bytes eq                 (diff: argument order does not matter)  rt-ok

% --- 6. clear-alloc-stats bumps the generation
//:status:heap-track-generation /gen-before-clear exch def
clear-alloc-stats
//:status:heap-track-generation gen-before-clear gt   (clear-alloc-stats bumps generation)    rt-ok
% old /before and /after are now stale -- vm-heap-diff catches this via
% the generation mismatch (smoke-tested separately; see /tmp/heap_diff_smoke.trx).

% --- 7. save/restore that prunes also bumps the generation
clear-alloc-stats
//:status:heap-track-generation /gen-pre-save exch def
/S save def
[1 2 3 4 5] pop
S restore
//:status:heap-track-generation gen-pre-save gt       (restore that prunes bumps generation)  rt-ok

% --- 8. heap-track-count grows with allocations
clear-alloc-stats
//:status:heap-track-count /c0 exch def
[42] pop
[43] pop
[44] pop
//:status:heap-track-count c0 gt                      (allocs increment heap-track-count)     rt-ok

% --- 9. diff results within the window match (sanity: 1 alloc -> at least 1 site).
%        (vm-heap-diff's "does not pollute itself" invariant -- the op
%        pauses tracking while building its result -- is design-level;
%        end-to-end pollute-free measurement is obscured by ExtValue
%        clone allocations on operand pushes outside the op.)
clear-alloc-stats
/single-a vm-heap-snapshot def
[100 200] pop
/single-b vm-heap-snapshot def
single-a single-b vm-heap-diff length 0 gt            (one alloc line -> >= 1 entry)          rt-ok

(test_vm_heap_track: all OK) =
rt-fails 0 get /integer-type cast 0 gt { /rt-assertions-failed throw } if
(__test_ok__) =
