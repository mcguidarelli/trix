% ====================================================================
% SECTION 24: boundary — capacity-1 mailbox
% ====================================================================

/cap1-result null def
/cap1-actor [ { } 1 actor-spawn-capacity def
cap1-actor actor-mailbox-empty?
    (cap1: empty at start) rt-ok
42 cap1-actor actor-send
cap1-actor actor-mailbox-count 1 eq
    (cap1: count 1 after send) rt-ok
cap1-actor actor-mailbox-empty? not
    (cap1: not empty after send) rt-ok
cap1-actor coroutine-kill clear

% capacity-1 with backpressure: send two, second blocks until first consumed
/cap1-val null def
/cap1-actor2 [ {
    actor-recv /cap1-val exch def
} 1 actor-spawn-capacity def
1 cap1-actor2 actor-send
2 cap1-actor2 actor-send     % blocks: mailbox full; @actor-send-retry
0 coroutine-sleep 0 coroutine-sleep 0 coroutine-sleep
cap1-val 1 eq
    (cap1: first message delivered through backpressure) rt-ok clear

