    (fuzz-match-deep: match at end of 15 messages) rt-ok clear

% ====================================================================
% SECTION 37: stress — 5 actors exchanging 1000 messages
% ====================================================================
% Success criterion #1 from the plan.  5 ring actors, each forwards
% received messages to the next actor in the ring.  Main injects 1000
% messages into ring-0; ring-4 (terminal) counts them.

/ring-count 0 def

% Build ring backwards: terminal first, then forwarders
/ring-4 [ {
    1 1 1000 { pop actor-recv pop ring-count 1 add /ring-count exch def } for
} actor-spawn def

/ring-3 [ ring-4 {
    1 1 1000 { pop actor-recv over actor-send } for pop
} actor-spawn def

/ring-2 [ ring-3 {
    1 1 1000 { pop actor-recv over actor-send } for pop
} actor-spawn def

/ring-1 [ ring-2 {
    1 1 1000 { pop actor-recv over actor-send } for pop
} actor-spawn def

/ring-0 [ ring-1 {
    1 1 1000 { pop actor-recv over actor-send } for pop
} actor-spawn def

% Inject 1000 messages into ring-0
1 1 1000 { ring-0 actor-send } for

% Yield enough for messages to traverse the 5-stage ring with backpressure
yield-many yield-many yield-many yield-many yield-many
yield-many yield-many yield-many yield-many yield-many

ring-count 1000 eq
    (stress-ring: 5 actors, 1000 messages through ring) rt-ok clear

