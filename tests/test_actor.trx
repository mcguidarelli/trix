% ====================================================================
% Actor Framework Tests
% ====================================================================

% rt-ok counts failures so the file can THROW at the end -- test_all.trx
% counts a file as failed only when its run throws, so a print-only
% rt-ok would let assertion failures slip past the suite verdict.
/rt-fails 1 string def
rt-fails 0 16#0#b put
/rt-ok { exch { = } { (FAILED: ) print = rt-fails 0  rt-fails 0 get /integer-type cast 1 add dup 255 gt { pop 255 } if /byte-type cast  put } if-else } def
/==s { /==s-v exch def =string ({0:O}) [ ==s-v ] asprint-fmt pop } def
/yield-many { 0 1 29 { pop 0 coroutine-sleep } for } def

% ====================================================================
% SECTION 1: actor-spawn basic
% ====================================================================

[ { } actor-spawn is-coroutine
    (spawn: returns coroutine) rt-ok clear
0 coroutine-sleep

[ { } actor-spawn is-actor
    (spawn: is-actor true) rt-ok clear
0 coroutine-sleep

[ { coroutine-die } coroutine-launch is-actor not
    (spawn: plain coroutine is not actor) rt-ok clear
0 coroutine-sleep

% ====================================================================
% SECTION 2: is-actor predicate
% ====================================================================

42 is-actor not
    (is-actor: false for integer) rt-ok clear
(hello) is-actor not
    (is-actor: false for string) rt-ok clear
null is-actor not
    (is-actor: false for null) rt-ok clear
true is-actor not
    (is-actor: false for boolean) rt-ok clear
[1 2 3] is-actor not
    (is-actor: false for array) rt-ok clear

% ====================================================================
% SECTION 3: actor-self
% ====================================================================

actor-self is-coroutine
    (self: returns coroutine in main) rt-ok clear

/self-result null def
[ { actor-self /self-result exch def } coroutine-launch pop
0 coroutine-sleep
self-result is-coroutine
    (self: returns coroutine in plain coroutine) rt-ok clear

/self-result2 null def
/my-actor [ {
    actor-self /self-result2 exch def
} actor-spawn def
0 coroutine-sleep
self-result2 my-actor eq
    (self: actor-self equals own handle) rt-ok clear

% ====================================================================
% SECTION 4: actor-spawn-capacity
% ====================================================================

[ { } 4 actor-spawn-capacity is-actor
    (spawn-capacity: creates actor) rt-ok clear
0 coroutine-sleep

{ [ { } 0 actor-spawn-capacity } try /no-error ne
    (spawn-capacity: zero capacity raises error) rt-ok clear
{ [ { } -1 actor-spawn-capacity } try /no-error ne
    (spawn-capacity: negative capacity raises error) rt-ok clear

% ====================================================================
% SECTION 5: actor-send and actor-recv basic
% ====================================================================

/recv-result null def
/echo [ {
    actor-recv /recv-result exch def
} actor-spawn def
42 echo actor-send
0 coroutine-sleep
recv-result 42 eq
    (send-recv: integer message delivered) rt-ok clear

/recv-result2 null def
/echo2 [ {
    actor-recv /recv-result2 exch def
} actor-spawn def
(hello) echo2 actor-send
0 coroutine-sleep
recv-result2 (hello) eq
    (send-recv: string message delivered) rt-ok clear

/recv-result3 null def
/recv-got-msg false def
/echo3 [ {
    actor-recv /recv-result3 exch def
    /recv-got-msg true def
} actor-spawn def
null echo3 actor-send
0 coroutine-sleep
recv-got-msg
    (send-recv: null message delivered) rt-ok clear

% ====================================================================
% SECTION 6: actor-send to non-actor raises error
% ====================================================================

/plain-coro [ { 100 coroutine-sleep } coroutine-launch def
{ 42 plain-coro actor-send } try /no-error ne
    (send: non-actor raises invalid-access) rt-ok
plain-coro coroutine-kill clear

% ====================================================================
% SECTION 7: actor-send to dead actor (silent drop)
% ====================================================================

/dead-actor [ { } actor-spawn def
0 coroutine-sleep 0 coroutine-sleep
{ 42 dead-actor actor-send } try /no-error eq
    (send: dead actor is silent drop, no error) rt-ok clear

% ====================================================================
% SECTION 8: actor-recv in non-actor raises error
% ====================================================================

/recv-err null def
[ {
    { actor-recv } try /recv-err exch def
} coroutine-launch pop
0 coroutine-sleep
recv-err /no-error ne
    (recv: non-actor raises invalid-access) rt-ok clear

% ====================================================================
% SECTION 9: multiple messages FIFO order
% ====================================================================

/fifo-1 null def
/fifo-2 null def
/fifo-3 null def
/fifo-actor [ {
    actor-recv /fifo-1 exch def
    actor-recv /fifo-2 exch def
    actor-recv /fifo-3 exch def
} actor-spawn def
1 fifo-actor actor-send
2 fifo-actor actor-send
3 fifo-actor actor-send
0 coroutine-sleep
fifo-1 1 eq
    (fifo: first message is 1) rt-ok
fifo-2 2 eq
    (fifo: second message is 2) rt-ok
fifo-3 3 eq
    (fifo: third message is 3) rt-ok
clear

% ====================================================================
% SECTION 10: actor-mailbox-count and actor-mailbox-empty?
% ====================================================================

/count-actor [ {
    1000 coroutine-sleep
} actor-spawn def

count-actor actor-mailbox-empty?
    (mailbox-empty: true when empty) rt-ok
count-actor actor-mailbox-count 0 eq
    (mailbox-count: 0 when empty) rt-ok
42 count-actor actor-send
count-actor actor-mailbox-empty? not
    (mailbox-empty: false after send) rt-ok
count-actor actor-mailbox-count 1 eq
    (mailbox-count: 1 after one send) rt-ok
99 count-actor actor-send
count-actor actor-mailbox-count 2 eq
    (mailbox-count: 2 after two sends) rt-ok
count-actor coroutine-kill clear

% ====================================================================
% SECTION 11: mailbox-count/empty on non-actor raises error
% ====================================================================

/plain2 [ { 100 coroutine-sleep } coroutine-launch def
{ plain2 actor-mailbox-count } try /no-error ne
    (mailbox-count: non-actor raises error) rt-ok clear
{ plain2 actor-mailbox-empty? } try /no-error ne
    (mailbox-empty: non-actor raises error) rt-ok
plain2 coroutine-kill clear

