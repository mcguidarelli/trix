% ====================================================================
% SECTION 41: recv-match blocks, then matching message arrives
% ====================================================================

/delayed-match null def
/dm-actor [ {
    % Start recv-match before any messages exist -- blocks
    { 99 eq } actor-recv-match /delayed-match exch def
} actor-spawn def
0 coroutine-sleep              % let actor start and block on recv-match
10 dm-actor actor-send         % non-matching
20 dm-actor actor-send         % non-matching
99 dm-actor actor-send         % match!
0 coroutine-sleep 0 coroutine-sleep 0 coroutine-sleep
delayed-match 99 eq
    (match-delayed: match arrives after blocking) rt-ok clear

