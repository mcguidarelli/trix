/ms-actor [ {
    1 1 10 { pop actor-recv pop ms-count 1 add /ms-count exch def } for
} actor-spawn def

% 10 different senders each send 1 message
0 1 9 {
    ms-actor actor-send
} for
yield-many
ms-count 10 eq
    (multi-sender: 10 senders delivered) rt-ok clear

