% ====================================================================
% SECTION 30: stress — 5 actors, 200 messages total
% ====================================================================

% 5 senders each send 40 messages (value 1) to a collector that sums them.
% Total = 200 messages, expected sum = 200.
/s5-sum 0 def
/s5-collector [ {
    0
    1 1 200 { pop actor-recv add } for
    /s5-sum exch def
} actor-spawn def

0 1 4 { pop
    [ s5-collector {
        1 1 40 { pop dup 1 exch actor-send } for
        pop
    } actor-spawn pop
} for

yield-many yield-many yield-many
s5-sum 200 eq
    (stress-5x200: 5 senders 40 each, sum correct) rt-ok clear

