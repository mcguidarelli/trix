/doubler [ {
    actor-recv 2 mul /doubled exch def
} actor-spawn def
21 doubler actor-send
0 coroutine-sleep
doubled 42 eq
    (request-response: doubled value received) rt-ok clear

% ====================================================================
% SECTION 14: actor-recv-timeout (message arrives before timeout)
% ====================================================================

/timeout-result null def
/timeout-flag null def
/to-actor [ {
    5000 actor-recv-timeout /timeout-flag exch def /timeout-result exch def
} actor-spawn def
99 to-actor actor-send
0 coroutine-sleep
timeout-flag true eq
    (recv-timeout: true when message arrives) rt-ok
timeout-result 99 eq
    (recv-timeout: correct message) rt-ok
clear

% ====================================================================
% SECTION 15: actor-recv-timeout (timeout expires)
% ====================================================================

/to-result null def
/to-flag null def
[ {
    1 actor-recv-timeout /to-flag exch def /to-result exch def
} actor-spawn pop
0 coroutine-sleep 0 coroutine-sleep 50 coroutine-sleep
to-flag false eq
    (recv-timeout: false on timeout) rt-ok
to-result null eq
    (recv-timeout: null on timeout) rt-ok
clear

% ====================================================================
% SECTION 16: actor death cleanup (no leak)
% ====================================================================

/die-actor [ {
} actor-spawn def
1 die-actor actor-send
2 die-actor actor-send
3 die-actor actor-send
0 coroutine-sleep
die-actor is-actor
    (death-cleanup: still reports is-actor) rt-ok
{ 4 die-actor actor-send } try /no-error eq
    (death-cleanup: send to dead is silent) rt-ok
clear

% ====================================================================
% SECTION 16: multi-actor communication (A forwards to B)
% ====================================================================

/ma-result 0 def
/actor-b [ {
    actor-recv /ma-result exch def
} actor-spawn def

/actor-a [ {
    actor-recv actor-recv add actor-b actor-send
} actor-spawn def

10 actor-a actor-send
20 actor-a actor-send
0 coroutine-sleep 0 coroutine-sleep 0 coroutine-sleep 0 coroutine-sleep
ma-result 30 eq
    (multi-actor: A sums and forwards to B) rt-ok clear

% ====================================================================
% SECTION 17: actor-recv-match basic
% ====================================================================

/match-result null def
[ {
    10 actor-self actor-send
    20 actor-self actor-send
    30 actor-self actor-send

    { 25 gt } actor-recv-match /match-result exch def
} actor-spawn pop
0 coroutine-sleep 0 coroutine-sleep
match-result 30 eq
    (recv-match: found matching message) rt-ok clear

% ====================================================================
% SECTION 18: actor-recv-match leaves non-matching messages
% ====================================================================

/match-result2 null def
/remain-1 null def
/remain-2 null def
[ {
    1 actor-self actor-send
    2 actor-self actor-send
    3 actor-self actor-send

    { 3 eq } actor-recv-match /match-result2 exch def

    actor-recv /remain-1 exch def
    actor-recv /remain-2 exch def
} actor-spawn pop
0 coroutine-sleep 0 coroutine-sleep
match-result2 3 eq
    (recv-match: correct match) rt-ok
remain-1 1 eq
    (recv-match: first remaining is 1) rt-ok
remain-2 2 eq
    (recv-match: second remaining is 2) rt-ok
clear

