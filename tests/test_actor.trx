[ {
    42 actor-self actor-send
    99 actor-self actor-send
    { 42 eq } actor-recv-match /match-first exch def
} actor-spawn pop
0 coroutine-sleep 0 coroutine-sleep
match-first 42 eq
    (match-first: first message is the match) rt-ok clear

% ====================================================================
% SECTION 43: is-actor on dead actor
% ====================================================================

/dead-check [ { } actor-spawn def
0 coroutine-sleep 0 coroutine-sleep
dead-check coroutine-status /dead eq
    (dead-is-actor: status is dead) rt-ok
dead-check is-actor
    (dead-is-actor: is-actor still true for dead actor) rt-ok
clear

% ====================================================================
% SECTION 44: death wakes blocked sender
% ====================================================================

/wake-err null def
/wake-actor [ { } 1 actor-spawn-capacity def
1 wake-actor actor-send    % fill cap-1 mailbox

% Spawn sender that will block on full mailbox
[ wake-actor {
    % send second message -- blocks because mailbox is full
    2 exch actor-send
} coroutine-launch pop

0 coroutine-sleep          % sender blocks on full mailbox
wake-actor coroutine-kill  % kill actor: should wake blocked sender
0 coroutine-sleep 0 coroutine-sleep
% Sender got woken, retried, found dead target -> silent drop -> done
{ /wake-err /no-error def } try pop
wake-err /no-error eq
    (death-wakes-sender: blocked sender recovers) rt-ok clear

% ====================================================================
% SECTION 45: multiple sequential recv-timeout calls
% ====================================================================

/seq-t1 null def
/seq-t2 null def
/seq-actor [ {
    5000 actor-recv-timeout /seq-t1 exch def pop
    5000 actor-recv-timeout /seq-t2 exch def pop
} actor-spawn def
(first) seq-actor actor-send
(second) seq-actor actor-send
0 coroutine-sleep
seq-t1 true eq
    (seq-timeout: first recv-timeout succeeds) rt-ok
seq-t2 true eq
    (seq-timeout: second recv-timeout succeeds) rt-ok
clear

% ====================================================================
% SECTION 46: boundary — actor-spawn-capacity large
% ====================================================================

[ { 1000 coroutine-sleep } 256 actor-spawn-capacity dup is-actor
    (cap-large: capacity 256 actor created) rt-ok
coroutine-kill clear

% ====================================================================
% SECTION 50: actor-recv-match-timeout — match arrives before timeout
% ====================================================================

/rmt-msg null def
/rmt-flag null def
/rmt-actor [ {
    10 actor-self actor-send
    20 actor-self actor-send
    30 actor-self actor-send

    { 25 gt } 5000 actor-recv-match-timeout /rmt-flag exch def /rmt-msg exch def
} actor-spawn def
0 coroutine-sleep 0 coroutine-sleep
rmt-flag true eq
    (recv-match-timeout: true on match) rt-ok
rmt-msg 30 eq
    (recv-match-timeout: correct matched message) rt-ok clear

% ====================================================================
% SECTION 51: actor-recv-match-timeout — timeout expires, no match
% ====================================================================

/rmt2-msg null def
/rmt2-flag null def
[ {
    % send messages that will NOT match the predicate
    1 actor-self actor-send
    2 actor-self actor-send

    { 100 gt } 1 actor-recv-match-timeout /rmt2-flag exch def /rmt2-msg exch def
} actor-spawn pop
0 coroutine-sleep 0 coroutine-sleep 50 coroutine-sleep
rmt2-flag false eq
    (recv-match-timeout: false on timeout) rt-ok
rmt2-msg null eq
    (recv-match-timeout: null on timeout) rt-ok clear

% ====================================================================
% SECTION 52: actor-recv-match-timeout — non-matching messages preserved
% ====================================================================

/rmt3-match null def
/rmt3-r1 null def
/rmt3-r2 null def
[ {
    1 actor-self actor-send
    2 actor-self actor-send
    3 actor-self actor-send

    { 3 eq } 5000 actor-recv-match-timeout pop /rmt3-match exch def

    actor-recv /rmt3-r1 exch def
    actor-recv /rmt3-r2 exch def
} actor-spawn pop
0 coroutine-sleep 0 coroutine-sleep
rmt3-match 3 eq
    (recv-match-timeout: correct match value) rt-ok
rmt3-r1 1 eq
    (recv-match-timeout: remaining msg 1) rt-ok
rmt3-r2 2 eq
    (recv-match-timeout: remaining msg 2) rt-ok clear

% ====================================================================
% SECTION 53: actor-recv-match-timeout — match arrives after initial scan
% ====================================================================

/rmt4-msg null def
/rmt4-flag null def
/rmt4-actor [ {
    % start with no matching messages; one arrives later
    { 42 eq } 5000 actor-recv-match-timeout /rmt4-flag exch def /rmt4-msg exch def
} actor-spawn def
0 coroutine-sleep                            % let actor start and block
42 rmt4-actor actor-send                     % send matching message
0 coroutine-sleep 0 coroutine-sleep
rmt4-flag true eq
    (recv-match-timeout: match after initial empty) rt-ok
rmt4-msg 42 eq
    (recv-match-timeout: correct late match) rt-ok clear

% ====================================================================
% SECTION 54: actor-recv-match-timeout — timeout 0 (immediate check)
% ====================================================================

/rmt5-msg null def
/rmt5-flag null def
/rmt5-actor [ {
    10 actor-self actor-send
    { 10 eq } 0 actor-recv-match-timeout /rmt5-flag exch def /rmt5-msg exch def
} actor-spawn def
0 coroutine-sleep 0 coroutine-sleep
rmt5-flag true eq
    (recv-match-timeout: immediate match with 0ms) rt-ok
rmt5-msg 10 eq
    (recv-match-timeout: correct immediate value) rt-ok clear

% ====================================================================
% SECTION 55: actor-recv-match-timeout — timeout 0, no match
% ====================================================================

/rmt6-flag null def
[ {
    5 actor-self actor-send
    { 100 eq } 0 actor-recv-match-timeout /rmt6-flag exch def pop
} actor-spawn pop
0 coroutine-sleep 0 coroutine-sleep 50 coroutine-sleep
rmt6-flag false eq
    (recv-match-timeout: immediate timeout with 0ms no match) rt-ok clear

% ====================================================================
% SECTION 56: actor-recv-match-timeout — type errors
% ====================================================================

[ {
    { 42 100 actor-recv-match-timeout } try /type-check eq
        (recv-match-timeout: non-callable pred error) rt-ok
    { { true } -1 actor-recv-match-timeout } try /range-check eq
        (recv-match-timeout: negative timeout error) rt-ok
} actor-spawn pop
0 coroutine-sleep 0 coroutine-sleep
clear

% ====================================================================
% SECTION 57: actor-recv-match-timeout — pred returns non-boolean
% ====================================================================

[ {
    42 actor-self actor-send
    { pop 99 } 5000 actor-recv-match-timeout
} actor-spawn pop
0 coroutine-sleep 0 coroutine-sleep
//:status:last-error /type-check eq
    (recv-match-timeout: pred non-bool error) rt-ok clear

% ====================================================================
% SECTION 58: actor-recv-match-timeout — non-actor coroutine
% ====================================================================

[ {
    { { true } 100 actor-recv-match-timeout } try /invalid-access eq
        (recv-match-timeout: non-actor error) rt-ok
} coroutine-launch pop
0 coroutine-sleep 0 coroutine-sleep
clear

% ====================================================================
% SECTION 59: stress — many messages, match is last
% ====================================================================

/rmt-stress-msg null def
/rmt-stress-flag null def
[ {
    1 1 15 { actor-self actor-send } for      % send 1..15
    { 15 eq } 5000 actor-recv-match-timeout
    /rmt-stress-flag exch def /rmt-stress-msg exch def
} actor-spawn pop
0 coroutine-sleep 0 coroutine-sleep
rmt-stress-flag true eq
    (recv-match-timeout: stress match last of 15) rt-ok
rmt-stress-msg 15 eq
    (recv-match-timeout: stress correct value) rt-ok clear

% ====================================================================
% SECTION 60: fuzz — ExtValue (Long) messages through match-timeout
% ====================================================================

/rmt-ext-msg null def
/rmt-ext-flag null def
[ {
    1111111111l actor-self actor-send
    9999999999l actor-self actor-send
    { 5000000000l gt } 5000 actor-recv-match-timeout
    /rmt-ext-flag exch def /rmt-ext-msg exch def
} actor-spawn pop
0 coroutine-sleep 0 coroutine-sleep
rmt-ext-flag true eq
    (recv-match-timeout: extvalue match found) rt-ok
rmt-ext-msg 9999999999l eq
    (recv-match-timeout: extvalue correct value) rt-ok clear

% ====================================================================
% SECTION 61: actor-try-send — success (space available)
% ====================================================================

mark {
    actor-self /me exch def
    42 me actor-try-send
        (try-send: delivered returns true) rt-ok
    actor-recv 42 eq
        (try-send: message received) rt-ok
} actor-spawn coroutine-join pop clear

% ====================================================================
% SECTION 62: actor-try-send — dead target returns false
% ====================================================================

mark {
    mark { } actor-spawn /dead exch def
    0 coroutine-sleep 0 coroutine-sleep
    99 dead actor-try-send not
        (try-send: dead target returns false) rt-ok
} actor-spawn coroutine-join pop clear

% ====================================================================
% SECTION 63: actor-try-send — full mailbox returns false
% ====================================================================

mark {
    mark { { actor-recv pop } loop } actor-spawn-capacity 1 exch
    /target exch def
    % Fill the 1-capacity mailbox
    1 target actor-send
    0 coroutine-sleep
    % Try to send again — should be full
    2 target actor-try-send not
        (try-send: full mailbox returns false) rt-ok
    target coroutine-kill
} actor-spawn coroutine-join pop clear

% ====================================================================
% SECTION 64: actor-try-send — type error
% ====================================================================

{ 42 99 actor-try-send } try /type-check eq
    (try-send: non-coroutine target) rt-ok clear

% ====================================================================
% SECTION 65: actor-broadcast — basic
% ====================================================================

/bc-results [] def
mark {
    % Spawn 3 receivers
    mark { actor-recv } actor-spawn /r1 exch def
    mark { actor-recv } actor-spawn /r2 exch def
    mark { actor-recv } actor-spawn /r3 exch def
    0 coroutine-sleep

    % Broadcast message
    (hello) [ r1 r2 r3 ] actor-broadcast

    % Collect results
    r1 coroutine-join pop /v1 exch def
    r2 coroutine-join pop /v2 exch def
    r3 coroutine-join pop /v3 exch def

    v1 (hello) eq (broadcast: r1 got hello) rt-ok
    v2 (hello) eq (broadcast: r2 got hello) rt-ok
    v3 (hello) eq (broadcast: r3 got hello) rt-ok
} actor-spawn coroutine-join pop clear

% ====================================================================
% SECTION 66: actor-broadcast — dead actor skipped
% ====================================================================

mark {
    mark { actor-recv } actor-spawn /alive exch def
    mark { } actor-spawn /dead exch def
    0 coroutine-sleep 0 coroutine-sleep
    % dead should be dead now
    42 [ alive dead ] actor-broadcast
    alive coroutine-join pop
    42 eq (broadcast: alive got msg, dead skipped) rt-ok
} actor-spawn coroutine-join pop clear

% ====================================================================
% SECTION 67: actor-broadcast — empty array
% ====================================================================

mark {
    (msg) [] actor-broadcast
    true (broadcast: empty array no-op) rt-ok
} actor-spawn coroutine-join pop clear

% ====================================================================
% SECTION 68: actor-flush — basic
% ====================================================================

mark {
    10 actor-self actor-send
    20 actor-self actor-send
    30 actor-self actor-send
    actor-flush 3 eq
        (flush: returned 3) rt-ok
    actor-self actor-mailbox-empty?
        (flush: mailbox empty after flush) rt-ok
} actor-spawn coroutine-join pop clear

% ====================================================================
% SECTION 69: actor-flush — empty mailbox
% ====================================================================

mark {
    actor-flush 0 eq
        (flush: empty returns 0) rt-ok
} actor-spawn coroutine-join pop clear

% ====================================================================
% SECTION 70: actor-flush — non-actor error
% ====================================================================

{ actor-flush } try /invalid-access eq
    (flush: non-actor error) rt-ok clear

% ====================================================================
% SECTION 71: actor-set-name / actor-name — basic
% ====================================================================

[ { actor-recv pop } actor-spawn /a exch def

% unnamed actor returns false
a actor-name false eq
    (actor-name: unnamed returns false) rt-ok

% set a debug name
/worker a actor-set-name

% named actor returns name true
a actor-name true eq
    (actor-name: named returns true) rt-ok
/worker eq
    (actor-name: returns correct name) rt-ok  clear

% ====================================================================
% SECTION 72: actor-set-name — == printing with name
% ====================================================================

[ { actor-recv pop } actor-spawn /a exch def
/logger a actor-set-name

a ==s (--actor:logger:) starts-with?
    (actor-name: ==s includes name) rt-ok  clear

% ====================================================================
% SECTION 73: actor-set-name — non-actor coroutine error
% ====================================================================

[ { 1 yield } coroutine-launch /c exch def
{ /test c actor-set-name } try /type-check eq
    (actor-set-name: non-actor error) rt-ok  clear

% ====================================================================
% SECTION 74: actor-set-name — type errors
% ====================================================================

{ /x 42 actor-set-name } try /type-check eq
    (actor-set-name: non-coroutine error) rt-ok

[ { actor-recv pop } actor-spawn /a exch def
{ 99 a actor-set-name } try /type-check eq
    (actor-set-name: non-name error) rt-ok  clear

% ====================================================================
% SECTION 75: actor-name — overwrite name
% ====================================================================

[ { actor-recv pop } actor-spawn /a exch def
/alpha a actor-set-name
a actor-name pop /alpha eq
    (actor-name: first name) rt-ok
/beta a actor-set-name
a actor-name pop /beta eq
    (actor-name: overwritten name) rt-ok  clear

% ====================================================================
% SECTION 76: recv registration survives an unrelated save/restore
% ====================================================================
% ENGINE BUG #12 regression (the tetrix --ai-peek wedge): a historical
% restore-time mailbox scrub nulled every parked reader registration --
% CoroutineContexts live in global VM, so the scrub's above-barrier
% offset test matched EVERY parked actor, and any save/restore between
% an actor's recv-park and the next send lost the wakeup forever.  The
% same fossil unlinked parked blocked-senders; both died with it.
% Shape: park an actor in actor-recv, run an unrelated save/restore,
% THEN send.  The actor must wake and process the message.  (No
% coroutine-await here -- on a regressed engine the actor never wakes
% and an await would hang the suite; the yield + flag check fails
% cleanly instead.)

/got-msg 1 array def
got-msg 0 0 put
[ { actor-recv  got-msg 0  3 -1 roll  put } actor-spawn /a exch def
0 coroutine-sleep                      % let the actor reach actor-recv and park
save restore                           % unrelated save/restore while it is parked
42 a actor-send                        % must wake the parked reader
0 coroutine-sleep                      % give the woken actor a slice
0 coroutine-sleep
got-msg 0 get 42 eq
    (actor-recv: parked registration survives unrelated restore) rt-ok  clear

% ====================================================================
% SECTION 77: blocked-sender link survives an unrelated save/restore
% ====================================================================
% Sender side of the same fossil scrub: a sender parked on a FULL
% mailbox (capacity 64) was unlinked from the blocked-sender list by
% any restore, so the receiver's drain never woke it.  Shape: receiver
% actor holds off recv'ing; sender actor pushes 70 messages (parks at
% 64); main runs save/restore while the sender is parked; receiver is
% released and drains everything; the sender must complete its loop.
% Hang-free on regression: flags simply stay 0 and the asserts fail.

/released 1 array def
released 0 0 put
/sender-done 1 array def
sender-done 0 0 put
/recv-count 1 array def
recv-count 0 0 put
[ {
    { released 0 get 0 eq } { 10 coroutine-sleep } while
    0 1 69 { pop actor-recv pop recv-count 0 recv-count 0 get 1 add put } for
} actor-spawn /r exch def
[ r {
    /tgt exch def
    0 1 69 { tgt actor-send } for
    sender-done 0 1 put
} actor-spawn pop
50 coroutine-sleep                     % sender fills 64 slots and parks
save restore                           % unrelated save/restore while it is parked
released 0 1 put                       % receiver starts draining
0 1 200 {                              % bounded wait (max ~4s); exits early when done
    pop
    sender-done 0 get 1 eq  recv-count 0 get 70 eq  and { exit } if
    20 coroutine-sleep
} for
sender-done 0 get 1 eq
    (actor-send: parked sender survives unrelated restore) rt-ok
recv-count 0 get 70 eq
    (actor-send: all 70 messages delivered after restore) rt-ok  clear

% ====================================================================
% vm-validate (final integrity check)
% ====================================================================

//:status:vm-validate
    (vm-validate: heap integrity after all actor tests) rt-ok

rt-fails 0 get /integer-type cast 0 gt { /actor-assertions-failed throw } if
(test_actor: ALL TESTS PASSED) =
(__test_ok__) =
