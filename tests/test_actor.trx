% ====================================================================
% SECTION 36: fuzz — recv-match stress (match deep in queue)
% ====================================================================

/deep-match null def
[ {
    1 1 15 { actor-self actor-send } for     % fill with 1..15
    { 15 eq } actor-recv-match /deep-match exch def
} actor-spawn pop
0 coroutine-sleep 0 coroutine-sleep
