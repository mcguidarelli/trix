% ====================================================================
% Mirror of test_curry.trx long/ulong cases for Int128/UInt128.
%
% test_int128_containers.trx covers the basic curry surface (capture,
% exec, uncurry). This file mirrors the broader test_curry.trx patterns
% exercised with `l`: curry with a proc-literal callable, nested curry,
% curry equality, curry-valued arrays and dicts, save/restore of
% curried bindings, and stress churn.
% ====================================================================

% rt-ok counts failures in a restore-immune slot -- string byte writes
% are unjournaled, so the count survives assertions made inside save
% scopes, and the 1-byte string lives in LOCAL VM, invisible to the
% global-heap/gc-counter probes some files assert on.  The file THROWS
% at EOF: test_all counts a file as failed only when its run throws,
% so print-only failures would slip the suite verdict.
/rt-fails 1 string def
rt-fails 0 16#0#b put
/rt-ok { exch { = } { (FAILED: ) print = rt-fails 0  rt-fails 0 get /integer-type cast 1 add dup 255 gt { pop 255 } if /byte-type cast  put } if-else } def

% ====================================================================
% SECTION 1: curry with proc-literal callable
% ====================================================================

100q { 2q mul } curry exec 200q deep-eq   (curry int128 + proc literal) rt-ok clear
100uq { 2uq mul } curry exec 200uq deep-eq (curry uint128 + proc literal) rt-ok clear

% ====================================================================
% SECTION 2: curry with named operator
% ====================================================================

100q //add curry 200q exch exec 300q deep-eq (curry int128 + //add) rt-ok clear
100uq //add curry 200uq exch exec 300uq deep-eq (curry uint128 + //add) rt-ok clear

% ====================================================================
% SECTION 3: uncurry recovers captured value and callable
% ====================================================================

42q //add curry uncurry
    //add eq exch 42q deep-eq and           (uncurry: int128 capture) rt-ok clear
100uq //sub curry uncurry
    //sub eq exch 100uq deep-eq and         (uncurry: uint128 capture) rt-ok clear

% ====================================================================
% SECTION 4: curry equality semantics
% ====================================================================

42q //add curry 42q //add curry deep-eq     (curry deep-eq: same int128 capture+op) rt-ok clear
42q //add curry 43q //add curry deep-eq not (curry deep-eq: differing int128 capture) rt-ok clear
42uq //add curry 42uq //add curry deep-eq   (curry deep-eq: same uint128) rt-ok clear

% ====================================================================
% SECTION 5: nested curry (curry of curry)
% ====================================================================

10q 20q //add curry curry exec 30q deep-eq  (nested curry int128 exec) rt-ok clear
10uq 20uq //add curry curry exec 30uq deep-eq (nested curry uint128 exec) rt-ok clear

% ====================================================================
% SECTION 6: curry-valued arrays
% ====================================================================

[ 42q //add curry 3.14d //mul curry ] length 2 eq
    (array of curries: length) rt-ok clear

[ 42q //add curry ] 0 get 8q exch exec 50q deep-eq
    (array element exec: int128 curry) rt-ok clear

% Multiple curries used together
100q //add curry 200q exch exec
50q //add curry 50q exch exec
add 400q deep-eq                            (two curries sum: int128) rt-ok clear

% ====================================================================
% SECTION 7: save/restore of curried bindings
% ====================================================================

/sv-curry-h 42q //add curry def
/s1 save def
    /sv-curry-h 99q //mul curry def
    8q sv-curry-h exec 792q deep-eq         (save curry: inner int128 binding) rt-ok clear
s1 restore
8q sv-curry-h exec 50q deep-eq              (save curry: outer int128 restored) rt-ok clear

% ====================================================================
% SECTION 8: curry inside dict values
% ====================================================================

<< /op 42q //add curry >> /ev-dict exch def
/s2 save def
    ev-dict /op 99q //mul curry put
    8q ev-dict /op get exec 792q deep-eq    (dict curry: inner int128) rt-ok clear
s2 restore
8q ev-dict /op get exec 50q deep-eq         (dict curry: restored int128) rt-ok clear

% ====================================================================
% SECTION 9: stress -- many curries churning WideValue heap
% ====================================================================

/s3 save def
    100 { 1q { add } curry pop } repeat
s3 restore
42q 1q add 43q deep-eq                      (post-stress: int128 arith OK) rt-ok clear

//:status:widevalue-validate (widevalue free-list integrity OK) rt-ok
//:status:vm-validate (vm heap integrity OK) rt-ok

(test_int128_curry_mirror.trx complete) =
rt-fails 0 get /integer-type cast 0 gt { /rt-assertions-failed throw } if
(__test_ok__) =
