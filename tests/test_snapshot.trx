% ====================================================================
% test_snapshot.trx -- snap-shot / thaw test suite (phase 1 + phase 2)
% ====================================================================
% Phase 1: in-process tests, then snap-shot, then post-snap-shot checks.
% Phase 2: thaw via tests/snapshot_thaw.trx re-runs post-snap-shot checks.
% File intentionally exceeds 4KB to exercise startup file tail serialization.

% rt-ok counts failures in a restore-immune slot -- string byte writes
% are unjournaled, so the count survives assertions made inside save
% scopes, and the 1-byte string lives in LOCAL VM, invisible to the
% global-heap/gc-counter probes some files assert on.  The file THROWS
% at EOF: test_all counts a file as failed only when its run throws,
% so print-only failures would slip the suite verdict.
/rt-fails 1 string def
rt-fails 0 16#0#b put
/rt-ok { exch { = } { (FAILED: ) print = rt-fails 0  rt-fails 0 get /integer-type cast 1 add dup 255 gt { pop 255 } if /byte-type cast  put } if-else } def

% --- error paths (phase-1 only, before snap-shot) ---
{ (nonexistent-file-12345.img) thaw } try
/file-open-error eq  (err: thaw nofile) rt-ok  clear
{ thaw } try /opstack-underflow eq  (err: thaw underflow) rt-ok  clear
{ 42 thaw } try /type-check eq  (err: thaw typecheck) rt-ok  clear
{ 42 snap-shot } try /type-check eq  (err: snap typecheck) rt-ok  clear
{ snap-shot } try /opstack-underflow eq  (err: snap underflow) rt-ok  clear
(/tmp/trix_snap_garbage.dat) (w)#b stream
dup (NOT A SNAPSHOT) write-string close-stream
{ (/tmp/trix_snap_garbage.dat) thaw } try
/invalid-image-file eq  (err: thaw garbage) rt-ok  clear
(/tmp/trix_snap_empty.dat) (w)#b stream close-stream
{ (/tmp/trix_snap_empty.dat) thaw } try
/invalid-image-file eq  (err: thaw empty) rt-ok  clear
(/tmp/trix_snap_garbage.dat) delete-file
(/tmp/trix_snap_empty.dat) delete-file

% --- setup state for round-trip ---
/si 42 def  /sn -7 def  /sz 0 def  /sr 3.14 def
/sl 123456789l def  /su 42ul def  /sd 2.718d def
/s128a 16#DEADBEEFCAFEBABE0123456789ABCDEF#uq def
/s128b 16#7FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF#q def
/s128c -42q def
/st true def  /sf false def  /ss (hello world) def
/sN null def  /sa [1 2 3] def
/sD << /a 1 /b 2 >> def
/sE [1 [2 3] [4 [5 6]]] def
/sP { 1 2 add } def
/sx 999 def  /sy (kept) def
12345ul rand-seed

% Screen state for D1 -- snap a small Screen with known cells, render to
% a string-stream pre-snap, and assert dims/cells/render-output post-snap
% (post-snap section runs in both phases, so phase-2 thaw is the round-trip).
/sScr 8 4 make-screen def
sScr 1 1 65 7 0 1 screen-put-cell pop  % 'A' bold at (1,1)
sScr 2 1 66 4 0 0 screen-put-cell pop  % 'B' blue at (2,1)
sScr 3 1 67 2 7 2 screen-put-cell pop  % 'C' green-on-gray underline at (3,1)
/sScrCap 256 make-string-stream def
sScr sScrCap screen-render-to pop
/sScrBytes sScrCap get-string-stream def

mark 100 200 300

% --- global VM round-trip: build state via every Phase-2 surface ---
% $/foo prefix:           literal name interned globally
% $\foo prefix:           executable name interned globally (scanned in proc literal, never invoked)
% <<...>>#$ suffix:       dict struct in global VM
% [arr]#$ suffix:         array storage in global VM
% {{set}}#$ suffix:       set struct in global VM
% (str)#$ suffix:         string bytes in global VM
% ${ N dict }:            runtime allocator routed via flag
% set-global / current-global: direct flag control
$/sg-name pop                                   % global Name interned
{ $\sg-exec-name } pop                          % executable global Name (scanned only)
/sg-dict << $/sg-key 100 >>#$ def
/sg-arr  [ 11 22 33 ]#$ def
/sg-set  {{ $/sg-x $/sg-y $/sg-z }}#$ def
/sg-str  (persistent)#$ def
/sg-rt-dict ${ 4 dict } def
sg-rt-dict $/sg-rt-key 999 put

(tests/snapshot.img) snap-shot
% ==== post-snap-shot: runs in BOTH phases ====
% Section 1: Value round-trip
si 42 eq (s:int) rt-ok
sn -7 eq (s:neg) rt-ok
sz 0 eq (s:zero) rt-ok
sr 3.14 eq (s:real) rt-ok
sl 123456789l eq (s:long) rt-ok
su 42ul eq (s:ulong) rt-ok
sd 2.718d eq (s:dbl) rt-ok
s128a 16#DEADBEEFCAFEBABE0123456789ABCDEF#uq deep-eq (s:uint128-payload) rt-ok
s128b 16#7FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF#q deep-eq (s:int128-max) rt-ok
s128c -42q deep-eq (s:int128-neg) rt-ok
st (s:true) rt-ok
sf not (s:false) rt-ok
ss (hello world) eq (s:str) rt-ok
sN null eq (s:null) rt-ok
sa length 3 eq (s:arr-len) rt-ok
sa 0 get 1 eq (s:a0) rt-ok
sa 1 get 2 eq (s:a1) rt-ok
sa 2 get 3 eq (s:a2) rt-ok
sD /a get 1 eq (s:d/a) rt-ok
sD /b get 2 eq (s:d/b) rt-ok
sD length 2 eq (s:d-len) rt-ok
sE 0 get 1 eq (s:n0) rt-ok
sE 1 get 0 get 2 eq (s:n10) rt-ok
sE 1 get 1 get 3 eq (s:n11) rt-ok
sE 2 get 0 get 4 eq (s:n20) rt-ok
sE 2 get 1 get 0 get 5 eq (s:n210) rt-ok
sE 2 get 1 get 1 get 6 eq (s:deep) rt-ok
sP exec 3 eq (s:proc) rt-ok

% Section 2: Stack preservation (mark 100 200 300 on stack before snap-shot)
300 eq (s:top) rt-ok
200 eq (s:mid) rt-ok
100 eq (s:bot) rt-ok
count-to-mark 0 eq (s:mark-empty) rt-ok
clear

% Section 3: Dictionary persistence
sx 999 eq (s:dx) rt-ok
sy (kept) eq (s:dy) rt-ok
/sx where pop current-dict eq (s:where) rt-ok  clear

% Section 4: RNG state
/rv1 rand-uinteger def
/rv2 rand-uinteger def
rv1 type /uinteger-type eq (s:rng1) rt-ok
rv2 type /uinteger-type eq (s:rng2) rt-ok
rv1 rv2 ne (s:rng-diff) rt-ok  clear

% Section 5: Snap-shot file verification
(tests/snapshot.img) (r)#b stream
dup type /stream-type eq (s:frz) rt-ok
close-stream  clear

% Section 6: Screen state round-trip (D1)
sScr screen? (s:screen-pred) rt-ok
sScr handle-kind /screen eq (s:screen-kind) rt-ok
sScr screen-cols 8 eq (s:screen-cols) rt-ok
sScr screen-rows 4 eq (s:screen-rows) rt-ok
% Cells set pre-snap: ('A' fg=7 bg=0 attrs=1 at 1,1), ('B' fg=4 attrs=0), ('C' fg=2 bg=7 attrs=2)
sScr 1 1 screen-get-cell                     % ch fg bg attrs
1 eq (s:scell-A-attrs) rt-ok
0 eq (s:scell-A-bg) rt-ok
7 eq (s:scell-A-fg) rt-ok
65 eq (s:scell-A-ch) rt-ok
sScr 3 1 screen-get-cell
2 eq (s:scell-C-attrs) rt-ok
7 eq (s:scell-C-bg) rt-ok
2 eq (s:scell-C-fg) rt-ok
67 eq (s:scell-C-ch) rt-ok
% Untouched cell: defaults (space=0x20, fg=7, bg=0, attrs=0)
sScr 0 0 screen-get-cell
0 eq (s:scell-d-attrs) rt-ok
0 eq (s:scell-d-bg) rt-ok
7 eq (s:scell-d-fg) rt-ok
32 eq (s:scell-d-ch) rt-ok
% Render output captured pre-snap survives unchanged across the snap-shot
sScrBytes length 0 ne (s:srender-nonempty) rt-ok

% ====================================================================
% Section 7: Past-buffer-boundary assertions
% These assertions are positioned past the 4KB stream buffer boundary
% to verify that the startup file tail serialization works correctly.
% Without Option B, thaw would get EOF here and miss these tests.
% ====================================================================

% Arithmetic round-trip through snap-shot
si sn add 35 eq (s:arith-add) rt-ok  clear
si 2 mul 84 eq (s:arith-mul) rt-ok  clear
sl 1000l mod 789l eq (s:arith-mod) rt-ok  clear
sd 1.0d add 3.718d eq (s:arith-dadd) rt-ok  clear

% String operations
ss length 11 eq (s:strlen) rt-ok  clear
(hello world) (world) search (s:search) rt-ok  clear
ss 0 get 104b eq (s:str-get) rt-ok  clear

% Array operations
sa reverse 0 get 3 eq (s:rev-arr) rt-ok  clear
[10 20 30 40 50] length 5 eq (s:arr5-len) rt-ok  clear

% Boolean logic
st sf and false eq (s:bool-and) rt-ok  clear
st sf or true eq (s:bool-or) rt-ok  clear
st not false eq (s:bool-not) rt-ok  clear

% Type checks on preserved values
si type /integer-type eq (s:type-int) rt-ok  clear
sr type /real-type eq (s:type-real) rt-ok  clear
sl type /long-type eq (s:type-long) rt-ok  clear
su type /ulong-type eq (s:type-ulong) rt-ok  clear
sd type /double-type eq (s:type-dbl) rt-ok  clear
ss type /string-type eq (s:type-str) rt-ok  clear
sa type /array-type eq (s:type-arr) rt-ok  clear
sD type /dict-type eq (s:type-dict) rt-ok  clear

% Nested proc execution after thaw
{ 10 20 add } exec 30 eq (s:proc-exec) rt-ok  clear
{ { 5 6 mul } exec } exec 30 eq (s:proc-nest) rt-ok  clear

% Dict access patterns
<< /x 42 /y 99 >> /x get 42 eq (s:dict-get) rt-ok  clear
sD /a known? (s:dict-known?) rt-ok  clear
sD /z known? not (s:dict-unknown?) rt-ok  clear

% --- global VM round-trip ---
% Names interned via $/foo survive thaw (in both phase-1 in-process
% and phase-2 cold thaw).  Their global Name structs were serialised
% with the global region.
sg-dict $/sg-key get 100 eq (s:global-dict-key) rt-ok  clear
sg-arr 0 get 11 eq (s:global-arr-0) rt-ok  clear
sg-arr 2 get 33 eq (s:global-arr-2) rt-ok  clear
sg-set $/sg-x set-member? (s:global-set-x) rt-ok  clear
sg-set $/sg-y set-member? (s:global-set-y) rt-ok  clear
sg-str (persistent) eq (s:global-str-eq) rt-ok  clear
sg-str length 10 eq (s:global-str-len) rt-ok  clear
sg-rt-dict $/sg-rt-key get 999 eq (s:global-rt-dict) rt-ok  clear
% vm-global-used must be > 0 after a thaw of a snapshot that contained globals
//:status:vm-global-used 0 gt (s:vm-global-used > 0) rt-ok  clear
% current-global flag was false at snapshot time (default); thaw must restore false
current-global false eq (s:current-global preserved) rt-ok  clear

% Final verification: this line is well past the 4KB buffer boundary.
% If you see this message after thaw, the startup file tail was restored.
rt-fails 0 get /integer-type cast 0 gt { /rt-assertions-failed throw } if
(test_snapshot: ALL TESTS PASSED) =
(__test_ok__) =
