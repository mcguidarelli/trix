% ====================================================================
% Phase 1 scaffolding smoke test for Int128 / UInt128 support.
%
% No user-level syntax or operators construct these values yet (Phase 2
% adds the h / uh suffixes; Phase 3 adds arithmetic).  This file only
% confirms that the type plumbing is wired: the type names resolve, the
% verify system's new masks exist, the //:status: queries for the
% WideValue heap work, and the introspection path still validates.
% ====================================================================

% rt-ok counts failures in a restore-immune slot -- string byte writes
% are unjournaled, so the count survives assertions made inside save
% scopes, and the 1-byte string lives in LOCAL VM, invisible to the
% global-heap/gc-counter probes some files assert on.  The file THROWS
% at EOF: test_all counts a file as failed only when its run throws,
% so print-only failures would slip the suite verdict.
/rt-fails 1 string def
rt-fails 0 16#0#b put
/rt-ok { exch { = } { (FAILED: ) print = rt-fails 0  rt-fails 0 get /integer-type cast 1 add dup 255 gt { pop 255 } if /byte-type cast  put } if-else } def

% ---------- type-name registration ----------
% The type_sv() additions must be interned by init.inl so that
% //systemdict:numbers resolves them like any other first-class type.
/int128-type /int128-type eq       (int128-type name is registered) rt-ok
/uint128-type /uint128-type eq     (uint128-type name is registered) rt-ok

% ---------- WideValue free-list accounting ----------
% At process start the WideValue free-list validator must report OK.
% The active count is non-zero because systemdict::numbers::int128-type
% and uint128-type pre-allocate 2 cells each (min + max limits).
//:status:widevalue-active 4 eq    (widevalue-active baseline: 4 limits pre-allocated) rt-ok
//:status:widevalue-validate       (widevalue free-list integrity OK) rt-ok

% ---------- integration with existing invariants ----------
% vm-validate and extvalue-validate also still hold: adding the
% WideValue plumbing didn't perturb the rest of the heap.
//:status:vm-validate               (vm heap integrity OK) rt-ok
//:status:extvalue-validate         (extvalue free-list integrity OK) rt-ok

(test_int128_scaffold.trx complete) =
rt-fails 0 get /integer-type cast 0 gt { /rt-assertions-failed throw } if
(__test_ok__) =
