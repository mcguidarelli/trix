% ====================================================================
% test_dollar_force_local_stress.trx -- force-local long-running stress
% ====================================================================
% 10K-iteration loop inside ${...} allocating mixed [arr]#$$,
% <<dict>>#$$, {proc}#$$ literals.  Each #$$ literal should land in
% local VM (not global) regardless of the enclosing ${...} scope.
% Goal: prove force-local truly bypasses the global VM -- no slow leak.
%
% Runs at default --vm-size (1 MiB) in well under 5 seconds.
% ====================================================================

% rt-ok counts failures in a restore-immune slot -- string byte writes
% are unjournaled, so the count survives assertions made inside save
% scopes, and the 1-byte string lives in LOCAL VM, invisible to the
% global-heap/gc-counter probes some files assert on.  The file THROWS
% at EOF: test_all counts a file as failed only when its run throws,
% so print-only failures would slip the suite verdict.
/rt-fails 1 string def
rt-fails 0 16#0#b put
/rt-ok { exch { = } { (FAILED: ) print = rt-fails 0  rt-fails 0 get /integer-type cast 1 add dup 255 gt { pop 255 } if /byte-type cast  put } if-else } def

% Baseline -- global VM size BEFORE the stress run.
//:status:vm-global-used /fl-vg0 exch def

% 10K-iter mixed allocation loop inside ${...}.
% Each iteration:
%   * one #$$ array     (force-local)
%   * one #$$ dict      (force-local)
%   * one #$$ packed proc (force-local)
% After each, pop the result -- but the storage is local-VM, which
% gets reclaimed when the surrounding save level is exited.  Crucial
% check: global VM does NOT grow proportionally to iteration count.

${
    10000 {
        [ 1 2 3 ]#$$ pop
        << /a 1 /b 2 >>#$$ pop
        { 1 2 add }#$$ pop
    } repeat
}

% Final -- global VM size AFTER the stress run.
//:status:vm-global-used /fl-vg1 exch def

% Total growth budget: 8 KiB.  Most of this is fixed overhead from
% the ${...} scope entry itself (frame dict, etc.) -- NOT the
% per-iteration allocations.  If #$$ leaked even 1 byte per literal
% to global, 30000 literals would blow this budget by ~30x.
fl-vg1 fl-vg0 sub /fl-delta exch def
fl-delta 8192 lt
    <(fl-stress: 30000 #$$ literals total <8 KiB global growth)> rt-ok clear

rt-fails 0 get /integer-type cast 0 gt { /rt-assertions-failed throw } if
(test_dollar_force_local_stress: ALL TESTS PASSED) =
(__test_ok__) =
