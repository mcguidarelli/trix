% test_interpolation.trx — String interpolation escape \{name}
% Tests: scan-time name lookup, type conversion, dict paths, error handling

% rt-ok counts failures in a restore-immune slot -- string byte writes
% are unjournaled, so the count survives assertions made inside save
% scopes, and the 1-byte string lives in LOCAL VM, invisible to the
% global-heap/gc-counter probes some files assert on.  The file THROWS
% at EOF: test_all counts a file as failed only when its run throws,
% so print-only failures would slip the suite verdict.
/rt-fails 1 string def
rt-fails 0 16#0#b put
/rt-ok { exch { = } { (FAILED: ) print = rt-fails 0  rt-fails 0 get /integer-type cast 1 add dup 255 gt { pop 255 } if /byte-type cast  put } if-else } def

% ====================================================================
% SECTION: basic interpolation
% ====================================================================

% Integer
/x 42 def
(\{x}) (42) eq (interp: integer) rt-ok clear

% Negative integer
/neg -100 def
(\{neg}) (-100) eq (interp: negative integer) rt-ok clear

% UInteger
/u 42u def
(\{u}) (42) eq (interp: uinteger) rt-ok clear

% Long
/lg 9999999999l def
(\{lg}) (9999999999) eq (interp: long) rt-ok clear

% ULong
/ulg 9999999999ul def
(\{ulg}) (9999999999) eq (interp: ulong) rt-ok clear

% Real
/r 3.5 def
(\{r}) (3.5) eq (interp: real) rt-ok clear

% Double
/d 3.5d def
(\{d}) (3.5) eq (interp: double) rt-ok clear

% Boolean true
/t true def
(\{t}) (true) eq (interp: true) rt-ok clear

% Boolean false
/f false def
(\{f}) (false) eq (interp: false) rt-ok clear

% String value (raw content, no parens)
/s (hello world) def
(\{s}) (hello world) eq (interp: string no parens) rt-ok clear

% Empty string value
/e () def
(\{e}) () eq (interp: empty string value) rt-ok clear

% Name value (raw name, no / prefix)
/n /greeting def
(\{n}) (greeting) eq (interp: name no slash) rt-ok clear

% Byte value
/ch 65b def
(\{ch}) (A) eq (interp: byte as char) rt-ok clear

% Byte zero
/z 0b def
(\{z}) length 1 eq (interp: byte zero is 1 char) rt-ok clear

% ====================================================================
% SECTION: multiple interpolations
% ====================================================================

% Two interpolations
/a 1 def
/b 2 def
(\{a}+\{b}=3) (1+2=3) eq (interp: two values) rt-ok clear

% Three interpolations
/x 10 def
/y 20 def
/z 30 def
(\{x},\{y},\{z}) (10,20,30) eq (interp: three values) rt-ok clear

% Interpolation at start
/x 42 def
(\{x} is the answer) (42 is the answer) eq (interp: at start) rt-ok clear

% Interpolation at end
(answer is \{x}) (answer is 42) eq (interp: at end) rt-ok clear

% Interpolation only (no surrounding text)
(\{x}) (42) eq (interp: only interpolation) rt-ok clear

% Adjacent interpolations
(\{a}\{b}) (12) eq (interp: adjacent) rt-ok clear

% ====================================================================
% SECTION: scan-time semantics
% ====================================================================

% Value captured at scan time, not execution time
/x 42 def
/s (\{x} is the answer) def
/x 99 def
s (42 is the answer) eq (interp: scan-time capture) rt-ok clear

% Inside a procedure: captured when procedure is scanned
/x 42 def
/f { (\{x}) } def
/x 99 def
f (42) eq (interp: proc scan-time capture) rt-ok clear

% ====================================================================
% SECTION: dictionary path lookup
% ====================================================================

% System dict path
(\{:systemdict:numbers:real-type:pi}) length 0 gt (interp: systemdict path) rt-ok clear

% ====================================================================
% SECTION: mixed with other escapes
% ====================================================================

% Interpolation + standard escapes
/x 42 def
(line1\n\{x}\nline3) length 0 gt (interp: mixed with \\n) rt-ok clear

% Interpolation + hex escape
(\x41\{x}) (A42) eq (interp: mixed with \\x) rt-ok clear

% Interpolation + octal escape
(\101\{x}) (A42) eq (interp: mixed with octal) rt-ok clear

% Literal braces without backslash still work
({hello}) ({hello}) eq (interp: literal braces unaffected) rt-ok clear

% ====================================================================
% SECTION: boundary tests
% ====================================================================

% Large integer
/big 2147483647 def
(\{big}) (2147483647) eq (interp: max int32) rt-ok clear

% Zero
/zero 0 def
(\{zero}) (0) eq (interp: zero) rt-ok clear

% String with special chars
/sp (hello world) def
(\{sp}) (hello world) eq (interp: string with space) rt-ok clear

% Long name (close to limit)
/abcdefghijklmnopqrstuvwxyzABCD 42 def
(\{abcdefghijklmnopqrstuvwxyzABCD}) (42) eq (interp: long name) rt-ok clear

% Multiple interpolations building a long result
/w (abcdefghij) def
(\{w}\{w}\{w}\{w}\{w}) length 50 eq (interp: 50-byte result) rt-ok clear

% ====================================================================
% SECTION: error handling notes
% ====================================================================
% \{name} errors (undefined, type-check, empty braces) are scan-time errors.
% They cannot be caught by try/try-catch from the same source file because
% the error occurs during scanning, before any operator executes.
% Error behavior is verified via manual testing (see test session notes).
rt-fails 0 get /integer-type cast 0 gt { /rt-assertions-failed throw } if
(__test_ok__) =
