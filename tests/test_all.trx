(====================================) =
(  Results:) =
(  {} tests, {} failures) mark test-count fail-count print-fmt pop pop nl
(====================================) =

fail-count 0 eq { (  ALL TESTS PASSED) = } { (  SOME TESTS FAILED) = } if-else
(__test_ok__) =
