% ====================================================================
% Master Test Runner
% ====================================================================
% Runs all test_*.trx files via the `run` operator, exercising the
% stream open/execute/close infrastructure in the process.

/test-count 0 def
/fail-count 0 def

/run-test-save null def
/run-test {
    % str run-test :- --
    % Opens and executes a test file, reports success or failure.
    % Wraps run in save/restore so each test's VM allocations are reclaimed.
    dup (  running: ) print =
    /run-test-save save def
    { run } try
    run-test-save restore
    dup /no-error eq {
        pop
        /test-count test-count 1 add def
    } {
        (  FAILED: ) print =
        /fail-count fail-count 1 add def
        /test-count test-count 1 add def
    } if-else
    clear
} def

(====================================) =
(  Trix Master Test Runner) =
(====================================) =

% --------------------------------------------------------------------
% Standalone-only tests -- NOT run here; tests/run_all.sh covers them
% with the per-test flags they require (see its SPECIAL_ARGS table):
%   test_screen.trx              needs --vm-size=2M
%   test_lazy.trx                needs --vm-size=2M
%   test_name_torture.trx        needs --vm-size=2M
%   test_find_all_persist.trx    needs --scratch-depth=2048
%   test_int128_actor_mirror.trx sl=0 only: run-test's save wrapper makes
%       its Int128 messages restore-fragile, so actor-try-send refuses and
%       actor-send raises by design (R6 guard, actor_send_complete).
% --------------------------------------------------------------------

