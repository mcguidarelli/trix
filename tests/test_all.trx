% Logic tests MUST run save-wrapped: a successful raw `choice` holds its
% save level open by design (bindings live above the barrier), so unwrapped
% they leave sl > 0 for every later test -- at which point actor message
% delivery of local values correctly raises /invalid-access (restore-fragile
% guard).  run-test's restore reclaims the open choice levels.  Neither file
% spawns coroutines, so the save wrapper is safe for them.
(tests/test_logic.trx) run-test
(tests/test_logic_aggregate_between.trx) run-test

% Kill any zombie coroutines left by a previous test.  With the O(1) ready-queue
% scheduler, live coroutines that weren't explicitly killed stay in the ready queue
% and corrupt subsequent tests.
/kill-zombies { coroutine-kill-all clear } def

% coroutine test runs without save/restore wrapper (coroutine allocations
% cannot survive restore; all coroutines clean up before the test returns)
(  running: tests/test_coroutine.trx) =
{ (tests/test_coroutine.trx) run } try
dup /no-error eq {
    pop
    /test-count test-count 1 add def
} {
    (  FAILED: ) print =
    /fail-count fail-count 1 add def
    /test-count test-count 1 add def
} if-else
clear kill-zombies

% eqref coroutine test runs without save/restore wrapper (same reason)
(  running: tests/test_eqref_coroutine.trx) =
{ (tests/test_eqref_coroutine.trx) run } try
dup /no-error eq {
    pop
    /test-count test-count 1 add def
} {
    (  FAILED: ) print =
    /fail-count fail-count 1 add def
    /test-count test-count 1 add def
} if-else
clear kill-zombies

