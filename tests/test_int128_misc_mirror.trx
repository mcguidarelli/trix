% ====================================================================
% Mirror of test_tier2_gaps.trx, test_match.trx, and test_pack.trx
% long/ulong cases for Int128/UInt128.
%
% Covers: clear-object, peek/poke round-trip, when/unless predicates,
% let bindings, and pack rejection of 128-bit (pack's width specs top
% out at 64-bit, by design; this verifies the rejection is clean).
% ====================================================================

% rt-ok counts failures in a restore-immune slot -- string byte writes
% are unjournaled, so the count survives assertions made inside save
% scopes, and the 1-byte string lives in LOCAL VM, invisible to the
% global-heap/gc-counter probes some files assert on.  The file THROWS
% at EOF: test_all counts a file as failed only when its run throws,
% so print-only failures would slip the suite verdict.
/rt-fails 1 string def
rt-fails 0 16#0#b put
/rt-ok { exch { = } { (FAILED: ) print = rt-fails 0  rt-fails 0 get /integer-type cast 1 add dup 255 gt { pop 255 } if /byte-type cast  put } if-else } def

% ====================================================================
% SECTION 1: clear-object -- zero-of-same-type
% ====================================================================

42q clear-object 0q deep-eq             (clear-object: int128 -> 0q) rt-ok clear
42uq clear-object 0uq deep-eq           (clear-object: uint128 -> 0uq) rt-ok clear
42q clear-object type /int128-type eq   (clear-object: int128 type preserved) rt-ok clear
42uq clear-object type /uint128-type eq (clear-object: uint128 type preserved) rt-ok clear

% ====================================================================
% SECTION 2: peek / poke with 128-bit values (already in UB sweep
% but re-asserted here alongside related ops)
% ====================================================================

16 alloc /addr exch def
123456789q addr poke
addr /int128-type peek 123456789q deep-eq (peek/poke: int128 round-trip) rt-ok clear

999uq addr poke
addr /uint128-type peek 999uq deep-eq   (peek/poke: uint128 round-trip) rt-ok clear

% Large boundary values
170141183460469231731687303715884105727q addr poke
addr /int128-type peek 170141183460469231731687303715884105727q deep-eq
    (peek/poke: INT128_MAX round-trip) rt-ok clear

340282366920938463463374607431768211455uq addr poke
addr /uint128-type peek 340282366920938463463374607431768211455uq deep-eq
    (peek/poke: UINT128_MAX round-trip) rt-ok clear

addr free

% ====================================================================
% SECTION 3: when / unless with 128-bit predicate subject
% ====================================================================

100000000000q { is-int128 } { 1q add } when
    100000000001q deep-eq               (when: int128 predicate true) rt-ok clear

1000q { is-uint128 } { 1q add } when
    1000q deep-eq                       (when: int128 pred false -> unchanged) rt-ok clear

1000uq { is-uint128 } { 1uq add } when
    1001uq deep-eq                      (when: uint128 predicate true) rt-ok clear

% ====================================================================
% SECTION 4: let bindings with 128-bit values
% ====================================================================

1000000000000q 3.14d [/a /b] let
    a 1000000000000q deep-eq            (let: int128 binding) rt-ok
    b 3.14d eq                          (let: coexisting double) rt-ok
end clear

100q 200q [/x /y] let
    x y add 300q deep-eq                (let: two int128 bindings) rt-ok
end clear

% ====================================================================
% SECTION 5: pack rejects 128-bit cleanly (documented limit)
% ====================================================================

{ mark 42q (h) pack } try /type-check eq
    (pack: int128 rejected cleanly) rt-ok clear
{ mark 42uq (H) pack } try /type-check eq
    (pack: uint128 rejected cleanly) rt-ok clear

(test_int128_misc_mirror.trx complete) =
rt-fails 0 get /integer-type cast 0 gt { /rt-assertions-failed throw } if
(__test_ok__) =
