% test_eqref_overflow.trx
%
% MUST be run with --test-eqgen-preload=4294967295 (UINT32_MAX).  That flag
% seeds all five eq-storage generation counters to their maximum at startup,
% so the very next ref-creation of any kind trips the 2^32-wrap LimitCheck
% path without needing to execute 2^32 real creations.
%
% Each kind has two entry points:
%   - the scanner syntax (#=, one per kind)
%   - the runtime op (=string / =array / =dict; no runtime equivalents for
%     eqproc or eqset, their only path is scan-time syntax)
%
% Scanner-path errors fire during scanning, so they cannot be caught by a
% plain `{ ... } try`: at the time the try-proc is being built, no runtime
% error handler is active.  The wrapper `(source) make-executable exec`
% defers scanning to exec-time, which does let `try` catch the error.
%
% Runtime ops fire the counter check at runtime, so a plain try catches.

(=== eqref overflow tests ===) =

% rt-ok counts failures in a restore-immune slot -- string byte writes
% are unjournaled, so the count survives assertions made inside save
% scopes, and the 1-byte string lives in LOCAL VM, invisible to the
% global-heap/gc-counter probes some files assert on.  The file THROWS
% at EOF: test_all counts a file as failed only when its run throws,
% so print-only failures would slip the suite verdict.
/rt-fails 1 string def
rt-fails 0 16#0#b put
/rt-ok { exch { = } { (FAILED: ) print = rt-fails 0  rt-fails 0 get /integer-type cast 1 add dup 255 gt { pop 255 } if /byte-type cast  put } if-else } def

% ---- Scan-time overflow, one per kind ----
% (Test-name strings avoid the literal scanner tokens, which would otherwise
%  be parsed mid-string and re-trip the overflow during the name itself.)

{ ((x)#= pop) make-executable exec } try /limit-check eq
    (overflow: eqstring scan-time) rt-ok clear

{ ([1]#= pop) make-executable exec } try /limit-check eq
    (overflow: eqarray scan-time) rt-ok clear

{ ({ 1 2 add }#= pop) make-executable exec } try /limit-check eq
    (overflow: eqproc scan-time) rt-ok clear

{ (<< /a 1 >>#= pop) make-executable exec } try /limit-check eq
    (overflow: eqdict scan-time) rt-ok clear

{ ({{ /a /b }}#= pop) make-executable exec } try /limit-check eq
    (overflow: eqset scan-time) rt-ok clear

% ---- Runtime overflow, one per kind with a runtime op ----

{ =string pop } try /limit-check eq
    (overflow: eqstring runtime via =string) rt-ok clear

{ =array pop } try /limit-check eq
    (overflow: eqarray runtime via =array) rt-ok clear

{ =dict pop } try /limit-check eq
    (overflow: eqdict runtime via =dict) rt-ok clear

(eqref overflow tests complete.) =
rt-fails 0 get /integer-type cast 0 gt { /rt-assertions-failed throw } if
(__test_ok__) =
