% test_eqref_save_restore.trx
%
% The eqref generation counters (m_eq*_generation) must be monotonic and must
% NOT roll back on restore.  The invariant exists because the shared storage
% buffer is overwritten whenever a new eqref of the same kind is created; if
% restore rolled the counter back, a pre-save ref's gen would match the
% post-restore counter but the buffer contents would be the post-save ones --
% silent corruption.
%
% These tests verify:
%   A. The counter is strictly greater after save/create/restore than before.
%   B. A ref created BEFORE the save is still stale AFTER the restore -- i.e.,
%      the staleness survives the restore boundary.

(=== eqref save/restore tests ===) =

% rt-ok counts failures in a restore-immune slot -- string byte writes
% are unjournaled, so the count survives assertions made inside save
% scopes, and the 1-byte string lives in LOCAL VM, invisible to the
% global-heap/gc-counter probes some files assert on.  The file THROWS
% at EOF: test_all counts a file as failed only when its run throws,
% so print-only failures would slip the suite verdict.
/rt-fails 1 string def
rt-fails 0 16#0#b put
/rt-ok { exch { = } { (FAILED: ) print = rt-fails 0  rt-fails 0 get /integer-type cast 1 add dup 255 gt { pop 255 } if /byte-type cast  put } if-else } def

% --- eqstring ---
/gen-before //:status:eqstring-generation def
/ref-before (first)#= def
/boundary save def
(garbage)#= pop
boundary restore
//:status:eqstring-generation gen-before gt
  (save-restore: eqstring counter monotonic across restore) rt-ok clear
{ ref-before 0 get pop } try /unsupported eq
  (save-restore: eqstring pre-save ref stays stale after restore) rt-ok clear

% --- eqarray ---
/gen-before //:status:eqarray-generation def
/ref-before [1 2 3]#= def
/boundary save def
[9 9 9]#= pop
boundary restore
//:status:eqarray-generation gen-before gt
  (save-restore: eqarray counter monotonic across restore) rt-ok clear
{ ref-before 0 get pop } try /unsupported eq
  (save-restore: eqarray pre-save ref stays stale after restore) rt-ok clear

% --- eqdict ---
/gen-before //:status:eqdict-generation def
/ref-before << /a 1 >>#= def
/boundary save def
<< /x 99 >>#= pop
boundary restore
//:status:eqdict-generation gen-before gt
  (save-restore: eqdict counter monotonic across restore) rt-ok clear
{ ref-before /a get pop } try /unsupported eq
  (save-restore: eqdict pre-save ref stays stale after restore) rt-ok clear

% --- eqset ---
/gen-before //:status:eqset-generation def
/ref-before {{ /a /b }}#= def
/boundary save def
{{ /x /y }}#= pop
boundary restore
//:status:eqset-generation gen-before gt
  (save-restore: eqset counter monotonic across restore) rt-ok clear
{ ref-before length pop } try /unsupported eq
  (save-restore: eqset pre-save ref stays stale after restore) rt-ok clear

% --- eqproc ---
/gen-before //:status:eqproc-generation def
/ref-before { 1 2 add }#= def
/boundary save def
{ 9 9 add }#= pop
boundary restore
//:status:eqproc-generation gen-before gt
  (save-restore: eqproc counter monotonic across restore) rt-ok clear
{ ref-before exec pop } try /unsupported eq
  (save-restore: eqproc pre-save ref stays stale after restore) rt-ok clear

(eqref save/restore tests complete.) =
rt-fails 0 get /integer-type cast 0 gt { /rt-assertions-failed throw } if
(__test_ok__) =
