% test_finally.trx -- tests for the finally operator

% rt-ok counts failures in a restore-immune slot -- string byte writes
% are unjournaled, so the count survives assertions made inside save
% scopes, and the 1-byte string lives in LOCAL VM, invisible to the
% global-heap/gc-counter probes some files assert on.  The file THROWS
% at EOF: test_all counts a file as failed only when its run throws,
% so print-only failures would slip the suite verdict.
/rt-fails 1 string def
rt-fails 0 16#0#b put
/rt-ok { exch { = } { (FAILED: ) print = rt-fails 0  rt-fails 0 get /integer-type cast 1 add dup 255 gt { pop 255 } if /byte-type cast  put } if-else } def

% ====================================================================
% SECTION 1: Normal completion -- finally-block runs
% ====================================================================

/ran-finally false def
{ /ran-finally true def } { 42 } finally
ran-finally true eq          (normal: finally-block ran) rt-ok clear

% Verify proc result is on stack
{ (cleanup) pop } { 99 } finally
99 eq                        (normal: proc result on stack) rt-ok clear

% ====================================================================
% SECTION 2: Error path -- finally-block runs, error re-raised
% ====================================================================

/finally-ran false def
{
    { /finally-ran true def }
    { /type-check throw }
    finally
} try
/type-check eq               (error: error propagated) rt-ok clear
finally-ran true eq           (error: finally-block ran) rt-ok clear

% ====================================================================
% SECTION 3: Finally with try-catch -- error caught after finally runs
% ====================================================================

/finally-ran2 false def
<< /range-check { pop (caught) } >>
{
    { /finally-ran2 true def }
    { /range-check throw }
    finally
} try-catch
% stack has: (caught)
(caught) eq                   (try-catch: error caught after finally) rt-ok clear
finally-ran2 true eq          (try-catch: finally-block ran) rt-ok clear

% ====================================================================
% SECTION 4: Nested finally
% ====================================================================

/outer-ran false def
/inner-ran false def
{
    { /outer-ran true def }
    {
        { /inner-ran true def }
        { /type-check throw }
        finally
    } finally
} try
/type-check eq                (nested: error propagated) rt-ok clear
inner-ran true eq             (nested: inner finally ran) rt-ok clear
outer-ran true eq             (nested: outer finally ran) rt-ok clear

% ====================================================================
% SECTION 5: Finally-block itself throws -- replaces original error
% ====================================================================

{
    { /range-check throw }
    { /type-check throw }
    finally
} try
/range-check eq               (finally-throws: finally error replaces original) rt-ok clear

% Finally-block throws via explicit throw -- different error names
{
    { /index-check throw }
    { /type-check throw }
    finally
} try
/index-check eq            (finally-throws: different error name replaces original) rt-ok clear

% Finally-block throws a real error (not explicit throw)
{
    { 1 (hello) add }
    { /range-check throw }
    finally
} try
/type-check eq                (finally-throws: real error from finally replaces original) rt-ok clear

% Original error was real, finally-block throws real error
{
    { 1 (oops) add }
    { 1 (bad) add }
    finally
} try
/type-check eq                (finally-throws: both real errors, finally wins) rt-ok clear

% Finally-block throws, verify outer try-catch sees finally's error
<< /index-check { pop (got-ic) } >>
{
    { /index-check throw }
    { /type-check throw }
    finally
} try-catch
(got-ic) eq                   (finally-throws: outer try-catch sees finally error) rt-ok clear

% Verify finally error propagates through nested finally
/outer-cleanup false def
{
    { /outer-cleanup true def }
    {
        { /range-check throw }
        { /type-check throw }
        finally
    } finally
} try
/range-check eq               (finally-throws: propagates through outer finally) rt-ok clear
outer-cleanup true eq          (finally-throws: outer finally still ran) rt-ok clear

% ====================================================================
% SECTION 6: No error, finally-block runs side effects only
% ====================================================================

/count 0 def
{ /count count 1 add def } { 10 20 add } finally
30 eq                         (side-effect: proc result correct) rt-ok clear
count 1 eq                    (side-effect: finally ran once) rt-ok clear

% ====================================================================
% SECTION 7: Finally with exit/stop -- cleanup occurs
% ====================================================================

% stop unwinds past finally-barrier: error stack must be cleaned up
% so subsequent try/try-catch still works correctly
{
    { pop } { stop } finally
} stopped
% stopped returns true (stop was called)
true eq                       (stop: stopped caught stop) rt-ok clear
% verify error stack not corrupted: try still works after stop through finally
{ 42 } try /no-error eq      (stop: try works after stop-through-finally) rt-ok clear

% ====================================================================
% SECTION 8: exit unwinds past finally-barrier inside a loop
% ====================================================================

% exit from within a finally-protected block inside for-all
/cleanup-count 0 def
[1 2 3] {
    pop
    { (cleanup) pop } { exit } finally
    /cleanup-count cleanup-count 1 add def
} for-all
% exit terminated the loop after first iteration; cleanup ran
cleanup-count 0 eq            (exit-finally: loop exited) rt-ok clear
% verify error stack not corrupted
{ 42 } try /no-error eq       (exit-finally: try works after) rt-ok clear

% exit from within finally-protected block inside repeat
/count 0 def
3 {
    { (done) pop } { /count count 1 add def count 2 eq { exit } if } finally
} repeat
count 2 eq                    (exit-finally: repeat stops at 2) rt-ok clear
{ 99 } try /no-error eq       (exit-finally: try works after repeat) rt-ok clear

% exit through nested finally blocks in a loop
/n 0 def
[1 2 3] {
    pop
    { (outer) pop } {
        { (inner) pop } { /n n 1 add def exit } finally
    } finally
} for-all
n 1 eq                        (exit-finally: nested finally exit) rt-ok clear
% two finally error stack entries must both be cleaned
{ 42 } try /no-error eq       (exit-finally: try after nested) rt-ok clear

% exit through try-catch inside finally-protected block in a loop
/m 0 def
3 {
    { (cleanup) pop } {
        << /div-by-zero { pop 0 } >> { /m m 1 add def m 2 eq { exit } if } try-catch
    } finally
} repeat
m 2 eq                        (exit-finally: try-catch+finally in repeat) rt-ok clear
{ 1 } try /no-error eq        (exit-finally: try after try-catch+finally) rt-ok clear

% ====================================================================
% SECTION 9: Type errors
% ====================================================================

{ 1 { 2 } finally } try /type-check eq     (error: non-proc finally-block) rt-ok clear
{ { 1 } 2 finally } try /type-check eq     (error: non-proc proc) rt-ok clear
{ finally } try /opstack-underflow eq       (error: underflow) rt-ok clear

(finally tests complete.) =
rt-fails 0 get /integer-type cast 0 gt { /rt-assertions-failed throw } if
(__test_ok__) =
