% ====================================================================
% test_gc_stress_r6_clone.trx -- GC-UAF guard for the R6 clone-into-global
% path (Save::clone_fragile_local_into_global): storing a restore-fragile LOCAL
% value into a GLOBAL container deep-clones it into global.  That clone is a
% gvm_alloc, so under vm-gc-stress it fires a full vm_global_gc; this test
% checks the clone window holds up (the clone is rooted via the op-stack slot
% for array stores, or done immediately before the move-store with no
% intervening alloc for dict/set, and co-rooted across the entry alloc in the
% put-persist-or-create path).
% ====================================================================
% Debug-only (vm-gc-stress / vm-gc-poison).  Run via run_gc_stress_tests.sh.
% The fragile-local values are built OUTSIDE ${...} at save level >= 1 (LOCAL,
% above the barrier); the containers are built in ${...} (GLOBAL).  Exact-value
% asserts: poison 0xA5.. cannot pass an exact equality.

% rt-ok counts failures in a restore-immune slot -- string byte writes
% are unjournaled, so the count survives assertions made inside save
% scopes, and the 1-byte string lives in LOCAL VM, invisible to the
% global-heap/gc-counter probes some files assert on.  The file THROWS
% at EOF: test_all counts a file as failed only when its run throws,
% so print-only failures would slip the suite verdict.
/rt-fails 1 string def
rt-fails 0 16#0#b put
/rt-ok { exch { = } { (FAILED: ) print = rt-fails 0  rt-fails 0 get /integer-type cast 1 add dup 255 gt { pop 255 } if /byte-type cast  put } if-else } def

true vm-gc-stress
true vm-gc-poison

${ << >> } /gd exch def
${ {{ }} } /gs exch def
${ [ 0l 0l 0l ] } /ga exch def

save /tok exch def
% fragile-local Long key+value into a global dict (new-entry: clone BOTH, root the
% key clone across the value clone's GC, then store into the not-yet-chained entry)
gd 100l 200l put
gd 100l get 200l eq              (dict: Long key+val clone under stress)    rt-ok
% Int128 too (WideValue clone)
gd 111q 222q put
gd 111q get 222q eq              (dict: Int128 clone under stress)          rt-ok
% global set: fragile-local key clone
gs 300l set-add
gs 300l set-member? true eq      (set: Long clone under stress)             rt-ok
% global array: clone + write-back to op-stack slot
ga 0 400l put
ga 0 get 400l eq                 (array: Long clone under stress)           rt-ok clear

tok restore
% global containers persist (journal-skipped); the clones survive the restore
gd 100l get 200l eq              (dict: Long clone survives restore)        rt-ok
gd 111q get 222q eq              (dict: Int128 clone survives restore)      rt-ok
gs 300l set-member? true eq      (set: Long clone survives restore)         rt-ok
ga 0 get 400l eq                 (array: Long clone survives restore)       rt-ok clear

false vm-gc-poison
false vm-gc-stress

rt-fails 0 get /integer-type cast 0 gt { /rt-assertions-failed throw } if
(test_gc_stress_r6_clone: ALL TESTS PASSED) =
(__test_ok__) =
