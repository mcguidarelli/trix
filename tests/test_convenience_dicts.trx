% ====================================================================
% test_convenience_dicts.trx -- convenience dictionary tests
% ====================================================================
% Tests for opt-in short-name convenience dicts: /pipeline, /actors,
% /lazy, /records, /cells, /genserver, /logic, /supervision.
% Also tests the dict path shortcut (systemdict fallback).

% rt-ok counts failures in a restore-immune slot -- string byte writes
% are unjournaled, so the count survives assertions made inside save
% scopes, and the 1-byte string lives in LOCAL VM, invisible to the
% global-heap/gc-counter probes some files assert on.  The file THROWS
% at EOF: test_all counts a file as failed only when its run throws,
% so print-only failures would slip the suite verdict.
/rt-fails 1 string def
rt-fails 0 16#0#b put
/rt-ok { exch { = } { (FAILED: ) print = rt-fails 0  rt-fails 0 get /integer-type cast 1 add dup 255 gt { pop 255 } if /byte-type cast  put } if-else } def

% ====================================================================
% SECTION 1: EXISTENCE -- all 8 dicts exist in systemdict
% ====================================================================

//:systemdict:pipeline is-dict               (exist: /pipeline is dict) rt-ok  clear
//:systemdict:actors is-dict                 (exist: /actors is dict) rt-ok  clear
//:systemdict:lazy is-dict                   (exist: /lazy is dict) rt-ok  clear
//:systemdict:records is-dict                (exist: /records is dict) rt-ok  clear
//:systemdict:cells is-dict                  (exist: /cells is dict) rt-ok  clear
//:systemdict:genserver is-dict              (exist: /genserver is dict) rt-ok  clear
//:systemdict:logic is-dict                  (exist: /logic is dict) rt-ok  clear
//:systemdict:supervision is-dict            (exist: /supervision is dict) rt-ok  clear

% ====================================================================
% SECTION 2: SIZE -- each dict has expected entry count
% ====================================================================

//:systemdict:pipeline length 22 eq          (size: pipeline = 22) rt-ok  clear
//:systemdict:actors length 19 eq            (size: actors = 19) rt-ok  clear
//:systemdict:lazy length 48 eq              (size: lazy = 48) rt-ok  clear
//:systemdict:records length 15 eq           (size: records = 15) rt-ok  clear
//:systemdict:cells length 21 eq             (size: cells = 21) rt-ok  clear
//:systemdict:genserver length 6 eq          (size: genserver = 6) rt-ok  clear
//:systemdict:logic length 17 eq             (size: logic = 17) rt-ok  clear
//:systemdict:supervision length 15 eq       (size: supervision = 15) rt-ok  clear

% ====================================================================
% SECTION 3: DICT PATH SHORTCUT -- //:dictname:key resolves operators
% ====================================================================

//:pipeline:map is-operator                  (path: pipeline:map) rt-ok  clear
//:actors:spawn is-operator                  (path: actors:spawn) rt-ok  clear
//:lazy:map is-operator                      (path: lazy:map) rt-ok  clear
//:records:type is-operator                  (path: records:type) rt-ok  clear
//:cells:computed is-operator                (path: cells:computed) rt-ok  clear
//:genserver:call is-operator                (path: genserver:call) rt-ok  clear
//:logic:var is-operator                     (path: logic:var) rt-ok  clear
//:supervision:spec is-operator              (path: supervision:spec) rt-ok  clear

% existing systemdict sub-dict still works
//:numbers:real-type:pi is-real              (path: numbers:pi still works) rt-ok  clear

% ====================================================================
% SECTION 4: PATH IDENTITY -- short name resolves to same operator
% ====================================================================

//:pipeline:map //pipe-map eq               (identity: pipeline:map = pipe-map) rt-ok  clear
//:pipeline:filter //pipe-filter eq         (identity: pipeline:filter = pipe-filter) rt-ok  clear
//:actors:spawn //actor-spawn eq            (identity: actors:spawn = actor-spawn) rt-ok  clear
//:actors:send //actor-send eq              (identity: actors:send = actor-send) rt-ok  clear
//:lazy:head //lazy-head eq                 (identity: lazy:head = lazy-head) rt-ok  clear
//:lazy:fold //lazy-fold eq                 (identity: lazy:fold = lazy-fold) rt-ok  clear
//:records:schema //record-schema eq        (identity: records:schema = record-schema) rt-ok  clear
//:records:merge //record-merge eq          (identity: records:merge = record-merge) rt-ok  clear
//:cells:computed //cell-computed eq        (identity: cells:computed = cell-computed) rt-ok  clear
//:cells:get //cell-get eq                  (identity: cells:get = cell-get) rt-ok  clear
//:genserver:server //gen-server eq         (identity: genserver:server = gen-server) rt-ok  clear
//:genserver:cast //gen-cast eq             (identity: genserver:cast = gen-cast) rt-ok  clear
//:logic:var //logic-var eq                 (identity: logic:var = logic-var) rt-ok  clear
//:logic:choose //choice eq                (identity: logic:choose = choice) rt-ok  clear
//:supervision:spec //supervisor-spec eq    (identity: supervision:spec = supervisor-spec) rt-ok  clear
//:supervision:stop //supervisor-stop eq    (identity: supervision:stop = supervisor-stop) rt-ok  clear

% ====================================================================
% SECTION 5: BEGIN/END -- scoped access to short names
% ====================================================================

% pipeline: map resolves to pipe-map inside begin/end
//:systemdict:pipeline begin
    /map where
end
                                              (begin/end: pipeline map found) rt-ok  clear

% actors: self resolves to actor-self
//:systemdict:actors begin
    /self where
end
                                              (begin/end: actors self found) rt-ok  clear

% records: schema resolves
10 20 [ /x /y ] record
//:systemdict:records begin
    schema length 2 eq
end
                                              (begin/end: records schema works) rt-ok  clear

% cells: computed resolves to cell-computed
/base 10 cell def
//:systemdict:cells begin
    { base cell-get 2 mul } computed
    get 20 eq
end
                                              (begin/end: cells computed works) rt-ok  clear

% genserver: call resolves
//:systemdict:genserver begin
    /call where
end
                                              (begin/end: genserver call found) rt-ok  clear

% lazy: short names resolve inside begin/end
//:systemdict:lazy begin
    /map where
end
                                              (begin/end: lazy map found) rt-ok  clear

% logic: var resolves to logic-var
//:systemdict:logic begin
    var is-logic-var
end
                                              (begin/end: logic var works) rt-ok  clear

% supervision: spec resolves
//:systemdict:supervision begin
    /spec where
end
                                              (begin/end: supervision spec found) rt-ok  clear

% ====================================================================
% SECTION 6: SHADOWING -- begin shadows, end restores
% ====================================================================

% verify core map still works before begin
[1 2 3] { 1 add } map
2 get 4 eq                                    (shadow: core map before begin) rt-ok  clear

% pipeline begin shadows core map
//:systemdict:pipeline begin
    /map where
end
                                              (shadow: pipeline map found) rt-ok  clear

% after end, core map is restored
[1 2 3] { 1 add } map
2 get 4 eq                                    (shadow: core map after end) rt-ok  clear

% ====================================================================
% SECTION 7: READONLY -- convenience dicts reject modification
% ====================================================================

{ //:systemdict:pipeline /x 42 put } try
/read-only eq                                 (readonly: pipeline rejects put) rt-ok  clear

{ //:systemdict:actors /x 42 put } try
/read-only eq                                 (readonly: actors rejects put) rt-ok  clear

% ====================================================================
% SECTION 8: FUNCTIONAL -- operators actually work through short names
% ====================================================================

% pipeline: path operator resolves and is callable
//:pipeline:buffer //pipe-buffer eq           (functional: pipeline:buffer callable) rt-ok  clear

% lazy: range + map via path
1 5 1 lazy-range { 2 mul } lazy-map lazy-to-array
[2 4 6 8] deep-eq                             (functional: lazy range+map) rt-ok  clear

% records: path operator executes via \\ (executable immediate lookup)
100 200 [ /w /h ] record
\\:records:schema length 2 eq                 (functional: records schema length) rt-ok  clear

% cells: path operator executes via \\
/x 5 cell def
{ x cell-get 10 mul } \\:cells:computed
\\:cells:get 50 eq                            (functional: cells computed get) rt-ok  clear

