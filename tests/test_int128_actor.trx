% ====================================================================
% Phase 7: Int128 / UInt128 actor mailbox integration tests.
%
% Verifies that the actor mailbox correctly handles WideValue-backed
% messages across send, recv, FIFO order, request/response, and
% mailbox accounting.
%
% Actor bodies receive messages and stash them via /name exch def,
% then the main test inspects the userdict slot.
% ====================================================================

% rt-ok counts failures in a restore-immune slot -- string byte writes
% are unjournaled, so the count survives assertions made inside save
% scopes, and the 1-byte string lives in LOCAL VM, invisible to the
% global-heap/gc-counter probes some files assert on.  The file THROWS
% at EOF: test_all counts a file as failed only when its run throws,
% so print-only failures would slip the suite verdict.
/rt-fails 1 string def
rt-fails 0 16#0#b put
/rt-ok { exch { = } { (FAILED: ) print = rt-fails 0  rt-fails 0 get /integer-type cast 1 add dup 255 gt { pop 255 } if /byte-type cast  put } if-else } def

% ---------- shared 128-bit values ----------
/msg-i128 42q def
/msg-u128 16#FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFE#uq def
/msg-i128-c -7q def
/msg-u128-a 100uq def

% ====================================================================
% SECTION 1: send + recv Int128 message
% ====================================================================

/recv-i128 null def
/i128-actor [ {
    actor-recv /recv-i128 exch def
} actor-spawn def
msg-i128 i128-actor actor-send
0 coroutine-sleep
recv-i128 msg-i128 deep-eq
    (actor: Int128 message delivered) rt-ok clear

% ====================================================================
% SECTION 2: send + recv UInt128 message
% ====================================================================

/recv-u128 null def
/u128-actor [ {
    actor-recv /recv-u128 exch def
} actor-spawn def
msg-u128 u128-actor actor-send
0 coroutine-sleep
recv-u128 msg-u128 deep-eq
    (actor: UInt128 message delivered) rt-ok clear

% ====================================================================
% SECTION 3: multiple 128-bit messages in FIFO order
% ====================================================================

/fifo-a null def
/fifo-b null def
/fifo-c null def
/fifo-actor [ {
    actor-recv /fifo-a exch def
    actor-recv /fifo-b exch def
    actor-recv /fifo-c exch def
} actor-spawn def
msg-i128     fifo-actor actor-send
msg-u128     fifo-actor actor-send
msg-i128-c   fifo-actor actor-send
0 coroutine-sleep
fifo-a msg-i128 deep-eq
    (fifo: Int128 first delivered in order) rt-ok
fifo-b msg-u128 deep-eq
    (fifo: UInt128 second delivered in order) rt-ok
fifo-c msg-i128-c deep-eq
    (fifo: Int128 third delivered in order) rt-ok clear

% ====================================================================
% SECTION 4: mailbox-count reports queued 128-bit messages
% ====================================================================

/count-actor [ {
    1000 coroutine-sleep
} actor-spawn def

count-actor actor-mailbox-count 0 eq
    (mailbox-count: empty at start) rt-ok
msg-i128    count-actor actor-send
msg-u128    count-actor actor-send
msg-u128-a  count-actor actor-send
count-actor actor-mailbox-count 3 eq
    (mailbox-count: 3 after three 128-bit sends) rt-ok clear
count-actor coroutine-kill clear

% ====================================================================
% SECTION 5: request / response with 128-bit (doubler)
% ====================================================================

/doubled-128 null def
/doubler128 [ {
    actor-recv 2q mul /doubled-128 exch def
} actor-spawn def
msg-i128 doubler128 actor-send
0 coroutine-sleep
doubled-128 84q deep-eq
    (request/response: Int128 doubled) rt-ok clear

% ====================================================================
% SECTION 6: send to dead actor silently drops 128-bit message
% (no leak -- the WideValue must be freed)
% ====================================================================

/dead-i128-actor [ { } actor-spawn def
0 coroutine-sleep 0 coroutine-sleep
{ msg-i128 dead-i128-actor actor-send } try /no-error eq
    (actor: send Int128 to dead actor is silent drop) rt-ok clear

% ====================================================================
% SECTION 7: heap integrity after all actor traffic
% ====================================================================

//:status:widevalue-validate  (widevalue free-list OK after 128-bit actor) rt-ok
//:status:vm-validate         (vm heap OK after 128-bit actor)             rt-ok
//:status:extvalue-validate   (extvalue free-list OK after 128-bit actor)  rt-ok

(test_int128_actor.trx complete) =
rt-fails 0 get /integer-type cast 0 gt { /rt-assertions-failed throw } if
(__test_ok__) =
