% ====================================================================
% test_gc_vmfull.trx -- Phase 10 GC behavior under VM exhaustion
% ====================================================================
% Constructs scenarios where the global VM cannot satisfy an
% allocation request, exercising the auto-on-VMFull retry hook in
% gvm_alloc + the wrapper try/catch in vm_global_gc that resets
% m_in_gc / m_vm_temp_ptr on failure.
%
% This test runs at default VM size (1MB) and depends on rooting
% every allocation so GC reclaims 0.  After the exhaustion, the
% heap is full enough that the scanner can't allocate space for new
% string literals.  All string literals used by assertions + the
% test sentinel are pre-bound at the top of the file, where there
% IS room to allocate.
%
% Lives in its own file because the Trix scanner reads tokens
% incrementally; a test that exhausts the heap mid-file leaves the
% remaining lines unscannable.
% ====================================================================

% rt-ok counts failures in a restore-immune slot -- string byte writes
% are unjournaled, so the count survives assertions made inside save
% scopes, and the 1-byte string lives in LOCAL VM, invisible to the
% global-heap/gc-counter probes some files assert on.  The file THROWS
% at EOF: test_all counts a file as failed only when its run throws,
% so print-only failures would slip the suite verdict.
/rt-fails 1 string def
rt-fails 0 16#0#b put
/rt-ok { exch { = } { (FAILED: ) print = rt-fails 0  rt-fails 0 get /integer-type cast 1 add dup 255 gt { pop 255 } if /byte-type cast  put } if-else } def

% Pre-bind all strings used in assertion messages + sentinels BEFORE
% the heap-exhausting workload runs.  After exhaustion, the scanner
% can't allocate fresh literals; any string referenced post-failure
% must already exist in local VM.
/msg-rooted-churn (1: rooted churn raises /vm-full) def
/msg-in-progress  (1: gc-in-progress cleared post-VMFull) def
/msg-followup-gc  (2: follow-up vm-global-gc succeeds post-throw) def
rt-fails 0 get /integer-type cast 0 gt { /rt-assertions-failed throw } if
/sentinel-banner  (test_gc_vmfull: ALL TESTS PASSED) def
/sentinel-ok      (__test_ok__) def

% ====================================================================
% SECTION 1: rooted churn raises /vm-full cleanly
% ====================================================================
% Every allocation is rooted via array-slot put into oom-store.
% Auto-on-VMFull retry in gvm_alloc fires when the bump path can't
% fit; GC reclaims 0 (nothing is unreachable); the workload
% terminates with /vm-full.  Whether the final VMFull surfaces from
% gvm_alloc's "global region exhausted" path or from vm_temp_alloc's
% "temporary space" path during the GC's own work-queue alloc is
% an implementation detail -- both are Error::VMFull and both
% terminate the workload correctly.
%
% Verifies:
%   (a) the rooted-everything case terminates with /vm-full
%       (not some other error, no infinite loop);
%   (b) the bounded for-attempt-2 retry in gvm_alloc doesn't
%       recurse or hang;
%   (c) m_in_gc returns to false even when GC throws mid-impl
%       (the try/catch in vm_global_gc must reset the guard);
%   (d) m_vm_temp_ptr is reset on the throw path (via the wrapper's
%       temp_save / m_vm_temp_ptr restore in vm_global_gc).

% Build a rooted Array store at sl=0 to avoid persist semantics.
${ 10000 array } /oom-store exch def

{
    1 1 1000000 { /i exch def
        oom-store i ${ 200 string } put
    } for
} try /vm-full eq                            msg-rooted-churn rt-ok clear

% m_in_gc cleared correctly even when GC throws mid-pass.
//:status:gc-in-progress not                 msg-in-progress rt-ok

% ====================================================================
% SECTION 2: follow-up vm-global-gc post-throw must not assert
% ====================================================================
% Regression guard for the C1 fix in vm_global_gc()'s catch handler
% (commit 2026-05-10).  Pre-fix: if GC threw mid-mark (e.g.
% grow_gc_local_visited's allocation hit VMFull), the catch only
% restored m_in_gc + m_vm_temp_ptr; the per-block m_next_in_work
% chain anchored at m_gc_work_head and the per-Dict m_next_in_visit
% chain anchored at m_gc_visit_head were left populated.  The next
% pass's gc_work_push / gc_visit_mark assert(off-list) would then
% abort the binary.
%
% Post-fix: catch drains both chains, resets m_gc_marked_count.
%
% LIMITATION: Section 1's rooted-churn throw typically fires during
% scratch alloc (before walk_all_roots), so chains are empty at
% throw time -- meaning this section passes whether or not the C1
% fix is in place under the current workload.  It still guards the
% broader "next GC pass after a throw must succeed" contract; a
% deterministic chain-population test that throws mid-mark would
% need internal injection points (deferred Wave-4 polish).

vm-global-gc pop  true                       msg-followup-gc rt-ok

% Sentinels -- pre-bound, so just printing pre-allocated string
% Objects with no fresh allocation needed.
sentinel-banner =
sentinel-ok =
