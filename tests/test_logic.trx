% SECTION 84: HAPPY -- find-all all fail
% =================================================================

[ { false guard } { false guard } ] find-all
length 0 eq                               (find-all: all fail -> empty) rt-ok  clear

% =================================================================
% SECTION 85: HAPPY -- find-all empty alternatives
% =================================================================

[ ] find-all
length 0 eq                               (find-all: empty input -> empty) rt-ok  clear

% =================================================================
% SECTION 86: HAPPY -- find-all with logic variables
% =================================================================

logic-var /x exch def
[
    { x 1 unify guard  x deref }
    { x 2 unify guard  x deref 10 gt guard }
    { x 3 unify guard  x deref }
] find-all
dup length 2 eq                           (find-all: 2 of 3 match) rt-ok
dup 0 get 1 eq                            (find-all: first match 1) rt-ok
1 get 3 eq                                (find-all: second match 3) rt-ok
x bound? not                            (find-all: x unbound after) rt-ok  clear

% =================================================================
% SECTION 87: HAPPY -- find-all with ExtValue types (Long, Double)
% =================================================================

[ { 9999999999l } { 1111111111l } ] find-all
dup 0 get 9999999999l eq                  (find-all: long result 0) rt-ok
1 get 1111111111l eq                      (find-all: long result 1) rt-ok  clear

[ { 3.14d } { 2.71d } ] find-all
dup 0 get 3.14d eq                        (find-all: double result 0) rt-ok
1 get 2.71d eq                            (find-all: double result 1) rt-ok  clear

