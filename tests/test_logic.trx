% =================================================================

2 [
    { logic-var /x exch def  x 10 unify guard  x deref }
    { logic-var /x exch def  x 20 unify guard  x deref }
    { logic-var /x exch def  x 30 unify guard  x deref }
] find-n
dup length 2 eq                           (find-n-unify: length = 2) rt-ok
dup 0 get 10 eq                           (find-n-unify: first = 10) rt-ok
1 get 20 eq                               (find-n-unify: second = 20) rt-ok  clear

