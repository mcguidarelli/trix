% SECTION 98: BOUNDARY -- find-all with Byte result
% =================================================================

[ { 42b } { 0b } ] find-all
dup 0 get 42b eq                          (find-all: byte result 0) rt-ok
1 get 0b eq                               (find-all: byte result 1) rt-ok  clear

% Save/restore scope: reclaim save levels consumed by successful once calls.
save /once-save exch def

% =================================================================
% SECTION 99: once — basic success
% =================================================================

logic-var /x exch def
{ x 42 unify guard  x deref } once
42 eq                                     (once: success returns 42) rt-ok  clear

% =================================================================
% SECTION 100: once — failure propagates
% =================================================================

{ { false guard } once } try
/fail eq                                  (once: fail propagates) rt-ok  clear

% =================================================================
% SECTION 101: once — bindings persist on success
% =================================================================

logic-var /x exch def
{ x 99 unify guard } once
x deref 99 eq                             (once: bindings persist) rt-ok  clear

% =================================================================
% SECTION 102: once — bindings rolled back on failure
% =================================================================

logic-var /x exch def
{ { x 77 unify guard  false guard } once } try pop
x bound? not                            (once: bindings rolled back on fail) rt-ok  clear

% =================================================================
% SECTION 103: once — non-fail errors propagate
% =================================================================

{ { 1 0 div } once } try
/div-by-zero eq                           (once: div-by-zero propagates) rt-ok  clear

% =================================================================
% SECTION 104: once — type error
% =================================================================

{ 42 once } try
/type-check eq                            (once: non-proc error) rt-ok  clear

% End save scope: reclaim save levels from successful once calls above.
once-save restore

% =================================================================
% SECTION 105: naf — goal fails → true
% =================================================================

{ false guard } naf
                                          (naf: failing goal returns true) rt-ok  clear

% =================================================================
% SECTION 106: naf — goal succeeds → false
% =================================================================

{ true guard } naf not
                                          (naf: succeeding goal returns false) rt-ok  clear

% =================================================================
% SECTION 107: naf — bindings rolled back on success
% =================================================================

logic-var /x exch def
{ x 42 unify guard } naf pop
x bound? not                            (naf: bindings rolled back when goal succeeds) rt-ok  clear

% =================================================================
% SECTION 108: naf — bindings rolled back on failure
% =================================================================

logic-var /x exch def
{ x 42 unify guard  false guard } naf pop
x bound? not                            (naf: bindings rolled back when goal fails) rt-ok  clear

% =================================================================
% SECTION 109: naf — non-fail error propagates
% =================================================================

{ { 1 0 div } naf } try
/div-by-zero eq                           (naf: div-by-zero propagates) rt-ok  clear

% =================================================================
% SECTION 110: naf — composable with guard
% =================================================================

logic-var /x exch def
x 10 unify guard
{ x deref 20 eq guard } naf              (naf: x=10 not= 20 is true) rt-ok  clear

% =================================================================
