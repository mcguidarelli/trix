    { 9999999999l cut }
    { 0l }
] choice
9999999999l eq                            (boundary: cut with long) rt-ok  clear

[
    { 3.14d cut }
    { 0.0d }
] choice
3.14d eq                                  (boundary: cut with double) rt-ok  clear

% =================================================================
% SECTION 66: FUZZ -- cut + unify + deref interaction
% =================================================================

% Bindings from BEFORE the choice persist; bindings INSIDE the
% chosen branch also persist after cut.
logic-var /pre exch def
pre 100 unify pop
logic-var /inner exch def
[
    { inner 200 unify guard  cut }
    { inner 999 unify guard }
] choice
pre deref 100 eq inner deref 200 eq and  (fuzz: pre+inner bindings) rt-ok  clear

% =================================================================
% SECTION 67: FUZZ -- cut inside loop inside choice
% =================================================================

/loop-result 0 def
[
    {
        1 1 3 { pop /loop-result loop-result 1 add def } for
        cut
    }
    { /loop-result 999 def }
] choice
loop-result 3 eq                          (fuzz: cut inside loop) rt-ok  clear

