/r logic-var def
77 /val tag [
    [ r /val tag  { (matched) } ]
] unify-match
(matched) eq                              (um-persist: body ran) rt-ok
r deref 77 eq                             (um-persist: binding persists) rt-ok  clear

um-s6 restore

