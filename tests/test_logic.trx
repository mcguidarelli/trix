% =================================================================

3 [ { 10 } { fail } { 20 } { fail } { 30 } { 40 } ] find-n
dup length 3 eq                           (find-n-fail: length = 3) rt-ok
dup 0 get 10 eq                           (find-n-fail: first = 10) rt-ok
dup 1 get 20 eq                           (find-n-fail: second = 20) rt-ok
2 get 30 eq                               (find-n-fail: third = 30) rt-ok  clear

