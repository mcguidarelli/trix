% SECTION 120: find-n — n=1 (like once but collects)
% =================================================================

1 [ { 10 } { 20 } { 30 } ] find-n
dup length 1 eq                           (find-n-one: length = 1) rt-ok
0 get 10 eq                               (find-n-one: first = 10) rt-ok  clear

