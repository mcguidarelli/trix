% =================================================================

2 [ { 1000000000l } { 2000000000l } { 3000000000l } ] find-n
dup length 2 eq                           (find-n-long: length = 2) rt-ok
dup 0 get 1000000000l eq                  (find-n-long: first) rt-ok
1 get 2000000000l eq                      (find-n-long: second) rt-ok  clear

% =================================================================
% SECTION 122: unify-match — first pattern matches
% =================================================================

% Each successful unify-match leaves a save level active (bindings persist).
% Wrap groups in save/restore scopes to reclaim levels.
save /um-s1 exch def

42 [
    [ 42 { (first) } ]
    [ 99 { (second) } ]
] unify-match
(first) eq                                (um-first: matched first) rt-ok  clear

% =================================================================
% SECTION 123: unify-match — second pattern matches
% =================================================================

99 [
    [ 42 { (first) } ]
    [ 99 { (second) } ]
] unify-match
(second) eq                               (um-second: matched second) rt-ok  clear

um-s1 restore

