    }
    { /outer-val 999 def }
] choice
outer-val 10 eq                           (fuzz: two cuts inner+outer) rt-ok  clear

% =================================================================
% SECTION 69: HAPPY -- copy-term scalar passthrough
% =================================================================

42 copy-term 42 eq                        (copy-term: integer passthrough) rt-ok  clear
(hello) copy-term (hello) eq              (copy-term: string passthrough) rt-ok  clear
true copy-term true eq                    (copy-term: bool passthrough) rt-ok  clear
null copy-term null eq                    (copy-term: null passthrough) rt-ok  clear
3.14 copy-term 3.14 eq                    (copy-term: real passthrough) rt-ok  clear
/foo copy-term /foo eq                    (copy-term: name passthrough) rt-ok  clear
9999999999l copy-term 9999999999l eq      (copy-term: long passthrough) rt-ok  clear

% =================================================================
% SECTION 70: HAPPY -- copy-term unbound lvar produces fresh lvar
% =================================================================

logic-var /x exch def
x copy-term /y exch def
y is-logic-var                            (copy-term: fresh is lvar) rt-ok
y bound? not                            (copy-term: fresh is unbound) rt-ok
y 99 unify pop
x bound? not                            (copy-term: fresh is independent) rt-ok  clear

% =================================================================
% SECTION 71: HAPPY -- copy-term bound lvar is dereferenced
% =================================================================

logic-var /x exch def
x 42 unify pop
x copy-term 42 eq                         (copy-term: bound lvar derefed) rt-ok  clear

% =================================================================
% SECTION 72: HAPPY -- copy-term array with lvars
% =================================================================

logic-var /x exch def
[ 1 x 3 ] copy-term /r exch def
r length 3 eq                             (copy-term: array length) rt-ok
r 0 get 1 eq                              (copy-term: array elem 0) rt-ok
r 1 get is-logic-var                      (copy-term: array elem 1 is lvar) rt-ok
r 1 get bound? not                      (copy-term: array elem 1 unbound) rt-ok
r 2 get 3 eq                              (copy-term: array elem 2) rt-ok  clear

% =================================================================
% SECTION 73: HAPPY -- copy-term shared variable preservation
% =================================================================

logic-var /x exch def
[ x 1 x ] copy-term /r exch def
r 0 get is-logic-var                      (copy-term: shared elem 0 is lvar) rt-ok
r 2 get is-logic-var                      (copy-term: shared elem 2 is lvar) rt-ok
r 0 get r 2 get eq                        (copy-term: shared same lvar) rt-ok
r 0 get 77 unify pop
r 2 get deref 77 eq                       (copy-term: shared binding) rt-ok  clear

% =================================================================
% SECTION 74: HAPPY -- copy-term tagged value
% =================================================================

logic-var /x exch def
x /:some tag copy-term /r exch def
r tag-name /:some eq                      (copy-term: tagged name) rt-ok
r tag-value is-logic-var                  (copy-term: tagged payload is lvar) rt-ok
r tag-value bound? not                  (copy-term: tagged payload unbound) rt-ok  clear

% =================================================================
% SECTION 75: HAPPY -- copy-term record
% =================================================================

logic-var /x exch def
x 20 [ /a /b ] record copy-term /r exch def
r /a get is-logic-var                     (copy-term: record field a is lvar) rt-ok
r /b get 20 eq                            (copy-term: record field b is 20) rt-ok  clear

% =================================================================
% SECTION 76: HAPPY -- copy-term nested structures
% =================================================================

logic-var /x exch def
[ [ x ] ] copy-term /r exch def
r 0 get 0 get is-logic-var               (copy-term: nested array lvar) rt-ok
r 0 get 0 get bound? not               (copy-term: nested lvar unbound) rt-ok  clear

% =================================================================
% SECTION 77: BOUNDARY -- copy-term empty array
% =================================================================

[ ] copy-term length 0 eq                 (copy-term: empty array) rt-ok  clear

% =================================================================
% SECTION 78: BOUNDARY -- copy-term no lvars (plain deep copy)
% =================================================================

[ 1 2 [ 3 4 ] ] copy-term /r exch def
r 0 get 1 eq                              (copy-term: plain elem 0) rt-ok
r 2 get 0 get 3 eq                        (copy-term: plain nested) rt-ok  clear

% =================================================================
% SECTION 79: STRESS -- copy-term many distinct lvars
% =================================================================

10 array /r exch def
0 1 9 { /i exch def  r i logic-var put } for
r copy-term /r exch def
r 0 get is-logic-var
r 9 get is-logic-var and
r 0 get r 1 get eq not and                (stress: 10 distinct lvars) rt-ok  clear

% =================================================================
% SECTION 80: FUZZ -- copy-term + unify on copy
% =================================================================

logic-var /x exch def
[ x x ] copy-term /r exch def
r 0 get 42 unify pop
x bound? not                            (fuzz: copy unify independent) rt-ok
r 0 get deref 42 eq                       (fuzz: copy unified value) rt-ok
r 1 get deref 42 eq                       (fuzz: copy shared unified) rt-ok  clear

% =================================================================
% SECTION 81: FUZZ -- copy-term inside choice with backtrack
% =================================================================

logic-var /x exch def
1 array dup 0 x put /r exch def
[
    { r copy-term 0 get 99 unify guard  false guard }
    { r copy-term 0 get 77 unify guard }
] choice
x bound? not                            (fuzz: copy in choice, orig unbound) rt-ok  clear

% End save scope: reclaim save levels from choice/cut tests above.
choice-scope restore

% =================================================================
% SECTION 82: HAPPY -- find-all basic
% =================================================================

[ { 1 } { 2 } { 3 } ] find-all
dup length 3 eq                           (find-all: 3 results) rt-ok
dup 0 get 1 eq                            (find-all: first is 1) rt-ok
dup 1 get 2 eq                            (find-all: second is 2) rt-ok
2 get 3 eq                                (find-all: third is 3) rt-ok  clear

% =================================================================
% SECTION 83: HAPPY -- find-all some fail
% =================================================================

[ { 10 } { false guard } { 30 } { false guard } { 50 } ] find-all
dup length 3 eq                           (find-all: 3 of 5 succeed) rt-ok
dup 0 get 10 eq                           (find-all: first is 10) rt-ok
dup 1 get 30 eq                           (find-all: second is 30) rt-ok
2 get 50 eq                               (find-all: third is 50) rt-ok  clear

