% =================================================================

[ 9999999999l 3.14d ] copy-term /r exch def
r 0 get 9999999999l eq                    (copy-term: long in array) rt-ok
r 1 get 3.14d eq                          (copy-term: double in array) rt-ok  clear

% =================================================================
% SECTION 97: FUZZ -- find-all + cut inside alternative
% =================================================================

% cut inside a find-all alternative should not interfere with find-all's
% own save/restore cycle (find-all uses @find-all-barrier, not @choice-barrier)
[
    { [ { 10 cut } { 99 } ] choice }
    { 20 }
] find-all
dup length 2 eq                           (find-all+cut: 2 results) rt-ok
dup 0 get 10 eq                           (find-all+cut: cut result) rt-ok
1 get 20 eq                               (find-all+cut: normal result) rt-ok  clear

