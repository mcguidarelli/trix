% =====================================================================
% combat-core.trx -- Bestagon Wars shared combat resolver (Phase 0.5A)
% =====================================================================
%
% Source of truth: examples/bestagon-design.md (the GDD).  Specifically:
%   §4   terrain defense stars
%   §6   unit costs + movement classes
%   §7.1 combat formula:  actual = ((base + luck_pp) x atk_CO_mult)
%                                  x def_factor x (atk_HP / 10)
%                         def_total  = sum_def_pct + def_terrain_stars
%                                                    x def_HP
%                         def_factor = 1 - def_total / 100
%   §7.5 damage table (sparse 17x17)
%   §7.8 veterancy thresholds: 3/5/8 kills -> tier 1/2/3 (+5/+10/+15 atk)
%   §8.3 CO roster (6 COs: bishop / hammer / hawk / boots / veil / talon)
%   §8.4 resolver order:
%        1. vet bonus (vet-tier * 5 -> sum_atk_pct)
%        2. CO passives
%        3. Power-OR-Super (mutually exclusive; never stacked)
%        4. weather modifiers
%        5. terrain stars (HP-scaled at step 7)
%        6. HP scaling (atk_HP/10 and def_HP/10 both folded into formula)
%        7. luck (luck_pp added to base BEFORE multiplications)
%   §9.3 worked example -- canonical regression target.
%
% Public API (this file is the resolver imported by every sim AND by
% Phase 6 production code in bestagon.trx):
%
%   compute-vet-tier  kills -- tier             (§7.8)
%   resolve-modifiers atk-spec def-spec ctx --
%                     sum-atk-pct sum-def-pct def-terrain-stars
%   lookup-base-damage atk-type def-type --
%                     base-pct true | false
%   predict-damage    atk-spec def-spec ctx --
%                     min-damage max-damage     (range under luck mode)
%   resolve-attack    atk-spec def-spec ctx luck-pp --
%                     damage counter-damage     (single exchange)
%
% Spec shape (`atk-spec` / `def-spec` mirror §17.4 Unit Dict subset):
%   << /type          Name (/infantry, /tank, ...)
%      /hp            integer 1-10
%      /vet-tier      integer 0-3
%      /co            Name (/bishop, /hammer, ...)
%      /power-active  bool
%      /super-active  bool
%      /terrain       Name (/plain, /forest, ...)
%   >>
%
% Context:
%   << /luck-mode                     /on | /off
%      /weather-current               Name (/clear by default)
%      /attacker-can-see-defender     bool (true by default;
%                                          gates /vs-revealed-atk)
%   >>
%
% Run self-test:
%   ./trix.opt examples/bestagon-sim/combat-core.trx --self-test
% =====================================================================


% ====================================================================
% Section 1: static data (immutable Dicts, ReadOnly via #r suffix)
% ====================================================================

% Unit costs -- §6 dict literal.  Used for star_gain (§9.1) funds math.
/unit-costs <<
    /infantry      1000    /mech         3000    /recon        4000
    /apc           5000    /tank         7000    /heavy-tank  16000
    /anti-air      8000    /artillery    6000    /rocket      15000
    /fighter      20000    /bomber      22000    /battle-copter 9000
    /lander       12000    /destroyer   18000    /submarine   20000
    /battleship   28000    /carrier     30000
>>#r def

% Base terrain defense stars -- §4 table (non-inf column).
/terrain-defense-stars <<
    /plain     1
    /road      0
    /forest    2
    /mountain  4       % impassable for non-inf but stat is 4 inf-only
    /river     0
    /bridge    0
    /sea       0
    /reef      1
    /beach     0
>>#r def

% Infantry-bonus terrain defense stars -- §4 inf-only column.
/terrain-defense-stars-inf <<
    /plain     2
    /road      0
    /forest    3
    /mountain  4
    /river     0
    /bridge    0
    /sea       0
    /reef      1
    /beach     0
>>#r def

% Veterancy threshold table -- §7.8.  kills >= N -> tier T; tier T bonus
% folds into sum_atk_pct as `vet-tier * 5`.  Cap at tier 3.
/vet-threshold-kills <<
    /tier-0  0    /tier-1  3    /tier-2  5    /tier-3  8
>>#r def

% Class lookups -- §6 movement classes plus §7.1 firing-class.  Used by
% the modifier-applicability filter (§8.4 key reader column).

% Movement class per unit -- foot | wheel | tread | air | sea.
/unit-move-class <<
    /infantry      /foot       /mech          /foot
    /recon         /wheel      /apc           /wheel
    /anti-air      /wheel      /artillery     /wheel      /rocket /wheel
    /tank          /tread      /heavy-tank    /tread
    /fighter       /air        /bomber        /air        /battle-copter /air
    /lander        /sea        /destroyer     /sea        /submarine     /sea
    /battleship    /sea        /carrier       /sea
>>#r def

% Firing kind per unit -- /direct | /indirect | /none.  /none = no
% attack (APC, Lander, Carrier).
/unit-fire-kind <<
    /infantry      /direct     /mech          /direct
    /recon         /direct     /apc           /none
    /tank          /direct     /heavy-tank    /direct
    /anti-air      /direct     /artillery     /indirect   /rocket        /indirect
    /fighter       /direct     /bomber        /direct     /battle-copter /direct
    /lander        /none       /destroyer     /direct     /submarine     /direct
    /battleship    /indirect   /carrier       /none
>>#r def

% "Direct-ground" set -- §8.4 narrow definition: Inf/Mech/Recon/Tank/
% HTank/AA.  /direct-atk and /direct-move modifiers apply ONLY to these
% six.  Does NOT include Fighter/Bomber/BCop/Destroyer/Submarine.
/direct-ground-units {{
    /infantry  /mech  /recon  /tank  /heavy-tank  /anti-air
}}#r def

% Damage table -- §7.5.  Sparse: missing keys = attack illegal.  Top-
% level keys are attackers; second-level keys are defenders; values are
% base damage percentages.
/damage-table <<
    /infantry <<
        /infantry 55  /mech 45  /recon 12  /apc 14  /tank 5  /heavy-tank 1
        /anti-air 5   /artillery 15  /rocket 25   /battle-copter 7
        /lander 14    /destroyer 5   /submarine 1 /battleship 1   /carrier 1
    >>
    /mech <<
        /infantry 65  /mech 55  /recon 85  /apc 75  /tank 55 /heavy-tank 15
        /anti-air 65  /artillery 70  /rocket 85   /battle-copter 9
        /lander 75    /destroyer 55  /submarine 15 /battleship 15 /carrier 15
    >>
    /recon <<
        /infantry 70  /mech 65  /recon 35  /apc 45  /tank 8  /heavy-tank 1
        /anti-air 4   /artillery 45  /rocket 55   /battle-copter 10
        /lander 55    /destroyer 8   /submarine 1 /battleship 1   /carrier 1
    >>
    % /apc has no attack
    /tank <<
        /infantry 75  /mech 70  /recon 85  /apc 75  /tank 55  /heavy-tank 15
        /anti-air 65  /artillery 70  /rocket 85   /battle-copter 10
        /lander 75
    >>
    /heavy-tank <<
