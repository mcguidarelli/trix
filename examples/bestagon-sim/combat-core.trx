% CO roster -- §8.3.  charge-rate stored as integer percent (100 = 1.0x).
/co-roster <<
    /bishop <<
        /callsign    (Bishop)
        /color       /white
        /passives    << /all-atk +5  /all-def +5 >>
        /power-name  (Air Support)
        /power-cost  5
        /power       << /all-hp +2  /all-atk +15 >>
        /super-name  (Air Crusade)
        /super-cost  9
        /super       << /all-hp +4  /all-atk +35  /all-move +1 >>
        /charge-rate 100
    >>
    /hammer <<
        /callsign    (Hammer)
        /color       /red
        /passives    << /direct-atk +20  /indirect-atk -20  /indirect-range -1 >>
        /power-name  (Max Force)
        /power-cost  6
        /power       << /direct-atk +30  /direct-move +1 >>
        /super-name  (Maximum Force)
        /super-cost  10
        /super       << /direct-atk +50  /direct-move +1  /indirect-range +1 >>
        /charge-rate 100
    >>
    /hawk <<
