% =====================================================================
% proto-fog-perf.trx -- Phase 0.6E fog-of-war perf-budget prototype
% =====================================================================
%
% Tier P1 of plan_bestagon_derisk_prototyping.md.  Implements GDD
% section 11.1 `compute-fog faction state -- visible-set` on Standard
% 50x36 + Epic 75x54 fixtures with 30-unit mixed-class faction, then
% benches 1000 invocations per variant to validate locked decision
% 32-D ("no cache, recomputed on demand").
%
% Three variants:
%   1. naive-bool   -- cell-major scan into Array<Byte>; O(cells x units)
%   2. bbox-bool    -- unit-major bbox scan into Array<Byte>; O(units x disk)
%   3. bbox-set     -- unit-major bbox scan into fresh Trix Set per call
%
% The bool variants reuse a pre-allocated Array<Byte> (zero-fill at
% start of each call).  The Set variant allocates per call -- the
% bench wraps each iteration in save/restore so its heap stays bounded.
%
% Spec details from section 11.1 covered:
%   - effective vision = unit.vision + Mountain +3 for Inf/Mech
%   - Forest hides enemy GROUND units at distance > 1
%   - Reef   hides enemy NAVAL  units at distance > 1
%   - building positions added (stub: 5 buildings)
%
% Stub simplifications:
%   - CO modifiers absent (no /all-vision active)
%   - Weather modifiers absent
%   - Sub-state always /surfaced (no /submerged hiding)
%   - Veil /vs-revealed bonus untested (combat-only; out of fog scope)
%
% Run with the prod build (debug is 10-30x slower):
%   ./trix.opt examples/bestagon-proto/proto-fog-perf.trx
%
% Output: stdout bench summary + out/fog-perf.md verdict on 32-D survival.
% Default 1 MB VM; per-iteration save/restore brackets reclaim transient
% allocations from the Set variant.
% =====================================================================


% ====================================================================
% Section 0: inlined hex-distance (allocation-free; from 0.6D lesson)
% ====================================================================

% pos1 pos2 -- distance     UInteger pos in; Integer dist out
/hex-distance {|p1 p2|#+8
    /q1  p1 0 get /integer-type cast  local-def
    /r1  p1 1 get /integer-type cast  local-def
    /q2  p2 0 get /integer-type cast  local-def
    /r2  p2 1 get /integer-type cast  local-def
    /z1  $[ r1 - (q1 - (q1 % 2)) / 2 ]  local-def
    /z2  $[ r2 - (q2 - (q2 % 2)) / 2 ]  local-def
    /dx  $[ abs(q1 - q2) ]  local-def
    /dz  $[ abs(z1 - z2) ]  local-def
    $[ (dx + dz + abs(q1 + z1 - q2 - z2)) / 2 ]
} def


% ====================================================================
% Section 1: locked tables (per GDD section 6 + section 11.1)
% ====================================================================

% section 6 vision radius per unit class
/vision-for-class <<
    /infantry    2
    /mech        2
    /recon       5
    /apc         1
    /tank        3
    /heavy-tank  1
    /anti-air    2
    /artillery   1
    /rocket      1
    /fighter     5
    /bomber      3
    /battle-copter 3
    /lander      1
    /destroyer   5
    /submarine   5
    /battleship  2
    /carrier     4
>>#r def

% section 4 terrain stars (used to detect Mountain for +3 vision bonus)
% terrain encoding in state /terrain Array<Integer>:
%   0 = plain      (default)
%   1 = forest     (hides enemy ground at dist > 1)
%   2 = mountain   (+3 vision to inf/mech occupant)
%   3 = reef       (hides enemy naval at dist > 1)
/T-PLAIN    0 def
/T-FOREST   1 def
/T-MOUNTAIN 2 def
/T-REEF     3 def

% domain encoding in state /enemy-domain-at-idx Array<Integer>:
%   0 = no enemy
%   1 = ground enemy
%   2 = naval enemy
%   3 = air enemy
/D-NONE   0 def
/D-GROUND 1 def
/D-NAVAL  2 def
/D-AIR    3 def

% per-class domain
/domain-for-class <<
    /infantry    1
    /mech        1
    /recon       1
    /apc         1
    /tank        1
    /heavy-tank  1
    /anti-air    1
    /artillery   1
    /rocket      1
    /fighter     3
    /bomber      3
    /battle-copter 3
    /lander      2
    /destroyer   2
    /submarine   2
    /battleship  2
    /carrier     2
>>#r def

% section 4 + section 11.1 Mountain +3 vision applies to inf/mech ONLY
/mountain-bonus-classes <<
    /infantry true
    /mech     true
>>#r def

% 30-unit mid-game fixture mix per plan section 0.6E (10 inf + 8 tank +
% 4 recon + 3 AA + 3 rocket + 2 bomber = 30)
/own-roster-mix [
    /infantry /infantry /infantry /infantry /infantry
    /infantry /infantry /infantry /infantry /infantry
    /tank /tank /tank /tank /tank /tank /tank /tank
    /recon /recon /recon /recon
    /anti-air /anti-air /anti-air
    /rocket /rocket /rocket
    /bomber /bomber
] def

% Enemy roster: same mix, includes naval for reef-hide stress
/enemy-roster-mix [
    /infantry /infantry /infantry /infantry /infantry /infantry /infantry /infantry
    /tank /tank /tank /tank
    /recon /recon /recon
    /anti-air /anti-air
    /destroyer /destroyer /destroyer
    /submarine /submarine
    /battleship /battleship
    /lander
    /bomber /bomber /bomber
    /fighter /fighter
] def


% ====================================================================
% Section 2: helpers
% ====================================================================

% pos h -- idx     Linear index q*h + r (UInteger)
/pos-idx {|pos h|#+2
    /q  pos 0 get  local-def
    /r  pos 1 get  local-def
    $[ q * h + r ]
} def

/imin {|a b| a b lt { a } { b } if-else } def
/imax {|a b| a b gt { a } { b } if-else } def


% ====================================================================
% Section 3: state fixture builder
% ====================================================================
%
% state Dict layout:
%   /w           UInteger width
%   /h           UInteger height
%   /units       Array of own-unit Dicts (30 entries)
%   /enemies     Array of enemy-unit Dicts (30 entries)
%   /buildings   Array of building pos Arrays (5 entries)
%   /occupied    Array<Integer> length w*h (1 if any unit at idx)
%   /terrain     Array<Integer> length w*h (T-PLAIN | T-FOREST | T-MOUNTAIN | T-REEF)
%   /enemy-domain-at-idx Array<Integer> length w*h (D-NONE | D-GROUND | D-NAVAL | D-AIR)

% w h -- state
/make-state {|w h|#+15
    /state-dict   24 dict  local-def
    /n-own        own-roster-mix length  local-def
    /n-enemy      enemy-roster-mix length  local-def
    /units-arr    n-own array  local-def
    /enemies-arr  n-enemy array  local-def
    /buildings    5 array  local-def
    /cells        $[ w * h ]  local-def
    /cells-i      cells /integer-type cast  local-def
    /occupied     cells-i array  local-def
    /terrain      cells-i array  local-def
    /edom         cells-i array  local-def

    % zero-fill the int arrays
    0 1 $[ cells-i - 1 ] {|i|
        occupied i 0 put
        terrain  i T-PLAIN put
        edom     i D-NONE  put
    } for

    % seed terrain: ~10% forest, ~5% mountain, ~5% reef
    0 1 $[ cells-i - 1 ] {|i|#+1
        /roll  100u rand-bounded-uinteger /integer-type cast  local-def
        roll 80 ge roll 90 lt and { terrain i T-FOREST   put } if
        roll 90 ge roll 95 lt and { terrain i T-MOUNTAIN put } if
        roll 95 ge                { terrain i T-REEF     put } if
    } for

    % place own faction
    0 1 $[ n-own - 1 ] {|i|#+10
        /placed false  local-def
        { placed not } {
            /qu   w rand-bounded-uinteger  local-def
            /ru   h rand-bounded-uinteger  local-def
            /pos  [ qu ru ]  local-def
            /idx  pos h pos-idx  local-def
            occupied idx get 0 eq {
                occupied idx 1 put
                /klass  own-roster-mix i get  local-def
                /vis    vision-for-class klass get  local-def
                /dom    domain-for-class klass get  local-def
                /unit   << /id i /pos pos /class klass /vision vis /domain dom >>  local-def
                units-arr i unit put
                /placed true store
            } if
        } while
    } for

    % place enemy faction + index enemy-domain-at-idx for hide checks
    0 1 $[ n-enemy - 1 ] {|i|#+10
        /placed false  local-def
        { placed not } {
            /qu   w rand-bounded-uinteger  local-def
            /ru   h rand-bounded-uinteger  local-def
            /pos  [ qu ru ]  local-def
            /idx  pos h pos-idx  local-def
            occupied idx get 0 eq {
                occupied idx 1 put
                /klass  enemy-roster-mix i get  local-def
                /vis    vision-for-class klass get  local-def
                /dom    domain-for-class klass get  local-def
                /enemy  << /id i /pos pos /class klass /vision vis /domain dom >>  local-def
                enemies-arr i enemy put
                edom idx dom put
                /placed true store
            } if
        } while
    } for

    % 5 own buildings (HQs, cities) -- contribute their pos to visible-set
    0 1 4 {|i|#+5
        /placed false  local-def
        { placed not } {
            /qu   w rand-bounded-uinteger  local-def
            /ru   h rand-bounded-uinteger  local-def
            /pos  [ qu ru ]  local-def
            /idx  pos h pos-idx  local-def
            occupied idx get 0 eq {
                occupied idx 1 put
                buildings i pos put
                /placed true store
            } if
        } while
    } for

    state-dict /w        w        put
    state-dict /h        h        put
    state-dict /units    units-arr put
    state-dict /enemies  enemies-arr put
    state-dict /buildings buildings put
    state-dict /occupied occupied put
    state-dict /terrain  terrain  put
    state-dict /enemy-domain-at-idx edom put
    state-dict
} def


% ====================================================================
% Section 4: core ops (per GDD section 11.1)
% ====================================================================

% Section 11.1: effective vision = unit.vision + Mountain bonus (inf/mech)
% unit state -- vision
/effective-vision {|unit state|#+5
    /base   unit /vision get  local-def
    /klass  unit /class get  local-def
    /pos    unit /pos get  local-def
    mountain-bonus-classes klass known? {
        /h    state /h get  local-def
        /idx  pos h pos-idx  local-def
        state /terrain get idx get T-MOUNTAIN eq {
            $[ base + 3 ]
        } {
            base
        } if-else
    } {
        base
    } if-else
} def


% section 11.1 visible? check on a single hex given the current unit's
% pos + effective vision + distance + domain of enemy at hex (if any).
%
% Returns true if the hex should be added to visible-set.
%   - distance > vision -> not visible (caller already filters this)
%   - terrain Forest + enemy ground at hex + dist > 1 -> hidden
%   - terrain Reef   + enemy naval  at hex + dist > 1 -> hidden
%   - otherwise visible
%
% dist terrain enemy-domain -- bool
/hex-visible? {|dist terrain enemy-domain|
    terrain T-FOREST eq enemy-domain D-GROUND eq and dist 1 gt and {
        false
    } {
        terrain T-REEF eq enemy-domain D-NAVAL eq and dist 1 gt and {
            false
        } {
            true
        } if-else
    } if-else
} def


% Mode 1: NAIVE cell-major scan.
% For each hex in the map, walk every own unit and test
% hex-distance(unit.pos, hex) <= effective-vision(unit).
% O(cells x units) per call.
%
% state fog-map --   (mutates fog-map in place; Array<Integer> length w*h, 1=visible 0=not)
/compute-fog-naive {|state fog-map|#+12
    /w        state /w get  local-def
    /h        state /h get  local-def
    /h-i      h /integer-type cast  local-def
    /units    state /units get  local-def
    /buildings state /buildings get  local-def
    /terrain  state /terrain get  local-def
    /edom     state /enemy-domain-at-idx get  local-def
    /n-units  units length  local-def
    /n-buildings  buildings length  local-def
    /cells    $[ w * h ] /integer-type cast  local-def

    % zero-fill the fog-map
    0 1 $[ cells - 1 ] {|i|
        fog-map i 0 put
    } for

    0u 1u $[ w - 1u ] {|qu|
        0u 1u $[ h - 1u ] {|ru|#+6
            /hex     [ qu ru ]  local-def
            /idx     hex h pos-idx  local-def
            /vis     false  local-def
            /trn     terrain idx get  local-def
            /edm     edom idx get  local-def
            0 1 $[ n-units - 1 ] {|j|#+3
                vis not {
                    /unit  units j get  local-def
                    /vrad  unit state effective-vision  local-def
                    /d     hex unit /pos get hex-distance  local-def
                    d vrad le {
                        d trn edm hex-visible? { /vis true store } if
                    } if
                } if
            } for
            vis { fog-map idx 1 put } if
        } for
    } for

    % buildings always visible
    0 1 $[ n-buildings - 1 ] {|j|#+2
        /bpos  buildings j get  local-def
        /idx   bpos h pos-idx  local-def
        fog-map idx 1 put
    } for
} def


% Mode 2: BBOX unit-major scan.
% For each own unit, iterate the (2*vision+1)^2 bounding box around
% unit.pos and mark visible hexes.  Filters by cube-distance + hide rules.
% O(units x disk-size) per call.  Disk size ~ pi*vision^2.
%
% state fog-map --   (mutates fog-map in place; bool variant)
/compute-fog-bbox {|state fog-map|#+12
    /w        state /w get  /integer-type cast  local-def
    /h        state /h get  /integer-type cast  local-def
    /h-u      state /h get  local-def
    /units    state /units get  local-def
    /buildings state /buildings get  local-def
    /terrain  state /terrain get  local-def
    /edom     state /enemy-domain-at-idx get  local-def
    /n-units  units length  local-def
    /n-buildings  buildings length  local-def
    /cells    $[ w * h ]  local-def

    % zero-fill the fog-map
    0 1 $[ cells - 1 ] {|i|
        fog-map i 0 put
    } for

    0 1 $[ n-units - 1 ] {|j|#+12
        /unit   units j get  local-def
        /upos   unit /pos get  local-def
        /vrad   unit state effective-vision  local-def
        /uq     upos 0 get /integer-type cast  local-def
        /ur     upos 1 get /integer-type cast  local-def
        /qlo    $[ uq - vrad ] 0 imax  local-def
        /qhi    $[ uq + vrad ] $[ w - 1 ] imin  local-def
        /rlo    $[ ur - vrad ] 0 imax  local-def
        /rhi    $[ ur + vrad ] $[ h - 1 ] imin  local-def

        qlo 1 qhi {|qi|
            rlo 1 rhi {|ri|#+7
                /qu    qi /uinteger-type cast  local-def
                /ru    ri /uinteger-type cast  local-def
                /hex   [ qu ru ]  local-def
                /d     hex upos hex-distance  local-def
                d vrad le {
                    /idx  hex h-u pos-idx  local-def
                    /trn  terrain idx get  local-def
                    /edm  edom idx get  local-def
                    d trn edm hex-visible? {
                        fog-map idx 1 put
                    } if
                } if
            } for
        } for
    } for

    % buildings always visible
    0 1 $[ n-buildings - 1 ] {|j|#+2
        /bpos  buildings j get  local-def
        /idx   bpos h-u pos-idx  local-def
        fog-map idx 1 put
    } for
} def


% Mode 3: BBOX unit-major scan producing a Trix Set (spec representation).
% Allocates a fresh Set per call.  Used to measure Set-allocation cost
% against the bool-array representation.
%
% IMPORTANT: Trix Sets use IDENTITY equality for compound keys (Arrays).
% Adding `[ 5u 3u ]` from two different unit-vision discs creates two
% distinct Array allocations and the Set treats them as different keys.
% This stub uses the LINEAR index `q*h + r` as the Set key (an immediate
% Integer, which dedupes by value) so set length matches bbox popcount.
% A spec-faithful production impl would do the same: hex IDs (idx or
% packed Long) NOT fresh [q r] tuples, OR a single pre-allocated [q r]
% per hex that's looked up by idx.
%
% state -- set (of Integer hex-idx values)
/compute-fog-bbox-set {|state|#+12
    /w        state /w get  /integer-type cast  local-def
    /h        state /h get  /integer-type cast  local-def
    /h-u      state /h get  local-def
    /units    state /units get  local-def
    /buildings state /buildings get  local-def
    /terrain  state /terrain get  local-def
    /edom     state /enemy-domain-at-idx get  local-def
    /n-units  units length  local-def
    /n-buildings  buildings length  local-def

    % size set capacity heuristically: 30 units x ~25 hex disk = 750
    /vset  1024 set  local-def

    0 1 $[ n-units - 1 ] {|j|#+12
        /unit   units j get  local-def
        /upos   unit /pos get  local-def
        /vrad   unit state effective-vision  local-def
        /uq     upos 0 get /integer-type cast  local-def
        /ur     upos 1 get /integer-type cast  local-def
        /qlo    $[ uq - vrad ] 0 imax  local-def
        /qhi    $[ uq + vrad ] $[ w - 1 ] imin  local-def
        /rlo    $[ ur - vrad ] 0 imax  local-def
        /rhi    $[ ur + vrad ] $[ h - 1 ] imin  local-def

        qlo 1 qhi {|qi|
            rlo 1 rhi {|ri|#+7
                /qu    qi /uinteger-type cast  local-def
                /ru    ri /uinteger-type cast  local-def
                /hex   [ qu ru ]  local-def
                /d     hex upos hex-distance  local-def
                d vrad le {
                    /idx  hex h-u pos-idx /integer-type cast  local-def
                    /trn  terrain idx get  local-def
                    /edm  edom idx get  local-def
                    d trn edm hex-visible? {
                        vset idx set-add pop
                    } if
                } if
            } for
        } for
    } for

    % buildings always visible
    0 1 $[ n-buildings - 1 ] {|j|#+2
        /bpos  buildings j get  local-def
        /bidx  bpos h-u pos-idx /integer-type cast  local-def
        vset bidx set-add pop
    } for

    vset
} def


% ====================================================================
% Section 5: bench harness
% ====================================================================
%
% Wall-clock per variant on prod build.  1000 invocations per variant.
% Bool variants reuse pre-allocated fog-map (zero-fill at start of call).
% Set variant allocates per call; per-iteration save/restore reclaims.

/out-md (examples/bestagon-proto/out/fog-perf.md) def

% Iteration counts: bbox and set need ~200 to give a stable mean against
% the per-iter save/restore overhead.  Naive is so far over budget that
% 20 iterations is plenty to characterise its failure mode -- and at
% ~275-706 ms per call it would otherwise dominate the bench wall-clock
% (3+ minutes for naive alone).  Run-time on prod: ~30 s with these.
/N-NAIVE 20 def
/N-BBOX  200 def

% w h label -- correctness + timing printed inline
/bench-fog {|w h label|#+18
    1234567890ul rand-seed

    /state   w h make-state  local-def
    /cells   $[ w * h ]  /integer-type cast  local-def
    /fog-a   cells array  local-def   % naive output buffer
    /fog-b   cells array  local-def   % bbox output buffer

    % zero-fill both buffers
    0 1 $[ cells - 1 ] {|i|
        fog-a i 0 put
        fog-b i 0 put
    } for

    % --- Correctness: assert naive and bbox produce identical Array<Byte> ---
    state fog-a compute-fog-naive
    state fog-b compute-fog-bbox

    /mismatches  0  local-def
    /visible-a   0  local-def
    /visible-b   0  local-def
    0 1 $[ cells - 1 ] {|i|#+2
        /a fog-a i get  local-def
        /b fog-b i get  local-def
        a 0 ne { /visible-a $[ visible-a + 1 ] store } if
        b 0 ne { /visible-b $[ visible-b + 1 ] store } if
        a b ne { /mismatches $[ mismatches + 1 ] store } if
    } for

    mismatches 0 ne {
        ({0}: CORRECTNESS FAIL -- naive vs bbox differ on {1} cells\n)
            mark label mismatches print-fmt pop pop
        /fog-correctness-fail throw
    } if

    % All three modes need per-iteration save/restore brackets: each
    % compute-fog call allocates O(cells) [q r] hex Arrays during its
    % scan (naive: 1800/4050 per call; bbox: ~1500 per call across all
    % unit-bboxes).  Per-iter brackets reclaim these between iterations
    % so the 1000-iter bench stays inside the default 1 MB VM.
    %
    % Overhead: ~2 save/restore per iter ~ 500 ns on prod.  For a 1000-
    % iter bench reporting mean wall-clock in microseconds, that's a
    % systematic ~0.5 us bias on every variant -- absorbs into the noise
    % floor.

    % --- Bench mode 1: naive ---
    /naive-us  0ul  local-def
    { 0 1 $[ N-NAIVE - 1 ] {|i|
        save pop
            state fog-a compute-fog-naive
        -1 restore
    } for } time
    /naive-us  exch  store

    % --- Bench mode 2: bbox-bool ---
    /bbox-us  0ul  local-def
    { 0 1 $[ N-BBOX - 1 ] {|i|
        save pop
            state fog-b compute-fog-bbox
        -1 restore
    } for } time
    /bbox-us  exch  store

    % --- Bench mode 3: bbox-set (allocates fresh Set per call) ---
    /set-us  0ul  local-def
    /set-popcount 0 local-def
    { 0 1 $[ N-BBOX - 1 ] {|i|
        save pop
            state compute-fog-bbox-set pop
        -1 restore
    } for } time
    /set-us  exch  store

    % Re-compute set once unwrapped to get popcount for correctness check
    save pop
        state compute-fog-bbox-set length
    -1 restore
    /set-popcount exch store

    set-popcount visible-b ne {
        ({0}: CORRECTNESS FAIL -- set len {1} != bbox-bool popcount {2}\n)
            mark label set-popcount visible-b
            print-fmt pop pop
        /fog-set-correctness-fail throw
    } if

    % --- Print stdout summary row ---
    % mean = total / N-iter (in microseconds); naive and bbox use different N
    /n-naive-ul    N-NAIVE /ulong-type cast  local-def
    /n-bbox-ul     N-BBOX  /ulong-type cast  local-def
    /naive-mean-us $[ naive-us / n-naive-ul ]  /integer-type cast  local-def
    /bbox-mean-us  $[ bbox-us  / n-bbox-ul  ]  /integer-type cast  local-def
    /set-mean-us   $[ set-us   / n-bbox-ul  ]  /integer-type cast  local-def

    ({0:9s} |  {1:5} |    {2:5} |     {3:5} us |    {4:5} us |   {5:5} us |  {6:5}\n)
        mark label cells visible-b naive-mean-us bbox-mean-us set-mean-us set-popcount
        print-fmt pop pop

    % --- Write markdown row ---
    md-stream (| {0} | {1} | {2} | {3} us | {4} us | {5} us | {6} |\n)
        mark label cells visible-b naive-mean-us bbox-mean-us set-mean-us set-popcount
        fprint-fmt pop pop
} def


% ====================================================================
% Section 6: main
% ====================================================================

(proto-fog-perf: building fixtures + benching three variants...\n) print
(  (debug build is 10-30x slower than ./trix.opt -- use prod build for budget verdict)\n\n) print

% Ensure the output directory exists.  out/ is gitignored, so it is absent on a
% fresh checkout; mkdir is not idempotent (raises on EEXIST), so guard the
% create on file-exists?.
(examples/bestagon-proto/out) file-exists? not
    { (examples/bestagon-proto/out) mkdir } if

/md-stream  out-md (w)#b stream  def

md-stream (# Phase 0.6E: fog-of-war perf-budget verdict\n\n) write-string
md-stream (Sister of 0.6D AI v2 perf.  Implements GDD section 11.1\n) write-string
md-stream (compute-fog -- recomputed on demand, no cache per locked decision\n) write-string
md-stream (32-D -- on Standard 50x36 and Epic 75x54 fixtures with a 30-unit\n) write-string
md-stream (mixed faction.  Three variants benchmarked -- 20 iterations for\n) write-string
md-stream (naive, 200 for bbox + set:\n\n) write-string

md-stream (1. naive-bool : cell-major scan, O[cells x units]\n) write-string
md-stream (2. bbox-bool  : unit-major bbox, O[units x disk-size]\n) write-string
