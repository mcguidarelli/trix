% z-game-key -- "rel:serial" key for known-games lookup
/z-game-key { ||#+1
    16 string ({0}:{1}) mark h-release h-serial sprint-fmt pop
} def

% z-print-splash -- emit a one-line italic-dimmed "Recognized:" plate
% if the running story matches a known IFhd.  Silent for unknown.
% Routed through z-output-text so transcript capture sees it.  Uses
% ANSI SGR 2 (dim) + 3 (italic) for soft contrast against the game's
% banner and SGR 0 to reset.
/z-print-splash { ||#+1
    /key z-game-key local-def
    known-games key known? {
        (\x1B[2;3m  [ Recognized: ) z-output-text
        known-games key get z-output-text
        ( ]\x1B[0m\n\n) z-output-text
    } if
} def

% ----- CRT theme (Phase 15 feature 3)
%
% Themes set the terminal's default foreground and background colours
% via xterm-style OSC sequences ESC ] 10 ; #RRGGBB BEL (default fg)
% and OSC ] 11 (default bg).  We use OSC over SGR so that downstream
% `set_text_style 0` (SGR 0 = reset) falls back to the theme colours
% rather than the user's raw terminal default.  At interpreter exit
% we emit OSC 110 / 111 to restore the user's defaults.
%
% --theme=phosphor   bright-green text on black (Apple //e style)
% --theme=amber      amber text on black (DEC VT220 style)
% --theme=paper      near-black text on cream (typewritten manuscript)
% --theme=classic    no theme; terminal defaults (the default mode)

/themes 8 dict def
themes (classic)  ()                                                      put
themes (phosphor) (\x1B]10;#00FF00\x07\x1B]11;#000000\x07\x1B[2J\x1B[H)   put
themes (amber)    (\x1B]10;#FFB000\x07\x1B]11;#000000\x07\x1B[2J\x1B[H)   put
themes (paper)    (\x1B]10;#1A1A1A\x07\x1B]11;#FAF6E6\x07\x1B[2J\x1B[H)   put

/theme-reset-seq (\x1B]110\x07\x1B]111\x07) def

% z-apply-theme -- called once at z-run-story entry.  Silent for
% mode-theme = classic (the default) or any unknown name.
/z-apply-theme { ||#+1
    themes mode-theme known? {
        /seq themes mode-theme get local-def
        seq length 0 gt { seq z-output-text } if
    } if
} def

% z-reset-theme -- called on clean shutdown to restore the user's
% terminal defaults; emits OSC 110 / 111.  Goes via `print` and an
% explicit flush so the bytes hit the terminal even when Trix exits
% immediately after.
/z-reset-theme {
    mode-theme (classic) eq not { theme-reset-seq print flush } if
} def

% ----- auto-map (Phase 17 feature 12)
%
% --auto-map records edges between V3 game rooms as the player walks.
% Each turn, after the user's command is read but BEFORE the game runs
% it, we look at:
%   * the current room (V3 location global, decoded via obj-short-name)
%   * the previous prompt's room (saved last turn)
%   * the previous prompt's command (saved last turn)
% If the previous command was a directional verb and the room has
% changed since last prompt, the previous command moved the player
% from prev-room to cur-room -- record an edge.  /map renders the
% accumulated graph.  V4+ has no spec-mandated location global, so
% auto-map gracefully no-ops.

/z-auto-map-graph     64 dict def        % name -> dict (dir -> name)
/z-auto-map-prev-room null def
/z-auto-map-prev-cmd  () def

/z-auto-map-dirs 24 dict def
z-auto-map-dirs (n)         (north) put
z-auto-map-dirs (north)     (north) put
z-auto-map-dirs (s)         (south) put
z-auto-map-dirs (south)     (south) put
z-auto-map-dirs (e)         (east)  put
z-auto-map-dirs (east)      (east)  put
z-auto-map-dirs (w)         (west)  put
z-auto-map-dirs (west)      (west)  put
z-auto-map-dirs (ne)        (NE)    put
z-auto-map-dirs (northeast) (NE)    put
z-auto-map-dirs (nw)        (NW)    put
z-auto-map-dirs (northwest) (NW)    put
z-auto-map-dirs (se)        (SE)    put
z-auto-map-dirs (southeast) (SE)    put
z-auto-map-dirs (sw)        (SW)    put
z-auto-map-dirs (southwest) (SW)    put
z-auto-map-dirs (u)         (up)    put
z-auto-map-dirs (up)        (up)    put
z-auto-map-dirs (d)         (down)  put
z-auto-map-dirs (down)      (down)  put
z-auto-map-dirs (in)        (in)    put
z-auto-map-dirs (out)       (out)   put
z-auto-map-dirs (enter)     (in)    put
z-auto-map-dirs (exit)      (out)   put

% Lowercase, take first whitespace-delimited word, look up in
% z-auto-map-dirs.  Returns the canonical direction name or "" if
% the input doesn't start with a directional verb.
/z-auto-map-direction-of {|input|#+3
    /sp 0 local-def
    /done false local-def
    { done not } {
        sp input length ge {
            /done true store
        } {
            input sp get /integer-type cast 32 eq
                { /done true store }
                { /sp sp 1 add store } if-else
        } if-else
    } while
    /first input 0 sp get-interval local-def
    z-auto-map-dirs first known? {
        z-auto-map-dirs first get
    } {
        ()
    } if-else
} def

% Read the V3 location-global object (= 16) and return its short-name,
% or "" if no V3 / no location set.  obj-short-name shares a singleton
% decoder buffer (/zd-out) with every other text-decoding call, so we
% must COPY the result before stashing it as a map key -- otherwise
% subsequent text-decode calls overwrite the saved key in place.
/z-auto-map-current-room { ||#+2
    h-version 4 ge {
        ()
    } {
        h-globals-addr 0 eq { () } {
            /loc 16 z-global-read local-def
            loc 0 eq {
                ()
            } {
                /raw loc obj-short-name local-def
                raw () concat
            } if-else
        } if-else
    } if-else
} def

% Hook called from sread after reading input but before the game runs
% the new command.  Records an edge whenever the previous prompt's
% command was directional AND the room changed since then.
/z-auto-map-record {|input|#+3
    mode-auto-map {
        /cur z-auto-map-current-room local-def
        cur length 0 gt {
            z-auto-map-prev-room null eq not {
                /dir z-auto-map-prev-cmd z-auto-map-direction-of local-def
                dir length 0 gt cur z-auto-map-prev-room ne and {
                    z-auto-map-graph z-auto-map-prev-room known? not {
                        z-auto-map-graph z-auto-map-prev-room 12 dict put
                    } if
                    z-auto-map-graph z-auto-map-prev-room get  dir  cur put
                    z-auto-map-graph cur known? not {
                        z-auto-map-graph cur 12 dict put
                    } if
                } if
            } if
            /z-auto-map-prev-room cur store
            /z-auto-map-prev-cmd input store
        } if
    } if
} def

% ----- InvisiClues hints (Phase 19)
%
% Optional hint file paired with the story.  Format:
%
%   # Lines starting with '#' are comments
%   [Q] How do I open the trophy case?
%   - First spoiler-light hint.
%   - Slightly more revealing.
%   - Direct solution.
%
%   [Q] Next question
%   - One hint
%
% Loaded once via --hints <path>.  /hint with no arg lists questions
% with their reveal counters; /hint <N> reveals the next hint for
% question N (1-based); /hint reset resets all counters; /hint reset
% <N> resets one.  Period-style progressive reveal so a stuck player
% can dial up the spoiler level only as much as they need.

/z-hints-loaded false def
/z-hints-questions [] def         % array of [question-text, hints-array, revealed-count]

% Read the hints file at /hints-path into /z-hints-questions.  Quiet
% no-op if /hints-path is empty (the user didn't supply --hints).
/z-load-hints { ||#+10
    hints-path () eq { } {
        /strm hints-path (r)#b stream local-def
        /qs [] local-def
        /cur-q () local-def
        /cur-hints [] local-def
        /done false local-def
        { done not } {
            /buf 1024 string local-def
            strm buf read-line
            {
                /line exch local-def
                line length 0 eq {
                    % blank line, skip
                } {
                line 0 get /integer-type cast 16#23 eq {
                    % '#' comment, skip
                } {
                line length 4 ge {
                    line 0 4 get-interval ([Q] ) eq {
                        cur-q () eq not {
                            /qs qs [ cur-q  cur-hints  0 ] append store
                        } if
                        /cur-q line 4 line length 4 sub get-interval () concat store
                        /cur-hints [] store
                    } {
                    line 0 2 get-interval (- ) eq {
                        /cur-hints cur-hints  line 2 line length 2 sub get-interval () concat  append store
                    } { } if-else } if-else
                } {
                line length 2 ge {
                    line 0 2 get-interval (- ) eq {
                        /cur-hints cur-hints  line 2 line length 2 sub get-interval () concat  append store
                    } { } if-else
                } { } if-else } if-else } if-else } if-else
            } {
                pop  /done true store
            } if-else
        } while
        cur-q () eq not {
            /qs qs [ cur-q  cur-hints  0 ] append store
        } if
        strm close-stream
        /z-hints-questions qs store
        /z-hints-loaded true store
    } if-else
} def

% z-showcase-dispatch line --
% Invoked by z-read-line for any input starting with '/'.  Splits into
% [cmd tail], looks up cmd in showcase-cmds, runs the handler.  Unknown
% commands print a hint and return.  Empty input ("/") prints help.
/z-showcase-dispatch {|line|#+4
    /split line z-split-showcase-line local-def
    /cmd split 0 get local-def
    /rest split 1 get local-def
    cmd length 0 eq {
        () showcase-cmds (help) get exec
    } {
    showcase-cmds cmd known? {
        rest showcase-cmds cmd get exec
    } {
        (Unknown showcase command: /) z-output-text  cmd z-output-text  (\n) z-output-text
        (Type /help for the list.\n) z-output-text
    } if-else } if-else
} def

/print-usage {
    (Usage: ./trix examples/zmachine.trx <story-file>\n) print
    (       ./trix examples/zmachine.trx --header <story-file>\n) print
    (       ./trix examples/zmachine.trx --script <commands> <story-file>\n) print
    (       ./trix examples/zmachine.trx --self-test\n) print
    (       ./trix examples/zmachine.trx --help\n\n) print
    (Plays a .z3/.z4/.z5/.z7/.z8 story file in the terminal.  Without a\n) print
    (mode flag, runs interactively.  --header dumps the 64-byte header\n) print
    (in infodump / txd format and exits.  --script feeds commands from a\n) print
    (text file (one per line) instead of stdin -- the transcript is echoed\n) print
    (to stdout for hands-off integration testing.  --self-test runs the\n) print
    (in-source assertion suite.\n) print
    nl
    (Showcase flags:\n) print
    (  --auto-map           record V3 room transitions; /map renders graph\n) print
    (  --theme <name>       CRT palette: classic \(default\), phosphor, amber, paper\n) print
    (  --hints <file>       load InvisiClues hint file; /hint commands available\n) print
    (  --pager              auto-pause every page of game text \(tty only\)\n) print
    (  --pager-pause=<ms>   pager pause length \(default 500\)\n) print
    (  --typewriter         per-char delay on game output \(tty only\)\n) print
    (  --typewriter-delay=<ms>  per-char delay \(default 12, ~80 cps\)\n) print
} def

/mode-header        false def
/mode-self-test     false def
/mode-script        false def
/mode-dict-debug    false def
/mode-auto-map      false def
/mode-theme         (classic) def
/mode-pager         false def
/mode-typewriter    false def
/typewriter-delay-ms  12 def     % default ~80 chars/sec; tunable via --typewriter-delay=
/pager-pause-ms      500 def     % default 0.5 sec auto-pause; tunable via --pager-pause=
/story-path      ()    def
/script-path     ()    def
/hints-path      ()    def
/expecting-arg   /none def

/parse-flag {|arg|#+5
    expecting-arg /script eq {
        /script-path arg store
        /expecting-arg /none store
    } {
    expecting-arg /theme eq {
        /mode-theme arg store
        /expecting-arg /none store
    } {
    expecting-arg /hints eq {
        /hints-path arg store
        /expecting-arg /none store
    } {
        arg (--header) eq    { /mode-header true store } if
        arg (--self-test) eq { /mode-self-test true store } if
        arg (--help) eq arg (-h) eq or { print-usage quit } if
        arg (--script) eq    { /mode-script true store /expecting-arg /script store } if
        arg (--dict-debug) eq { /mode-dict-debug true store } if
        arg (--auto-map) eq  { /mode-auto-map true store } if
        arg (--theme) eq     { /expecting-arg /theme store } if
        arg (--hints) eq     { /expecting-arg /hints store } if
        arg (--pager) eq     { /mode-pager true store } if
        arg (--typewriter) eq { /mode-typewriter true store } if
        % --theme=<name> / --hints=<path> single-arg forms.  Bounds-
        % check arg length BEFORE substring or get-interval throws.
        arg length 8 gt {
            /pfx arg 0 8 get-interval local-def
            /val arg 8 arg length 8 sub get-interval local-def
            pfx (--theme=) eq { /mode-theme val store } if
            pfx (--hints=) eq { /hints-path val store } if
        } if
        % --typewriter-delay=<ms> / --pager-pause=<ms> tunables.
        arg length 19 gt {
            arg 0 19 get-interval (--typewriter-delay=) eq {
                /tdval arg 19 arg length 19 sub get-interval z-parse-int local-def
                tdval 0 ge { /typewriter-delay-ms tdval store } if
            } if
        } if
        arg length 14 gt {
            arg 0 14 get-interval (--pager-pause=) eq {
                /ppval arg 14 arg length 14 sub get-interval z-parse-int local-def
                ppval 0 ge { /pager-pause-ms ppval store } if
            } if
        } if
        % Anything not starting with '-' is the story-file path.
        arg length 0 gt arg 0 get 16#2D#b ne and {
            arg (--header) ne arg (--self-test) ne and arg (--help) ne and arg (-h) ne and arg (--script) ne and arg (--auto-map) ne and arg (--theme) ne and arg (--hints) ne and arg (--pager) ne and arg (--typewriter) ne and {
                /story-path arg store
            } if
        } if
    } if-else } if-else } if-else
} def

/parse-args { ||#3
    /args command-line-args local-def
    /n args length local-def
    0 1 n 1 sub {
        /i exch local-def
        args i get parse-flag
    } for
} def

/main {
    parse-args
    mode-self-test { run-self-test quit } if
    mode-header {
        story-path () eq {
            (--header requires a path: --header <story-file>\n) print quit
        } if
        story-path load-story
        print-header
        quit
    } if
    story-path () eq { print-usage quit } if

    % DEBUG: dump dictionary header + first entry, then quit.
    % Activated by --dict-debug for one-shot diagnostic.
    mode-dict-debug {
        story-path load-story
        (Dictionary at 0x{0:X}\n) mark h-dict-addr print-fmt pop pop
        (  num separators: {0}\n) mark z-dict-num-separators print-fmt pop pop
        (  entry length:   {0}\n) mark z-dict-entry-length print-fmt pop pop
        (  entry count:    {0}\n) mark z-dict-entry-count print-fmt pop pop
        (  entries at:     0x{0:X}\n) mark z-dict-entries-addr print-fmt pop pop
        % Encode several words and dump bytes
        [ (look) (north) (open) (quit) (the) (a) ] {|w|
            /key w 4 z-encode-text def
            (Encoded "{0}": ) mark w print-fmt pop pop
            0 1 3 {
                /i exch def
                ({0:02X} ) mark key i get print-fmt pop pop
            } for
            nl
            % Linear-search for this key in the dict
            /found-at -1 def
            0 1 z-dict-entry-count 1 sub {
                /i exch def
                /addr z-dict-entries-addr i z-dict-entry-length mul add def
                /eq? true def
                0 1 3 {
                    /j exch def
                    addr j add z-rb  key j get /integer-type cast ne { /eq? false def } if
                } for
                eq? found-at 0 lt and { /found-at i def } if
            } for
            (  -> found at index {0}\n) mark found-at print-fmt pop pop
        } for-all
        % Dump entries at the indexes where "look" alphabetically sorts.
        % Compute the byte triple of "look" key first 2 bytes; binary search.
        (Entries 100-104:\n) print
        100 1 104 {
            /i exch def
            (  [{0}]: ) mark i print-fmt pop pop
            /addr z-dict-entries-addr i z-dict-entry-length mul add def
            0 1 z-dict-entry-length 1 sub {
                /j exch def
                ({0:02X} ) mark addr j add z-rb print-fmt pop pop
            } for
            nl
        } for
        quit
    } if

    % Default mode: load story file + run.
    story-path load-story
    mode-script {
        script-path () eq { (--script requires a commands file\n) print quit } if
        /z-script-stream script-path (r)#b stream store
        /z-input-source /script-file store
    } if
    z-load-hints
    z-run-story
    z-status-teardown
    z-reset-theme
    z-script-stream null ne { z-script-stream close-stream } if
} def

main
