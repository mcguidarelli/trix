% bind-locals: atomic batch bind into the current frame dict.
{ |x|#5 1 2 3 [/a /b /c] bind-locals a b c add add } 0 exch exec
{ |x|#10 1 2 3 4 5 6 7 8 [/p1 /p2 /p3 /p4 /p5 /p6 /p7 /p8] bind-locals p1 p8 add } 0 exch exec
{ |x|#5 99 [/only] bind-locals only } 0 exch exec                   % single-name bind
{ |x|#5 4 5 6 [/u /v /w]#= bind-locals u v w add add } 0 exch exec  % eqarray names
{ |x|#5 [ ] bind-locals } 0 exch try                                % empty -> unsupported
{ |x|#5 1 2 [/a /a] bind-locals } 0 exch try                        % dup -> unsupported
{ |x|#5 1 2 [/a (b)] bind-locals } 0 exch try                       % non-Name -> type-check
{ 1 [/x] bind-locals } try                                          % no frame -> unsupported
{ |x|#5 1 [/a /b /c] bind-locals } 0 exch try                       % underflow
{ |x|#1 1 2 [/a /b] bind-locals } 0 exch try                        % capacity -> limit-check
{ |x|#5 /pre 100 local-def save 10 20 [/a /b] bind-locals restore } 0 exch exec  % save/restore
{ |scratch|#10 /total 0 local-def 5 { 1 2 3 4 5 [/a /b /c /d /e] bind-locals /total a b c d e add add add add total add store } repeat total } 0 exch exec
