# EditorConfig: https://editorconfig.org/
# Whitespace and charset rules honored by most editors/IDEs.

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

# Markdown intentionally uses trailing double-space as a line break.
[*.md]
trim_trailing_whitespace = false

# YAML and CFF are 2-space by convention.
[*.{yml,yaml,cff}]
indent_size = 2

# Makefiles require hard tabs.
[Makefile]
indent_style = tab
